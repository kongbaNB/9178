scrollFrame.CanvasSize = UDim2.new(0,0,0,0)
scrollFrame.ScrollBarThickness = 6
scrollFrame.BorderSizePixel = 0
scrollFrame.Parent = mainFrame

local allTags = {}
local selectedItemTags = {}
local quickSelectedItemTags = {}
local currentTab = "all"

local function renderTags(tags, emptyText)
    for _, child in ipairs(scrollFrame:GetChildren()) do
        child:Destroy()
    end
    if #tags == 0 then
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -10, 0, 30)
        label.Position = UDim2.new(0, 5, 0, 5)
        label.BackgroundTransparency = 1
        label.Text = emptyText or "暂无标签"
        label.TextColor3 = Color3.fromRGB(200,200,200)
        label.Font = Enum.Font.SourceSans
        label.TextSize = 16
        label.Parent = scrollFrame
        scrollFrame.CanvasSize = UDim2.new(0,0,0,40)
        return
    end

    local y = 5
    for _, tag in ipairs(tags) do
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(1, -10, 0, 80)
        frame.Position = UDim2.new(0, 5, 0, y)
        frame.BackgroundColor3 = Color3.fromRGB(45,45,45)
        frame.BorderSizePixel = 0
        frame.Parent = scrollFrame
        Instance.new("UICorner", frame).CornerRadius = UDim.new(0,8)

        local chinese = Instance.new("TextLabel")
        chinese.Size = UDim2.new(1, -10, 0, 22)
        chinese.Position = UDim2.new(0,5,0,3)
        chinese.BackgroundTransparency = 1
        chinese.Text = "翻译中..."
        chinese.TextColor3 = Color3.fromRGB(200,200,200)
        chinese.Font = Enum.Font.SourceSansBold
        chinese.TextSize = 16
        chinese.TextXAlignment = Enum.TextXAlignment.Left
        chinese.Parent = frame

        local original = Instance.new("TextLabel")
        original.Size = UDim2.new(1, -10, 0, 22)
        original.Position = UDim2.new(0,5,0,28)
        original.BackgroundTransparency = 1
        original.Text = tag
        original.TextColor3 = Color3.new(1,1,1)
        original.Font = Enum.Font.SourceSans
        original.TextSize = 14
        original.TextXAlignment = Enum.TextXAlignment.Left
        original.Parent = frame

        local copyCN = Instance.new("TextButton")
        copyCN.Size = UDim2.new(0, 100, 0, 22)
        copyCN.Position = UDim2.new(0,5,0,53)
        copyCN.Text = "复制中文名"
        copyCN.Font = Enum.Font.SourceSans
        copyCN.TextSize = 12
        copyCN.TextColor3 = Color3.new(1,1,1)
        copyCN.BackgroundColor3 = Color3.fromRGB(0,150,0)
        copyCN.Parent = frame
        Instance.new("UICorner", copyCN).CornerRadius = UDim.new(0,4)

        local copyOrig = Instance.new("TextButton")
        copyOrig.Size = UDim2.new(0, 100, 0, 22)
        copyOrig.Position = UDim2.new(0,115,0,53)
        copyOrig.Text = "复制原标签"
        copyOrig.Font = Enum.Font.SourceSans
        copyOrig.TextSize = 12
        copyOrig.TextColor3 = Color3.new(1,1,1)
        copyOrig.BackgroundColor3 = Color3.fromRGB(0,100,200)
        copyOrig.Parent = frame
        Instance.new("UICorner", copyOrig).CornerRadius = UDim.new(0,4)

        task.spawn(function()
            local trans = translateText(tag)
            chinese.Text = trans or "翻译失败"
            copyCN.MouseButton1Click:Connect(function()
                copyToClipboard(trans or tag)
            end)
        end)
        copyOrig.MouseButton1Click:Connect(function()
            copyToClipboard(tag)
        end)

        y = y + 85
    end
    scrollFrame.CanvasSize = UDim2.new(0,0,0, y + 10)
end

local function switchTab(tab)
    currentTab = tab
    if tab == "all" then
        setActiveTab(allTabBtn)
        allTags = getAllUniqueTags()
        renderTags(allTags, "游戏中暂无标签")
    elseif tab == "selected" then
        setActiveTab(selectedTabBtn)
        renderTags(selectedItemTags, "尚未精准选择物品")
    elseif tab == "quick" then
        setActiveTab(quickTabBtn)
        renderTags(quickSelectedItemTags, "尚未点击2D元素")
    end
end

switchTab("all")

allTabBtn.MouseButton1Click:Connect(function() switchTab("all") end)
selectedTabBtn.MouseButton1Click:Connect(function() switchTab("selected") end)
quickTabBtn.MouseButton1Click:Connect(function() switchTab("quick") end)

