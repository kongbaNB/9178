ball.Position = UDim2.new(0.8, 0, 0.3, 0)
ball.BackgroundTransparency = 1
ball.AutoButtonColor = false
ball.Image = "rbxassetid://113517588654522"
ball.Visible = false
ball.Draggable = true
ball.Parent = screenGui
Instance.new("UICorner", ball).CornerRadius = UDim.new(1,0)

local ballSpinConn
local function startBallSpin()
    if ballSpinConn then ballSpinConn:Disconnect() end
    local lastTime = tick()
    ballSpinConn = RunService.Heartbeat:Connect(function()
        local dt = tick() - lastTime
        lastTime = tick()
        ball.Rotation = (ball.Rotation + 60 * dt) % 360
    end)
end
local function stopBallSpin()
    if ballSpinConn then
        ballSpinConn:Disconnect()
        ballSpinConn = nil
    end
end

