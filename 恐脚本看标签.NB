local blockedTags = {}

local selecting = false
local selectionGui = nil
local currentHighlight = nil

local function clearHighlight()
    if currentHighlight then
        currentHighlight:Destroy()
        currentHighlight = nil
    end
end

local function highlightTarget(target)
    clearHighlight()
    if target and target:IsA("BasePart") then
        local highlight = Instance.new("Highlight")
        highlight.FillTransparency = 1
        highlight.OutlineColor = Color3.fromRGB(0, 255, 200)
        highlight.OutlineTransparency = 0
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = target
        currentHighlight = highlight
    elseif target and (target:IsA("Model") or target:IsA("Accessory")) then
        local primaryPart = target.PrimaryPart or (target:FindFirstChild("HumanoidRootPart") or target:FindFirstChildWhichIsA("BasePart"))
        if primaryPart then
            local highlight = Instance.new("Highlight")
            highlight.FillTransparency = 1
            highlight.OutlineColor = Color3.fromRGB(0, 255, 200)
            highlight.OutlineTransparency = 0
            highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            highlight.Parent = primaryPart
            currentHighlight = highlight
        end
    end
end

local function getCrosshairTarget()
    local viewportSize = Camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    local ray = Camera:ScreenPointToRay(screenCenter.X, screenCenter.Y)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
    local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
    if result then
        return result.Instance
    end
    return nil
end

local function startPreciseSelection()
    if selecting then return end
    selecting = true
    minimizeWindow()
    
    selectionGui = Instance.new("ScreenGui")
    selectionGui.Name = "SelectionGui"
    selectionGui.Parent = PlayerGui
    selectionGui.IgnoreGuiInset = true
    selectionGui.ResetOnSpawn = false
    
    local crosshair = Instance.new("Frame")
    crosshair.Size = UDim2.new(0, 30, 0, 30)
    crosshair.Position = UDim2.new(0.5, -15, 0.5, -15)
    crosshair.BackgroundTransparency = 1
    crosshair.Parent = selectionGui
    
    local hLine = Instance.new("Frame")
    hLine.Size = UDim2.new(1, 0, 0, 2)
    hLine.Position = UDim2.new(0, 0, 0.5, -1)
    hLine.BackgroundColor3 = Color3.new(0, 255, 0)
    hLine.BorderSizePixel = 0
    hLine.Parent = crosshair
    
    local vLine = Instance.new("Frame")
    vLine.Size = UDim2.new(0, 2, 1, 0)
    vLine.Position = UDim2.new(0.5, -1, 0, 0)
    vLine.BackgroundColor3 = Color3.new(0, 255, 0)
    vLine.BorderSizePixel = 0
    vLine.Parent = crosshair
    
    local confirmBtn = Instance.new("TextButton")
    confirmBtn.Size = UDim2.new(0, 120, 0, 35)
    confirmBtn.Position = UDim2.new(0.5, -60, 0.7, 0)
    confirmBtn.Text = "确定此物品"
    confirmBtn.Font = Enum.Font.SourceSansBold
    confirmBtn.TextSize = 16
    confirmBtn.TextColor3 = Color3.new(1,1,1)
    confirmBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
    confirmBtn.Parent = selectionGui
    Instance.new("UICorner", confirmBtn).CornerRadius = UDim.new(0, 8)
    
    local cancelBtn = Instance.new("TextButton")
    cancelBtn.Size = UDim2.new(0, 80, 0, 35)
    cancelBtn.Position = UDim2.new(0.5, -40, 0.8, 0)
    cancelBtn.Text = "取消"
    cancelBtn.Font = Enum.Font.SourceSansBold
    cancelBtn.TextSize = 16
    cancelBtn.TextColor3 = Color3.new(1,1,1)
    cancelBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
    cancelBtn.Parent = selectionGui
    Instance.new("UICorner", cancelBtn).CornerRadius = UDim.new(0, 8)
    
    local heartbeatConnection
    heartbeatConnection = RunService.Heartbeat:Connect(function()
        if not selecting then return end
        local target = getCrosshairTarget()
        highlightTarget(target)
    end)
    
    confirmBtn.MouseButton1Click:Connect(function()
        if not selecting then return end
        local target = getCrosshairTarget()
        local tags = target and CollectionService:GetTags(target) or {}
        if #tags > 0 then
            selectedItemTags = {}
            for _, t in ipairs(tags) do selectedItemTags[#selectedItemTags+1] = t end
            table.sort(selectedItemTags)
            switchTab("selected")
            print("精准选择物体: " .. target:GetFullName() .. "  标签: " .. table.concat(selectedItemTags, ", "))
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "精准选择",
                    Text = "已记录在「选定物品」分类",
                    Duration = 5
                })
            end)
        else
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "精准选择",
                    Text = "该物体没有标签",
                    Duration = 3
                })
            end)
        end
        clearHighlight()
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if selectionGui then selectionGui:Destroy() end
        selecting = false
        restoreWindow()
    end)
    
    cancelBtn.MouseButton1Click:Connect(function()
        clearHighlight()
        if heartbeatConnection then heartbeatConnection:Disconnect() end
        if selectionGui then selectionGui:Destroy() end
        selecting = false
        restoreWindow()
    end)
    
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "精准选择模式",
            Text = "将准星对准物体，点击确定按钮",
            Duration = 3
        })
    end)
end

local esp3DEnabled = false
local esp2DEnabled = false
local esp3DContainer = nil
local esp2DContainer = nil

local function clear3DESP()
    if esp3DContainer then
        esp3DContainer:Destroy()
        esp3DContainer = nil
    end
end

local function clear2DESP()
    if esp2DContainer then
        esp2DContainer:Destroy()
        esp2DContainer = nil
    end
end

local function updateBlockButtonVisibility()
    clearBlockBtn.Visible = next(blockedTags) ~= nil
end

local function makeLongPressable(button, tagText)
    local pressStart = nil
    local isPressed = false
    local blockConnection

    button.MouseButton1Down:Connect(function()
        if isPressed then return end
        isPressed = true
        pressStart = tick()
        button.TextColor3 = Color3.fromRGB(255, 0, 0)
        blockConnection = RunService.Heartbeat:Connect(function()
            if not isPressed then
                blockConnection:Disconnect()
                return
            end
            local elapsed = tick() - pressStart
            if elapsed >= 10 then
                blockedTags[tagText] = true
                if esp2DContainer then
                    for _, child in ipairs(esp2DContainer:GetChildren()) do
                        if child:IsA("TextButton") and child.Text == tagText then
                            child:Destroy()
                        end
                    end
                end
                updateBlockButtonVisibility()
                pcall(function()
                    game:GetService("StarterGui"):SetCore("SendNotification", {
                        Title = "标签已屏蔽",
                        Text = "已屏蔽所有同名2D标签: " .. tagText,
                        Duration = 5
                    })
                end)
                isPressed = false
                blockConnection:Disconnect()
            end
        end)
    end)

    button.MouseButton1Up:Connect(function()
        isPressed = false
        if blockConnection then
            blockConnection:Disconnect()
        end
        button.TextColor3 = Color3.fromRGB(255, 165, 0)
    end)

    button.MouseLeave:Connect(function()
        isPressed = false
        if blockConnection then
            blockConnection:Disconnect()
        end
        button.TextColor3 = Color3.fromRGB(255, 165, 0)
    end)
end

local function update2DESP()
    clear2DESP()
    if not esp2DEnabled then return end
    local container = Instance.new("ScreenGui")
    container.Name = "ESP_2D"
    container.Parent = PlayerGui
    container.IgnoreGuiInset = true
    container.ResetOnSpawn = false
    container.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    esp2DContainer = container

    local function addLabels(parent)
        for _, obj in ipairs(parent:GetChildren()) do
            if obj:IsA("GuiObject") and obj.Visible then
                local tags = CollectionService:GetTags(obj)
                if #tags > 0 then
                    local tagText = table.concat(tags, ", ")
                    if blockedTags[tagText] then
                        addLabels(obj)
                        continue
                    end
                    local btn = Instance.new("TextButton")
                    btn.Size = UDim2.new(0, 200, 0, 16)
                    btn.BackgroundTransparency = 0.5
                    btn.BackgroundColor3 = Color3.new(0,0,0)
                    btn.Text = tagText
                    btn.TextColor3 = Color3.fromRGB(255, 165, 0)
                    btn.Font = Enum.Font.SourceSansBold
                    btn.TextSize = 12
                    btn.AutoButtonColor = false
                    btn.Parent = container
                    makeLongPressable(btn, tagText)
                    coroutine.wrap(function()
                        while esp2DEnabled and obj and obj.Parent and btn and btn.Parent do
                            local pos = obj.AbsolutePosition
                            local size = obj.AbsoluteSize
                            btn.Position = UDim2.new(0, pos.X + size.X/2 - btn.AbsoluteSize.X/2, 0, pos.Y - btn.AbsoluteSize.Y - 2)
                            RunService.RenderStepped:Wait()
                        end
                        if btn then btn:Destroy() end
                    end)()
                end
            end
            addLabels(obj)
        end
    end

    for _, gui in ipairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") and gui ~= container and gui ~= screenGui then
            addLabels(gui)
        end
    end
    for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do
        if gui:IsA("ScreenGui") then
            addLabels(gui)
        end
    end
end

clearBlockBtn.MouseButton1Click:Connect(function()
    blockedTags = {}
    updateBlockButtonVisibility()
    if esp2DEnabled then
        update2DESP()
    end
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "屏蔽已清空",
            Text = "所有2D标签屏蔽已解除",
            Duration = 3
        })
    end)
end)

local function update3DESP()
    clear3DESP()
    if not esp3DEnabled then return end
    local container = Instance.new("Folder")
    container.Name = "ESP_3D"
    container.Parent = workspace
    esp3DContainer = container
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("Accessory") then
            local tags = CollectionService:GetTags(obj)
            if #tags > 0 then
                local part = obj
                if obj:IsA("Model") then
                    part = obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChildWhichIsA("BasePart")
                end
                if part then
                    local billboard = Instance.new("BillboardGui")
                    billboard.Name = "TagESP"
                    billboard.Adornee = part
                    billboard.Size = UDim2.new(0, 200, 0, 30)
                    billboard.StudsOffset = Vector3.new(0, 2, 0)
                    billboard.AlwaysOnTop = true
                    billboard.Parent = container
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(1,0,1,0)
                    label.BackgroundTransparency = 0.7
                    label.BackgroundColor3 = Color3.fromRGB(0,0,0)
                    label.TextColor3 = Color3.fromRGB(0,255,0)
                    label.Font = Enum.Font.SourceSans
                    label.TextSize = 14
                    label.Text = table.concat(tags, ", ")
                    label.Parent = billboard
                end
            end
        end
    end
end

esp3DBtn.MouseButton1Click:Connect(function()
    esp3DEnabled = not esp3DEnabled
    esp3DBtn.Text = esp3DEnabled and "透视3D标签:开" or "透视3D标签:关"
    esp3DBtn.BackgroundColor3 = esp3DEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80,80,80)
    update3DESP()
end)

esp2DBtn.MouseButton1Click:Connect(function()
    esp2DEnabled = not esp2DEnabled
    esp2DBtn.Text = esp2DEnabled and "透视2D标签:开" or "透视2D标签:关"
    esp2DBtn.BackgroundColor3 = esp2DEnabled and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(80,80,80)
    if esp2DEnabled then
        update2DESP()
    else
        clear2DESP()
    end
end)

preciseSelectBtn.MouseButton1Click:Connect(function()
    if not selecting then startPreciseSelection() end
end)
