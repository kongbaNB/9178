local translatedTexts = {}
local speedAntiPull = nil
local SpinEnabled = false
local SpinSpeed = 360
local spinConnection = nil
local antiAFKEnabled = false
local antiAFKConnection = nil
local UIButtons = {}
local AntiFlingEnabled = false
local AntiFlingConnection = nil
local antiFlingOriginalStates = {}

local function disablePlayerCollision(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if antiFlingOriginalStates[part] == nil then
                antiFlingOriginalStates[part] = part.CanCollide
            end
            part.CanCollide = false
        end
    end
end

local function enablePlayerCollision(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if antiFlingOriginalStates[part] ~= nil then
                part.CanCollide = antiFlingOriginalStates[part]
                antiFlingOriginalStates[part] = nil
            end
        end
    end
end

local function enableAllPlayersCollision()
    for part, state in pairs(antiFlingOriginalStates) do
        if part and part.Parent then
            pcall(function() part.CanCollide = state end)
        end
    end
    antiFlingOriginalStates = {}
end

local function startAntiFling()
    if AntiFlingConnection then AntiFlingConnection:Disconnect() end
    for _, p in ipairs(Players:GetPlayers()) do
        disablePlayerCollision(p)
    end
    AntiFlingConnection = RunService.Heartbeat:Connect(function()
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                for _, part in ipairs(p.Character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        if antiFlingOriginalStates[part] == nil then
                            antiFlingOriginalStates[part] = part.CanCollide
                        end
                        part.CanCollide = false
                    end
                end
            end
        end
    end)
end

local function stopAntiFling()
    if AntiFlingConnection then AntiFlingConnection:Disconnect() end
    AntiFlingConnection = nil
    enableAllPlayersCollision()
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(char)
        if AntiFlingEnabled then
            task.wait(0.5)
            disablePlayerCollision(player)
        end
    end)
end)

Players.PlayerRemoving:Connect(function(player)
