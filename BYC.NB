local PlayerMain = Tabs.Player:AddLeftGroupbox("移动功能")
_env.NoStun = false
game.Players.LocalPlayer.Character.Humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
    if _env.NoStun == true and game.Players.LocalPlayer.Character.Humanoid.WalkSpeed < 16 then
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
    end
end)
game.Players.LocalPlayer.CharacterAdded:Connect(function()
    game.Players.LocalPlayer.Character.Humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if _env.NoStun == true and game.Players.LocalPlayer.Character.Humanoid.WalkSpeed < 16 then
            game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
        end
    end)
end)
PlayerMain:AddToggle("NoStun",{
    Text = "去除前摇/后摇/缓慢动作",
    Default = false,
    Callback = function(v)
        _env.NoStun = v
    end
})
_env.SpeedBoostValue = 1
_env.SpeedBoost = false
PlayerMain:AddSlider("SpeedSlider",{
    Text = "速度倍率",
    Min = 0, Max = 3,
    Default = 1, Compact = true,
    Rounding = 1,
    Callback = function(v)
        _env.SpeedBoostValue = v
    end
})
PlayerMain:AddToggle("SpeedToggle",{
    Text = "启用速度加速",
    Default = false,
    Callback = function(v)
        _env.SpeedBoost = v
        while _env.SpeedBoost do
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                LocalPlayer.Character.HumanoidRootPart.CFrame += LocalPlayer.Character.Humanoid.MoveDirection * _env.SpeedBoostValue
                LocalPlayer.Character.HumanoidRootPart.CanCollide = true
            end
            task.wait()
        end
    end
})
local desiredWalkSpeed = 16
PlayerMain:AddSlider("WalkSpeedSlider",{
    Text = "移动速度",
    Min = 16, Max = 200,
    Default = 16, Compact = true,
    Rounding = 0,
    Callback = function(v)
        desiredWalkSpeed = v
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then humanoid.WalkSpeed = v end
        end
    end
})
task.spawn(function()
    while true do
        task.wait(0.1)
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid and humanoid.WalkSpeed ~= desiredWalkSpeed then
                humanoid.WalkSpeed = desiredWalkSpeed
            end
        end
    end
end)
