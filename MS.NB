local repo = 'https://raw.githubusercontent.com/KingScriptAE/No-sirve-nada./refs/heads/main/' local function safeLoad(url) local success, result = pcall(function() return loadstring(game:HttpGet(url))() end) if not success then warn("加载失败: " .. url) return nil end return result end local Library = safeLoad(repo .. 'Library.lua') local ThemeManager = safeLoad(repo .. 'addons/ThemeManager.lua') local SaveManager = safeLoad(repo .. 'addons/SaveManager.lua') if not Library then game:GetService("StarterGui"):SetCore("SendNotification", { Title = "错误", Text = "UI 库加载失败，请检查网络或脚本资源", Duration = 5, }) return end local Options = Library.Options local Toggles = Library.Toggles local Players = game:GetService("Players") local RunService = game:GetService("RunService") local LocalPlayer = Players.LocalPlayer local isModelLoadActive = false local isDistanceShowActive = false local isDoubleMoneyActive = false local isScriptRunning = true local playerLoopHandle = {} local CurrentCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait() local CurrentHumanoid = CurrentCharacter:WaitForChild("Humanoid", 10) LocalPlayer.CharacterAdded:Connect(function(newChar) CurrentCharacter = newChar CurrentHumanoid = newChar:WaitForChild("Humanoid", 10) end) local function getWebContent(url) return game:HttpGet(url) end local function runLuaCode(code) loadstring(code)() end local function loadPlayerModel(player) if player == LocalPlayer then return end local loopRunning = true local function stopLoop() loopRunning = false end task.spawn(function() while loopRunning and isModelLoadActive and isScriptRunning and player:IsDescendantOf(Players) do task.wait(0.5) pcall(function() if player.Character then player.Character.Archivable = true player.Character.Parent = workspace end end) pcall(function() local char = player.Character if char then local hrp = char:FindFirstChild("HumanoidRootPart") local head = char:FindFirstChild("Head") if hrp then hrp.LocalTransparencyModifier = 0 end if head then head.LocalTransparencyModifier = 0 end end end) end end) return stopLoop end local function drawPlayerMarker(player) if player == LocalPlayer then return end local loopRunning = true local function stopLoop() loopRunning = false pcall(function() if player.Character then local marker = player.Character:FindFirstChild("PlayerMarker", true) if marker then marker.Parent:Destroy() end end end) end task.spawn(function() while loopRunning and isModelLoadActive and isScriptRunning and player:IsDescendantOf(Players) do task.wait(0.5) pcall(function() local char = player.Character if not char then return end local root = char:FindFirstChild("HumanoidRootPart") if not root then return end local existing = root:FindFirstChild("PlayerMarker") if existing then existing:Destroy() end local bg = Instance.new("BillboardGui") bg.Name = "PlayerMarker" bg.AlwaysOnTop = true bg.Size = UDim2.new(0.02, 0, 0.02, 0) bg.Adornee = root bg.Parent = root local f = Instance.new("Frame") f.Size = UDim2.new(1, 0, 1, 0) f.BackgroundColor3 = Color3.new(1, 0, 0) f.BorderSizePixel = 0 f.Parent = bg end) end end) return stopLoop end local function startAllPlayerFunc() for _, player in pairs(Players:GetPlayers()) do if player == LocalPlayer then continue end local stopLoad = loadPlayerModel(player) local stopMarker = drawPlayerMarker(player) playerLoopHandle[player.UserId] = {stopLoad, stopMarker} end end local function stopAllPlayerFunc() for userId, handleList in pairs(playerLoopHandle) do for _, stopFunc in pairs(handleList) do stopFunc() end end table.clear(playerLoopHandle) for _, player in pairs(Players:GetPlayers()) do if player.Character then local marker = player.Character:FindFirstChild("DistanceMarker") if marker then marker:Destroy() end end end end local renderSteppedConn = RunService.RenderStepped:Connect(function() local myChar = LocalPlayer.Character local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart") if not myRoot or not isScriptRunning then return end for _, player in pairs(Players:GetPlayers()) do if player == LocalPlayer then continue end local targetChar = player.Character local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart") if not targetRoot then continue end local distanceMarker = targetChar:FindFirstChild("DistanceMarker") if not distanceMarker then distanceMarker = Instance.new("BillboardGui") distanceMarker.Name = "DistanceMarker" distanceMarker.Adornee = targetRoot distanceMarker.Size = UDim2.new(0, 100, 0, 25) distanceMarker.StudsOffset = Vector3.new(0, 3, 0) distanceMarker.AlwaysOnTop = true distanceMarker.Parent = targetChar local textLabel = Instance.new("TextLabel") textLabel.Size = UDim2.new(1, 0, 1, 0) textLabel.BackgroundTransparency = 1 textLabel.TextColor3 = Color3.new(1, 1, 0) textLabel.TextScaled = true textLabel.Parent = distanceMarker end distanceMarker.Enabled = isModelLoadActive and isDistanceShowActive if distanceMarker.Enabled then local distance = (myRoot.Position - targetRoot.Position).Magnitude distanceMarker.TextLabel.Text = math.floor(distance) .. "m" end end end) local playerAddedConn = Players.PlayerAdded:Connect(function(player) player.CharacterAdded:Connect(function() task.wait(0.2) if isModelLoadActive and isScriptRunning then local stopLoad = loadPlayerModel(player) local stopMarker = drawPlayerMarker(player) playerLoopHandle[player.UserId] = {stopLoad, stopMarker} end end) end) local playerRemovingConn = Players.PlayerRemoving:Connect(function(player) local handleList = playerLoopHandle[player.UserId] if handleList then for _, stopFunc in pairs(handleList) do stopFunc() end playerLoopHandle[player.UserId] = nil end end) local function startDoubleMoney() local leaderstats = LocalPlayer:FindFirstChild("leaderstats") if not leaderstats then return end local money = leaderstats:FindFirstChild("Money") or leaderstats:FindFirstChild("Cash") or leaderstats:FindFirstChild("Coins") if not money then return end local lastValue = money.Value local connection connection = money:GetPropertyChangedSignal("Value"):Connect(function() if not isDoubleMoneyActive then connection:Disconnect() return end local newValue = money.Value local diff = newValue - lastValue if diff > 0 then money.Value = newValue + diff newValue = money.Value end lastValue = newValue end) end local function findTrophyAndTeleport() local keywords = {"奖杯", "奖", "杯", "Trophy", "trophy", "TROPHY", "Trofeo", "trofeo", "Trophäe", "trophäe", "トロフィー", "트로피", "трофей", "TROFEO"} local searchIn = workspace:GetDescendants() local found = nil for _, obj in ipairs(searchIn) do if obj:IsA("BasePart") or obj:IsA("Model") then for _, kw in ipairs(keywords) do if string.find(obj.Name, kw, 1, true) then found = obj break end end end if found then break end end if found then if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then local targetPos if found:IsA("BasePart") then targetPos = found.Position + Vector3.new(0, 5, 0) else local primaryPart = found.PrimaryPart or found:FindFirstChildWhichIsA("BasePart") if primaryPart then targetPos = primaryPart.Position + Vector3.new(0, 5, 0) else Library:Notify("无法确定奖杯位置", 3) return end end LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame = CFrame.new(targetPos) end else Library:Notify("未找到奖杯", 3) end end local Window = Library:CreateWindow({ Title = "盲射脚本", Footer = "By 恐拜大帝", Icon = 131153193945220, NotifySide = "Right", ShowCustomCursor = true, }) Library:Notify("恐拜大帝 制作", 5) local Tabs = { Notice = Window:AddTab("通知", "info"), Main = Window:AddTab("主要功能", "info"), Settings = Window:AddTab("设置", "settings"), } local NoticeGroup = Tabs.Notice:AddLeftGroupbox("作者消息") NoticeGroup:AddLabel('恐拜大帝将持续更新此脚本') NoticeGroup:AddLabel('创作者：恐拜大帝') local FuncGroup = Tabs.Main:AddLeftGroupbox("玩家工具") local modelToggle = FuncGroup:AddToggle('ModelLoadToggle', { Text = '显示玩家模型（持续刷新）', Default = false, Tooltip = '预载其他玩家模型并在角色位置显示红点', Callback = function(Value) isModelLoadActive = Value if Value then startAllPlayerFunc() else stopAllPlayerFunc() isDistanceShowActive = false local distToggle = Toggles.DistanceToggle if distToggle and distToggle.SetValue then distToggle:SetValue(false) end end end }) local distanceToggle = FuncGroup:AddToggle('DistanceToggle', { Text = '距离显示（持续刷新）', Default = false, Tooltip = '需先开启玩家显示', Callback = function(Value) if not isModelLoadActive then Library:Notify("请先开启玩家显示", 3) if distanceToggle.SetValue then distanceToggle:SetValue(false) end return end isDistanceShowActive = Value end }) FuncGroup:AddButton('召唤飞行脚本', function() local success, err = pcall(function() local targetUrl = "https://pastebin.com/raw/dZNN3GhY" local codeContent = getWebContent(targetUrl) runLuaCode(codeContent) end) if not success then Library:Notify("加载飞行脚本失败", 3) else Library:Notify("飞行脚本已执行", 3) end end) local doubleMoneyToggle = FuncGroup:AddToggle('DoubleMoneyToggle', { Text = '双倍金钱农场', Default = false, Tooltip = '开启后，任何获得的金钱将翻倍', Callback = function(Value) isDoubleMoneyActive = Value if Value then startDoubleMoney() Library:Notify("双倍金钱已激活", 3) else Library:Notify("双倍金钱已关闭", 3) end end }) FuncGroup:AddButton('传送到跑酷终点奖杯处', function() findTrophyAndTeleport() end) local SettingsGroup = Tabs.Settings:AddLeftGroupbox("菜单") SettingsGroup:AddButton('卸载脚本', function() isScriptRunning = false isModelLoadActive = false isDistanceShowActive = false isDoubleMoneyActive = false stopAllPlayerFunc() if renderSteppedConn then renderSteppedConn:Disconnect() end if playerAddedConn then playerAddedConn:Disconnect() end if playerRemovingConn then playerRemovingConn:Disconnect() end local moveGui = LocalPlayer.PlayerGui:FindFirstChild("main") if moveGui then moveGui:Destroy() end Library:Unload() end) if ThemeManager then ThemeManager:SetLibrary(Library) ThemeManager:SetFolder("MyScriptTheme") ThemeManager:ApplyToTab(Tabs.Settings) end if SaveManager then SaveManager:SetLibrary(Library) SaveManager:IgnoreThemeSettings() SaveManager:SetFolder("MyScriptConfig") SaveManager:BuildConfigSection(Tabs.Settings) end
