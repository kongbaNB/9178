local HSMeta = {
    {name="HiderESP", type="player", func=Script.Functions.HiderESP},
    {name="SeekerESP", type="player", func=Script.Functions.SeekerESP},
    {name="KeyESP", type="key", func=Script.Functions.KeyESP},
    {name="DoorESP", type="door", func=Script.Functions.DoorESP},
}
for _,m in ipairs(HSMeta) do
    Toggles[m.name]:OnChanged(function(b)
        if not b then for _,e in pairs(Script.ESPTable[m.name=="DoorESP" and "Door" or m.name=="KeyESP" and "Key" or m.name=="HiderESP" and "Hider" or "Seeker"]) do e.Destroy() end return end
        if not Script.GameState:find("HideAndSeek") then return end
        if m.type=="player" then for _,p in pairs(Players:GetPlayers()) do m.func(p) end
        elseif m.type=="key" then
            local map = workspace:FindFirstChild("HideAndSeekMap")
            if map and map:FindFirstChild("KEYS") then for _,k in pairs(map.KEYS:GetChildren()) do Script.Functions.KeyESP(k) end end
        elseif m.type=="door" then
            local map = workspace:FindFirstChild("HideAndSeekMap")
            if map and map:FindFirstChild("NEWFIXEDDOORS") then
                for _,floor in pairs(map.NEWFIXEDDOORS:GetChildren()) do
                    if floor.Name:match("^Floor") then for _,door in pairs(floor:GetChildren()) do Script.Functions.DoorESP(door) end end
                end
            end
        end
    end)
end

table.insert(Script.Connections, workspace.DescendantAdded:Connect(function(d)
    if not Script.GameState:find("HideAndSeek") then return end
    if Toggles.KeyESP and Toggles.KeyESP.Value then
        local map = workspace:FindFirstChild("HideAndSeekMap")
        if map and d:IsA("Model") and d.Parent and d.Parent.Name=="KEYS" and d.Parent.Parent==map then Script.Functions.KeyESP(d) end
    end
    if Toggles.DoorESP and Toggles.DoorESP.Value then
        local map = workspace:FindFirstChild("HideAndSeekMap")
        if map and d:IsA("Model") and d.Name=="FullDoorAnimated" and d.Parent and d.Parent.Parent and d.Parent.Parent.Name=="NEWFIXEDDOORS" then
            Script.Functions.DoorESP(d)
        end
    end
end))

