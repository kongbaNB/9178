local controlModule
Toggles.Fly:OnChanged(function(b)
    local root = lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local hum = lplr.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = b end
    local body = Script.Temp.FlyBody or Instance.new("BodyVelocity")
    body.Velocity = Vector3.zero; body.MaxForce = Vector3.one*9e9
    Script.Temp.FlyBody = body
    body.Parent = b and root or nil
    if b then
        controlModule = controlModule or Script.Functions.SafeRequire(lplr.PlayerScripts.PlayerModule.ControlModule)
        Script.Connections.Fly = RunService.RenderStepped:Connect(function()
            local mv = controlModule:GetMoveVector()
            body.Velocity = -((camera.CFrame.LookVector*mv.Z)-(camera.CFrame.RightVector*mv.X))*Options.FlySpeed.Value
        end)
    else
        if Script.Connections.Fly then Script.Connections.Fly:Disconnect() end
    end
end)

local function hookAntiFling()
    if not lplr.Character or not Toggles.FlingAuraToggle.Value then return end
    local main = lplr.Character:WaitForChild("Main")
    main.Enabled = false; main.Disabled = true
    Script.Temp.AntiFlingHook = main:GetPropertyChangedSignal("Enabled"):Connect(function() main.Enabled=false; main.Disabled=true end)
end
table.insert(Script.Connections, lplr.CharacterAdded:Connect(hookAntiFling))
pcall(hookAntiFling)

Toggles.FlingAuraToggle:OnChanged(function(b)
    if b then
        local function setNoclip(state) if Toggles.Noclip.Value~=state then Toggles.Noclip:SetValue(state) end end
        setNoclip(true)
        Script.Temp.FlingActive = true
        task.spawn(function()
            local movel = 0.1
            while Script.Temp.FlingActive do
                local char = lplr.Character
                local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
                if root then
                    local vel = root.Velocity
                    root.Velocity = vel*10000 + Vector3.new(0,10000,0)
                    RunService.RenderStepped:Wait()
                    root.Velocity = vel
                    RunService.Stepped:Wait()
                    root.Velocity = vel + Vector3.new(0,movel,0)
                    movel = -movel
                end
                RunService.Heartbeat:Wait()
            end
        end)
    else
        Script.Temp.FlingActive = false
        if Script.Temp.AntiFlingHook then Script.Temp.AntiFlingHook:Disconnect() end
        if lplr.Character then
            local main = lplr.Character:WaitForChild("Main")
            main.Enabled = true; main.Disabled = false
        end
    end
end)

FunGroup:AddToggle('FlingAuraToggle',{Text='投掷光环',Default=false})
FunGroup:AddToggle('AntiFlingToggle',{Text='防投掷',Default=false})
Toggles.AntiFlingToggle:OnChanged(function(b)
    if b then
        Script.Temp.AntiFlingActive = true
        task.spawn(function()
            local last
            while Script.Temp.AntiFlingActive do
                local char = lplr.Character
                local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
                if root then
                    if root.Velocity.Magnitude > 100 then
                        root.Velocity = Vector3.new(math.clamp(root.Velocity.X,-100,100), math.clamp(root.Velocity.Y,-100,100), math.clamp(root.Velocity.Z,-100,100))
                    end
                    if not last or (root.Position-last.Position).Magnitude<20 then last = root.CFrame
                    elseif (root.Position-last.Position).Magnitude>50 then root.CFrame = last; root.Velocity = Vector3.zero end
                end
                task.wait(0.05)
            end
        end)
    else Script.Temp.AntiFlingActive = false end
end)

local SecGroup = MainTab:AddRightGroupbox("安全")
SecGroup:AddToggle('AntiAfk',{Text='防挂机',Default=true})
Toggles.AntiAfk:OnChanged(function(b)
    if b then
        local vu = game:GetService("VirtualUser")
        Script.Temp.AfkConn = lplr.Idled:Connect(function() vu:Button2Down(Vector2.new(),camera.CFrame); wait(1); vu:Button2Up(Vector2.new(),camera.CFrame) end)
    else
        if Script.Temp.AfkConn then Script.Temp.AfkConn:Disconnect() end
    end
end)
SecGroup:AddToggle('StaffDetector',{Text='管理员检测',Default=true})
Toggles.StaffDetector:OnChanged(function(b)
    if b then
        local gid = 12398672; local minRank = 120
        local roles = {[120]="版主",[254]="开发者",[255]="所有者"}
        local detected = {}
        local function check(p)
            local ok,rank = pcall(function() return p:GetRankInGroup(gid) end)
            if ok and rank and rank>=minRank then
                local role = roles[rank] or "等级"..rank
                Script.Functions.Alert("[管理员] "..p.Name.." ("..role..")",10)
                detected[p.UserId] = {Name=p.Name,Role=role}
            end
        end
        for _,p in pairs(Players:GetPlayers()) do if p~=lplr then check(p) end end
        table.insert(Script.Connections, Players.PlayerAdded:Connect(function(p) if p~=lplr then task.wait(1); check(p) end end))
        table.insert(Script.Connections, Players.PlayerRemoving:Connect(function(p)
            if detected[p.UserId] then Script.Functions.Alert("[管理员离开] "..detected[p.UserId].Name,10) end
        end))
    end
end)

local PerfGroup = MainTab:AddRightGroupbox("性能")
PerfGroup:AddToggle('LowGFX',{Text='低画质',Default=false})
PerfGroup:AddToggle('DisableEffects',{Text='禁用特效',Default=false})
Toggles.DisableEffects:OnChanged(function(b)
    if b then
        local ef = workspace:WaitForChild("Effects",15)
        if not ef then return end
        ef:ClearAllChildren()
        Script.Temp.DisableEffectsConn = ef.ChildAdded:Connect(function(c) c:Destroy() end)
    else
        if Script.Temp.DisableEffectsConn then Script.Temp.DisableEffectsConn:Disconnect() end
    end
end)
PerfGroup:AddButton({Text='清除特效缓存',Func=function() if workspace:FindFirstChild("Effects") then workspace.Effects:ClearAllChildren() end end})

table.insert(Script.Connections, lplr.CharacterAdded:Connect(function(c)
    if Toggles.SpeedToggle.Value and c:WaitForChild("Humanoid",10) then
        c.Humanoid.WalkSpeed = Options.SpeedSlider.Value
    end
end))

table.insert(Script.Connections, workspace:WaitForChild("Values"):WaitForChild("CurrentGame"):GetPropertyChangedSignal("Value"):Connect(function()
    Script.GameState = tostring(workspace.Values.CurrentGame.Value)
    Script.GameStateChanged:Fire(Script.GameState)
    if Toggles.InkGameAutowin.Value then Script.Functions.HandleAutowin() end
    if Script.GameState:find("HideAndSeek") then
        for _,m in ipairs(HSMeta) do
            if Toggles[m.name] and Toggles[m.name].Value then
                Toggles[m.name]:SetValue(false)
                Toggles[m.name]:SetValue(true)
            end
        end
    end
end))

table.insert(Script.Connections, UserInputService.JumpRequest:Connect(function()
    if Toggles.InfiniteJump.Value and lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
        lplr.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end))

for _,p in pairs(Players:GetPlayers()) do if p~=lplr then Script.Functions.SetupOtherPlayerConnection(p) end end
table.insert(Script.Connections, Players.PlayerAdded:Connect(function(p) if p~=lplr then Script.Functions.SetupOtherPlayerConnection(p) end end))

task.spawn(function() pcall(Script.Functions.OnLoad) end)

Library:OnUnload(function()
    for _,c in pairs(Script.Connections) do pcall(function() c:Disconnect() end) end
    if SaveManager then SaveManager:Save() end
    Library.Unloaded = true
    shared.Voidware_InkGame_Library = nil
end)

local MenuGroup = TabsUI.Settings:AddLeftGroupbox('菜单')
MenuGroup:AddToggle('KeybindMenuOpen',{Text='打开快捷键菜单',Default=false,Callback=function(v) Library.KeybindFrame.Visible=v end})
MenuGroup:AddToggle('ShowCustomCursor',{Text='自定义光标',Default=true,Callback=function(v) Library.ShowCustomCursor=v end})
MenuGroup:AddDivider()
MenuGroup:AddLabel('菜单快捷键'):AddKeyPicker('MenuKeybind',{Default='RightShift',NoUI=false,Text='菜单快捷键'})
MenuGroup:AddButton({Text='加入 Discord',Func=Script.Functions.JoinDiscord})
MenuGroup:AddButton({Text='卸载',Func=function() Library:Unload() end})

local CreditsGroup = TabsUI.Settings:AddRightGroupbox('鸣谢')
CreditsGroup:AddLabel("RTaOHUB 团队 - Python / Dex")
CreditsGroup:AddLabel("所有功能移植完成")

Library.ToggleKeybind = Options.MenuKeybind

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("RTaOHUB_linoria")
    ThemeManager:ApplyToTab(TabsUI.Settings)
end
if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("RTaOHUB_linoria/ink_game")
    SaveManager:BuildConfigSection(TabsUI.Settings)
    SaveManager:LoadAutoloadConfig()
end