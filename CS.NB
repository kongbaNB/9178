SheriffLeft:AddButton({ Title = "甩飞杀手", Func = function() local m = Yisan_findMurderer() if not m then Notify("找不到杀手") elseif m == Yisan_LocalPlayer then Notify("不能甩飞自己") else Yisan_powerfulFling(m) end end })
SheriffLeft:AddButton({ Title = "射击杀手", Func = function() if Yisan_findSheriff() ~= Yisan_LocalPlayer then Notify("你不是警长") return end local m = Yisan_findMurderer() or Yisan_findSheriffThatsNotMe() if not m then Notify("找不到杀手") return end if not Yisan_LocalPlayer.Character:FindFirstChild("Gun") then if Yisan_LocalPlayer.Backpack:FindFirstChild("Gun") then Yisan_LocalPlayer.Character:FindFirstChild("Humanoid"):EquipTool(Yisan_LocalPlayer.Backpack:FindFirstChild("Gun")) else Notify("你没有枪") return end end local hrp = m.Character:FindFirstChild("HumanoidRootPart") if not hrp then Notify("找不到杀手部位") return end local pp = Yisan_getPredictedPosition(m, Yisan_TaffyshootTChina) Yisan_LocalPlayer.Character.Gun.KnifeLocal.CreateBeam.RemoteFunction:InvokeServer(1, pp, "AH2") Notify("已射击杀手") end end })
