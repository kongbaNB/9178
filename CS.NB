        local hl = Instance.new("Highlight", Workspace) hl.OutlineTransparency = 1 hl.FillColor = Color3.fromRGB(255,255,0) hl.Name = "GunESP" hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop hl.Adornee = Yisan_getMap():FindFirstChild("GunDrop") hl.Enabled = true
    end
