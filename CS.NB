local KillerLeft = Tabs.Killer:AddLeftGroupbox("杀手攻击")
KillerLeft:AddToggle({ Title = "杀戮光环", Default = false, Callback = function(state) if state then Yisan_EnableKillAura() Notify("杀戮光环已开启") else Yisan_DisableKillAura() Notify("杀戮光环已关闭") end end })
KillerLeft:AddButton({ Title = "甩飞警长", Func = function() local s = Yisan_findSheriff() if not s then Notify("找不到警长") elseif s == Yisan_LocalPlayer then Notify("不能甩飞自己") else Yisan_powerfulFling(s) end end })
KillerLeft:AddButton({ Title = "杀死最近玩家", Func = function() if Yisan_findMurderer() ~= Yisan_LocalPlayer then Notify("你不是杀手") return end if not Yisan_LocalPlayer.Character:FindFirstChild("Knife") then if Yisan_LocalPlayer.Backpack:FindFirstChild("Knife") then Yisan_LocalPlayer.Character:FindFirstChild("Humanoid"):EquipTool(Yisan_LocalPlayer.Backpack:FindFirstChild("Knife")) else Notify("你没有刀") return end end local np = Yisan_findNearestPlayer() if not np or not np.Character then Notify("找不到玩家") return end local nhrp = np.Character:FindFirstChild("HumanoidRootPart") if not nhrp then Notify("找不到玩家部位") return end if not Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then Notify("你的角色无效") return end if not Yisan_TaffyMooKnife then nhrp.Anchored = true nhrp.CFrame = Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame + Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector * 2 task.wait(0.1) Yisan_LocalPlayer.Character.Knife.Stab:FireServer("Slash") else local lpknife = Yisan_LocalPlayer.Character:FindFirstChild("Knife") if not lpknife then return end local raycastParams = RaycastParams.new() raycastParams.FilterType = Enum.RaycastFilterType.Exclude raycastParams.FilterDescendantsInstances = {Yisan_LocalPlayer.Character} Yisan_LocalPlayer.Character.Knife.Throw:FireServer(lpknife:GetPivot(), nhrp.Position) end Notify("已杀死最近玩家") end end })
KillerLeft:AddButton({ Title = "杀死所有人", Func = function() if Yisan_findMurderer() ~= Yisan_LocalPlayer then Notify("你不是杀手") return end if not Yisan_LocalPlayer.Character:FindFirstChild("Knife") then if Yisan_LocalPlayer.Backpack:FindFirstChild("Knife") then Yisan_LocalPlayer.Character:FindFirstChild("Humanoid"):EquipTool(Yisan_LocalPlayer.Backpack:FindFirstChild("Knife")) else Notify("你没有刀") return end end for _, player in ipairs(Yisan_Players:GetPlayers()) do if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= Yisan_LocalPlayer then player.Character:FindFirstChild("HumanoidRootPart").Anchored = true player.Character:FindFirstChild("HumanoidRootPart").CFrame = Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame + Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector * 1 end end Yisan_LocalPlayer.Character.Knife.Stab:FireServer("Slash") Notify("已尝试杀死所有人") end end })
KillerLeft:AddButton({ Title = "扣为人质", Func = function() if Yisan_findMurderer() ~= Yisan_LocalPlayer then Notify("你不是杀手") return end for _, player in ipairs(Yisan_Players:GetPlayers()) do if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= Yisan_LocalPlayer then player.Character:FindFirstChild("HumanoidRootPart").Anchored = true player.Character:FindFirstChild("HumanoidRootPart").CFrame = Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame + Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector * 5 end end Notify("已扣为人质") end end })
KillerLeft:AddToggle({ Title = "模拟飞刀击杀", Default = false, Callback = function(state) Yisan_TaffyMooKnife = state end })

local MiscLeft = Tabs.Misc:AddLeftGroupbox("杂项")
