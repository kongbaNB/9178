if not getgenv().shared then
    getgenv().shared = {}
end

if not getgenv().RTaOHUB_loaded then
    getgenv().RTaOHUB_loaded = true
else
    local oldLib = shared.Voidware_InkGame_Library or shared.RTaOHUB_InkGame_Library
    if oldLib then
        pcall(function() oldLib:Unload() end)
    end
    shared.Voidware_InkGame_Library = nil
    shared.RTaOHUB_InkGame_Library = nil
end

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
