function Yisan_findMurderer()
    for _, i in ipairs(Players:GetPlayers()) do if i.Backpack:FindFirstChild("Knife") then return i end end
    for _, i in ipairs(Players:GetPlayers()) do if i.Character and i.Character:FindFirstChild("Knife") then return i end end
    if Yisan_playerData then for player, data in pairs(Yisan_playerData) do if data.Role == "Murderer" then if Players:FindFirstChild(player) then return Players:FindFirstChild(player) end end end end
    return nil
end

function Yisan_findSheriff()
    for _, i in ipairs(Players:GetPlayers()) do if i.Backpack:FindFirstChild("Gun") then return i end end
    for _, i in ipairs(Players:GetPlayers()) do if i.Character and i.Character:FindFirstChild("Gun") then return i end end
    if Yisan_playerData then for player, data in pairs(Yisan_playerData) do if data.Role == "Sheriff" then if Players:FindFirstChild(player) then return Players:FindFirstChild(player) end end end end
    return nil
end

function Yisan_findSheriffThatsNotMe()
    for _, i in ipairs(Players:GetPlayers()) do if i == LocalPlayer then continue end if i.Backpack:FindFirstChild("Gun") then return i end end
    for _, i in ipairs(Players:GetPlayers()) do if i == LocalPlayer then continue end if i.Character and i.Character:FindFirstChild("Gun") then return i end end
    if Yisan_playerData then for player, data in pairs(Yisan_playerData) do if data.Role == "Sheriff" then if Players:FindFirstChild(player) and Players:FindFirstChild(player) ~= LocalPlayer then return Players:FindFirstChild(player) end end end end
    return nil
end

function Yisan_getMap()
    for _, o in ipairs(Workspace:GetChildren()) do if o:FindFirstChild("CoinContainer") and o:FindFirstChild("Spawns") then return o end end
    return nil
end

function Yisan_getPredictedPosition(player, offset)
    local char = player.Character
    if not char then return Vector3.new(0,0,0) end
    local upperTorso = char:FindFirstChild("UpperTorso")
    local hum = char:FindFirstChild("Humanoid")
    if not upperTorso or not hum then return Vector3.new(0,0,0) end
    local velocity = upperTorso.AssemblyLinearVelocity
    local moveDir = hum.MoveDirection
    local pos = upperTorso.Position + ((velocity * Vector3.new(0, 0.5, 0))) * (offset / 15) + moveDir * offset
    pos = pos * (((LocalPlayer:GetNetworkPing() * 1000) * ((Yisan_TaffyPing - 1) * 0.01)) + 1)
    return pos
end

function Yisan_findNearestPlayer()
    local nearest = nil
    local minDist = math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local otherRoot = p.Character:FindFirstChild("HumanoidRootPart")
            if otherRoot then
                local d = (myRoot.Position - otherRoot.Position).Magnitude
                if d < minDist then minDist = d; nearest = p end
            end
        end
    end
    return nearest
end

function Yisan_powerfulFling(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then Notify("目标玩家无效") return end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = hum and hum.RootPart
    local tChar = targetPlayer.Character
    local tHum = tChar:FindFirstChildOfClass("Humanoid")
    local tRoot = tHum and tHum.RootPart
    local tHead = tChar:FindFirstChild("Head")
    local acc = tChar:FindFirstChildOfClass("Accessory")
    local handle = acc and acc:FindFirstChild("Handle")
    if not char or not hum or not root then Notify("你的角色无效") return end
    if root.Velocity.Magnitude < 50 then getgenv().OldPos = root.CFrame end
    if not getgenv().FPDH then getgenv().FPDH = Workspace.FallenPartsDestroyHeight end
    if tHead then Workspace.CurrentCamera.CameraSubject = tHead
    elseif not tHead and handle then Workspace.CurrentCamera.CameraSubject = handle
    elseif tHum and tRoot then Workspace.CurrentCamera.CameraSubject = tHum end
    if not tChar:FindFirstChildWhichIsA("BasePart") then Notify("目标没有有效部位") return end
    local FPos = function(bp, pos, ang)
        root.CFrame = CFrame.new(bp.Position) * pos * ang
        char:SetPrimaryPartCFrame(CFrame.new(bp.Position) * pos * ang)
        root.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        root.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end
    local SFBasePart = function(bp)
        local timeout = tick() + 2
        local angle = 0
        repeat
            if root and tHum then
                if bp.Velocity.Magnitude < 50 then
                    angle = angle + 100
                    FPos(bp, CFrame.new(0, 1.5, 0) + tHum.MoveDirection * bp.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, 0) + tHum.MoveDirection * bp.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(2.25, 1.5, -2.25) + tHum.MoveDirection * bp.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(-2.25, -1.5, 2.25) + tHum.MoveDirection * bp.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, 1.5, 0) + tHum.MoveDirection, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, 0) + tHum.MoveDirection, CFrame.Angles(math.rad(angle),0,0))
                    task.wait()
                else
                    FPos(bp, CFrame.new(0, 1.5, tHum.WalkSpeed), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, -tHum.WalkSpeed), CFrame.Angles(0,0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, 1.5, tHum.WalkSpeed), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, 1.5, tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, -tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(0,0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, 1.5, tRoot.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, 0), CFrame.Angles(0,0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5 ,0), CFrame.Angles(math.rad(-90),0,0))
                    task.wait()
                    FPos(bp, CFrame.new(0, -1.5, 0), CFrame.Angles(0,0,0))
                    task.wait()
                end
            else break end
        until bp.Velocity.Magnitude > 500 or bp.Parent ~= targetPlayer.Character or targetPlayer.Parent ~= Players or targetPlayer.Character ~= tChar or (tHum and tHum.Sit) or hum.Health <= 0 or tick() > timeout
    end
    Workspace.FallenPartsDestroyHeight = 0/0
    local bv = Instance.new("BodyVelocity") bv.Name = "EpixVel" bv.Parent = root bv.Velocity = Vector3.new(9e8,9e8,9e8) bv.MaxForce = Vector3.new(1/0,1/0,1/0)
    hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    if tRoot and tHead then
        if (tRoot.CFrame.p - tHead.CFrame.p).Magnitude > 5 then SFBasePart(tHead) else SFBasePart(tRoot) end
    elseif tRoot and not tHead then SFBasePart(tRoot)
    elseif not tRoot and tHead then SFBasePart(tHead)
    elseif not tRoot and not tHead and acc and handle then SFBasePart(handle)
    else Notify("找不到合适的甩飞部位") bv:Destroy() return end
    bv:Destroy()
    hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    Workspace.CurrentCamera.CameraSubject = hum
    repeat
        root.CFrame = getgenv().OldPos * CFrame.new(0, 0.5, 0)
        char:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, 0.5, 0))
        hum:ChangeState("GettingUp")
        for _, x in pairs(char:GetChildren()) do if x:IsA("BasePart") then x.Velocity, x.RotVelocity = Vector3.new(), Vector3.new() end end
        task.wait()
    until (root.Position - getgenv().OldPos.p).Magnitude < 25
    Workspace.FallenPartsDestroyHeight = getgenv().FPDH
end

function Yisan_reloadESP()
    for _, v in ipairs(Workspace:GetChildren()) do if v.Name == "PlayerESP" then v:Destroy() end end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            local char = plr.Character
            if not char:FindFirstChild("PlayerESP") then
                local hl = Instance.new("Highlight", Workspace) hl.Name = "PlayerESP" hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop hl.Adornee = char hl.FillColor = Color3.fromRGB(255,255,255) hl.FillTransparency = 0.5
                task.spawn(function()
                    if plr == Yisan_findMurderer() then hl.FillColor = Color3.fromRGB(255,0,0) hl.OutlineColor = Color3.fromRGB(255,0,0)
                    elseif plr == Yisan_findSheriff() then hl.FillColor = Color3.fromRGB(0,150,255) hl.OutlineColor = Color3.fromRGB(0,150,255)
                    else hl.FillColor = Color3.fromRGB(0,255,0) hl.OutlineColor = Color3.fromRGB(0,255,0) end
                end)
            end
        end
    end
end

function Yisan_getClosestModelToPlayer(player, models)
    local closest, minDist = nil, math.huge
    local myRoot = player.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    for _, model in ipairs(models) do
        local pos = model:GetPivot().Position
        local dist = (myRoot.Position - pos).Magnitude
        if dist < minDist then minDist = dist; closest = model end
    end
    return closest
end

function Yisan_startFlying()
    if Yisan_flying then return end
    Yisan_flying = true
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    char.Humanoid.PlatformStand = true
    if Yisan_bodyVelocity then Yisan_bodyVelocity:Destroy() end
    if Yisan_bodyGyro then Yisan_bodyGyro:Destroy() end
    Yisan_bodyVelocity = Instance.new("BodyVelocity") Yisan_bodyVelocity.MaxForce = Vector3.new(100000,100000,100000) Yisan_bodyVelocity.Velocity = Vector3.new() Yisan_bodyVelocity.Parent = char.HumanoidRootPart
    Yisan_bodyGyro = Instance.new("BodyGyro") Yisan_bodyGyro.MaxTorque = Vector3.new(100000,100000,100000) Yisan_bodyGyro.CFrame = char.HumanoidRootPart.CFrame Yisan_bodyGyro.Parent = char.HumanoidRootPart
    local start = tick()
    while tick() - start < 1 do Yisan_bodyVelocity.Velocity = Vector3.new(0,10,0) RunService.RenderStepped:Wait() end
    if Yisan_renderSteppedConnection then Yisan_renderSteppedConnection:Disconnect() end
    Yisan_renderSteppedConnection = RunService.RenderStepped:Connect(function()
        if Yisan_flying then
            local move = char.Humanoid.MoveDirection * Yisan_flySpeed
            local look = Workspace.CurrentCamera.CFrame.LookVector
            if move.Magnitude > 0 then
                if look.Y > 0.2 then move = move + Vector3.new(0, look.Y * Yisan_flySpeed, 0)
                elseif look.Y < -0.2 then move = move + Vector3.new(0, look.Y * Yisan_flySpeed, 0) end
            else move = Vector3.new() end
            Yisan_bodyVelocity.Velocity = move
            local tilt = 30 local factor = move.Magnitude / Yisan_flySpeed local dir = 1
            if Workspace.CurrentCamera.CFrame:VectorToObjectSpace(move).Z < 0 then dir = -1 end
            local tiltCF = CFrame.Angles(math.rad(tilt) * factor * dir, 0, 0)
            local targetCF = CFrame.new(char.HumanoidRootPart.Position, char.HumanoidRootPart.Position + look) * tiltCF
            Yisan_bodyGyro.CFrame = Yisan_bodyGyro.CFrame:Lerp(targetCF, 0.2)
        end
    end)
end

function Yisan_stopFlying()
    if not Yisan_flying then return end
    Yisan_flying = false
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    char.Humanoid.PlatformStand = false
    if Yisan_bodyVelocity then Yisan_bodyVelocity:Destroy() end
    if Yisan_bodyGyro then Yisan_bodyGyro:Destroy() end
    if Yisan_renderSteppedConnection then Yisan_renderSteppedConnection:Disconnect() end
end

function Yisan_splitString(str, delim)
    local res = {} delim = delim or ","
    for w in string.gmatch(str, "[^"..delim.."]+") do table.insert(res, w) end
    return res
end

function Yisan_toTokens(str)
    local res = {}
    for op, name in string.gmatch(str, "([+-])([^+-]+)") do table.insert(res, {Operator=op, Name=name}) end
    return res
end

function Yisan_onlyIncludeInTable(tab, matches)
    local mt, rt = {}, {}
    for _, v in ipairs(matches) do mt[v.Name] = true end
    for _, v in ipairs(tab) do if mt[v.Name] then table.insert(rt, v) end end
    return rt
end

function Yisan_removeTableMatches(tab, matches)
    local mt, rt = {}, {}
    for _, v in ipairs(matches) do mt[v.Name] = true end
    for _, v in ipairs(tab) do if not mt[v.Name] then table.insert(rt, v) end end
    return rt
end

function Yisan_getPlayersByName(name)
    local lower, len, found = string.lower(name), #name, {}
    for _, v in ipairs(Players:GetPlayers()) do
        if lower:sub(1,1) == '@' then
            if string.sub(string.lower(v.Name), 1, len-1) == lower:sub(2) then table.insert(found, v) end
        else
            if string.sub(string.lower(v.Name), 1, len) == lower or string.sub(string.lower(v.DisplayName), 1, len) == lower then table.insert(found, v) end
        end
    end
    return found
end

function Yisan_getPlayer(list, speaker)
    if not list then return {speaker.Name} end
    local names = Yisan_splitString(list, ",")
    local found = {}
    for _, name in ipairs(names) do
        if name:sub(1,1) ~= "+" and name:sub(1,1) ~= "-" then name = "+"..name end
        local tokens = Yisan_toTokens(name)
        local initial = Players:GetPlayers()
        for _, tok in ipairs(tokens) do
            if tok.Operator == "+" then initial = Yisan_onlyIncludeInTable(initial, Yisan_getPlayersByName(tok.Name))
            else initial = Yisan_removeTableMatches(initial, Yisan_getPlayersByName(tok.Name)) end
        end
        for _, v in ipairs(initial) do table.insert(found, v) end
    end
    local foundNames = {}
    for _, v in ipairs(found) do table.insert(foundNames, v.Name) end
    return foundNames[1]
end

function Yisan_secondsToMinutes(sec)
    if sec == -1 then return "" end
    return string.format("%dm %ds", math.floor(sec/60), sec%60)
end

function Yisan_EnableTimeDisplay()
    Yisan_LinniTime = true
    Yisan_Linnitask = task.spawn(function()
        while task.wait(0.5) and Yisan_LinniTime do
            local ok, left = pcall(function() return game.ReplicatedStorage.Remotes.Extras.GetTimer:InvokeServer() end)
            if ok and left then Notify("回合剩余时间: "..Yisan_secondsToMinutes(left)) else Notify("无法获取回合时间") break end
        end
    end)
end

function Yisan_DisableTimeDisplay()
    Yisan_LinniTime = false
    if Yisan_Linnitask then task.cancel(Yisan_Linnitask) Yisan_Linnitask = nil end
end

