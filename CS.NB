function Script.Functions.GetHider()
    for _, pl in pairs(Players:GetPlayers()) do
        if pl == lplr then continue end
        if not pl.Character then continue end
        if not pl:GetAttribute("IsHider") then continue end
        if pl.Character:FindFirstChild("HumanoidRootPart") and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0 then
            return pl.Character
        end
    end
end

