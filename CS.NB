        spinBtn.MouseButton1Click:Connect(function()
            state.spin = not state.spin
            spinBtn.Text = state.spin and "原地旋转：开" or "原地旋转：关"
            if state.spin then startSpin() else stopSpin() end
        end)
        spinSpeedBtn.MouseButton1Click:Connect(function()
            local panel = createSpinSpeedPanel()
            panel.Visible = not panel.Visible
        end)
        followNearestBtn.MouseButton1Click:Connect(function()
            state.followNearest = not state.followNearest
            followNearestBtn.Text = state.followNearest and "跟随最近玩家：开" or "跟随最近玩家：关"
        end)
        smoothFollowBtn.MouseButton1Click:Connect(function()
            state.smoothFollow = not state.smoothFollow
            smoothFollowBtn.Text = state.smoothFollow and "平滑跟随：开" or "平滑跟随：关"
        end)
        harassBtn.MouseButton1Click:Connect(function()
            if state.harassEnabled then
                stopHarass()
                harassBtn.Text = "操人"
            else
                showHarassSelect()
            end
        end)
        harassSpeedBtn.MouseButton1Click:Connect(function()
            local panel = createHarassSpeedPanel()
            panel.Visible = not panel.Visible
        end)
    elseif i == 4 then
        addBtn("显示时间", posX1, 4, function()
            game:GetService("StarterGui"):SetCore("SendNotification", { Title = "显示时间", Text = "正在加载中...", Duration = 5 })
            task.spawn(function() loadstring(game:HttpGet("https://pastebin.com/raw/0zKLyd4W"))() end)
