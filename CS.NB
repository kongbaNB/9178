local RLGLGroup = MainTab:AddLeftGroupbox("红灯/绿灯")
RLGLGroup:AddToggle('RedLightGodmode',{Text='无敌模式',Default=false})
local RLGL_Original
Toggles.RedLightGodmode:OnChanged(function(b)
    if b then
        if not hookmetamethod then Script.Functions.Alert("你的执行器不支持元方法钩子"); Toggles.RedLightGodmode:SetValue(false); return end
        local traffic = lplr.PlayerGui:FindFirstChild("ImpactFrames") and lplr.PlayerGui.ImpactFrames:FindFirstChild("TrafficLightEmpty")
        local isGreen = true
        local lastCF
        if traffic and ReplicatedStorage:FindFirstChild("Effects") and ReplicatedStorage.Effects:FindFirstChild("Images") and ReplicatedStorage.Effects.Images:FindFirstChild("TrafficLights") and ReplicatedStorage.Effects.Images.TrafficLights:FindFirstChild("GreenLight") then
            isGreen = traffic.Image == ReplicatedStorage.Effects.Images.TrafficLights.GreenLight.Image
        end
        local function update() if lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart") then lastCF = lplr.Character.HumanoidRootPart.CFrame end end
        update()
        local conn = ReplicatedStorage.Remotes.Effects.OnClientEvent:Connect(function(d)
            if d.EffectName~="TrafficLight" then return end
            isGreen = d.GreenLight == true
            update()
        end)
        Script.Temp.RLGL_Conn = conn
        RLGL_Original = RLGL_Original or hookmetamethod(game, "__namecall", function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            if tostring(self)=="rootCFrame" and method=="FireServer" and Toggles.RedLightGodmode.Value and not isGreen and lastCF then
                args[1] = lastCF
                return RLGL_Original(self, unpack(args))
            end
            return RLGL_Original(self, ...)
        end)
        Script.Functions.Alert("红灯绿灯无敌已开启",3)
    else
        if Script.Temp.RLGL_Conn then Script.Temp.RLGL_Conn:Disconnect() end
        if RLGL_Original then hookmetamethod(game, "__namecall", RLGL_Original) end
    end
end)
RLGLGroup:AddButton({Text='完成红灯/绿灯',Func=function()
    if not workspace:FindFirstChild("RedLightGreenLight") then Script.Functions.Alert("游戏未开始") return end
    Script.Functions.WinRLGL()
end})
RLGLGroup:AddButton({Text='移除受伤行走',Func=function()
    if lplr.Character and lplr.Character:FindFirstChild("InjuredWalking") then lplr.Character.InjuredWalking:Destroy() end
    Script.Functions.BypassRagdoll()
end})

