end

Script.Functions.CompleteDalgonaGame = function()
    ReplicatedStorage.Replication.Event:FireServer("Clicked")
    ReplicatedStorage.Remotes.DALGONATEMPREMPTE:FireServer({ Completed = true })
end

Script.Functions.PullRope = function()
    ReplicatedStorage.Remotes.TemporaryReachedBindable:FireServer({ PerfectQTE = true })
end

Script.Functions.RevealGlassBridge = function()
    local Effects = Script.Functions.SafeRequire(ReplicatedStorage.Modules.Effects) or { AnnouncementTween = function(a) Script.Functions.Alert(a.AnnouncementDisplayText, a.DisplayTime) end }
    local holder = workspace:FindFirstChild("GlassBridge") and workspace.GlassBridge:FindFirstChild("GlassHolder")
    if not holder then return end
    for _, pair in pairs(holder:GetChildren()) do
        for _, tile in pairs(pair:GetChildren()) do
            if tile:IsA("Model") and tile.PrimaryPart then
                local breakable = tile.PrimaryPart:GetAttribute("exploitingisevil") == true
                local col = breakable and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0)
                for _, p in pairs(tile:GetDescendants()) do
                    if p:IsA("BasePart") then
                        TweenService:Create(p, TweenInfo.new(0.5), {Transparency=0.5, Color=col}):Play()
                    end
                end
                local hi = Instance.new("Highlight")
                hi.FillColor = col; hi.FillTransparency = 0.7; hi.OutlineTransparency = 0.5
                hi.Parent = tile
            end
        end
    end
    Effects.AnnouncementTween({AnnouncementOneLine=true, FasterTween=true, DisplayTime=10, AnnouncementDisplayText="[RTaOHUB]: 绿色安全，红色碎裂"})
end

Script.Functions.BypassRagdoll = function()
    local char = lplr.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    local torso = char:FindFirstChild("Torso")
    if not hum or not root or not torso then return end
    hum.PlatformStand = false
    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
    hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    for _,s in pairs({Enum.HumanoidStateType.FallingDown,Enum.HumanoidStateType.Seated,Enum.HumanoidStateType.Swimming,Enum.HumanoidStateType.Flying,Enum.HumanoidStateType.StrafingNoPhysics,Enum.HumanoidStateType.Ragdoll}) do
        hum:SetStateEnabled(s, false)
    end
    for _,obj in pairs(root:GetChildren()) do
        if obj:IsA("BallSocketConstraint") or obj.Name:match("^CacheAttachment") then obj:Destroy() end
    end
    local joints = {"Left Hip","Left Shoulder","Neck","Right Hip","Right Shoulder"}
    for _,j in pairs(joints) do
        local m = torso:FindFirstChild(j)
        if m and m:IsA("Motor6D") and not m.Part0 then m.Part0 = torso end
    end
    for _,p in pairs(char:GetChildren()) do
        if p:IsA("BasePart") and p:FindFirstChild("BoneCustom") then p.BoneCustom:Destroy() end
    end
    for _,f in pairs({"Ragdoll","Stun","RotateDisabled","RagdollWakeupImmunity","InjuredWalking"}) do
        local folder = char:FindFirstChild(f)
        if folder then folder:Destroy() end
    end
    local localRagdolls = workspace.Effects and workspace.Effects:FindFirstChild("LocalRagdolls")
    if localRagdolls then
        local rm = localRagdolls:FindFirstChild(lplr.Name)
        if rm then rm:Destroy() end
    end
end

Script.Functions.BypassDalgonaGame = function()
    local Shared = Script.Functions.SafeRequire(ReplicatedStorage.Modules.SharedFunctions)
    local char = lplr.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    local pg = lplr.PlayerGui
    local Debris = lplr:WaitForChild("DebrisBD")
    local cam = workspace.CurrentCamera
    local effects = workspace:FindFirstChild("Effects")
    local impact = pg:FindFirstChild("ImpactFrames")
    local shape, outline, pick, reddot
    if effects then
        for _,o in pairs(effects:GetChildren()) do
            if o:IsA("Model") and o.Name:match("Outline$") then outline = o
            elseif o:IsA("Model") and not o.Name:match("Outline$") and o.Name~="Pick" and o.Name~="RedDot" then shape = o
            elseif o.Name=="Pick" then pick = o
            elseif o.Name=="RedDot" then reddot = o end
        end
    end
    local progressBar = impact and impact:FindFirstChild("ProgressBar")
    local pickModel
    if impact then
        for _,o in pairs(impact:GetChildren()) do
            if o:IsA("ViewportFrame") and o:FindFirstChild("PickModel") then pickModel = o.PickModel; break end
        end
    end
    local DalgonaRemote = ReplicatedStorage.Remotes:WaitForChild("DALGONATEMPREMPTE")
    task.spawn(function()
        Shared.CreateFolder(lplr, "RecentGameStartedMessage", 0.01)
        if shape and shape:FindFirstChild("shape") then
            TweenService:Create(shape.shape, TweenInfo.new(2), {Position = shape.shape.Position + Vector3.new(0,0.5,0)}):Play()
        end
        if shape then
            for _,p in pairs(shape:GetChildren()) do
                if p.Name=="DalgonaClickPart" then TweenService:Create(p, TweenInfo.new(2), {Transparency=1}):Play() end
            end
        end
        if pick and pick.Parent then TweenService:Create(pick, TweenInfo.new(2), {Transparency=1}):Play() end
        if reddot and reddot.Parent then TweenService:Create(reddot, TweenInfo.new(2), {Transparency=1}):Play() end
        if pickModel then
            for _,p in pairs(pickModel:GetDescendants()) do
                if p:IsA("BasePart") then TweenService:Create(p, TweenInfo.new(2), {Transparency=1}):Play() end
            end
        end
        if hrp then
            TweenService:Create(cam, TweenInfo.new(2), {CFrame=hrp.CFrame*CFrame.new(0.084,8.454,6.697,0.9999,-0.00898,0.00908,0,0.7109,0.7033,-0.0128,-0.7032,0.7109)}):Play()
        end
        Shared.Invisible(char, 0, true)
        DalgonaRemote:FireServer({Success=true})
        task.wait(2)
        for _,o in pairs({shape,outline,pick,reddot,progressBar}) do if o and o.Parent then o:Destroy() end end
        UserInputService.MouseIconEnabled = true
        if pg:FindFirstChild("Hotbar") and pg.Hotbar:FindFirstChild("Backpack") then
            TweenService:Create(pg.Hotbar.Backpack, TweenInfo.new(1.5), {Position=UDim2.new(0,0,0,0)}):Play()
        end
        if progressBar then
            Debris:Fire(progressBar,2)
            TweenService:Create(progressBar, TweenInfo.new(1.5), {Position=UDim2.new(progressBar.Position.X.Scale,0,progressBar.Position.Y.Scale+1,0)}):Play()
        end
        cam.CameraType = Enum.CameraType.Custom
        if hum then cam.CameraSubject = hum end
        local st = tick()
        local cc = RunService.RenderStepped:Connect(function()
            if tick()-st>=5 then cc:Disconnect() return end
            if cam.CameraType~=Enum.CameraType.Custom or cam.CameraSubject~=hum then
                cam.CameraType=Enum.CameraType.Custom
                if hum then cam.CameraSubject=hum end
            end
        end)
    end)
end

Script.Functions.GetFork = function()
    for _,n in pairs({"Fork","Bottle","Knife"}) do
        local t = lplr.Character and lplr.Character:FindFirstChild(n) or lplr.Backpack and lplr.Backpack:FindFirstChild(n)
        if t then return t end
    end
end

Script.Functions.FireForkRemote = function()
    local fork = Script.Functions.GetFork()
    if not fork then return end
    if fork.Parent.Name == "Backpack" then lplr.Character.Humanoid:EquipTool(fork) end
    fork = Script.Functions.GetFork()
    if not fork then return end
    ReplicatedStorage.Remotes.UsedTool:FireServer("UsingMoveCustom", fork, nil, nil, {Clicked=true})
    ReplicatedStorage.Remotes.UsedTool:FireServer("UsingMoveCustom", fork, true, {Clicked=true})
end

Script.Functions.JoinDiscord = function()
    local inv = "https://dsc.gg/dyhub"
    local function getCode(s)
        for i=#s,1,-1 do if s:sub(i,i)=="/" then return s:sub(i+1) end end
        return s
    end
    local function getData(s)
        local ok,res = pcall(function() return HttpService:JSONDecode(request({Url="https://ptb.discord.com/api/invites/"..getCode(s), Method="GET"}).Body) end)
        if ok then return res end
    end
    local data = getData(inv)
    if data then
        request({Url="http://127.0.0.1:6463/rpc?v=1", Method="POST", Headers={["Content-Type"]="application/json",["Origin"]="https://discord.com"}, Body=HttpService:JSONEncode({cmd="INVITE_BROWSER",args={code=data.code},nonce=HttpService:GenerateGUID(false)})})
    end
    pcall(function() setclipboard("dsc.gg/dyhub") end)
    StarterGui:SetCore("SendNotification",{Title="DYHUB Discord",Text="已复制邀请链接: dsc.gg/dyhub",Duration=10})
end

Script.Functions.EffectsNotification = function(text, dur)
    local Effects = Script.Functions.SafeRequire(ReplicatedStorage.Modules.Effects) or { AnnouncementTween = function(a) Script.Functions.Alert(a.AnnouncementDisplayText, a.DisplayTime) end }
    Effects.AnnouncementTween({AnnouncementOneLine=true, FasterTween=true, DisplayTime=dur or 5, AnnouncementDisplayText=tostring(text)})
end

Script.Functions.OnLoad = function()
    Script.Functions.EffectsNotification("DYHUB - 墨水游戏已加载！", 5)
    Script.Functions.EffectsNotification("请先点击修复摄像机！", 5)
    Script.Functions.EffectsNotification("加入 Discord: dsc.gg/dyhub", 5)
end

function Script.Functions.HandleAutowin()
    pcall(function() Script.GameState = tostring(workspace.Values.CurrentGame.Value) end)
    if States[Script.GameState] then
        Script.Functions.Alert("[自动获胜] 当前游戏: "..Script.GameState, 3)
        task.spawn(function() Script.Functions.EffectsNotification("[自动获胜] 运行 "..Script.GameState, 10) end)
        Script.Temp.AutowinCleanup = States[Script.GameState]()
    else
        Script.Functions.Alert("[自动获胜] 等待游戏开始...", 3)
    end
end

States = {
    RedLightGreenLight = function()
        if not Toggles.AntiFlingToggle.Value then Toggles.AntiFlingToggle:SetValue(true) end
        local active = true
        task.spawn(function()
            while active and Toggles.InkGameAutowin.Value and Script.GameState=="RedLightGreenLight" do
                Script.Functions.WinRLGL()
                task.wait(5)
            end
        end)
        return function()
            active = false
            if Toggles.AntiFlingToggle.Value then Toggles.AntiFlingToggle:SetValue(false) end
        end
    end,
    Mingle = function()
        if not Toggles.AutoMingleQTE.Value then Toggles.AutoMingleQTE:SetValue(true) end
        return function()
            if Toggles.AutoMingleQTE.Value then Toggles.AutoMingleQTE:SetValue(false) end
        end
    end,
    TugOfWar = function()
        if not Toggles.AutoPull.Value then Toggles.AutoPull:SetValue(true) end
        if not Toggles.PerfectPull.Value then Toggles.PerfectPull:SetValue(true) end
        return function()
            if Toggles.AutoPull.Value then Toggles.AutoPull:SetValue(false) end
        end
    end,
    GlassBridge = function()
        Script.Functions.RevealGlassBridge()
        Script.Functions.WinGlassBridge()
    end,
    HideAndSeek = function()
        if lplr:GetAttribute("IsHider") then
            Script.Functions.TeleportSafe()
        else
            Script.Functions.Alert("[自动获胜] 抓捕者模式暂不支持自动")
        end
    end,
    LightsOut = Script.Functions.TeleportSafe,
    Dalgona = function()
        task.spawn(function()
            repeat task.wait() until Script.Functions.GetDalgonaRemote() or not Toggles.InkGameAutowin.Value
            if not Toggles.InkGameAutowin.Value then return end
            task.wait(3)
            Script.Functions.CompleteDalgonaGame()
            Script.Functions.BypassDalgonaGame()
            Script.Functions.FixCamera()
        end)
        return function() Script.Functions.FixCamera() end
    end,
}

function Script.Functions.GetDalgonaRemote()
    return ReplicatedStorage.Remotes:FindFirstChild("DALGONATEMPREMPTE")
end

function Script.Functions.GetHider()
    for _,p in pairs(Players:GetPlayers()) do
        if p~=lplr and p.Character and p:GetAttribute("IsHider") and p.Character:FindFirstChild("HumanoidRootPart") then
            return p.Character
        end
    end
end

local function applyNameTag(character)
    local torso = character:WaitForChild("Torso",5)
    if not torso then return end
    local nametag = torso:WaitForChild("Player_Nametag",5)
    if not nametag then return end
    local level = nametag:WaitForChild("LevelText",5)
    local display = nametag:WaitForChild("DisplayName",5)
    if not level or not display then return end
    local isOwner = lplr.Name == "Yolmar_43"
    level.Text = isOwner and "[ RTaOHUB - OWNER ]" or "[ RTaOHUB - MEMBER ]"
    local wave, hue = 0,0
    local msgs = {"RTaO THE BEST (dsc.gg/rtao_rs)", "@"..lplr.Name.." (dsc.gg/rtao_rs)"}
    local idx = 1
    display.Text = msgs[idx]
    task.spawn(function()
        while character and character.Parent do
            idx = idx%#msgs + 1
            display.Text = msgs[idx]
            task.wait(2)
        end
    end)
    RunService.RenderStepped:Connect(function(dt)
        wave = (wave + dt*2)%(2*math.pi)
        hue = (hue + dt*0.2)%1
        local b = (math.sin(wave)+1)/2
        level.TextColor3 = isOwner and Color3.new(1,b,b) or Color3.new(b,1,b)
        display.TextColor3 = Color3.fromHSV(hue,1,1)
    end)
    level:GetPropertyChangedSignal("Text"):Connect(function()
        local correct = isOwner and "[ RTaOHUB - OWNER ]" or "[ RTaOHUB - MEMBER ]"
        if level.Text ~= correct then level.Text = correct end
    end)
end

if lplr.Character then applyNameTag(lplr.Character) end
table.insert(Script.Connections, lplr.CharacterAdded:Connect(applyNameTag))

