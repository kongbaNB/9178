        if not hookmetamethod then Script.Functions.Alert("不支持"); Toggles.ImmuneDalgonaGame:SetValue(false); return end
        DalgonaHook = hookmetamethod(game, "__namecall", function(self,...)
            local args = {...}
            if tostring(self)=="DALGONATEMPREMPTE" and getnamecallmethod()=="FireServer" and type(args[1])=="table" and args[1].CrackAmount~=nil then
                Script.Functions.Alert("已阻止饼干碎裂",3)
                return nil
            end
            return DalgonaHook(self,...)
        end)
