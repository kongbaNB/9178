local HS_META = {
    { metaName = "HiderESP", text = "Hider", checktype = "player", func = Script.Functions.HiderESP },
    { metaName = "SeekerESP", text = "Seeker", checktype = "player", func = Script.Functions.SeekerESP },
    { metaName = "KeyESP", text = "Key", checktype = "key", func = Script.Functions.KeyESP },
    { metaName = "DoorESP", text = "Door", checktype = "door", func = Script.Functions.DoorESP },
}

for _, meta in ipairs(HS_META) do
    Toggles[meta.metaName]:OnChanged(function(call)
        if not call then
            for _, esp in pairs(Script.ESPTable[meta.text]) do esp.Destroy() end
            return
        end
        if not string.find(Script.GameState, "HideAndSeek") then return end
        if meta.checktype == "player" then
            for _, pl in pairs(Players:GetPlayers()) do
                meta.func(pl)
            end
        elseif meta.checktype == "key" then
            local map = workspace:FindFirstChild("HideAndSeekMap")
            if map then
                local keysFolder = map:FindFirstChild("KEYS")
                if keysFolder then for _, key in pairs(keysFolder:GetChildren()) do Script.Functions.KeyESP(key) end end
            end
        elseif meta.checktype == "door" then
            local map = workspace:FindFirstChild("HideAndSeekMap")
            if map then
                local doors = map:FindFirstChild("NEWFIXEDDOORS")
                if doors then
                    for _, floor in pairs(doors:GetChildren()) do
                        if floor.Name:match("^Floor") then
                            for _, door in pairs(floor:GetChildren()) do Script.Functions.DoorESP(door) end
                        end
                    end
                end
            end
        end
    end)
end

for _, meta in ipairs({"Hider", "Seeker", "Key", "Door"}) do
    Options[meta.."EspColor"]:OnChanged(function(value)
        local txt = meta == "Door" and "Door" or meta
        for _, esp in pairs(Script.ESPTable[txt]) do esp.SetColor(value) end
    end)
end

Library:GiveSignal(workspace.DescendantAdded:Connect(function(descendant)
    if not string.find(Script.GameState, "HideAndSeek") then return end
    if Toggles.KeyESP and Toggles.KeyESP.Value then
        local map = workspace:FindFirstChild("HideAndSeekMap")
        if map and descendant:IsA("Model") and descendant.Parent and descendant.Parent.Name == "KEYS" and descendant.Parent.Parent == map then
            Script.Functions.KeyESP(descendant)
        end
    end
    if Toggles.DoorESP and Toggles.DoorESP.Value then
        local map = workspace:FindFirstChild("HideAndSeekMap")
        if map and descendant:IsA("Model") and descendant.Name == "FullDoorAnimated" and descendant.Parent and descendant.Parent.Parent and descendant.Parent.Parent.Name == "NEWFIXEDDOORS" then
            Script.Functions.DoorESP(descendant)
        end
    end
end))

