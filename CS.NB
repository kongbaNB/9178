MiscLeft:AddButton({ Title = "发送警长/杀手名到聊天", Func = function() local channels = game:GetService("TextChatService"):WaitForChild("TextChannels"):GetChildren() for _, ch in ipairs(channels) do if ch.Name == "RBXSystem" then continue end local murd = Yisan_findMurderer() local sher = Yisan_findSheriff() local mn = murd and murd.Name or "[未检测到]" local sn = sher and sher.Name or "[未检测到]" ch:SendAsync("警长:"..sn.." | 杀手:"..mn) end Notify("已发送") end })
MiscLeft:AddButton({ Title = "传送到大厅", Func = function() Yisan_LocalPlayer.Character:MoveTo(Vector3.new(-4985.83203125, 308.9087829589844, 7.557879447937012)) end })
MiscLeft:AddButton({ Title = "传送到地图", Func = function() local map = Yisan_getMap() if not map then Notify("找不到地图") return end local spawnsFolder = map:FindFirstChild("Spawns") if spawnsFolder and #spawnsFolder:GetChildren() > 0 then local spawns = spawnsFolder:GetChildren() local r = spawns[math.random(1, #spawns)] if Yisan_LocalPlayer.Character and Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then Yisan_LocalPlayer.Character:MoveTo(r.Position) end else Notify("找不到生成点") end end })
MiscLeft:AddButton({ Title = "传送到掉落的枪", Func = function() local map = Yisan_getMap() if not map or not map:FindFirstChild("GunDrop") then Notify("没有掉落枪支") return end local gd = map:FindFirstChild("GunDrop") if Yisan_LocalPlayer.Character and Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then local prev = Yisan_LocalPlayer.Character.HumanoidRootPart.CFrame Yisan_LocalPlayer.Character.HumanoidRootPart.CFrame = gd:GetPivot() local conn conn = Yisan_LocalPlayer.Backpack.ChildAdded:Connect(function(child) if child.Name == "Gun" then conn:Disconnect() task.wait(0.5) Yisan_LocalPlayer.Character.HumanoidRootPart.CFrame = prev end end) task.delay(5, function() if conn then conn:Disconnect() Yisan_LocalPlayer.Character.HumanoidRootPart.CFrame = prev end end) end end })

local CtSection = Tabs.Attr:AddLeftGroupbox("范围修改")
CtSection:AddInput({ Title = "范围数值", Value = "1", Placeholder = "", Callback = function(i) Yisan_Taffyhit = tonumber(i) or 1 for _, v in ipairs(Yisan_Players:GetPlayers()) do if v ~= Yisan_LocalPlayer and v.Character:FindFirstChild('HumanoidRootPart') then local sizeArg = tonumber(i) local Size = Vector3.new(sizeArg,sizeArg,sizeArg) if Yisan_TaffyBox then for _, part in ipairs(v.Character:GetChildren()) do if part:IsA("BasePart") then if not i or sizeArg == 1 then part.Size = Vector3.new(2,1,1) part.Transparency = 0.2 else part.Size = Size part.Transparency = 0.2 end end end else local Root = v.Character:FindFirstChild('HumanoidRootPart') if Root:IsA("BasePart") then if not i or sizeArg == 1 then Root.Size = Vector3.new(2,1,1) Root.Transparency = 0.2 else Root.Size = Size Root.Transparency = 0.2 end Root.CanCollide = false end end end end end })
CtSection:AddToggle({ Title = "范围 v1 (仅根部件)", Default = false, Callback = function(state) if state then Yisan_loopTaffyhit = Yisan_RunService.Heartbeat:Connect(function() for _, v in ipairs(Yisan_Players:GetPlayers()) do if v ~= Yisan_LocalPlayer and v.Character:FindFirstChild('HumanoidRootPart') then local sizeArg = tonumber(Yisan_Taffyhit) local Size = Vector3.new(sizeArg,sizeArg,sizeArg) local Root = v.Character:FindFirstChild('HumanoidRootPart') if Root:IsA("BasePart") then if not Yisan_Taffyhit or sizeArg == 1 then Root.Size = Vector3.new(2,1,1) Root.Transparency = 0.2 else Root.Size = Size Root.Transparency = 0.2 end Root.CanCollide = false end end end end) else if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end end end })
CtSection:AddToggle({ Title = "范围 v2 (所有部位)", Default = false, Callback = function(state) Yisan_TaffyBox = state if state then Yisan_loopTaffyhit = Yisan_RunService.Heartbeat:Connect(function() for _, v in ipairs(Yisan_Players:GetPlayers()) do if v ~= Yisan_LocalPlayer and v.Character:FindFirstChild('HumanoidRootPart') then local sizeArg = tonumber(Yisan_Taffyhit) local Size = Vector3.new(sizeArg,sizeArg,sizeArg) for _, part in ipairs(v.Character:GetChildren()) do if part:IsA("BasePart") then if not Yisan_Taffyhit or sizeArg == 1 then part.Size = Vector3.new(2,1,1) part.Transparency = 0.2 else part.Size = Size part.Transparency = 0.2 end end end end end end) else if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end end end })

local AmSection = Tabs.Attr:AddLeftGroupbox("瞄准")
AmSection:AddInput({ Title = "目标玩家", Value = "", Placeholder = "", Callback = function(i) if not Yisan_Players:FindFirstChild(Yisan_getPlayer(i, Yisan_LocalPlayer)) then Notify("玩家未找到") return end Yisan_target = Yisan_Players:FindFirstChild(Yisan_getPlayer(i, Yisan_LocalPlayer)) Notify("目标设置为 "..Yisan_target.Name) end })
AmSection:AddButton({ Title = "瞄准锁定", Func = function() if Yisan_Taffyaim then return end if Yisan_Taffyaimrscon then Yisan_Taffyaimrscon:Disconnect() end if not Yisan_target then Notify("没有输入玩家名字") return end Yisan_Taffyaimrscon = Yisan_RunService.RenderStepped:Connect(function() if not Yisan_target or not Yisan_target.Character or not Yisan_target.Character:FindFirstChild("HumanoidRootPart") then Notify("目标无效") Yisan_Taffyaimrscon:Disconnect() return end Yisan_Workspace.CurrentCamera.CFrame = CFrame.new(Yisan_Workspace.CurrentCamera.CFrame.Position, Yisan_target.Character:FindFirstChild("HumanoidRootPart").Position) end) Yisan_Taffyaim = true end })
AmSection:AddButton({ Title = "取消瞄准锁定", Func = function() if not Yisan_Taffyaim then return end Yisan_Taffyaim = false if Yisan_Taffyaimrscon then Yisan_Taffyaimrscon:Disconnect() end end })

local FgSection = Tabs.Attr:AddLeftGroupbox("甩飞")
FgSection:AddInput({ Title = "甩飞目标", Value = "", Placeholder = "", Callback = function(i) if not Yisan_Players:FindFirstChild(Yisan_getPlayer(i, Yisan_LocalPlayer)) then Notify("玩家未找到") return end Yisan_TaffyplayerFt = Yisan_Players:FindFirstChild(Yisan_getPlayer(i, Yisan_LocalPlayer)) Notify("甩飞目标设置为 "..Yisan_TaffyplayerFt.Name) end })
FgSection:AddButton({ Title = "甩飞指定玩家", Func = function() if not Yisan_TaffyplayerFt then Notify("请先设置甩飞目标") return end if not Yisan_Players:FindFirstChild(Yisan_TaffyplayerFt.Name) then Notify("目标玩家不存在") return end if Yisan_TaffyplayerFt == Yisan_LocalPlayer then Notify("不能甩飞自己") return end Yisan_powerfulFling(Yisan_TaffyplayerFt) end })
FgSection:AddToggle({ Title = "防甩飞", Default = false, Callback = function(state) Yisan_TaffyantiFly = state if state then Yisan_flingDetectionCon = Yisan_RunService.Heartbeat:Connect(function() for _, pl in ipairs(Yisan_Players:GetPlayers()) do if pl.Character:IsDescendantOf(Yisan_Workspace) then if pl.Character.PrimaryPart.AssemblyAngularVelocity.Magnitude > 50 or pl.Character.PrimaryPart.AssemblyLinearVelocity.Magnitude > 100 then if not Yisan_detectedPlayers[pl.Name] then Notify("检测到甩飞者: "..pl.Name) Yisan_detectedPlayers[pl.Name] = true end for _, p in ipairs(pl.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false p.AssemblyAngularVelocity = Vector3.zero p.AssemblyLinearVelocity = Vector3.zero p.CustomPhysicalProperties = PhysicalProperties.new(0,0,0) end end end end end end) Yisan_flingNeutralizerCon = Yisan_RunService.Heartbeat:Connect(function() if Yisan_LocalPlayer.Character and Yisan_LocalPlayer.Character.PrimaryPart then if Yisan_LocalPlayer.Character.PrimaryPart.AssemblyLinearVelocity.Magnitude > 250 or Yisan_LocalPlayer.Character.PrimaryPart.AssemblyAngularVelocity.Magnitude > 250 then Yisan_LocalPlayer.Character.PrimaryPart.AssemblyLinearVelocity = Vector3.zero Yisan_LocalPlayer.Character.PrimaryPart.AssemblyAngularVelocity = Vector3.zero if Yisan_TaffyantiFlyLastPos ~= Vector3.zero then Yisan_LocalPlayer.Character.PrimaryPart.CFrame = CFrame.new(Yisan_TaffyantiFlyLastPos) end else Yisan_TaffyantiFlyLastPos = Yisan_LocalPlayer.Character.PrimaryPart.Position end end end) else if Yisan_flingDetectionCon then Yisan_flingDetectionCon:Disconnect() end if Yisan_flingNeutralizerCon then Yisan_flingNeutralizerCon:Disconnect() end Yisan_detectedPlayers = {} end end })

Yisan_Workspace.ChildAdded:Connect(function(ch)
    if ch == Yisan_getMap() and Yisan_playerESP then Notify("地图已加载等待分配角色...") repeat task.wait(1) until Yisan_findMurderer() Notify("玩家ESP已移除,请重新开启") end
end)
Yisan_Workspace.ChildRemoved:Connect(function(ch)
    if ch == Yisan_getMap() and Yisan_playerESP then Notify("游戏结束移除玩家ESP") Yisan_playerData = {} for _, v in ipairs(Yisan_Workspace:GetChildren()) do if v.Name == "PlayerESP" then v:Destroy() end end end
end)
Yisan_Workspace.DescendantAdded:Connect(function(ch)
    if Yisan_TaffyDete and ch.Name == "Trap" and ch.Parent:IsDescendantOf(Yisan_Workspace) then
        ch.Transparency = 0
        local trapesp = Yisan_trapESP:Clone() trapesp.Parent = Yisan_Workspace trapesp.Adornee = ch
        Notify("杀手放置了陷阱")
    end
    if Yisan_TaffygunESP and ch.Name == "GunDrop" then
        if not Yisan_Workspace:FindFirstChild("GunESP") then
            local gunesp = Instance.new("Highlight", Yisan_Workspace) gunesp.OutlineTransparency = 1 gunesp.FillColor = Color3.fromRGB(255, 255, 0) gunesp.Name = "GunESP" gunesp.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop gunesp.Adornee = ch gunesp.Enabled = true
        end
        Yisan_Workspace:FindFirstChild("GunESP").Adornee = ch Yisan_Workspace:FindFirstChild("GunESP").Enabled = true
        Notify("枪已掉落,寻找黄色透视物品")
        if Yisan_TaffyGetGun then
            task.wait(0.01)
            if not Yisan_getMap():FindFirstChild("GunDrop") then return end
            local prevPos = Yisan_LocalPlayer.Character:GetPivot()
            Yisan_LocalPlayer.Character:MoveTo(Yisan_getMap():FindFirstChild("GunDrop").Position)
            Yisan_LocalPlayer.Backpack.ChildAdded:Wait()
            Yisan_LocalPlayer.Character:PivotTo(prevPos)
        end
    end
end)
Yisan_Workspace.DescendantRemoving:Connect(function(ch)
    if Yisan_TaffygunESP and ch.Name == "GunDrop" then
        if Yisan_Workspace:FindFirstChild("GunESP") then Yisan_Workspace:FindFirstChild("GunESP"):Destroy() end
        Notify("有人拿走了掉落的枪")
        task.wait(0.6)
        local sheriff = Yisan_findSheriff()
        if sheriff then Notify("警长是 "..sheriff.DisplayName) end
    end
end)
game.Workspace.ChildAdded:Connect(function(chi)
    if chi.Name == "ThrowingKnife" and Yisan_TaffyChinaknife then chi:Destroy() end
end)

Yisan_LocalPlayer.CharacterAdded:Connect(function(character)
    character:WaitForChild("Humanoid")
    task.wait(0.5)
    if Yisan_ws ~= 16 then character:FindFirstChild("Humanoid").WalkSpeed = Yisan_ws end
    if Yisan_LocalPlayer.Character and Yisan_LocalPlayer.Character:FindFirstChildOfClass("Humanoid") and Yisan_LocalPlayer.Character:FindFirstChildOfClass("Humanoid").JumpPower ~= 50 then
        Yisan_LocalPlayer.Character:FindFirstChildOfClass("Humanoid").JumpPower = 50
    end
end)

task.spawn(function()
    if game:GetService("RunService"):IsStudio() then return end
    local OldNameCall
    OldNameCall = hookmetamethod(game, "__namecall", function(Self, ...)
        local Args = {...}
        local NamecallMethod = getnamecallmethod()
        if Yisan_antifail and NamecallMethod == "FireServer" and Args[1] == "SetPlayerMinigameResult" then
            Args[2] = true
        end
        return OldNameCall(Self, unpack(Args))
    end)
end)

local MiscRight = Tabs.Misc:AddRightGroupbox("防失败")
MiscRight:AddToggle({ Title = "防失败[秒完成互动]", Default = false, Callback = function(state) Yisan_antifail = state end })

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("DestroyerMystery2")
    ThemeManager:ApplyToTab(Tabs.Settings)
end
if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("DestroyerMystery2")
    SaveManager:BuildConfigSection(Tabs.Settings)
end
