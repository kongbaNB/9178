        end)
        flyControlBtn.MouseButton1Click:Connect(function()
            flyToggleBtn.Visible = not flyToggleBtn.Visible
            flyControlBtn.Text = flyToggleBtn.Visible and "飞行控制：开" or "飞行控制：关"
