local ToolsDamageIDs = {
    ["Old Axe"] = "3_7367831688",
    ["Good Axe"] = "112_7367831688",
    ["Strong Axe"] = "116_7367831688",
    ["Chainsaw"] = "647_8992824875",
    ["Infernal Sword"] = "2_4340578793",
    ["Spear"] = "196_8999010016"
}

local function getAnyTool(isChop)
    for name, _ in pairs(ToolsDamageIDs) do
        if isChop and name ~= "Old Axe" and name ~= "Good Axe" and name ~= "Strong Axe" then continue end
        local tool = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(name)
        if tool then return tool end
    end
    return nil
end

local function equipTool(tool)
    if tool then
        ReplicatedStorage.RemoteEvents.EquipItemHandle:FireServer("FireAllClients", tool)
    end
end

local function unequipTool(tool)
    if tool then
        ReplicatedStorage.RemoteEvents.UnequipItemHandle:FireServer("FireAllClients", tool)
    end
end

local function moveItemToPos(item, position)
    if not item or not item:IsDescendantOf(Workspace) then return end
    local part = item:IsA("Model") and (item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart") or item:FindFirstChild("Handle")) or item
    if not part or not part:IsA("BasePart") then return end
    pcall(function()
        ReplicatedStorage.RemoteEvents.RequestStartDraggingItem:FireServer(item)
        if item:IsA("Model") then
            item:SetPrimaryPartCFrame(CFrame.new(position))
        else
            part.CFrame = CFrame.new(position)
        end
        ReplicatedStorage.RemoteEvents.StopDraggingItem:FireServer(item)
    end)
end

task.spawn(function()
    while true do
        if KillAura.Enabled then
            local char = LP.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local tool = getAnyTool(false)
                if tool then
                    equipTool(tool)
                    for _, target in ipairs(Workspace.Characters:GetChildren()) do
                        if target:IsA("Model") and target:FindFirstChild("HumanoidRootPart") and target:FindFirstChild("HitRegisters") then
                            local targetHRP = target.HumanoidRootPart
                            local dist = (hrp.Position - targetHRP.Position).Magnitude
                            if KillAura.Method == "全图" or dist <= KillAura.Range then
                                pcall(function()
                                    ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(target, tool, true, hrp.CFrame)
                                end)
                            end
                        end
                    end
                end
            end
        end

        if ChopAura.Enabled then
            local char = LP.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local tool = getAnyTool(true)
                if tool then
                    equipTool(tool)
                    local trees = {}
                    local map = Workspace:FindFirstChild("Map")
                    if map then
                        local function addTrees(folder)
                            if folder then
                                for _, obj in ipairs(folder:GetChildren()) do
                                    if obj:IsA("Model") and ({["Small Tree"]=true, ["TreeBig1"]=true, ["TreeBig2"]=true})[obj.Name] and obj.PrimaryPart then
                                        table.insert(trees, obj)
                                    end
                                end
                            end
                        end
                        addTrees(map:FindFirstChild("Foliage"))
                        addTrees(map:FindFirstChild("Landmarks"))
                    end
                    for _, tree in ipairs(trees) do
                        if (tree.PrimaryPart.Position - hrp.Position).Magnitude <= ChopAura.Range then
                            pcall(function()
                                ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(tree, tool, 999, hrp.CFrame)
                            end)
                        end
                    end
                end
            end
        end

        if AutoFeed.Enabled then
            local function getHunger()
                return math.floor(LP.PlayerGui.Interface.StatBars.HungerBar.Bar.Size.X.Scale * 100)
            end
            local function feed(name)
                for _, item in ipairs(Workspace.Items:GetChildren()) do
                    if item.Name == name then
                        ReplicatedStorage.RemoteEvents.RequestConsumeItem:InvokeServer(item)
                        break
                    end
                end
            end
            if getHunger() <= AutoFeed.Threshold then
                for _, food in ipairs(AutoFeed.Foods) do
                    local count = 0
                    for _, item in ipairs(Workspace.Items:GetChildren()) do
                        if item.Name == food then count = count + 1 end
                    end
                    if count > 0 then
                        feed(food)
                        break
                    end
                end
            end
        end

        if AutoCook.Enabled then
            for _, item in ipairs(Workspace.Items:GetChildren()) do
                if table.find(AutoCook.Items, item.Name) then
                    moveItemToPos(item, Vector3.new(1.4, 25.9, -0.9))
                end
            end
        end

        if AutoUpgradeCampfire.Enabled and AutoUpgradeCampfire.Item then
            for _, item in ipairs(Workspace.Items:GetChildren()) do
                if item.Name == AutoUpgradeCampfire.Item then
                    moveItemToPos(item, Vector3.new(0, 19, 0))
                end
            end
        end

        if AutoScrap.Enabled and AutoScrap.Item then
            for _, item in ipairs(Workspace.Items:GetChildren()) do
                if item.Name == AutoScrap.Item then
                    moveItemToPos(item, Vector3.new(21, 20, -5))
                end
            end
        end

        if AutoCraft.Enabled then
            pcall(function()
                ReplicatedStorage.RemoteEvents.CraftItem:InvokeServer(AutoCraft.ItemName)
            end)
            task.wait(AutoCraft.Interval)
        end

        if AutoPlant.Enabled then
        end

        if FunPattern.Enabled then
        end

        if BearTrap.Enabled and BearTrap.Player ~= "无" then
            local target = Players:FindFirstChild(BearTrap.Player)
            if target and target.Character then
                local tpos = target.Character.HumanoidRootPart.Position
                for _, trap in ipairs(Workspace:GetDescendants()) do
                    if trap.Name:find("Bear Trap") and trap:IsA("Model") then
                        pcall(function()
                            ReplicatedStorage.RemoteEvents.RequestStartDraggingItem:FireServer(trap)
                            trap:SetPrimaryPartCFrame(CFrame.new(tpos))
                            ReplicatedStorage.RemoteEvents.StopDraggingItem:FireServer(trap)
                            ReplicatedStorage.RemoteEvents.RequestSetTrap:FireServer(trap)
                        end)
                    end
                end
            end
        end

        if Bring.AllItems then
            local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, item in ipairs(Workspace.Items:GetChildren()) do
                    local part = item:FindFirstChildWhichIsA("BasePart")
                    if part then
                        part.CFrame = hrp.CFrame * CFrame.new(math.random(-5,5),0,math.random(-5,5))
                    end
                end
            end
        end

        if Fishing.Instant then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("FinishFishing")
                if remote then remote:FireServer(true) end
            end)
        end

        if Toggles.AutoStunDeer then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("DeerHitByTorch")
                local deer = Workspace:FindFirstChild("Characters") and Workspace.Characters:FindFirstChild("Deer")
                if remote and deer then remote:InvokeServer(deer) end
            end)
        end

        task.wait(0.1)
    end
end)

