local MiscGroup = MainTab:AddRightGroupbox("杂项")
MiscGroup:AddDropdown('EmotesList',{Text='表情列表',Values={},AllowNull=true})
task.spawn(function()
    local function refresh()
        local res = {}
        local anims = ReplicatedStorage:WaitForChild("Animations",10)
        if not anims then return end
        local emotes = anims:WaitForChild("Emotes",10)
        if not emotes then return end
        for _,v in pairs(emotes:GetChildren()) do
            if v.ClassName=="Animation" and v.AnimationId then res[v.Name]={anim=v.AnimationId,obj=v} end
        end
        Script.Temp.EmoteList = res
        local names = {}
        for k in pairs(res) do table.insert(names,k) end
        Options.EmotesList:SetValues(names)
    end
    refresh()
    local emotes = ReplicatedStorage:WaitForChild("Animations"):WaitForChild("Emotes")
    table.insert(Script.Connections, emotes.ChildAdded:Connect(refresh))
    table.insert(Script.Connections, emotes.ChildRemoved:Connect(refresh))
end)
MiscGroup:AddButton({Text='播放表情',Func=function()
    if Options.EmotesList.Value then
        local d = Script.Temp.EmoteList and Script.Temp.EmoteList[Options.EmotesList.Value]
        if d and d.anim then
            local char = lplr.Character
            if not char then return end
            local hum = char:FindFirstChildOfClass("Humanoid")
            if not hum then return end
            if Script.Temp.EmoteTrack then Script.Temp.EmoteTrack:Stop() end
            local a = Instance.new("Animation"); a.AnimationId=d.anim
            local t = hum:LoadAnimation(a); t.Priority=Enum.AnimationPriority.Action; t:Play()
            Script.Temp.EmoteTrack = t
        end
    else Script.Functions.Alert("未选择表情") end
end})
MiscGroup:AddButton({Text='停止表情',Func=function() if Script.Temp.EmoteTrack then Script.Temp.EmoteTrack:Stop() end end})
