function Yisan_findMurderer()
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i.Backpack:FindFirstChild("Knife") then return i end
    end
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i.Character and i.Character:FindFirstChild("Knife") then return i end
    end
    if Yisan_playerData then
        for player, data in pairs(Yisan_playerData) do
            if data.Role == "Murderer" then
                if Yisan_Players:FindFirstChild(player) then return Yisan_Players:FindFirstChild(player) end
            end
        end
    end
    return nil
end

function Yisan_findSheriff()
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i.Backpack:FindFirstChild("Gun") then return i end
    end
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i.Character and i.Character:FindFirstChild("Gun") then return i end
    end
    if Yisan_playerData then
        for player, data in pairs(Yisan_playerData) do
            if data.Role == "Sheriff" then
                if Yisan_Players:FindFirstChild(player) then return Yisan_Players:FindFirstChild(player) end
            end
        end
    end
    return nil
end

function Yisan_findSheriffThatsNotMe()
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i == Yisan_LocalPlayer then continue end
        if i.Backpack:FindFirstChild("Gun") then return i end
    end
    for _, i in ipairs(Yisan_Players:GetPlayers()) do
        if i == Yisan_LocalPlayer then continue end
        if i.Character and i.Character:FindFirstChild("Gun") then return i end
    end
    if Yisan_playerData then
        for player, data in pairs(Yisan_playerData) do
            if data.Role == "Sheriff" then
                if Yisan_Players:FindFirstChild(player) and Yisan_Players:FindFirstChild(player) ~= Yisan_LocalPlayer then return Yisan_Players:FindFirstChild(player) end
            end
        end
    end
    return nil
end

function Yisan_getMap()
    for _, o in ipairs(Yisan_Workspace:GetChildren()) do
        if o:FindFirstChild("CoinContainer") and o:FindFirstChild("Spawns") then return o end
    end
    return nil
end

function Yisan_getPredictedPosition(player, TaffyshootTChina)
    pcall(function()
        player = player.Character
        if not player.Character then return Vector3.new(0,0,0) end
    end)
    local playerHRP = player:FindFirstChild("UpperTorso")
    local playerHum = player:FindFirstChild("Humanoid")
    if not playerHRP or not playerHum then return Vector3.new(0,0,0) end
    local velocity = playerHRP.AssemblyLinearVelocity
    local playerMoveDirection = playerHum.MoveDirection
    local predictedPosition = playerHRP.Position + ((velocity * Vector3.new(0, 0.5, 0))) * (TaffyshootTChina / 15) + playerMoveDirection * TaffyshootTChina
    predictedPosition = predictedPosition * (((Yisan_LocalPlayer:GetNetworkPing() * 1000) * ((Yisan_TaffyPing - 1) * 0.01)) + 1)
    return predictedPosition
end

function Yisan_findNearestPlayer()
    local nearestPlayer = nil
    local shortestDistance = math.huge
    for _, player in ipairs(Yisan_Players:GetPlayers()) do
        if player ~= Yisan_LocalPlayer and player.Character then
            local localRootPart = Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local otherRootPart = player.Character:FindFirstChild("HumanoidRootPart")
            if localRootPart and otherRootPart then
                local distance = (localRootPart.Position - otherRootPart.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    nearestPlayer = player
                end
            end
        end
    end
    return nearestPlayer
end

function Yisan_powerfulFling(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then
        Notify("目标玩家无效")
        return
    end
    local Character = Yisan_LocalPlayer.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = targetPlayer.Character
    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")
    if not Character or not Humanoid or not RootPart then
        Notify("你的角色无效")
        return
    end
    if RootPart.Velocity.Magnitude < 50 then
        getgenv().OldPos = RootPart.CFrame
    end
    if not getgenv().FPDH then
        getgenv().FPDH = Yisan_Workspace.FallenPartsDestroyHeight
    end
    if THead then
        Yisan_Workspace.CurrentCamera.CameraSubject = THead
    elseif not THead and Handle then
        Yisan_Workspace.CurrentCamera.CameraSubject = Handle
    elseif THumanoid and TRootPart then
        Yisan_Workspace.CurrentCamera.CameraSubject = THumanoid
    end
    if not TCharacter:FindFirstChildWhichIsA("BasePart") then
        Notify("目标没有有效部位")
        return
    end
    local FPos = function(BasePart, Pos, Ang)
        RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
        Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
        RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
        RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
    end
    local SFBasePart = function(BasePart)
        local TimeToWait = 2
        local Time = tick()
        local Angle = 0
        repeat
            if RootPart and THumanoid then
                if BasePart.Velocity.Magnitude < 50 then
                    Angle = Angle + 100
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle),0 ,0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(2.25, 1.5, -2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(-2.25, -1.5, 2.25) + THumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, 0) + THumanoid.MoveDirection,CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0) + THumanoid.MoveDirection,CFrame.Angles(math.rad(Angle), 0, 0))
                    task.wait()
                else
                    FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, -THumanoid.WalkSpeed), CFrame.Angles(0, 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, THumanoid.WalkSpeed), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, -TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(0, 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, 1.5, TRootPart.Velocity.Magnitude / 1.25), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(math.rad(90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5 ,0), CFrame.Angles(math.rad(-90), 0, 0))
                    task.wait()
                    FPos(BasePart, CFrame.new(0, -1.5, 0), CFrame.Angles(0, 0, 0))
                    task.wait()
                end
            else
                break
            end
        until BasePart.Velocity.Magnitude > 500 or BasePart.Parent ~= targetPlayer.Character or targetPlayer.Parent ~= Yisan_Players or targetPlayer.Character ~= TCharacter or (THumanoid and THumanoid.Sit) or Humanoid.Health <= 0 or tick() > Time + TimeToWait
    end
    Yisan_Workspace.FallenPartsDestroyHeight = 0/0
    local BV = Instance.new("BodyVelocity")
    BV.Name = "EpixVel"
    BV.Parent = RootPart
    BV.Velocity = Vector3.new(9e8, 9e8, 9e8)
    BV.MaxForce = Vector3.new(1/0, 1/0, 1/0)
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    if TRootPart and THead then
        if (TRootPart.CFrame.p - THead.CFrame.p).Magnitude > 5 then
            SFBasePart(THead)
        else
            SFBasePart(TRootPart)
        end
    elseif TRootPart and not THead then
        SFBasePart(TRootPart)
    elseif not TRootPart and THead then
        SFBasePart(THead)
    elseif not TRootPart and not THead and Accessory and Handle then
        SFBasePart(Handle)
    else
        Notify("找不到合适的甩飞部位")
        BV:Destroy()
        return
    end
    BV:Destroy()
    Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    Yisan_Workspace.CurrentCamera.CameraSubject = Humanoid
    repeat
        RootPart.CFrame = getgenv().OldPos * CFrame.new(0, .5, 0)
        Character:SetPrimaryPartCFrame(getgenv().OldPos * CFrame.new(0, .5, 0))
        Humanoid:ChangeState("GettingUp")
        for _, x in pairs(Character:GetChildren()) do
            if x:IsA("BasePart") then
                x.Velocity, x.RotVelocity = Vector3.new(), Vector3.new()
            end
        end
        task.wait()
    until (RootPart.Position - getgenv().OldPos.p).Magnitude < 25
    Yisan_Workspace.FallenPartsDestroyHeight = getgenv().FPDH
end

function Yisan_reloadESP()
    for _, v in ipairs(Yisan_Workspace:GetChildren()) do if v.Name == "PlayerESP" then v:Destroy() end end
    for _, player in ipairs(Yisan_Players:GetPlayers()) do
        if player.Character then
            local character = player.Character
            if not character:FindFirstChild("PlayerESP") then
                local a = Instance.new("Highlight", Yisan_Workspace)
                a.Name = "PlayerESP"
                a.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                a.Adornee = character
                a.FillColor = Color3.fromRGB(255, 255, 255)
                a.FillTransparency = 0.5
                task.spawn(function()
                    if player == Yisan_findMurderer() then
                        a.FillColor = Color3.fromRGB(255,0,0)
                        a.OutlineColor = Color3.fromRGB(255,0,0)
                    elseif player == Yisan_findSheriff() then
                        a.FillColor = Color3.fromRGB(0, 150, 255)
                        a.OutlineColor = Color3.fromRGB(0, 150, 255)
                    else
                        a.FillColor = Color3.fromRGB(0,255,0)
                        a.OutlineColor = Color3.fromRGB(0, 255, 0)
                    end
                end)
            end
        end
    end
end

function Yisan_getClosestModelToPlayer(player, models)
    local closestModel = nil
    local closestDistance = math.huge
    local playerPosition = player.Character.HumanoidRootPart.Position
    for _, model in ipairs(models) do
        local modelPosition = model:GetPivot().Position
        local distance = (modelPosition - playerPosition).Magnitude
        if distance < closestDistance then
            closestDistance = distance
            closestModel = model
        end
    end
    return closestModel
end

local Yisan_ws = 16
local Yisan_fov = 70
local Yisan_clip = true
local Yisan_nocliploop
local Yisan_flySpeed = 50
local Yisan_flying = false
local Yisan_bodyVelocity, Yisan_bodyGyro
local Yisan_renderSteppedConnection

function Yisan_startFlying()
    if Yisan_flying then return end
    Yisan_flying = true
    local character = Yisan_LocalPlayer.Character or Yisan_LocalPlayer.CharacterAdded:Wait()
    character.Humanoid.PlatformStand = true
    if Yisan_bodyVelocity then Yisan_bodyVelocity:Destroy() end
    if Yisan_bodyGyro then Yisan_bodyGyro:Destroy() end
    Yisan_bodyVelocity = Instance.new("BodyVelocity")
    Yisan_bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
    Yisan_bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    Yisan_bodyVelocity.Parent = character.HumanoidRootPart
    Yisan_bodyGyro = Instance.new("BodyGyro")
    Yisan_bodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
    Yisan_bodyGyro.CFrame = character.HumanoidRootPart.CFrame
    Yisan_bodyGyro.Parent = character.HumanoidRootPart
    local startTime = tick()
    while tick() - startTime < 1 do
        Yisan_bodyVelocity.Velocity = Vector3.new(0, 10, 0)
        Yisan_RunService.RenderStepped:Wait()
    end
    if Yisan_renderSteppedConnection then Yisan_renderSteppedConnection:Disconnect() end
    Yisan_renderSteppedConnection = Yisan_RunService.RenderStepped:Connect(function()
        if Yisan_flying then
            local moveDirection = character.Humanoid.MoveDirection * Yisan_flySpeed
            local camLookVector = Yisan_Workspace.CurrentCamera.CFrame.LookVector
            if moveDirection.Magnitude > 0 then
                if camLookVector.Y > 0.2 then
                    moveDirection = moveDirection + Vector3.new(0, camLookVector.Y * Yisan_flySpeed, 0)
                elseif camLookVector.Y < -0.2 then
                    moveDirection = moveDirection + Vector3.new(0, camLookVector.Y * Yisan_flySpeed, 0)
                end
            else
                moveDirection = Vector3.new(0, 0, 0)
            end
            Yisan_bodyVelocity.Velocity = moveDirection
            local tiltAngle = 30
            local tiltFactor = moveDirection.Magnitude / Yisan_flySpeed
            local tiltDirection = 1
            if Yisan_Workspace.CurrentCamera.CFrame:VectorToObjectSpace(moveDirection).Z < 0 then tiltDirection = -1 end
            local tiltCFrame = CFrame.Angles(math.rad(tiltAngle) * tiltFactor * tiltDirection, 0, 0)
            local targetCFrame = CFrame.new(character.HumanoidRootPart.Position, character.HumanoidRootPart.Position + camLookVector) * tiltCFrame
            Yisan_bodyGyro.CFrame = Yisan_bodyGyro.CFrame:Lerp(targetCFrame, 0.2)
        end
    end)
end

function Yisan_stopFlying()
    if not Yisan_flying then return end
    Yisan_flying = false
    local character = Yisan_LocalPlayer.Character or Yisan_LocalPlayer.CharacterAdded:Wait()
    character.Humanoid.PlatformStand = false
    if Yisan_bodyVelocity then Yisan_bodyVelocity:Destroy() end
    if Yisan_bodyGyro then Yisan_bodyGyro:Destroy() end
    if Yisan_renderSteppedConnection then Yisan_renderSteppedConnection:Disconnect() end
end

function Yisan_splitString(str,delim)
    local broken = {}
    if delim == nil then delim = "," end
    for w in string.gmatch(str,"[^"..delim.."]+") do
        table.insert(broken,w)
    end
    return broken
end

function Yisan_toTokens(str)
    local tokens = {}
    for op,name in string.gmatch(str,"([+-])([^+-]+)") do
        table.insert(tokens,{Operator = op,Name = name})
    end
    return tokens
end

function Yisan_onlyIncludeInTable(tab,matches)
    local matchTable = {}
    local resultTable = {}
    for i,v in pairs(matches) do matchTable[v.Name] = true end
    for i,v in pairs(tab) do if matchTable[v.Name] then table.insert(resultTable,v) end end
    return resultTable
end

function Yisan_removeTableMatches(tab,matches)
    local matchTable = {}
    local resultTable = {}
    for i,v in pairs(matches) do matchTable[v.Name] = true end
    for i,v in pairs(tab) do if not matchTable[v.Name] then table.insert(resultTable,v) end end
    return resultTable
end

function Yisan_getPlayersByName(Name)
    local Name,Len,Found = string.lower(Name),#Name,{}
    for _,v in pairs(Yisan_Players:GetPlayers()) do
        if Name:sub(0,1) == '@' then
            if string.sub(string.lower(v.Name),1,Len-1) == Name:sub(2) then
                table.insert(Found,v)
            end
        else
            if string.sub(string.lower(v.Name),1,Len) == Name or string.sub(string.lower(v.DisplayName),1,Len) == Name then
                table.insert(Found,v)
            end
        end
    end
    return Found
end

function Yisan_getPlayer(list,speaker)
    if list == nil then return {speaker.Name} end
    local nameList = Yisan_splitString(list,",")
    local foundList = {}
    for _,name in pairs(nameList) do
        if string.sub(name,1,1) ~= "+" and string.sub(name,1,1) ~= "-" then name = "+"..name end
        local tokens = Yisan_toTokens(name)
        local initialPlayers = Yisan_Players:GetPlayers()
        for i,v in pairs(tokens) do
            if v.Operator == "+" then
                initialPlayers = Yisan_onlyIncludeInTable(initialPlayers,Yisan_getPlayersByName(v.Name))
            else
                initialPlayers = Yisan_removeTableMatches(initialPlayers,Yisan_getPlayersByName(v.Name))
            end
        end
        for i,v in pairs(initialPlayers) do table.insert(foundList,v) end
    end
    local foundNames = {}
    for i,v in pairs(foundList) do table.insert(foundNames,v.Name) end
    return foundNames[1]
end

local function Yisan_secondsToMinutes(seconds)
    if seconds == -1 then return "" end
    local minutes = math.floor(seconds / 60)
    local remainingSeconds = seconds % 60
    return string.format("%dm %ds", minutes, remainingSeconds)
end

function Yisan_EnableTimeDisplay()
    Yisan_LinniTime = true
    Yisan_Linnitask = task.spawn(function()
        while task.wait(0.5) and Yisan_LinniTime do
            local success, timeLeft = pcall(function()
                return game.ReplicatedStorage.Remotes.Extras.GetTimer:InvokeServer()
            end)
            if success and timeLeft then
                Notify("回合剩余时间: " .. Yisan_secondsToMinutes(timeLeft))
            else
                Notify("无法获取回合时间")
                break
            end
        end
    end)
end

function Yisan_DisableTimeDisplay()
    Yisan_LinniTime = false
    if Yisan_Linnitask then
        task.cancel(Yisan_Linnitask)
        Yisan_Linnitask = nil
    end
end

function Yisan_EnablePlayerHighlightESP()
    Yisan_playerESP = true
    if not Yisan_findMurderer() or not Yisan_findSheriff() then
        repeat task.wait(1) until Yisan_findSheriff() or Yisan_findMurderer()
    end
    Yisan_reloadESP()
end

function Yisan_DisablePlayerHighlightESP()
    Yisan_playerESP = false
    for _, v in ipairs(Yisan_Workspace:GetChildren()) do if v.Name == "PlayerESP" then v:Destroy() end end
end

function Yisan_EnableGunESP()
    Yisan_TaffygunESP = true
    if Yisan_getMap() and Yisan_getMap():FindFirstChild("GunDrop") then
        local gunesp = Instance.new("Highlight", Yisan_Workspace)
        gunesp.OutlineTransparency = 1
        gunesp.FillColor = Color3.fromRGB(255, 255, 0)
        gunesp.Name = "GunESP"
        gunesp.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        gunesp.Adornee = Yisan_getMap():FindFirstChild("GunDrop")
        gunesp.Enabled = true
    end
end

function Yisan_DisableGunESP()
    Yisan_TaffygunESP = false
    if Yisan_Workspace:FindFirstChild("GunESP") then Yisan_Workspace:FindFirstChild("GunESP"):Destroy() end
end

function Yisan_EnableTrapDetection()
    Yisan_TaffyDete = true
    for _, v in ipairs(Yisan_Workspace:GetDescendants()) do
        if v.Name == "Trap" and v.Parent:IsDescendantOf(Yisan_Workspace) then
            v.Transparency = 0
            local trapesp = Yisan_trapESP:Clone()
            trapesp.Parent = Yisan_Workspace
            trapesp.Adornee = v
        end
    end
end

function Yisan_DisableTrapDetection()
    Yisan_TaffyDete = false
    for _, v in ipairs(Yisan_Workspace:GetChildren()) do if v.Name == "TrapESP" then v:Destroy() end end
end

function Yisan_EnableAutoShoot()
    Yisan_TaffyShoot = true
    task.spawn(function()
        while task.wait(1) do
            if Yisan_findSheriff() == Yisan_LocalPlayer and Yisan_TaffyShoot then
                repeat
                    task.wait(0.1)
                    local murderer = Yisan_findMurderer()
                    if not murderer then continue end
                    local murdererPosition = murderer.Character.HumanoidRootPart.Position
                    local characterRootPart = Yisan_LocalPlayer.Character.HumanoidRootPart
                    local rayDirection = murdererPosition - characterRootPart.Position
                    local raycastParams = RaycastParams.new()
                    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                    raycastParams.FilterDescendantsInstances = {Yisan_LocalPlayer.Character}
                    local hit = Yisan_Workspace:Raycast(characterRootPart.Position, rayDirection, raycastParams)
                    if not hit or hit.Instance.Parent == murderer.Character then
                        if not Yisan_LocalPlayer.Character:FindFirstChild("Gun") then
                            if Yisan_LocalPlayer.Backpack:FindFirstChild("Gun") then
                                Yisan_LocalPlayer.Character:FindFirstChild("Humanoid"):EquipTool(Yisan_LocalPlayer.Backpack:FindFirstChild("Gun"))
                            else
                                return
                            end
                        end
                        local predictedPosition = Yisan_getPredictedPosition(murderer, Yisan_TaffyshootTChina)
                        local args = {[1] = 1, [2] = predictedPosition, [3] = "AH2"}
                        Yisan_LocalPlayer.Character.Gun.KnifeLocal.CreateBeam.RemoteFunction:InvokeServer(unpack(args))
                    end
                until Yisan_findSheriff() ~= Yisan_LocalPlayer or not Yisan_TaffyShoot
            end
        end
    end)
end

function Yisan_DisableAutoShoot()
    Yisan_TaffyShoot = false
end

function Yisan_EnableKillAura()
    Yisan_TaffyAu = true
    if Yisan_TaffyAuChina then Yisan_TaffyAuChina:Disconnect() end
    Yisan_TaffyAuChina = Yisan_RunService.Heartbeat:Connect(function()
        if Yisan_findMurderer() ~= Yisan_LocalPlayer then return end
        for _, player in ipairs(Yisan_Players:GetPlayers()) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player ~= Yisan_LocalPlayer then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if (hrp.Position - Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").Position).Magnitude < 7 then
                    hrp.Anchored = true
                    hrp.CFrame = Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame + Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").CFrame.LookVector * 2
                    task.wait(0.1)
                    local args = {[1] = "Slash"}
                    if Yisan_LocalPlayer.Character:FindFirstChild("Knife") then
                        Yisan_LocalPlayer.Character.Knife.Stab:FireServer(unpack(args))
                    elseif Yisan_LocalPlayer.Backpack:FindFirstChild("Knife") then
                        Yisan_LocalPlayer.Character.Humanoid:EquipTool(Yisan_LocalPlayer.Backpack:FindFirstChild("Knife"))
                        task.wait(0.2)
                        Yisan_LocalPlayer.Character.Knife.Stab:FireServer(unpack(args))
                    end
                    return
                end
            end
        end
    end)
end

function Yisan_DisableKillAura()
    Yisan_TaffyAu = false
    if Yisan_TaffyAuChina then Yisan_TaffyAuChina:Disconnect() end
end

function Yisan_EnableCollectCoinsV2()
    Yisan_coinTaffy = true
    task.spawn(function()
        while task.wait(0.01) do
            if not Yisan_coinTaffy then continue end
            if Yisan_getMap() then
                if Yisan_getMap():FindFirstChild("CoinContainer") and #Yisan_getMap():FindFirstChild("CoinContainer"):GetChildren() > 1 then
                    local closestCoin = Yisan_getClosestModelToPlayer(Yisan_LocalPlayer, Yisan_getMap():FindFirstChild("CoinContainer"):GetChildren())
                    if closestCoin then
                        if not Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then continue end
                        local distance = (Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart").Position - closestCoin:GetPivot().Position).Magnitude
                        local toclosestcoin = Yisan_TweenService:Create(Yisan_LocalPlayer.Character:FindFirstChild("HumanoidRootPart"), TweenInfo.new(distance*0.05, Enum.EasingStyle.Linear), {
                            CFrame = closestCoin:GetPivot()
                        })
                        toclosestcoin:Play()
                        toclosestcoin.Completed:Wait()
                        task.wait(0.01)
                        closestCoin:Destroy()
                        Yisan_claimedCoins[closestCoin] = true
                    end
                end
            end
        end
    end)
end

function Yisan_DisableCollectCoinsV2()
    Yisan_coinTaffy = false
end

function Yisan_EnableAutoPickGunV2()
    Yisan_TaffyGetGun = true
end

function Yisan_DisableAutoPickGunV2()
    Yisan_TaffyGetGun = false
end

function Yisan_GodMode()
    local Cam = Yisan_Workspace.CurrentCamera
    local Char = Yisan_LocalPlayer.Character
    local Human = Char and Char:FindFirstChildOfClass("Humanoid")
    if not Human then Notify("找不到角色") return end
    local nHuman = Human:Clone()
    nHuman.Parent = Char
    Yisan_LocalPlayer.Character = nil
    nHuman:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
    nHuman:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
    nHuman:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    nHuman.BreakJointsOnDeath = false
    Human:Destroy()
    Yisan_LocalPlayer.Character = Char
    Cam.CameraSubject = nHuman
    nHuman.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
    local Script = Char:FindFirstChild("Animate")
    if Script then
        Script.Disabled = true
        task.wait(0.1)
        Script.Disabled = false
    end
    nHuman.Health = nHuman.MaxHealth
    Notify("上帝模式已开启")
end

local function CreateCrosshair()
    if crosshairUI then return end
    crosshairUI = Instance.new("ScreenGui")
    crosshairUI.Name = "CrosshairUI"
    crosshairUI.Parent = PlayerGui
    crosshairUI.IgnoreGuiInset = true
    local dot = Instance.new("Frame")
    dot.Parent = crosshairUI
    dot.Size = UDim2.new(0, 4, 0, 4)
    dot.Position = UDim2.new(0.5, -2, 0.5, -2)
    dot.BackgroundColor3 = Color3.new(1, 1, 1)
    dot.BorderSizePixel = 0
    local dotCorner = Instance.new("UICorner")
    dotCorner.CornerRadius = UDim.new(1, 0)
    dotCorner.Parent = dot
    local outer = Instance.new("Frame")
    outer.Parent = crosshairUI
    outer.Size = UDim2.new(0, 20, 0, 20)
    outer.Position = UDim2.new(0.5, -10, 0.5, -10)
    outer.BackgroundTransparency = 1
    outer.BorderSizePixel = 0
    for i = 1, 4 do
        local line = Instance.new("Frame")
        line.Parent = outer
        line.BackgroundColor3 = Color3.new(1, 1, 1)
        line.BorderSizePixel = 0
        if i == 1 or i == 2 then
            line.Size = UDim2.new(0, 8, 0, 2)
            line.Position = i == 1 and UDim2.new(0, -8, 0.5, -1) or UDim2.new(1, 0, 0.5, -1)
        else
            line.Size = UDim2.new(0, 2, 0, 8)
            line.Position = i == 3 and UDim2.new(0.5, -1, 0, -8) or UDim2.new(0.5, -1, 1, 0)
        end
    end
end

local function RemoveCrosshair()
    if crosshairUI then crosshairUI:Destroy() crosshairUI = nil end
end

local function GetJob(p)
    local k, s = false, false
    local function c(it) if it:IsA("Tool") then local n = it.Name:lower() if n:find("knife") or n:find("刀") then k = true end if n:find("gun") or n:find("手枪") or n:find("警长") or n:find("revolver") then s = true end end end
    if p.Backpack then for _, v in pairs(p.Backpack:GetChildren()) do c(v) end end
    if p.Character then for _, v in pairs(p.Character:GetChildren()) do c(v) end end
    return k and "杀手" or s and "警长" or "平民"
end

local function GetWeapon(p, weaponType)
    local char = p.Character local backpack = p.Backpack
    if not char and not backpack then return nil end
    local targetNames = weaponType == "knife" and {"knife", "刀"} or {"gun", "手枪", "警长", "revolver"}
    local function checkTool(item) if not item or not item:IsA("Tool") then return false end local nameLower = item.Name:lower() for _, keyword in ipairs(targetNames) do if nameLower:find(keyword) then return true end end return false end
    if char then for _, item in ipairs(char:GetChildren()) do if checkTool(item) then return item end end end
    if backpack then for _, item in ipairs(backpack:GetChildren()) do if checkTool(item) then return item end end end
    return nil
end

local function FollowTargetByJob(targetJob)
    if currentFollowLoop then currentFollowLoop:Disconnect() currentFollowLoop = nil end
    local targetPlayer = nil
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            if GetJob(player) == targetJob then targetPlayer = player break end
        end
    end
    if not targetPlayer then Notify("未找到存活的"..targetJob.."目标") return end
    Notify("跟随已开启，锁定 "..targetPlayer.Name)
    currentFollowLoop = RunService.Heartbeat:Connect(function()
        if not targetPlayer or not targetPlayer:IsDescendantOf(Players) or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") or not targetPlayer.Character:FindFirstChild("Humanoid") or targetPlayer.Character.Humanoid.Health <= 0 or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            currentFollowLoop:Disconnect() currentFollowLoop = nil Notify("跟随已停止") return
        end
        local targetRoot = targetPlayer.Character.HumanoidRootPart local myRoot = LocalPlayer.Character.HumanoidRootPart
        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 2)
    end)
end

local function ForceStopFollow()
    if currentFollowLoop then currentFollowLoop:Disconnect() currentFollowLoop = nil Notify("跟随已强制取消") else Notify("当前没有跟随目标") end
end

local function StartTracking(targetJob)
    if trackLoop then trackLoop:Disconnect() trackLoop = nil end RemoveCrosshair()
    local targetPlayer = nil
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
            if GetJob(player) == targetJob then targetPlayer = player break end
        end
    end
    if not targetPlayer then Notify("未找到存活的"..targetJob) return end
    Notify("自瞄已锁定 "..targetPlayer.Name)
    CreateCrosshair()
    trackLoop = RunService.RenderStepped:Connect(function()
        if not targetPlayer or not targetPlayer:IsDescendantOf(Players) or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            trackLoop:Disconnect() trackLoop = nil RemoveCrosshair() Notify("自瞄已停止") return
        end
        local myChar = LocalPlayer.Character if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
        local targetRoot = targetPlayer.Character.HumanoidRootPart
        Camera.CameraSubject = targetRoot Camera.CameraType = Enum.CameraType.Scriptable
        local cameraPos = Camera.CFrame.Position local targetPos = targetRoot.Position
        Camera.CFrame = CFrame.lookAt(cameraPos, targetPos)
    end)
end

local function StopTracking()
    if trackLoop then trackLoop:Disconnect() trackLoop = nil end RemoveCrosshair()
    Camera.CameraSubject = LocalPlayer.Character Camera.CameraType = Enum.CameraType.Custom Notify("自瞄已停止")
end

local function EnableAutoCollectGold()
    if autoCollectGoldLoop then task.cancel(autoCollectGoldLoop) autoCollectGoldLoop = nil end
    autoCollectGoldLoop = task.spawn(function()
        while autoCollectGoldEnabled do
            task.wait(0.3)
            pcall(function()
                local myChar = LocalPlayer.Character local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart") local myHumanoid = myChar and myChar:FindFirstChild("Humanoid")
                if not myChar or not myRoot or not myHumanoid or myHumanoid.Health <= 0 then return end
                local goldList = {}
                for _, descendant in pairs(Workspace:GetDescendants()) do
                    local nameLower = descendant.Name:lower()
                    local isGold = false
                    for _, keyword in ipairs({"coin", "金币", "gold", "money", "cash", "钱"}) do
                        if nameLower:find(keyword) then isGold = true break end
                    end
                    if isGold and (descendant:IsA("Tool") or descendant:IsA("BasePart") or descendant:IsA("Model")) then
                        table.insert(goldList, descendant)
                    end
                end
                for _, gold in ipairs(goldList) do
                    if not autoCollectGoldEnabled then break end
                    if not myChar or not myChar.Parent or not myRoot or not myRoot.Parent then break end
                    if gold:IsA("Tool") then
                        if gold.Parent ~= LocalPlayer.Backpack and gold.Parent ~= myChar then
                            gold.Parent = LocalPlayer.Backpack task.wait(0.3)
                        end
                    elseif gold:IsA("BasePart") or gold:IsA("Model") then
                        local goldPos = gold:IsA("Model") and gold:FindFirstChild("HumanoidRootPart") and gold.HumanoidRootPart.Position or (gold:IsA("BasePart") and gold.Position or nil)
                        if goldPos then
                            local originalPos = myRoot.CFrame myRoot.CFrame = CFrame.new(goldPos + Vector3.new(0, 2, 0))
                            task.wait(0.05) myRoot.CFrame = originalPos task.wait(0.3)
                        end
                    end
                end
            end)
        end
    end)
end

local function DisableAutoCollectGold()
    if autoCollectGoldLoop then task.cancel(autoCollectGoldLoop) autoCollectGoldLoop = nil end
end

local function ClearHighlights()
    for _, v in pairs(Workspace:GetDescendants()) do if v:IsA("Highlight") and v.Name == "JobHighlight" then v:Destroy() end end
end

local function UpdateHighlights()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LocalPlayer then continue end
        local character = plr.Character if not character then continue end
        local humanoid = character:FindFirstChild("Humanoid") if not humanoid or humanoid.Health <= 0 then continue end
        local highlight = character:FindFirstChild("JobHighlight")
        if not highlight then
            highlight = Instance.new("Highlight") highlight.Name = "JobHighlight" highlight.Parent = character
            highlight.FillTransparency = 0.6 highlight.OutlineTransparency = 0 highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        end
        local job = GetJob(plr)
        if job == "杀手" then highlight.FillColor = Color3.new(1, 0, 0) highlight.OutlineColor = Color3.new(1, 0, 0)
        elseif job == "警长" then highlight.FillColor = Color3.new(0, 0.5, 1) highlight.OutlineColor = Color3.new(0, 0.5, 1)
        else highlight.FillColor = Color3.new(1, 1, 1) highlight.OutlineColor = Color3.new(1, 1, 1) end
    end
end

local function EnableJobESP()
    jobEspEnabled = true
    if jobEspLoop then task.cancel(jobEspLoop) jobEspLoop = nil end
    jobEspLoop = task.spawn(function()
        while jobEspEnabled do
            pcall(function()
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character and plr.Character:FindFirstChild("Head") then
                        local head = plr.Character.Head local jobLabel = head:FindFirstChild("JobLabel")
                        if not jobLabel then
                            jobLabel = Instance.new("BillboardGui") jobLabel.Name = "JobLabel" jobLabel.Parent = head
                            jobLabel.Size = UDim2.new(0, 100, 0, 30) jobLabel.StudsOffset = Vector3.new(0, 2.5, 0) jobLabel.AlwaysOnTop = true
                            local text = Instance.new("TextLabel") text.Parent = jobLabel text.BackgroundTransparency = 1
                            text.Size = UDim2.new(1, 0, 1, 0) text.TextSize = 15 text.Font = Enum.Font.ArialBold jobLabel.TextLabel = text
                        end
                        local text = jobLabel.TextLabel local job = GetJob(plr) text.Text = job
                        if job == "杀手" then text.TextColor3 = Color3.new(1, 0, 0)
                        elseif job == "警长" then text.TextColor3 = Color3.new(0, 0.5, 1)
                        else text.TextColor3 = Color3.new(1, 1, 1) end
                    end
                end
                UpdateHighlights()
            end)
            task.wait(0.3)
        end
    end)
end

local function DisableJobESP()
    jobEspEnabled = false
    if jobEspLoop then task.cancel(jobEspLoop) jobEspLoop = nil end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and plr.Character:FindFirstChild("Head") then
            local jobLabel = plr.Character.Head:FindFirstChild("JobLabel") if jobLabel then jobLabel:Destroy() end
        end
    end
    ClearHighlights()
end

local function EnableAutoPickGun()
    autoPickGunEnabled = true
    autoPickGunLoop = task.spawn(function()
        while autoPickGunEnabled do
            task.wait(0.3)
            local myChar = LocalPlayer.Character local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart") local myHumanoid = myChar and myChar:FindFirstChild("Humanoid")
            if not myChar or not myRoot or not myHumanoid or myHumanoid.Health <= 0 then continue end
            if GetWeapon(LocalPlayer, "gun") then continue end
            local targetGun = nil
            for _, descendant in pairs(Workspace:GetDescendants()) do
                if descendant:IsA("Tool") then
                    local nameLower = descendant.Name:lower() local isGun = false
                    for _, keyword in ipairs({"gun", "手枪", "警长", "revolver"}) do if nameLower:find(keyword) then isGun = true break end end
                    if not isGun then continue end
                    if descendant:IsDescendantOf(Workspace) and not descendant:IsDescendantOf(LocalPlayer) then targetGun = descendant break end
                end
            end
            if targetGun then
                local originalPos = myRoot.CFrame local gunPos = targetGun:IsA("BasePart") and targetGun.Position or (targetGun:FindFirstChild("Handle") and targetGun.Handle.Position) or nil
                if gunPos then myRoot.CFrame = CFrame.new(gunPos + Vector3.new(0, 2, 0)) task.wait(0.3) pcall(function() targetGun.Parent = LocalPlayer.Backpack end) myRoot.CFrame = originalPos Notify("已拾取一把警长枪械") end
            end
        end
    end)
end

local function DisableAutoPickGun()
    autoPickGunEnabled = false
    if autoPickGunLoop then task.cancel(autoPickGunLoop) autoPickGunLoop = nil end
end

local function KillerAutoKillAll()
    if GetJob(LocalPlayer) ~= "杀手" then Notify("仅杀手可使用此功能") return end
    if autoKillLoop then task.cancel(autoKillLoop) autoKillLoop = nil Notify("自动清场已停止") return end
    local targetList = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            if GetJob(p) == "警长" then table.insert(targetList, 1, p) else table.insert(targetList, p) end
        end
    end
    if #targetList == 0 then Notify("未找到存活目标") return end
    local knife = GetWeapon(LocalPlayer, "knife") if not knife then Notify("未找到你的刀，无法执行") return end
    Notify("开始清场，共"..#targetList.."个目标")
    autoKillLoop = task.spawn(function()
        local killCount = 0
        for index, target in ipairs(targetList) do
            local myChar = LocalPlayer.Character local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart") local myHumanoid = myChar and myChar:FindFirstChild("Humanoid") local currentKnife = GetWeapon(LocalPlayer, "knife")
            if not myChar or not myRoot or not myHumanoid or myHumanoid.Health <= 0 or not currentKnife then autoKillLoop = nil Notify("你已死亡或武器丢失，清场停止") return end
            if not target or not target:IsDescendantOf(Players) or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") or not target.Character:FindFirstChild("Humanoid") or target.Character.Humanoid.Health <= 0 then Notify("目标"..target.Name.."已死亡") continue end
            local targetRoot = target.Character.HumanoidRootPart myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 2) task.wait(0.1)
            currentKnife:Equip() task.wait(0.05) currentKnife:Activate()
            local waitStart = os.clock() local targetDied = false
            while os.clock() - waitStart < 5 do
                task.wait(0.1)
                local newTargetHumanoid = target.Character and target.Character:FindFirstChild("Humanoid") if not newTargetHumanoid or newTargetHumanoid.Health <= 0 then targetDied = true break end
                local newMyHumanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") if not newMyHumanoid or newMyHumanoid.Health <= 0 then autoKillLoop = nil Notify("你已死亡，清场停止") return end
                local newKnife = GetWeapon(LocalPlayer, "knife") if not newKnife then autoKillLoop = nil Notify("武器丢失，清场停止") return end
                local newTargetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart") local newMyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if newTargetRoot and newMyRoot then newMyRoot.CFrame = newTargetRoot.CFrame * CFrame.new(0, 0, 2) newKnife:Equip() task.wait(0.05) newKnife:Activate() end
            end
            if targetDied then killCount += 1 Notify("已击杀 "..target.Name.." ("..killCount.."/"..#targetList..")") else Notify("超时，跳过 "..target.Name) end
        end
        autoKillLoop = nil Notify("清场完成，共击杀"..killCount.."个目标")
    end)
end

local function TP(p)
    local r = LocalPlayer.Character:FindFirstChild("HumanoidRootPart") local tr = p.Character:FindFirstChild("HumanoidRootPart")
    if r and tr then r.CFrame = tr.CFrame * CFrame.new(0, 0, 2) Notify("已传送到 "..p.Name) end
end

local function TPC()
    local l = LocalPlayer.Character:FindFirstChild("HumanoidRootPart") if not l then return end
    local m = math.huge local t
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and GetJob(p) == "平民" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - l.Position).Magnitude if d < m then m = d; t = p end
        end
    end
    if t then TP(t) else Notify("未找到平民") end
end

local function TPS()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and GetJob(p) == "警长" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then TP(p) return end
    end
    Notify("未找到警长")
end

local function TPK()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and GetJob(p) == "杀手" and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then TP(p) return end
    end
    Notify("未找到杀手")
end

local function TeleportKillerToSpawn()
    local found = false
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and GetJob(player) == "杀手" then
            local char = player.Character if char and char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.CFrame = CFrame.new(352.42, 522.05, -8.30) found = true Notify("已将杀手 "..player.Name.." 传送到出生点") end
        end
    end
    if not found then Notify("未找到存活的杀手") end
end

