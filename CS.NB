    Settings = Window:AddTab("界面设置", "settings"),
}

local lplr = Players.LocalPlayer
local localPlayer = lplr
local camera = workspace.CurrentCamera

local Script = {
    GameState = "unknown",
    Connections = {},
    Functions = {},
    ESPTable = { Player = {}, Seeker = {}, Hider = {}, Guard = {}, Door = {}, None = {}, Key = {} },
    Temp = {},
    GameStateChanged = Instance.new("BindableEvent")
}
local States = {}

function Script.Functions.Alert(msg, t)
    Library:Notify(msg, t or 5)
    local s = Instance.new("Sound", workspace)
    s.SoundId = "rbxassetid://4590662766"
    s.Volume = 2
    s.PlayOnRemove = true
    s:Destroy()
end

function Script.Functions.Warn(msg) warn("RTaOHUB 警告: "..msg) end

function Script.Functions.ESP(args)
    if not args.Object then return end
    local esp = {
        Object = args.Object, Text = args.Text or "", TextParent = args.TextParent,
        Color = args.Color or Color3.new(1,1,1), Offset = args.Offset or Vector3.new(),
        IsEntity = args.IsEntity or false, Type = args.Type or "None",
        Highlights = {}, Humanoid = nil, RSConnection = nil, Connections = {}
    }
    local idx = #Script.ESPTable[esp.Type] + 1

    if esp.IsEntity and esp.Object.PrimaryPart and esp.Object.PrimaryPart.Transparency == 1 then
        esp.Object:SetAttribute("Transparency", esp.Object.PrimaryPart.Transparency)
        esp.Humanoid = Instance.new("Humanoid", esp.Object)
        esp.Object.PrimaryPart.Transparency = 0.99
    end

    local hi = Instance.new("Highlight")
    hi.Adornee = esp.Object
    hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hi.FillColor = esp.Color
    hi.FillTransparency = Options.ESPFillTransparency and Options.ESPFillTransparency.Value or 0.75
    hi.OutlineColor = esp.Color
    hi.OutlineTransparency = Options.ESPOutlineTransparency and Options.ESPOutlineTransparency.Value or 0
    hi.Enabled = Toggles.ESPHighlight and Toggles.ESPHighlight.Value or true
    hi.Parent = esp.Object
    table.insert(esp.Highlights, hi)

    local bg = Instance.new("BillboardGui")
    bg.Adornee = esp.TextParent or esp.Object
    bg.AlwaysOnTop = true
    bg.Size = UDim2.new(0,1,0,1)
    bg.StudsOffset = esp.Offset
    bg.Parent = esp.TextParent or esp.Object

    local tl = Instance.new("TextLabel")
    tl.BackgroundTransparency = 1
    tl.Font = Enum.Font.Oswald
    tl.Size = UDim2.new(1,0,1,0)
    tl.Text = esp.Text
    tl.TextColor3 = esp.Color
    tl.TextSize = Options.ESPTextSize and Options.ESPTextSize.Value or 22
    tl.TextStrokeColor3 = Color3.new()
    tl.TextStrokeTransparency = 0.75
    tl.Parent = bg

    function esp.SetColor(c)
        esp.Color = c
        for _,h in pairs(esp.Highlights) do h.FillColor = c; h.OutlineColor = c end
        tl.TextColor3 = c
    end

    function esp.Destroy()
        if esp.RSConnection then esp.RSConnection:Disconnect() end
        if esp.IsEntity and esp.Object then
            if esp.Object.PrimaryPart then esp.Object.PrimaryPart.Transparency = esp.Object.PrimaryPart:GetAttribute("Transparency") end
            if esp.Humanoid then esp.Humanoid:Destroy() end
        end
        for _,h in pairs(esp.Highlights) do h:Destroy() end
        bg:Destroy()
        Script.ESPTable[esp.Type][idx] = nil
        for _,c in pairs(esp.Connections) do pcall(function() c:Disconnect() end) end
    end

    esp.RSConnection = RunService.RenderStepped:Connect(function()
        if not esp.Object or not esp.Object:IsDescendantOf(workspace) then esp.Destroy() return end
        for _,h in pairs(esp.Highlights) do
            h.Enabled = Toggles.ESPHighlight and Toggles.ESPHighlight.Value or true
            h.FillTransparency = Options.ESPFillTransparency and Options.ESPFillTransparency.Value or 0.75
            h.OutlineTransparency = Options.ESPOutlineTransparency and Options.ESPOutlineTransparency.Value or 0
        end
        tl.TextSize = Options.ESPTextSize and Options.ESPTextSize.Value or 22
        if Toggles.ESPDistance and Toggles.ESPDistance.Value then
            tl.Text = string.format("%s\n[%.0f]", esp.Text, Script.Functions.DistanceFromCharacter(esp.Object))
        else
            tl.Text = esp.Text
        end
    end)

    Script.ESPTable[esp.Type][idx] = esp
    return esp
end

function Script.Functions.DistanceFromCharacter(pos)
    if typeof(pos) == "Instance" then pos = pos:GetPivot().Position end
    if lplr.Character and lplr.Character:FindFirstChild("HumanoidRootPart") then
        return (lplr.Character.HumanoidRootPart.Position - pos).Magnitude
    end
    return (camera.CFrame.Position - pos).Magnitude
end

function Script.Functions.PlayerESP(pl)
    if not (pl.Character and pl.Character.PrimaryPart and pl.Character:FindFirstChild("Humanoid") and pl.Character.Humanoid.Health > 0) then return end
    local e = Script.Functions.ESP({
        Type = "Player", Object = pl.Character,
        Text = string.format("%s [%s]", pl.DisplayName, pl.Character.Humanoid.Health),
        TextParent = pl.Character.PrimaryPart,
        Color = Options.PlayerEspColor and Options.PlayerEspColor.Value or Color3.new(1,1,1)
    })
    local conn = pl.Character.Humanoid.HealthChanged:Connect(function(h)
        if h > 0 then e.Text = string.format("%s [%s]", pl.DisplayName, h)
        else e.Destroy() end
    end)
    table.insert(e.Connections, conn)
end

function Script.Functions.GuardESP(model)
    if model and model:FindFirstChild("HumanoidRootPart") then
        Script.Functions.ESP({
            Object = model, Text = "守卫",
            Color = Options.GuardEspColor and Options.GuardEspColor.Value or Color3.fromRGB(200,100,200),
            Offset = Vector3.new(0,3,0), Type = "Guard"
        })
    end
end

function Script.Functions.SeekerESP(pl)
    if pl:GetAttribute("IsHunter") and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
        Script.Functions.ESP({
            Object = pl.Character, Text = pl.Name .. " (抓捕者)",
            Color = Options.SeekerEspColor and Options.SeekerEspColor.Value or Color3.fromRGB(255,0,0),
            Offset = Vector3.new(0,3,0), Type = "Seeker"
        })
    end
end

function Script.Functions.HiderESP(pl)
    if pl:GetAttribute("IsHider") and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
        local e = Script.Functions.ESP({
            Object = pl.Character, Text = pl.Name .. " (躲藏者)",
            Color = Options.HiderEspColor and Options.HiderEspColor.Value or Color3.fromRGB(0,255,0),
            Offset = Vector3.new(0,3,0), Type = "Hider"
        })
        pl:GetAttributeChangedSignal("IsHider"):Once(function()
            if not pl:GetAttribute("IsHider") then e.Destroy() end
        end)
    end
end

function Script.Functions.KeyESP(key)
    if key:IsA("Model") and key.PrimaryPart then
        Script.Functions.ESP({
            Object = key, Text = key.Name .. " (钥匙)",
            Color = Options.KeyEspColor and Options.KeyEspColor.Value or Color3.fromRGB(255,255,0),
            Offset = Vector3.new(0,1,0), Type = "Key", IsEntity = true
        })
    end
end

function Script.Functions.DoorESP(door)
    if door:IsA("Model") and door.Name == "FullDoorAnimated" and door.PrimaryPart then
        local keyNeeded = door:GetAttribute("KeyNeeded") or "无"
        Script.Functions.ESP({
            Object = door, Text = "门 (需要钥匙: "..keyNeeded..")",
            Color = Options.DoorEspColor and Options.DoorEspColor.Value or Color3.fromRGB(0,128,255),
            Offset = Vector3.new(0,2,0), Type = "Door", IsEntity = true
        })
    end
end

Script.Functions.SafeRequire = function(module)
    if Script.Temp[tostring(module)] then return Script.Temp[tostring(module)] end
    local s,r = pcall(require, module)
    if not s then warn("[SafeRequire] "..tostring(module).." 失败: "..tostring(r)) return nil end
    Script.Temp[tostring(module)] = r
    return r
end

Script.Functions.FixCamera = function()
    if workspace.CurrentCamera then pcall(function() workspace.CurrentCamera:Destroy() end) end
    local cam = Instance.new("Camera", workspace)
    workspace.CurrentCamera = cam
    cam.CameraType = Enum.CameraType.Custom
    if lplr.Character then cam.CameraSubject = lplr.Character:FindFirstChildWhichIsA("Humanoid") end
end

Script.Functions.TeleportSafe = function()
    if not lplr.Character then return end
    local fling = Toggles.AntiFlingToggle and Toggles.AntiFlingToggle.Value
    if fling then Toggles.AntiFlingToggle:SetValue(false) end
    lplr.Character:PivotTo(CFrame.new(Vector3.new(-108, 329.1, 462.1)))
    if fling then task.delay(0.5, function() Toggles.AntiFlingToggle:SetValue(true) end) end
end

Script.Functions.WinRLGL = function()
    if not lplr.Character then return end
    local fling = Toggles.AntiFlingToggle and Toggles.AntiFlingToggle.Value
    if fling then Toggles.AntiFlingToggle:SetValue(false) end
    lplr.Character:PivotTo(CFrame.new(Vector3.new(-100.8, 1030, 115)))
    if fling then task.delay(0.5, function() Toggles.AntiFlingToggle:SetValue(true) end) end
end

Script.Functions.WinGlassBridge = function()
