KillerLeft:AddButton({ Title = "甩飞警长", Func = function() local s = Yisan_findSheriff() if not s then Notify("找不到警长") elseif s == LocalPlayer then Notify("不能甩飞自己") else Yisan_powerfulFling(s) end end })
KillerLeft:AddButton({ Title = "杀死最近玩家", Func = function() if Yisan_findMurderer() ~= LocalPlayer then Notify("你不是杀手") return end if not LocalPlayer.Character:FindFirstChild("Knife") then if LocalPlayer.Backpack:FindFirstChild("Knife") then LocalPlayer.Character:FindFirstChild("Humanoid"):EquipTool(LocalPlayer.Backpack:FindFirstChild("Knife")) else Notify("你没有刀") return end end local np = Yisan_findNearestPlayer() if not np or not np.Character then Notify("找不到玩家") return end local nhrp = np.Character:FindFirstChild("HumanoidRootPart") if not nhrp then Notify("找不到玩家部位") return end if not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then Notify("你的角色无效") return end if not Yisan_TaffyMooKnife then nhrp.Anchored = true nhrp.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame + LocalPlayer.Character.HumanoidRootPart.CFrame.LookVector * 2 task.wait(0.1) LocalPlayer.Character.Knife.Stab:FireServer("Slash") else local lpknife = LocalPlayer.Character:FindFirstChild("Knife") if not lpknife then return end local rp = RaycastParams.new() rp.FilterType = Enum.RaycastFilterType.Exclude rp.FilterDescendantsInstances = {LocalPlayer.Character} LocalPlayer.Character.Knife.Throw:FireServer(lpknife:GetPivot(), nhrp.Position) end Notify("已杀死最近玩家") end end })
