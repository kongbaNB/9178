MiscLeft:AddButton({ Title = "传送到地图", Func = function() local map = Yisan_getMap() if not map then Notify("找不到地图") return end local spawns = map:FindFirstChild("Spawns") if spawns and #spawns:GetChildren()>0 then local r = spawns:GetChildren()[math.random(1,#spawns:GetChildren())] if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then LocalPlayer.Character:MoveTo(r.Position) end else Notify("找不到生成点") end end })
MiscLeft:AddButton({ Title = "传送到掉落的枪", Func = function() local map = Yisan_getMap() if not map or not map:FindFirstChild("GunDrop") then Notify("没有掉落枪支") return end local gd = map:FindFirstChild("GunDrop") if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then local prev = LocalPlayer.Character.HumanoidRootPart.CFrame LocalPlayer.Character.HumanoidRootPart.CFrame = gd:GetPivot() local conn conn = LocalPlayer.Backpack.ChildAdded:Connect(function(child) if child.Name=="Gun" then conn:Disconnect() task.wait(0.5) LocalPlayer.Character.HumanoidRootPart.CFrame = prev end end) task.delay(5, function() if conn then conn:Disconnect() LocalPlayer.Character.HumanoidRootPart.CFrame = prev end end) end end })

local CtSection = Tabs.Attr:AddLeftGroupbox("范围修改")
CtSection:AddInput({ Title = "范围数值", Value = "1", Placeholder = "", Callback = function(i) Yisan_Taffyhit = tonumber(i) or 1 for _, v in ipairs(Players:GetPlayers()) do if v ~= LocalPlayer and v.Character:FindFirstChild('HumanoidRootPart') then local sz = Vector3.new(tonumber(i) or 1, tonumber(i) or 1, tonumber(i) or 1) if Yisan_TaffyBox then for _, part in ipairs(v.Character:GetChildren()) do if part:IsA("BasePart") then part.Size = sz part.Transparency = 0.2 end end else local root = v.Character.HumanoidRootPart if root:IsA("BasePart") then root.Size = sz root.Transparency = 0.2 root.CanCollide = false end end end end end })
CtSection:AddToggle({ Title = "范围 v1 (仅根部件)", Default = false, Callback = function(state)
    if state then
        if Yisan_TaffyBox then Notify("请先关闭范围 v2") return end
        if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end
        Yisan_loopTaffyhit = RunService.Heartbeat:Connect(function()
            for _, v in ipairs(Players:GetPlayers()) do
                if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild('HumanoidRootPart') then
                    local root = v.Character.HumanoidRootPart
                    local sz = Vector3.new(Yisan_Taffyhit, Yisan_Taffyhit, Yisan_Taffyhit)
                    root.Size = sz root.Transparency = 0.2 root.CanCollide = false
                end
            end
        end)
    else
        if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end
    end
end })
CtSection:AddToggle({ Title = "范围 v2 (所有部位)", Default = false, Callback = function(state)
    Yisan_TaffyBox = state
    if state then
        if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end
        Yisan_loopTaffyhit = RunService.Heartbeat:Connect(function()
            for _, v in ipairs(Players:GetPlayers()) do
                if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild('HumanoidRootPart') then
                    local sz = Vector3.new(Yisan_Taffyhit, Yisan_Taffyhit, Yisan_Taffyhit)
                    for _, part in ipairs(v.Character:GetChildren()) do
                        if part:IsA("BasePart") then part.Size = sz part.Transparency = 0.2 end
                    end
                end
            end
        end)
    else
        if Yisan_loopTaffyhit then Yisan_loopTaffyhit:Disconnect() end
    end
end })

local AmSection = Tabs.Attr:AddLeftGroupbox("瞄准")
AmSection:AddInput({ Title = "目标玩家", Value = "", Placeholder = "", Callback = function(i) if not Players:FindFirstChild(Yisan_getPlayer(i, LocalPlayer)) then Notify("玩家未找到") return end Yisan_target = Players:FindFirstChild(Yisan_getPlayer(i, LocalPlayer)) Notify("目标设置为 "..Yisan_target.Name) end })
AmSection:AddButton({ Title = "瞄准锁定", Func = function() if Yisan_Taffyaim then return end if Yisan_Taffyaimrscon then Yisan_Taffyaimrscon:Disconnect() end if not Yisan_target then Notify("没有输入玩家名字") return end Yisan_Taffyaimrscon = RunService.RenderStepped:Connect(function() if not Yisan_target or not Yisan_target.Character or not Yisan_target.Character:FindFirstChild("HumanoidRootPart") then Notify("目标无效") Yisan_Taffyaimrscon:Disconnect() return end Camera.CFrame = CFrame.new(Camera.CFrame.Position, Yisan_target.Character.HumanoidRootPart.Position) end) Yisan_Taffyaim = true end })
AmSection:AddButton({ Title = "取消瞄准锁定", Func = function() if not Yisan_Taffyaim then return end Yisan_Taffyaim = false if Yisan_Taffyaimrscon then Yisan_Taffyaimrscon:Disconnect() end end })

local FgSection = Tabs.Attr:AddLeftGroupbox("甩飞")
FgSection:AddInput({ Title = "甩飞目标", Value = "", Placeholder = "", Callback = function(i) if not Players:FindFirstChild(Yisan_getPlayer(i, LocalPlayer)) then Notify("玩家未找到") return end Yisan_TaffyplayerFt = Players:FindFirstChild(Yisan_getPlayer(i, LocalPlayer)) Notify("甩飞目标设置为 "..Yisan_TaffyplayerFt.Name) end })
FgSection:AddButton({ Title = "甩飞指定玩家", Func = function() if not Yisan_TaffyplayerFt then Notify("请先设置甩飞目标") return end if not Players:FindFirstChild(Yisan_TaffyplayerFt.Name) then Notify("目标玩家不存在") return end if Yisan_TaffyplayerFt == LocalPlayer then Notify("不能甩飞自己") return end Yisan_powerfulFling(Yisan_TaffyplayerFt) end })
FgSection:AddToggle({ Title = "防甩飞", Default = false, Callback = function(state) Yisan_TaffyantiFly = state if state then Yisan_flingDetectionCon = RunService.Heartbeat:Connect(function() for _, pl in ipairs(Players:GetPlayers()) do if pl.Character:IsDescendantOf(Workspace) then if pl.Character.PrimaryPart.AssemblyAngularVelocity.Magnitude>50 or pl.Character.PrimaryPart.AssemblyLinearVelocity.Magnitude>100 then if not Yisan_detectedPlayers[pl.Name] then Notify("检测到甩飞者: "..pl.Name) Yisan_detectedPlayers[pl.Name]=true end for _, p in ipairs(pl.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false p.AssemblyAngularVelocity=Vector3.zero p.AssemblyLinearVelocity=Vector3.zero p.CustomPhysicalProperties=PhysicalProperties.new(0,0,0) end end end end end end) Yisan_flingNeutralizerCon = RunService.Heartbeat:Connect(function() if LocalPlayer.Character and LocalPlayer.Character.PrimaryPart then if LocalPlayer.Character.PrimaryPart.AssemblyLinearVelocity.Magnitude>250 or LocalPlayer.Character.PrimaryPart.AssemblyAngularVelocity.Magnitude>250 then LocalPlayer.Character.PrimaryPart.AssemblyLinearVelocity=Vector3.zero LocalPlayer.Character.PrimaryPart.AssemblyAngularVelocity=Vector3.zero if Yisan_TaffyantiFlyLastPos~=Vector3.zero then LocalPlayer.Character.PrimaryPart.CFrame=CFrame.new(Yisan_TaffyantiFlyLastPos) end else Yisan_TaffyantiFlyLastPos=LocalPlayer.Character.PrimaryPart.Position end end end) else if Yisan_flingDetectionCon then Yisan_flingDetectionCon:Disconnect() end if Yisan_flingNeutralizerCon then Yisan_flingNeutralizerCon:Disconnect() end Yisan_detectedPlayers={} end end })

Workspace.ChildAdded:Connect(function(ch)
    if ch == Yisan_getMap() and Yisan_playerESP then Notify("地图已加载等待分配角色...") repeat task.wait(1) until Yisan_findMurderer() Notify("玩家ESP已移除,请重新开启") end
end)
Workspace.ChildRemoved:Connect(function(ch)
    if ch == Yisan_getMap() and Yisan_playerESP then Notify("游戏结束移除玩家ESP") Yisan_playerData={} for _, v in ipairs(Workspace:GetChildren()) do if v.Name=="PlayerESP" then v:Destroy() end end end
end)
Workspace.DescendantAdded:Connect(function(ch)
    if Yisan_TaffyDete and ch.Name=="Trap" and ch.Parent:IsDescendantOf(Workspace) then
        ch.Transparency=0
        local esp = Yisan_trapESP:Clone() esp.Parent=Workspace esp.Adornee=ch
        Notify("杀手放置了陷阱")
    end
    if Yisan_TaffygunESP and ch.Name=="GunDrop" then
        if not Workspace:FindFirstChild("GunESP") then
            local hl = Instance.new("Highlight", Workspace) hl.OutlineTransparency=1 hl.FillColor=Color3.fromRGB(255,255,0) hl.Name="GunESP" hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop hl.Adornee=ch hl.Enabled=true
        end
        Workspace:FindFirstChild("GunESP").Adornee=ch Workspace:FindFirstChild("GunESP").Enabled=true
        Notify("枪已掉落,寻找黄色透视物品")
        if Yisan_TaffyGetGun then
            task.wait(0.01)
            if not Yisan_getMap():FindFirstChild("GunDrop") then return end
            local prev = LocalPlayer.Character:GetPivot()
            LocalPlayer.Character:MoveTo(Yisan_getMap():FindFirstChild("GunDrop").Position)
            LocalPlayer.Backpack.ChildAdded:Wait()
            LocalPlayer.Character:PivotTo(prev)
        end
    end
end)
Workspace.DescendantRemoving:Connect(function(ch)
    if Yisan_TaffygunESP and ch.Name=="GunDrop" then
        if Workspace:FindFirstChild("GunESP") then Workspace:FindFirstChild("GunESP"):Destroy() end
        Notify("有人拿走了掉落的枪")
        task.wait(0.6)
        local sher = Yisan_findSheriff()
        if sher then Notify("警长是 "..sher.DisplayName) end
    end
end)
game.Workspace.ChildAdded:Connect(function(chi)
    if chi.Name=="ThrowingKnife" and Yisan_TaffyChinaknife then chi:Destroy() end
end)

LocalPlayer.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid")
    task.wait(0.5)
    if Yisan_ws ~= 16 then char:FindFirstChild("Humanoid").WalkSpeed = Yisan_ws end
    char:FindFirstChild("Humanoid").JumpPower = Yisan_JumpPower
end)

task.spawn(function()
    if RunService:IsStudio() then return end
    local OldNameCall
    OldNameCall = hookmetamethod(game, "__namecall", function(Self, ...)
        local Args = {...}
        if Yisan_antifail and getnamecallmethod() == "FireServer" and Args[1] == "SetPlayerMinigameResult" then
            Args[2] = true
        end
        return OldNameCall(Self, unpack(Args))
    end)
end)

local MiscRight = Tabs.Misc:AddRightGroupbox("防失败")
MiscRight:AddToggle({ Title = "防失败[秒完成互动]", Default = false, Callback = function(state) Yisan_antifail = state end })

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("DestroyerMystery2")
    ThemeManager:ApplyToTab(Tabs.Settings)
end
if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("DestroyerMystery2")
    SaveManager:BuildConfigSection(Tabs.Settings)
end
