        addBtn("美化包排行榜第一", posX2, 4, function()
            beautifyStats()
            game:GetService("StarterGui"):SetCore("SendNotification", { Title = "美化包", Text = "数值已修改为999（若游戏支持）", Duration = 3 })
        end)
        local crosshairBtn = addBtn("准星：关", posX1, 4 + rowHeight)
        local crosshairSpinBtn = addBtn("准星旋转：关", posX2, 4 + rowHeight)
        local antiAFKBtn = addBtn("反挂机踢出：关", posX1, 4 + 2*rowHeight)
        crosshairBtn.MouseButton1Click:Connect(function()
            state.crosshair = not state.crosshair
            crosshairBtn.Text = state.crosshair and "准星：开" or "准星：关"
        end)
        crosshairSpinBtn.MouseButton1Click:Connect(function()
            state.crosshairSpin = not state.crosshairSpin
            crosshairSpinBtn.Text = state.crosshairSpin and "准星旋转：开" or "准星旋转：关"
        end)
        antiAFKBtn.MouseButton1Click:Connect(function()
            state.antiAFK = not state.antiAFK
            antiAFKBtn.Text = state.antiAFK and "反挂机踢出：开" or "反挂机踢出：关"
            if state.antiAFK then startAntiAFK() else stopAntiAFK() end
        end)
    elseif i == 5 then
        addBtn("破坏者谜团2", posX1, 4, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/PHZMT.NB"))()
        end)
        addBtn("吃吃世界", posX2, 4, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/CCSJ.NB"))()
        end)
        addBtn("在超市生活一周", posX1, 4 + rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/ZCSSHYZ.NB"))()
        end)
        addBtn("亡命速递", posX2, 4 + rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/WMSD.NB"))()
        end)
        addBtn("巨剑骑士", posX1, 4 + 2*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/JJQS.NB"))()
        end)
        addBtn("doors", posX2, 4 + 2*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/DOORS.NB"))()
        end)
        addBtn("盲射", posX1, 4 + 3*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/MS.NB"))()
        end)
        addBtn("找到按钮", posX2, 4 + 3*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/ZDNN.NB"))()
        end)
        addBtn("墨水游戏", posX1, 4 + 4*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/MSYS.NB"))()
        end)
        addBtn("力量传奇", posX2, 4 + 4*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/LLCC.NB"))()
        end)
        addBtn("踢出幸运方块", posX1, 4 + 5*rowHeight, function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/TCXYFK.NB"))()
        end)
    end

    cat.MouseButton1Click:Connect(function()
        if selected then
            selected.BackgroundTransparency = 0.8; selected.BackgroundColor3 = Color3.fromRGB(25,25,25)
        end
        cat.BackgroundTransparency = 0.5; cat.BackgroundColor3 = Color3.fromRGB(70,70,70)
        selected = cat
        for _,p in pairs(pages) do p.Visible = false end
        if speedPanel then speedPanel.Visible = false end
        if coordPanel then coordPanel.Visible = false end
        if aimbotPanel then aimbotPanel.Visible = false end
        if harassSpeedPanel then harassSpeedPanel.Visible = false end
        if spinSpeedPanel then spinSpeedPanel.Visible = false end
        page.Visible = true
    end)
    categories[i] = cat; pages[i] = page
end

for i = 1, 5 do AddCat(i) end
task.defer(function() if categories[1] then categories[1]:MouseButton1Click() end end)

