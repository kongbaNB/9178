local MiscGroup = TabsUI.Main:AddRightGroupbox("杂项 / 复制")
MiscGroup:AddDropdown('EmotesList', { Text = '表情列表', Values = {}, AllowNull = true })
task.spawn(function()
    Script.Functions.RefreshEmoteList = function()
        local res = {}
        local Animations = ReplicatedStorage:WaitForChild("Animations", 10)
        if not Animations then return end
        local Emotes = Animations:WaitForChild("Emotes", 10)
        if not Emotes then return end
        for _, v in pairs(Emotes:GetChildren()) do
            if v.ClassName == "Animation" and v.AnimationId then
                res[v.Name] = { anim = v.AnimationId, object = v }
            end
        end
        Script.Temp.EmoteList = res
        local names = {}
        for k in pairs(res) do table.insert(names, k) end
        Options.EmotesList:SetValues(names)
    end
    Script.Functions.RefreshEmoteList()
    local Emotes = ReplicatedStorage:WaitForChild("Animations"):WaitForChild("Emotes")
    Library:GiveSignal(Emotes.ChildAdded:Connect(Script.Functions.RefreshEmoteList))
    Library:GiveSignal(Emotes.ChildRemoved:Connect(Script.Functions.RefreshEmoteList))
end)

MiscGroup:AddButton({ Text = '播放表情', Func = function()
    if Options.EmotesList.Value then
        local emoteData = Script.Temp.EmoteList and Script.Temp.EmoteList[Options.EmotesList.Value]
        if emoteData and emoteData.anim and emoteData.object then
            local character = lplr.Character
            if not character then Script.Functions.Alert("未找到角色", 3) return end
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if not humanoid then Script.Functions.Alert("未找到人形对象", 3) return end
            if Script.Temp.EmoteTrack then pcall(function() Script.Temp.EmoteTrack:Stop() end) end
            local anim = Instance.new("Animation")
            anim.AnimationId = emoteData.anim
            local track = humanoid:LoadAnimation(anim)
            track.Priority = Enum.AnimationPriority.Action
            track:Play()
            Script.Temp.EmoteTrack = track
        else
            Script.Functions.Alert("无效表情")
            Options.EmotesList:SetValue(nil)
            Script.Functions.RefreshEmoteList()
        end
    else
        Script.Functions.Alert("未选择表情！", 3)
    end
end })
MiscGroup:AddButton({ Text = '停止表情', Func = function()
    if Script.Temp.EmoteTrack then pcall(function() Script.Temp.EmoteTrack:Stop() end) Script.Temp.EmoteTrack = nil end
end })
