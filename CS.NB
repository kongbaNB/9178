        pcall(function() writefile("RTaOHUB_linoria/ink_game/settings/default.json", game:HttpGet("https://raw.githubusercontent.com/Erchobg/VoidwareProfiles/refs/heads/main/InkGame/ink_game/settings/default.json")) end)
    end
    if not isfile("RTaOHUB_linoria/ink_game/settings/autoload.txt") then writefile("RTaOHUB_linoria/ink_game/settings/autoload.txt","default") end
end)

