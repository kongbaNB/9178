Toggles.Noclip:OnChanged(function(call)
    if call then
        Script.Functions.Alert("穿墙已启用", 3)
        task.spawn(function()
            repeat
                if lplr.Character then
                    for _, child in pairs(lplr.Character:GetDescendants()) do
                        if child:IsA("BasePart") and child.CanCollide then child.CanCollide = false end
                    end
                end
                RunService.Heartbeat:Wait()
            until not Toggles.Noclip.Value or Library.Unloaded
        end)
    else
        Script.Functions.Alert("穿墙已禁用", 3)
        if lplr.Character then
            for _, child in pairs(lplr.Character:GetDescendants()) do
                if child:IsA("BasePart") and not child.CanCollide then child.CanCollide = true end
            end
        end
    end
end)

Options.SpeedSlider:OnChanged(function(val)
    if Toggles.SpeedToggle.Value and lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
        lplr.Character.Humanoid.WalkSpeed = val
    end
end)

Toggles.SpeedToggle:OnChanged(function(call)
    if call then
        Script.Functions.Alert("速度已启用", 3)
        Script.Temp.OldSpeed = lplr.Character and lplr.Character:FindFirstChild("Humanoid") and lplr.Character.Humanoid.WalkSpeed or 16
        task.spawn(function()
            repeat
                task.wait(0.5)
                if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
                    lplr.Character.Humanoid.WalkSpeed = Options.SpeedSlider.Value
                end
            until not Toggles.SpeedToggle.Value or Library.Unloaded
        end)
    else
        Script.Functions.Alert("速度已禁用", 3)
        if lplr.Character and lplr.Character:FindFirstChild("Humanoid") then
            lplr.Character.Humanoid.WalkSpeed = Script.Temp.OldSpeed or 16
        end
    end
end)

local controlModule
Toggles.Fly:OnChanged(function(value)
    local rootPart = Script.Functions.GetRootPart()
    if not rootPart then return end
    local humanoid = Script.Functions.GetHumanoid()
    if humanoid then humanoid.PlatformStand = value end
    local flyBody = Script.Temp.FlyBody or Instance.new("BodyVelocity")
    flyBody.Velocity = Vector3.zero
    flyBody.MaxForce = Vector3.one * 9e9
    Script.Temp.FlyBody = flyBody
    flyBody.Parent = value and rootPart or nil
    if value then
        controlModule = controlModule or Script.Functions.SafeRequire(lplr:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule"):WaitForChild("ControlModule"))
        Script.Connections["Fly"] = RunService.RenderStepped:Connect(function()
            local moveVector = controlModule:GetMoveVector()
            local velocity = -((camera.CFrame.LookVector * moveVector.Z) - (camera.CFrame.RightVector * moveVector.X)) * Options.FlySpeed.Value
            flyBody.Velocity = velocity
        end)
    else
        if Script.Connections["Fly"] then Script.Connections["Fly"]:Disconnect() end
    end
end)

function Script.Functions.HookShittyAntiFlingDetection()
    if not lplr.Character or not Toggles.FlingAuraToggle.Value then return end
    if Script.Temp.MainScriptHook then pcall(function() Script.Temp.MainScriptHook:Disconnect() end) end
    local Main = lplr.Character:WaitForChild("Main")
    if Main.Enabled then Script.Functions.Alert("已修补防投掷检测", 1) end
    pcall(function() Main.Enabled = false; Main.Disabled = true end)
    Script.Temp.MainScriptHook = Main:GetPropertyChangedSignal("Enabled"):Connect(function()
        Main.Enabled = false; Main.Disabled = true
    end)
end

Library:GiveSignal(lplr.CharacterAdded:Connect(Script.Functions.HookShittyAntiFlingDetection))
pcall(Script.Functions.HookShittyAntiFlingDetection)

function Script.Functions.RevertAntiFlingDetection()
    if Script.Temp.MainScriptHook then pcall(function() Script.Temp.MainScriptHook:Disconnect() end) end
    if lplr.Character then
        local Main = lplr.Character:WaitForChild("Main")
        Main.Enabled = true; Main.Disabled = false
    end
end

Toggles.FlingAuraToggle:OnChanged(function(enabled)
    local function setNoclip(state)
        if Toggles.Noclip.Value ~= state then Toggles.Noclip:SetValue(state) end
    end
    local function stopFling()
        Script.Temp.FlingAuraActive = false
        setNoclip(false)
        if Script.Temp.FlingAuraDeathConn then Script.Temp.FlingAuraDeathConn:Disconnect() end
    end
    if enabled then
        Script.Functions.Alert("投掷光环已启用", 3)
        Script.Temp.FlingAuraActive = true
        Script.Functions.HookShittyAntiFlingDetection()
        setNoclip(true)
        local humanoid = lplr.Character and lplr.Character:FindFirstChildOfClass("Humanoid")
        if humanoid then Script.Temp.FlingAuraDeathConn = humanoid.Died:Connect(stopFling) end
        task.spawn(function()
            local movel = 0.1
            while Script.Temp.FlingAuraActive and not Library.Unloaded do
                local character = lplr.Character
                local root = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
                if character and character.Parent and root and root.Parent then
                    local originalVel = root.Velocity
                    root.Velocity = originalVel * 10000 + Vector3.new(0, 10000, 0)
                    RunService.RenderStepped:Wait()
                    if character and character.Parent and root and root.Parent then
                        root.Velocity = originalVel
                    end
                    RunService.Stepped:Wait()
                    if character and character.Parent and root and root.Parent then
                        root.Velocity = originalVel + Vector3.new(0, movel, 0)
                        movel = -movel
                    end
                end
                RunService.Heartbeat:Wait()
            end
        end)
    else
        Script.Functions.Alert("投掷光环已禁用", 3)
        Script.Functions.RevertAntiFlingDetection()
        stopFling()
    end
end)

local SecurityGroup = TabsUI.Main:AddRightGroupbox("安全")
SecurityGroup:AddToggle('AntiAfk', { Text = '防挂机', Default = true })
Toggles.AntiAfk:OnChanged(function(call)
    if call then
        local VirtualUser = game:GetService("VirtualUser")
        Script.Temp.AntiAfkConnection = lplr.Idled:Connect(function()
            VirtualUser:Button2Down(Vector2.new(0,0), camera.CFrame)
            wait(1)
            VirtualUser:Button2Up(Vector2.new(0,0), camera.CFrame)
        end)
    else
        if Script.Temp.AntiAfkConnection then pcall(function() Script.Temp.AntiAfkConnection:Disconnect() end) end
    end
end)

SecurityGroup:AddToggle('StaffDetector', { Text = '管理员检测', Default = true })
Toggles.StaffDetector:OnChanged(function(call)
    if call then
        local STAFF_GROUP_ID = 12398672
        local STAFF_MIN_RANK = 120
        local staffRoles = { [120] = "版主", [254] = "开发者", [255] = "所有者" }
        Script.Temp.DetectedStaff = {}
        local function check(pl)
            local suc, rank = pcall(function() return pl:GetRankInGroup(STAFF_GROUP_ID) end)
            if suc and rank and rank >= STAFF_MIN_RANK then
                local role = staffRoles[rank] or ("等级 "..rank)
                Script.Functions.Alert("[管理员检测] 检测到管理员: " .. pl.Name .. " (" .. role .. ")", 10)
                Script.Temp.DetectedStaff[pl.UserId] = {Name = pl.Name, Role = role}
            end
        end
        for _, pl in pairs(Players:GetPlayers()) do if pl ~= lplr then check(pl) end end
        Script.Temp.StaffDetectorConnections = {
            Players.PlayerAdded:Connect(function(pl) if pl ~= lplr then task.wait(1); check(pl) end end),
            Players.PlayerRemoving:Connect(function(pl)
                local info = Script.Temp.DetectedStaff[pl.UserId]
                if info then Script.Functions.Alert("[管理员检测] 管理员离开: " .. info.Name .. " (" .. info.Role .. ")", 10) end
            end)
        }
    else
        if Script.Temp.StaffDetectorConnections then
            for _, conn in pairs(Script.Temp.StaffDetectorConnections) do pcall(function() conn:Disconnect() end) end
        end
        Script.Temp.DetectedStaff = nil
        Script.Functions.Alert("管理员检测已禁用", 3)
    end
end)

