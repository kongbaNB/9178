})

local unbreakableEnabled = false
local unbreakableHook = nil
CandyGroup:AddToggle('UnbreakableDalgona', {
    Text = '糖饼不破',
    Default = false,
    Callback = function(Value)
        unbreakableEnabled = Value
        if Value then
            Library:Notify("糖饼不破已开启", 3)
            task.spawn(function()
                while unbreakableEnabled do
                    pcall(function()
                        ReplicatedStorage.Remotes.DALGONATEMPREMTE:FireServer({
                            CrackAmount = 0,
                            FullyCracked = false,
                            ShapeName = detectPattern() or "Pig"
                        })
                    end)
                    task.wait(0.3)
                end
            end)
            unbreakableHook = hookmetamethod(game, "__namecall", function(self, ...)
                local args = {...}
                local method = getnamecallmethod()
                if tostring(self) == "DALGONATEMPREMPTE" and method == "FireServer" then
                    if args[1] ~= nil and type(args[1]) == "table" and args[1].CrackAmount ~= nil then
                        Library:Notify("已阻止你的饼干碎裂", 3)
                        return nil
                    end
                end
                return unbreakableHook(self, unpack(args))
            end)
        else
            Library:Notify("糖饼不破已关闭", 3)
            if unbreakableHook then
                hookmetamethod(game, "__namecall", unbreakableHook)
                unbreakableHook = nil
            end
        end
    end
})

