local flingAuraActive = false
local flingAuraThread, antiFlingHook, deathConnectionFling = nil, nil, nil

local function getRoot(character)
    return character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
end

local function hookGameAntiFling()
    if not LocalPlayer.Character then return end
    local mainScript = LocalPlayer.Character:FindFirstChild("Main")
    if not mainScript then return end
    mainScript.Enabled = false
    mainScript.Disabled = true
    if antiFlingHook then antiFlingHook:Disconnect() end
    antiFlingHook = mainScript:GetPropertyChangedSignal("Enabled"):Connect(function()
        mainScript.Enabled = false
        mainScript.Disabled = true
    end)
end

local function restoreGameAntiFling()
    if antiFlingHook then
        antiFlingHook:Disconnect()
        antiFlingHook = nil
    end
    if LocalPlayer.Character then
        local mainScript = LocalPlayer.Character:FindFirstChild("Main")
        if mainScript then
            mainScript.Enabled = true
            mainScript.Disabled = false
        end
    end
end

local function startFlingAura()
    if flingAuraActive then return end
    flingAuraActive = true
    hookGameAntiFling()
    local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Humanoid")
    if humanoid then
        deathConnectionFling = humanoid.Died:Connect(stopFlingAura)
    end
    flingAuraThread = task.spawn(function()
        local moveDelta = 0.1
        while flingAuraActive and not Library.Unloaded do
            local character = LocalPlayer.Character
            local root = getRoot(character)
            if character and root and root.Parent then
                local originalVel = root.Velocity
                root.Velocity = originalVel * 10000 + Vector3.new(0, 10000, 0)
                RunService.RenderStepped:Wait()
                if character and root and root.Parent then
                    root.Velocity = originalVel
                end
                RunService.Stepped:Wait()
                if character and root and root.Parent then
                    root.Velocity = originalVel + Vector3.new(0, moveDelta, 0)
                    moveDelta = -moveDelta
                end
            end
            RunService.Heartbeat:Wait()
        end
    end)
end

local function stopFlingAura()
    flingAuraActive = false
    if flingAuraThread then
        task.cancel(flingAuraThread)
        flingAuraThread = nil
    end
    if deathConnectionFling then
        deathConnectionFling:Disconnect()
        deathConnectionFling = nil
    end
    restoreGameAntiFling()
end

GuardAimGroup:AddToggle('FlingAura', {
    Text = '投掷光环',
    Default = false,
    Callback = function(Value)
        if Value then
            Library:Notify("投掷光环已启用", 3)
            startFlingAura()
        else
            Library:Notify("投掷光环已禁用", 3)
            stopFlingAura()
        end
    end
})

LocalPlayer.CharacterAdded:Connect(function()
    if flingAuraActive then
        hookGameAntiFling()
    end
end)

