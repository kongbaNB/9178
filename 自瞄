    Material = Enum.Material.Neon
}
local function CreateBulletTracer(startPos, endPos)
    if not BulletTracers.Enabled then return end
    local distance = (endPos - startPos).Magnitude
    if distance < 0.1 then return end
    local tracer = Instance.new("Part")
    tracer.Name = "BulletTracer"
    tracer.Anchored = true
    tracer.CanCollide = false
    tracer.CanQuery = false
    tracer.CanTouch = false
    tracer.Material = BulletTracers.Material
    tracer.Color = BulletTracers.Color
    tracer.Size = Vector3.new(BulletTracers.Width, BulletTracers.Width, distance)
    tracer.CFrame = CFrame.lookAt(startPos, endPos) * CFrame.new(0, 0, -distance / 2)
    tracer.Transparency = 0.3
    tracer.Parent = Workspace
    TweenService:Create(tracer, TweenInfo.new(BulletTracers.Duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Transparency = 1
    }):Play()
    task.delay(BulletTracers.Duration + 0.1, function()
        if tracer and tracer.Parent then
            tracer:Destroy()
        end
    end)
end
local function FireBulletTracer()
    if not BulletTracers.Enabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local startPos = Camera.CFrame.Position
    local tool = char:FindFirstChildOfClass("Tool")
    if tool then
        local handle = tool:FindFirstChild("Handle")
        if handle then
            startPos = handle.Position
        end
    end
    local direction = Camera.CFrame.LookVector * 5000
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {char}
    local result = Workspace:Raycast(startPos, direction, raycastParams)
    local endPos = result and result.Position or (startPos + direction)
    CreateBulletTracer(startPos, endPos)
end
