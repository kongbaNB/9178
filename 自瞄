local LockViewGyro = nil
local function GetLockViewGyro()
    if LockViewGyro and (not LockViewGyro.Parent or not LockViewGyro:IsDescendantOf(game)) then
        LockViewGyro:Destroy()
        LockViewGyro = nil
    end
    if not LockViewGyro then
        LockViewGyro = Instance.new("BodyGyro")
        LockViewGyro.Name = "LockViewGyro"
        LockViewGyro.MaxTorque = Vector3.new(0, math.huge, 0)
        LockViewGyro.P = 10000
        LockViewGyro.D = 500
    end
    return LockViewGyro
end
RunService:BindToRenderStep("LockView", Enum.RenderPriority.Camera.Value + 1, function()
    if not LockViewEnabled then
        if LockViewGyro and LockViewGyro.Parent then
            LockViewGyro.Parent = nil
        end
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local gyro = GetLockViewGyro()
    if gyro.Parent ~= root then
        gyro.Parent = root
    end
    local camDir = Camera.CFrame.LookVector
    local flatDir = Vector3.new(camDir.X, 0, camDir.Z)
    if flatDir.Magnitude > 0.01 then
        gyro.CFrame = CFrame.new(root.Position, root.Position + flatDir)
    end
end)
