local ToolsDamageIDs = {
    ["Old Axe"] = "3_7367831688",
    ["Good Axe"] = "112_7367831688",
    ["Strong Axe"] = "116_7367831688",
    ["Chainsaw"] = "647_8992824875",
    ["Infernal Sword"] = "2_4340578793",
    ["Spear"] = "196_8999010016"
}

local function getAnyTool(isChop)
    for name, _ in pairs(ToolsDamageIDs) do
        if isChop and name ~= "Old Axe" and name ~= "Good Axe" and name ~= "Strong Axe" then continue end
        local tool = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(name)
        if tool then return tool end
    end
    return nil
end

local function equipTool(tool)
    if tool then
        ReplicatedStorage.RemoteEvents.EquipItemHandle:FireServer("FireAllClients", tool)
    end
end

local function moveItemToPos(item, position)
    if not item or not item:IsDescendantOf(Workspace) then return end
    local part = item:IsA("Model") and (item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart") or item:FindFirstChild("Handle")) or item
    if not part or not part:IsA("BasePart") then return end
    pcall(function()
        ReplicatedStorage.RemoteEvents.RequestStartDraggingItem:FireServer(item)
        if item:IsA("Model") then
            item:SetPrimaryPartCFrame(CFrame.new(position))
        else
            part.CFrame = CFrame.new(position)
        end
        ReplicatedStorage.RemoteEvents.StopDraggingItem:FireServer(item)
    end)
end

local function getPullTargetPos()
    if PullTarget == "篝火" then
        return Vector3.new(-0.0967, 7.937, -0.178)
    elseif PullTarget == "建造台" then
        return Vector3.new(21.67, 6.34, -4.05)
    else
        local char = LP.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            return char.HumanoidRootPart.Position + Vector3.new(0, 2, 0)
        end
        return Vector3.new(0, 20, 0)
    end
end

local infJumpConnection
local function setInfiniteJump(state)
    InfiniteJumpEnabled = state
    if state then
        if infJumpConnection then infJumpConnection:Disconnect() end
        infJumpConnection = UIS.JumpRequest:Connect(function()
            local char = LP.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    root.Velocity = Vector3.new(root.Velocity.X, 50, root.Velocity.Z)
                end
            end
        end)
    else
        if infJumpConnection then
            infJumpConnection:Disconnect()
            infJumpConnection = nil
        end
    end
end

local function setNightVision(state)
    NightVisionEnabled = state
    if state then
        Lighting.Ambient = Color3.new(1, 1, 1)
        Lighting.ColorShift_Bottom = Color3.new(1, 1, 1)
        Lighting.ColorShift_Top = Color3.new(1, 1, 1)
        Lighting.FogEnd = 100000
        Lighting.FogStart = 100000
        Lighting.Brightness = 1
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        Lighting.ClockTime = 12
    else
        Lighting.Ambient = Color3.new(0, 0, 0)
        Lighting.ColorShift_Bottom = Color3.new(0, 0, 0)
        Lighting.ColorShift_Top = Color3.new(0, 0, 0)
        Lighting.FogEnd = 1000
        Lighting.FogStart = 0
        Lighting.Brightness = 1
        Lighting.GlobalShadows = true
        Lighting.OutdoorAmbient = Color3.new(0.7, 0.7, 0.7)
    end
end

local function loadLuGuan()
    local ToolName = "撸管（r15）"
    local function cleanupOldTool()
        if LP:FindFirstChild("Backpack") then
            local oldTool = LP.Backpack:FindFirstChild(ToolName)
            if oldTool then oldTool:Destroy() end
        end
        if LP.Character then
            local oldTool = LP.Character:FindFirstChild(ToolName)
            if oldTool then oldTool:Destroy() end
        end
        if Workspace:FindFirstChild("animationContainer") then
            Workspace.animationContainer:Destroy()
        end
    end

    local function giveTool()
        cleanupOldTool()
        local character = LP.Character or LP.CharacterAdded:Wait()
        local humanoid = character:WaitForChild("Humanoid")
        local backpack = LP:WaitForChild("Backpack")

        local function getCharacterModel()
            return humanoid.RigType == Enum.HumanoidRigType.R15 and "R15" or "R6"
        end

        local animationObject = Instance.new("Animation")
        animationObject.Name = "animationContainer"
        animationObject.Parent = Workspace

        if getCharacterModel() == "R15" then
            animationObject.AnimationId = "rbxassetid://698251653"
        else
            animationObject.AnimationId = "rbxassetid://72042024"
        end

        local toolObject = Instance.new("Tool")
        toolObject.Name = ToolName
        toolObject.RequiresHandle = false
        toolObject.Parent = backpack

        local isActive = false
        local currentAnimationTrack = nil

        toolObject.Equipped:Connect(function()
            local char = LP.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local animator = hum and (hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator"))
            if not animator then return end

            isActive = true
            while isActive do
                if not currentAnimationTrack then
                    currentAnimationTrack = animator:LoadAnimation(animationObject)
                end
                currentAnimationTrack:Play()
                currentAnimationTrack:AdjustSpeed(0.7)
                currentAnimationTrack.TimePosition = 0.6
                task.wait(0.1)

                while isActive and currentAnimationTrack and currentAnimationTrack.TimePosition < 0.7 do
                    task.wait(0.05)
                end

                if currentAnimationTrack then
                    currentAnimationTrack:Stop()
                    currentAnimationTrack:Destroy()
                    currentAnimationTrack = nil
                end
            end
        end)

        toolObject.Unequipped:Connect(function()
            isActive = false
            if currentAnimationTrack then
                currentAnimationTrack:Stop()
                currentAnimationTrack:Destroy()
                currentAnimationTrack = nil
            end
        end)

        humanoid.Died:Connect(function()
            isActive = false
            if currentAnimationTrack then
                currentAnimationTrack:Stop()
                currentAnimationTrack:Destroy()
                currentAnimationTrack = nil
            end
        end)
    end

    giveTool()
    if _G.AutoToolConnection then _G.AutoToolConnection:Disconnect() end
    _G.AutoToolConnection = LP.CharacterAdded:Connect(function()
        task.wait(0.5)
        giveTool()
    end)
end

local antiAFKConnection
local function setAntiAFK(state)
    AntiAFKEnabled = state
    if state then
        if antiAFKConnection then antiAFKConnection:Disconnect() end
        antiAFKConnection = LP.Idled:Connect(function()
            local vu = game:GetService("VirtualUser")
            vu:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            wait(1)
            vu:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end)
    else
        if antiAFKConnection then
            antiAFKConnection:Disconnect()
            antiAFKConnection = nil
        end
    end
end

RunService.Heartbeat:Connect(function()
    if PlayerState.SpeedEnabled and Humanoid and Humanoid.Parent then
        Humanoid.WalkSpeed = PlayerState.Speed
    end
    if GodMode then
        pcall(function()
            ReplicatedStorage.RemoteEvents.DamagePlayer:FireServer(-math.huge)
        end)
    end
end)

task.spawn(function()
    while true do
        if KillAura.Enabled then
            local char = LP.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local tool = getAnyTool(false)
                if tool then
                    equipTool(tool)
                    for _, target in ipairs(Workspace.Characters:GetChildren()) do
                        if target:IsA("Model") and target:FindFirstChild("HumanoidRootPart") and target:FindFirstChild("HitRegisters") then
                            local dist = (hrp.Position - target.HumanoidRootPart.Position).Magnitude
                            if KillAura.Method == "全图" or dist <= KillAura.Range then
                                pcall(function()
                                    ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(target, tool, true, hrp.CFrame)
                                end)
                            end
                        end
                    end
                end
            end
        end

        if ChopAura.Enabled then
            local char = LP.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local tool = getAnyTool(true)
                if tool then
                    equipTool(tool)
                    local trees = {}
                    local map = Workspace:FindFirstChild("Map")
                    if map then
                        local function addTrees(folder)
                            if folder then
                                for _, obj in ipairs(folder:GetChildren()) do
                                    if obj:IsA("Model") and ({["Small Tree"]=true, ["TreeBig1"]=true, ["TreeBig2"]=true})[obj.Name] and obj.PrimaryPart then
                                        table.insert(trees, obj)
                                    end
                                end
                            end
                        end
                        addTrees(map:FindFirstChild("Foliage"))
                        addTrees(map:FindFirstChild("Landmarks"))
                    end
                    for _, tree in ipairs(trees) do
                        if (tree.PrimaryPart.Position - hrp.Position).Magnitude <= ChopAura.Range then
                            pcall(function()
                                ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(tree, tool, 999, hrp.CFrame)
                            end)
                        end
                    end
                end
            end
        end

        if AutoFeed.Enabled then
            local function getHunger()
                return math.floor(LP.PlayerGui.Interface.StatBars.HungerBar.Bar.Size.X.Scale * 100)
            end
            local function feed(name)
                for _, item in ipairs(Workspace.Items:GetChildren()) do
                    if item.Name == name then
                        ReplicatedStorage.RemoteEvents.RequestConsumeItem:InvokeServer(item)
                        break
                    end
                end
            end
            if getHunger() <= AutoFeed.Threshold then
                for _, food in ipairs(AutoFeed.Foods) do
                    if Workspace.Items:FindFirstChild(food) then
                        feed(food)
                        break
                    end
                end
            end
        end

        if AutoCook.Enabled then
            for _, item in ipairs(Workspace.Items:GetChildren()) do
                if table.find(AutoCook.Items, item.Name) then
                    moveItemToPos(item, Vector3.new(1.4, 25.9, -0.9))
                end
            end
        end

        if AutoCraft.Enabled then
            pcall(function()
                ReplicatedStorage.RemoteEvents.CraftItem:InvokeServer(AutoCraft.ItemName)
            end)
            task.wait(AutoCraft.Interval)
        end

        if PullConfig.Enabled then
            local allItems = {}
            local targetPos = getPullTargetPos()
            local function gather(list)
                for _, en in ipairs(list) do
                    for _, item in ipairs(Workspace.Items:GetChildren()) do
                        if item.Name == en then table.insert(allItems, item) end
                    end
                end
            end
            gather(PullConfig.SelectedFuel)
            gather(PullConfig.SelectedScrap)
            gather(PullConfig.SelectedEquip)
            gather(PullConfig.SelectedFood)
            gather(PullConfig.SelectedMed)

            PullConfig.TotalCount = #allItems
            PullConfig.PulledCount = 0
            local lastReport = 0
            for _, item in ipairs(allItems) do
                if not PullConfig.Enabled then break end
                moveItemToPos(item, targetPos)
                PullConfig.PulledCount = PullConfig.PulledCount + 1
                if PullConfig.PulledCount - lastReport >= 10 then
                    Library:Notify("拉取进度: " .. PullConfig.PulledCount .. "/" .. PullConfig.TotalCount, 2)
                    lastReport = PullConfig.PulledCount
                end
                task.wait(math.max(0.1, PullConfig.Speed))
            end
            if PullConfig.PulledCount > 0 and PullConfig.PulledCount ~= lastReport then
                Library:Notify("拉取完成: " .. PullConfig.PulledCount .. "/" .. PullConfig.TotalCount, 3)
            end
            PullConfig.Enabled = false
            Toggles.PullToggle:SetValue(false)
        end

        if AutoPullRawMeat then
            for _, item in ipairs(Workspace.Items:GetChildren()) do
                if item.Name == "Morsel" or item.Name == "Steak" then
                    moveItemToPos(item, Vector3.new(1.4, 25.9, -0.9))
                end
            end
        end

        if Fishing.Instant then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("FinishFishing")
                if remote then remote:FireServer(true) end
            end)
        end

        if AutoStunDeer then
            pcall(function()
                local remote = ReplicatedStorage:FindFirstChild("RemoteEvents") and ReplicatedStorage.RemoteEvents:FindFirstChild("DeerHitByTorch")
                local deer = Workspace:FindFirstChild("Characters") and Workspace.Characters:FindFirstChild("Deer")
                if remote and deer then remote:InvokeServer(deer) end
            end)
        end

        task.wait(0.1)
    end
end)

