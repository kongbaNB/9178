PullGroup1:AddSlider('PullSpeed', {Text = '拉取间隔(秒)', Default = 0.5, Min = 0.1, Max = 5, Float = 1, Callback = function(v) PullConfig.Speed = v end})
PullGroup1:AddToggle('PullToggle', {Text = '开始拉取', Default = false, Callback = function(v) PullConfig.Enabled = v end})

local PullGroup2 = Tabs.Pull:AddRightGroupbox("选择物品")
PullGroup2:AddDropdown('PullFuel', {Text = '燃烧物', Values = {"木头","煤","油桶","椅子","生物燃料"}, Multi = true, Callback = function(v)
    local en = {}
    for _, cn in ipairs(v) do if ItemCN[cn] then table.insert(en, ItemCN[cn]) end end
    PullConfig.SelectedFuel = en
end})
PullGroup2:AddDropdown('PullScrap', {Text = '废品物', Values = {"螺栓","破风扇","坏微波炉","旧收音机","洗衣机","旧汽车引擎","轮胎","金属板"}, Multi = true, Callback = function(v)
    local en = {}
    for _, cn in ipairs(v) do if ItemCN[cn] then table.insert(en, ItemCN[cn]) end end
    PullConfig.SelectedScrap = en
end})
PullGroup2:AddDropdown('PullEquip', {Text = '装备物', Values = {"左轮手枪","步枪","皮革背心","铁甲","左轮弹药","步枪弹药","巨袋","好的背包","强力斧头","好的斧头"}, Multi = true, Callback = function(v)
    local en = {}
    for _, cn in ipairs(v) do if ItemCN[cn] then table.insert(en, ItemCN[cn]) end end
    PullConfig.SelectedEquip = en
end})
PullGroup2:AddDropdown('PullFood', {Text = '食物', Values = {"苹果","浆果","胡萝卜","蛋糕","辣椒","熟肉块","熟牛排","生肉块","生牛排"}, Multi = true, Callback = function(v)
    local en = {}
    for _, cn in ipairs(v) do if ItemCN[cn] then table.insert(en, ItemCN[cn]) end end
    PullConfig.SelectedFood = en
end})
PullGroup2:AddDropdown('PullMed', {Text = '药品', Values = {"绷带","医疗包"}, Multi = true, Callback = function(v)
    local en = {}
    for _, cn in ipairs(v) do if ItemCN[cn] then table.insert(en, ItemCN[cn]) end end
    PullConfig.SelectedMed = en
end})

local PullStatusLabel = PullGroup1:AddLabel("待命中...")
task.spawn(function()
    while true do
        if PullConfig.Enabled then
            PullStatusLabel:SetText("进度: " .. PullConfig.PulledCount .. " / " .. PullConfig.TotalCount)
        else
            PullStatusLabel:SetText("待命中...")
        end
        task.wait(1)
    end
end)

local PlayerGroup1 = Tabs.Player:AddLeftGroupbox("移动与增强")
PlayerGroup1:AddToggle('SpeedToggle', {Text = '启用速度', Default = false, Callback = function(v) PlayerState.SpeedEnabled = v; if not v and Humanoid then Humanoid.WalkSpeed = 16 end end})
PlayerGroup1:AddSlider('SpeedSlider', {Text = '速度值', Default = 16, Min = 1, Max = 150, Callback = function(v) PlayerState.Speed = v end})
PlayerGroup1:AddToggle('InfiniteJump', {Text = '无限跳', Default = false, Callback = function(v) setInfiniteJump(v) end})
PlayerGroup1:AddButton({Text = '召唤飞行', Func = function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/9178/refs/heads/main/fly.lua"))()
end})
PlayerGroup1:AddToggle('InstantInteractToggle', {Text = '秒互动', Default = false, Callback = function(v) PlayerState.InstantInteract = v end})
PlayerGroup1:AddToggle('AntiAFK', {Text = '反挂机踢出', Default = false, Callback = function(v) setAntiAFK(v) end})

local VisGroup1 = Tabs.Visual:AddLeftGroupbox("透视")
VisGroup1:AddToggle('ESPItemsToggle', {Text = '物品透视', Default = false, Callback = function(v) ESP.ItemsEnabled = v end})
VisGroup1:AddDropdown('ESPItems', {Text = '选择物品', Values = {"木头","螺栓","煤","宝箱","步枪","绷带"}, Multi = true})
VisGroup1:AddToggle('ESPMobsToggle', {Text = '敌人透视', Default = false, Callback = function(v) ESP.MobsEnabled = v end})
VisGroup1:AddDropdown('ESPMobs', {Text = '选择实体', Values = {"狼","熊","邪教徒","兔子"}, Multi = true})

local VisGroup2 = Tabs.Visual:AddRightGroupbox("环境")
VisGroup2:AddToggle('DisableFog', {Text = '关闭雾效', Default = false, Callback = function(v) Environment.DisableFog = v end})
VisGroup2:AddToggle('DisableCampfireEffect', {Text = '关闭篝火夜间效果', Default = false, Callback = function(v) Environment.DisableCampfireEffect = v end})
VisGroup2:AddToggle('Fullbright', {Text = '全亮', Default = false, Callback = function(v) Environment.Fullbright = v end})

local FunGroup = Tabs.Fun:AddLeftGroupbox("种植与图案")
FunGroup:AddDropdown('PlantShape', {Text = '种植形状', Values = {"正方形","圆形","原地"}, Default = "正方形"})
FunGroup:AddInput('PlantSize', {Text = '种植范围', Default = '80'})
FunGroup:AddInput('PlantHeight', {Text = '种植高度', Default = '3'})
FunGroup:AddInput('PlantSpacing', {Text = '树苗间隔', Default = '1'})
FunGroup:AddInput('PlantDelay', {Text = '种植延迟(秒)', Default = '1'})
FunGroup:AddToggle('AutoPlantToggle', {Text = '自动种植', Default = false, Callback = function(v) AutoPlant.Enabled = v end})
FunGroup:AddDropdown('PatternType', {Text = '图案类型', Values = {"球形","项链","流星"}, Default = "球形"})
FunGroup:AddToggle('AutoPatternToggle', {Text = '自动形成图案', Default = false, Callback = function(v) FunPattern.Enabled = v end})

local FunGroup2 = Tabs.Fun:AddRightGroupbox("娱乐与工具")
FunGroup2:AddToggle('NightVision', {Text = '夜视', Default = false, Callback = function(v) setNightVision(v) end})
FunGroup2:AddButton({Text = '撸管', Func = function()
    Library:Notify("正在生成撸管工具...", 2)
    loadLuGuan()
end})

local SettGroup = Tabs.Settings:AddLeftGroupbox("菜单")
SettGroup:AddButton({Text = '卸载脚本', Func = function() Library:Unload() end})
SettGroup:AddLabel('菜单快捷键'):AddKeyPicker('MenuKeybind', {Default = 'RightShift', NoUI = true, Text = 'Menu keybind'})
Library.ToggleKeybind = Options.MenuKeybind

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("99NightsTheme")
    ThemeManager:ApplyToTab(Tabs.Settings)
end

if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("99NightsConfig")
    SaveManager:BuildConfigSection(Tabs.Settings)
end
