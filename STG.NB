local JumpGroup = Tabs.Main:AddLeftGroupbox("二段跳")
JumpGroup:AddToggle('DoubleJump', { Text = '二段跳（不回拉）', Default = false, }):OnChanged(function(value)
    if value then
        DoubleJump = true
        jumpCount = 0
        lastJumpTime = 0
        Library:Notify("二段跳已启用", 2)
    else
        DoubleJump = false
        jumpCount = 0
        Library:Notify("二段跳已关闭", 2)
    end
end)

UserInputService.JumpRequest:Connect(function()
    if not DoubleJump then return end
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end
    local now = tick()
    if hum.FloorMaterial ~= Enum.Material.Air then
        jumpCount = 0
    end
    if jumpCount < 1 then
        jumpCount = jumpCount + 1
        lastJumpTime = now
    elseif jumpCount == 1 and (now - lastJumpTime) < 1.5 then
        jumpCount = jumpCount + 1
        hrp.Velocity = Vector3.new(hrp.Velocity.X, 50, hrp.Velocity.Z)
    end
end)

local SpeedGroup = Tabs.Main:AddLeftGroupbox("修改移速")
SpeedGroup:AddSlider('WalkSpeed', { Text = '移速', Default = 16, Min = 5, Max = 20, Rounding = 0, }):OnChanged(function(value)
    WalkSpeed = value
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = value end
    end
    if speedThread then
        task.cancel(speedThread)
        speedThread = nil
    end
    speedThread = task.spawn(function()
        while true do
            local c = LocalPlayer.Character
            if c then
                local h = c:FindFirstChildOfClass("Humanoid")
                if h and h.WalkSpeed ~= WalkSpeed then
                    h.WalkSpeed = WalkSpeed
                end
            end
            task.wait(0.1)
        end
    end)
    Library:Notify("移速已设置为 " .. value, 2)
end)

