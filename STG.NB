local AutoInteractGroup = Tabs.Auto:AddLeftGroupbox("自动交互")
AutoInteractGroup:AddToggle('AutoInteract', { Text = '自动交互（点购买）', Default = false, }):OnChanged(function(value)
    if value then
        AutoInteract = true
        updateItemCache()
        autoInteractThread = task.spawn(function()
            while AutoInteract do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local target = nil
                local closestDist = math.huge
                if root then
                    local items = getCachedItems()
                    for _, item in ipairs(items) do
                        local dist = (item.Part.Position - root.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            target = item.Part
                        end
                    end
                end
                fireActionable(target)
                task.wait(0.05)
            end
        end)
        Library:Notify("自动交互已启用", 2)
    else
        AutoInteract = false
        if autoInteractThread then
            task.cancel(autoInteractThread)
            autoInteractThread = nil
        end
        Library:Notify("自动交互已关闭", 2)
    end
end)

local BringGroup = Tabs.Auto:AddLeftGroupbox("拉取物品")
BringGroup:AddToggle('BringItems', { Text = '拉取全图物品（疑似没有用）', Default = false, }):OnChanged(function(value)
    if value then
        BringItems = true
        collectedItems = {}
        itemsBrought = 0
        updateItemCache()
        totalItems = #cachedItems
        bringThread = task.spawn(function()
            while BringItems do
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then
                    task.wait(0.1)
                    continue
                end
                local items = getCachedItems()
                local closest = nil
                local closestDist = math.huge
                for _, item in ipairs(items) do
                    if not collectedItems[item.Model] then
                        local dist = (item.Part.Position - root.Position).Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closest = item
                        end
                    end
                end
                if closest then
                    collectedItems[closest.Model] = true
                    itemsBrought = itemsBrought + 1
                    for i = 1, 2 do
                        fireStore(closest.Part)
                        task.wait(0.05)
                    end
                    if itemsBrought % 10 == 0 then
                        Library:Notify(itemsBrought .. "/" .. totalItems, 2)
                    end
                else
                    task.wait(0.5)
                end
                task.wait(BringDelay)
            end
        end)
        Library:Notify("拉取全图物品已启用 发现" .. totalItems .. "个", 2)
    else
        BringItems = false
        if bringThread then
            task.cancel(bringThread)
            bringThread = nil
        end
        Library:Notify("拉取全图物品已关闭", 2)
    end
end)
BringGroup:AddSlider('BringDelay', { Text = '拉取速度', Default = 0.1, Min = 0.01, Max = 2, Rounding = 2, }):OnChanged(function(value)
    BringDelay = value
end)

