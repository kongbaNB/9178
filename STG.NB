local MiscGroup = Tabs.Misc:AddLeftGroupbox("环境清理")
MiscGroup:AddToggle('DeleteDecor', { Text = '删除杂物', Default = false, }):OnChanged(function(state)
    DeleteDecor = state
    if state then
        deleteDecorThread = task.spawn(function()
            while DeleteDecor do
                local decor = workspace:FindFirstChild("Decor")
                if decor then
                    for _, v in ipairs(decor:GetChildren()) do
                        pcall(function() v:Destroy() end)
                    end
                end
                task.wait(1)
            end
        end)
        Library:Notify("删除杂物已启用", 2)
    else
        DeleteDecor = false
        if deleteDecorThread then
            task.cancel(deleteDecorThread)
            deleteDecorThread = nil
        end
        Library:Notify("删除杂物已关闭", 2)
    end
end)

MiscGroup:AddToggle('DeleteLightning', { Text = '删除闪电', Default = false, }):OnChanged(function(state)
    DeleteLightning = state
    if state then
        deleteLightningThread = task.spawn(function()
            while DeleteLightning do
                for _, v in ipairs(workspace:GetChildren()) do
                    if v.Name == "LightningModel" then
                        pcall(function() v:Destroy() end)
                    end
                end
                task.wait(1)
            end
        end)
        Library:Notify("删除闪电已启用", 2)
    else
        DeleteLightning = false
        if deleteLightningThread then
            task.cancel(deleteLightningThread)
            deleteLightningThread = nil
        end
        Library:Notify("删除闪电已关闭", 2)
    end
end)

local InteractGroup = Tabs.Misc:AddLeftGroupbox("交互修改")
InteractGroup:AddToggle('InstantInteract', { Text = '秒交互', Default = false, }):OnChanged(function(state)
    InstantInteract = state
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            if state then
                oldDurations[v] = v.HoldDuration
                v.HoldDuration = 0
            else
                v.HoldDuration = oldDurations[v] or v.HoldDuration
            end
        end
    end
    if state then
        Library:Notify("秒交互已启用", 2)
    else
        Library:Notify("秒交互已关闭", 2)
    end
end)

InteractGroup:AddToggle('LongInteract', { Text = '远程交互', Default = false, }):OnChanged(function(state)
    LongInteract = state
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            if state then
                oldDistances[v] = v.MaxActivationDistance
                v.MaxActivationDistance = math.huge
            else
                v.MaxActivationDistance = oldDistances[v] or v.MaxActivationDistance
            end
        end
    end
    if state then
        Library:Notify("远程交互已启用", 2)
    else
        Library:Notify("远程交互已关闭", 2)
    end
end)

InteractGroup:AddToggle('NoLOSInteract', { Text = '无视野互动', Default = false, }):OnChanged(function(state)
    NoLOSInteract = state
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            v.RequiresLineOfSight = not state
        end
    end
    if state then
        Library:Notify("无视野互动已启用", 2)
    else
        Library:Notify("无视野互动已关闭", 2)
    end
end)

local NotifyGroup = Tabs.Misc:AddRightGroupbox("状态通知")
NotifyGroup:AddToggle('MonsterNotify', { Text = '预知今晚怪物', Default = false, }):OnChanged(function(state)
    MonsterNotify = state
    if state then
        if not monsterGui then createMonsterGui() end
        monsterNotified = false
        monsterGui.Enabled = false
        local nightEnemies = workspace:FindFirstChild("NightEnemies")
        if nightEnemies then
            for _, v in ipairs(nightEnemies:GetChildren()) do
                if v:IsA("Model") and not monsterNotified then
                    monsterNotified = true
                    local name = v.Name
                    if name == "Wolf" then name = "狼"
                    elseif name == "Werewolf" then name = "狼人"
                    elseif name == "Vampire" then name = "吸血鬼"
                    elseif name == "Walker" then name = "正常僵尸"
                    elseif name == "Runner" then name = "奔跑僵尸"
                    end
                    monsterLabel.Text = "今晚的怪物: " .. name
                    monsterGui.Enabled = true
                    task.delay(15, function()
                        if MonsterNotify then monsterGui.Enabled = false end
                    end)
                    break
                end
            end
        end
        monsterAddedConn = workspace.ChildAdded:Connect(function(child)
            if child.Name == "NightEnemies" and MonsterNotify then
                task.wait(0.5)
                for _, v in ipairs(child:GetChildren()) do
                    if v:IsA("Model") and not monsterNotified then
                        monsterNotified = true
                        local name = v.Name
                        if name == "Wolf" then name = "狼"
                        elseif name == "Werewolf" then name = "狼人"
                        elseif name == "Vampire" then name = "吸血鬼"
                        elseif name == "Walker" then name = "正常僵尸"
                        elseif name == "Runner" then name = "奔跑僵尸"
                        end
                        monsterLabel.Text = "今晚的怪物: " .. name
                        monsterGui.Enabled = true
                        task.delay(15, function()
                            if MonsterNotify then monsterGui.Enabled = false end
                        end)
                        break
                    end
                end
            end
        end)
        local existing = workspace:FindFirstChild("NightEnemies")
        if existing then
            monsterAddedConn2 = existing.ChildAdded:Connect(function(v)
                if v:IsA("Model") and not monsterNotified and MonsterNotify then
                    monsterNotified = true
                    local name = v.Name
                    if name == "Wolf" then name = "狼"
                    elseif name == "Werewolf" then name = "狼人"
                    elseif name == "Vampire" then name = "吸血鬼"
                    elseif name == "Walker" then name = "正常僵尸"
                    elseif name == "Runner" then name = "奔跑僵尸"
                    end
                    monsterLabel.Text = "今晚的怪物: " .. name
                    monsterGui.Enabled = true
                    task.delay(15, function()
                        if MonsterNotify then monsterGui.Enabled = false end
                    end)
                end
            end)
        end
        Library:Notify("预知今晚怪物已启用", 2)
    else
        MonsterNotify = false
        if monsterAddedConn then monsterAddedConn:Disconnect() end
        if monsterAddedConn2 then monsterAddedConn2:Disconnect() end
        if monsterGui then monsterGui.Enabled = false end
        monsterNotified = false
        Library:Notify("预知今晚怪物已关闭", 2)
    end
end)

NotifyGroup:AddToggle('FuelNotify', { Text = '显示火车燃料状态', Default = false, }):OnChanged(function(state)
    FuelNotify = state
    if state then
        if not fuelGui then createFuelGui() end
        fuelGui.Enabled = true
        fuelNotifyThread = task.spawn(function()
            while FuelNotify do
                local success, fuelValue = pcall(function()
                    local train = workspace:FindFirstChild("Train")
                    if train then
                        local fuel = train:FindFirstChild("Fuel")
                        if fuel then return fuel.Value end
                    end
                    return nil
                end)
                if success and fuelValue then
                    fuelLabel.Text = "燃料: " .. fuelValue .. " / 240"
                    if fuelValue <= 50 then
                        fuelLabel.TextColor3 = Color3.new(1, 0, 0)
                    elseif fuelValue <= 150 then
                        fuelLabel.TextColor3 = Color3.fromRGB(255, 165, 0)
                    else
                        fuelLabel.TextColor3 = Color3.new(0, 1, 0)
                    end
                end
                task.wait(0.5)
            end
        end)
        Library:Notify("火车燃料状态已启用", 2)
    else
        FuelNotify = false
        if fuelNotifyThread then
            task.cancel(fuelNotifyThread)
            fuelNotifyThread = nil
        end
        if fuelGui then fuelGui.Enabled = false end
        Library:Notify("火车燃料状态已关闭", 2)
    end
end)

local UnloadGroup = Tabs.Settings:AddLeftGroupbox("脚本管理")
UnloadGroup:AddButton("卸载脚本", function()
    if itemsConnection then itemsConnection:Disconnect() end
    if oreConnection then oreConnection:Disconnect() end
    if enemyConnection then enemyConnection:Disconnect() end
    if unicornConnection then unicornConnection:Disconnect() end
    if buildConnection then buildConnection:Disconnect() end
    if zombieConnection then zombieConnection:Disconnect() end
    if bankConnection then bankConnection:Disconnect() end
    if outlawConnection then outlawConnection:Disconnect() end
    if bondConnection then bondConnection:Disconnect() end
    if monsterAddedConn then monsterAddedConn:Disconnect() end
    if monsterAddedConn2 then monsterAddedConn2:Disconnect() end
    if monsterGui then monsterGui:Destroy() end
    if fuelGui then fuelGui:Destroy() end
    Library:Unload()
end)

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("DeadRailTheme")
    ThemeManager:ApplyToTab(Tabs.Settings)
end

if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("DeadRailConfig")
    SaveManager:BuildConfigSection(Tabs.Settings)
end
