                if v:IsA("Model") and v.Name == "Bond" then createESP(v, "债券", Color3.fromRGB(255, 215, 0)) end
            end
        end
        bondConnection = runtimeItems and runtimeItems.ChildAdded:Connect(function(v)
            if v:IsA("Model") and v.Name == "Bond" and BondESP then createESP(v, "债券", Color3.fromRGB(255, 215, 0)) end
        end)
    else
        if bondConnection then bondConnection:Disconnect() end
        local runtimeItems = workspace:FindFirstChild("RuntimeItems")
        if runtimeItems then
            for _, v in ipairs(runtimeItems:GetChildren()) do
                if v.Name == "Bond" then removeESP(v) end
            end
        end
    end
end)

