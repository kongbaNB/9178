ESPEnemyGroup:AddToggle('ZombieESP', { Text = '房子中的怪物透视', Default = false, }):OnChanged(function(state)
    ZombieESP = state
    if state then
        local buildings = workspace:FindFirstChild("RandomBuildings")
        if buildings then
            for _, building in ipairs(buildings:GetChildren()) do
                if building:FindFirstChild("StandaloneZombiePart") then
                    local zombies = building.StandaloneZombiePart:FindFirstChild("Zombies")
                    if zombies then
                        for _, zombie in ipairs(zombies:GetChildren()) do
                            if zombie:IsA("Model") then createESP(zombie, zombie.Name, Color3.fromRGB(0, 255, 0)) end
                        end
                    end
                end
            end
        end
        zombieConnection = buildings and buildings.ChildAdded:Connect(function(building)
            if building:FindFirstChild("StandaloneZombiePart") and ZombieESP then
                local zombies = building.StandaloneZombiePart:FindFirstChild("Zombies")
                if zombies then
                    for _, zombie in ipairs(zombies:GetChildren()) do
                        if zombie:IsA("Model") then createESP(zombie, zombie.Name, Color3.fromRGB(0, 255, 0)) end
                    end
                end
            end
        end)
    else
        if zombieConnection then zombieConnection:Disconnect() end
        local buildings = workspace:FindFirstChild("RandomBuildings")
        if buildings then
            for _, building in ipairs(buildings:GetChildren()) do
                if building:FindFirstChild("StandaloneZombiePart") then
                    local zombies = building.StandaloneZombiePart:FindFirstChild("Zombies")
                    if zombies then
                        for _, zombie in ipairs(zombies:GetChildren()) do removeESP(zombie) end
                    end
                end
            end
        end
    end
end)

