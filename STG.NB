AutoCollectGroup:AddToggle('AutoBond', { Text = '自动收集债券', Default = false, }):OnChanged(function(value)
    if value then
        AutoBond = true
        autoBondThread = task.spawn(function()
            while AutoBond do
                local runtimeItems = workspace:FindFirstChild("RuntimeItems")
                if runtimeItems then
                    for _, v in ipairs(runtimeItems:GetChildren()) do
                        if v.Name == "Bond" then
                            local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                            if root and v:IsA("BasePart") then
                                local distance = (root.Position - v.Position).Magnitude
                                if distance < 10 then
                                    pcall(function()
                                        ReplicatedStorage.Packages.ActivateObjectClient:FireServer(v)
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
        Library:Notify("自动收集债券已启用", 2)
    else
        AutoBond = false
        if autoBondThread then
            task.cancel(autoBondThread)
            autoBondThread = nil
        end
        Library:Notify("自动收集债券已关闭", 2)
    end
end)

AutoCollectGroup:AddToggle('AutoPickup', { Text = '自动收集物品', Default = false, }):OnChanged(function(value)
    if value then
        AutoPickup = true
        autoPickupThread = task.spawn(function()
            while AutoPickup do
                local runtimeItems = workspace:FindFirstChild("RuntimeItems")
                if runtimeItems then
                    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if root then
                        for _, v in ipairs(runtimeItems:GetChildren()) do
                            if v:IsA("BasePart") then
                                local distance = (root.Position - v.Position).Magnitude
                                if distance < 10 then
                                    pcall(function()
                                        ReplicatedStorage.Remotes.Tool.PickUpTool:FireServer(v)
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
        Library:Notify("自动收集物品已启用", 2)
    else
        AutoPickup = false
        if autoPickupThread then
            task.cancel(autoPickupThread)
            autoPickupThread = nil
        end
        Library:Notify("自动收集物品已关闭", 2)
    end
end)

AutoCollectGroup:AddToggle('AutoWalkBond', { Text = '自动走向债券', Default = false, }):OnChanged(function(value)
    if value then
        AutoWalkBond = true
        autoWalkBondThread = task.spawn(function()
            while AutoWalkBond do
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum then
                    local runtimeItems = workspace:FindFirstChild("RuntimeItems")
                    if runtimeItems then
                        for _, item in ipairs(runtimeItems:GetChildren()) do
                            if item.Name == "Bond" and item:IsA("Model") then
                                local part = getItemPart(item)
                                if part then
                                    hum.WalkToPoint = part.Position
                                    break
                                end
                            end
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
        Library:Notify("自动走向债券已启用", 2)
    else
        AutoWalkBond = false
        if autoWalkBondThread then
            task.cancel(autoWalkBondThread)
            autoWalkBondThread = nil
        end
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and root then
            hum.WalkToPoint = root.Position
        end
        Library:Notify("自动走向债券已关闭", 2)
    end
end)

local AutoTrainGroup = Tabs.Auto:AddRightGroupbox("火车功能")
AutoTrainGroup:AddToggle('AutoTrainHorn', { Text = '自动火车鸣声', Default = false, }):OnChanged(function(value)
    if value then
        AutoTrainHorn = true
        autoTrainHornThread = task.spawn(function()
            while AutoTrainHorn do
                pcall(function()
                    local train = workspace:FindFirstChild("Train")
                    if train then
                        local lever = train:FindFirstChild("TrainControls") and train.TrainControls:FindFirstChild("Lever")
                        if lever then
                            local hitbox = lever:FindFirstChild("HitBox")
                            if hitbox then
                                local detector = hitbox:FindFirstChild("ClickDetector")
                                if detector then
                                    detector.MaxActivationDistance = math.huge
                                    fireclickdetector(detector)
                                end
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
        Library:Notify("自动火车鸣声已启用", 2)
    else
        AutoTrainHorn = false
        if autoTrainHornThread then
            task.cancel(autoTrainHornThread)
            autoTrainHornThread = nil
        end
        Library:Notify("自动火车鸣声已关闭", 2)
    end
end)

AutoTrainGroup:AddToggle('AutoEndSwitch', { Text = '自动拉终点开关', Default = false, }):OnChanged(function(value)
    if value then
        AutoEndSwitch = true
        autoEndSwitchThread = task.spawn(function()
            while AutoEndSwitch do
                pcall(function()
                    local baseplates = workspace:FindFirstChild("Baseplates")
                    if baseplates then
                        local final = baseplates:FindFirstChild("FinalBasePlate")
                        if final then
                            local outlaw = final:FindFirstChild("OutlawBase")
                            if outlaw then
                                local bridge = outlaw:FindFirstChild("Bridge")
                                if bridge then
                                    local control = bridge:FindFirstChild("BridgeControl")
                                    if control then
                                        local crank = control:FindFirstChild("Crank")
                                        if crank then
                                            local model = crank:FindFirstChild("Model")
                                            if model then
                                                local mid = model:FindFirstChild("Mid")
                                                if mid then
                                                    local prompt = mid:FindFirstChild("EndGame")
                                                    if prompt and prompt:IsA("ProximityPrompt") then
                                                        prompt.MaxActivationDistance = math.huge
                                                        fireproximityprompt(prompt)
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
        Library:Notify("自动拉终点开关已启用", 2)
    else
        AutoEndSwitch = false
        if autoEndSwitchThread then
            task.cancel(autoEndSwitchThread)
            autoEndSwitchThread = nil
        end
        Library:Notify("自动拉终点开关已关闭", 2)
    end
end)

local AutoBandageGroup = Tabs.Auto:AddLeftGroupbox("自动绷带")
AutoBandageGroup:AddSlider('MinHealth', { Text = '使用绷带血量', Default = 30, Min = 1, Max = 100, Rounding = 0, }):OnChanged(function(value)
    MinHealth = value
end)
AutoBandageGroup:AddToggle('AutoBandage', { Text = '自动使用绷带', Default = false, }):OnChanged(function(value)
    if value then
        AutoBandage = true
        autoBandageThread = task.spawn(function()
            while AutoBandage do
                local char = LocalPlayer.Character
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health <= MinHealth then
                    for _, v in ipairs(LocalPlayer.Backpack:GetChildren()) do
                        if v.Name == "Bandage" then
                            pcall(function()
                                v.Parent = char
                                local bandage = char:FindFirstChild("Bandage")
                                if bandage then
                                    local use = bandage:FindFirstChild("Use")
                                    if use then
                                        use:FireServer()
                                    end
                                end
                            end)
                            break
                        end
                    end
                end
                task.wait(0.5)
            end
        end)
        Library:Notify("自动使用绷带已启用", 2)
    else
        AutoBandage = false
        if autoBandageThread then
            task.cancel(autoBandageThread)
            autoBandageThread = nil
        end
        Library:Notify("自动使用绷带已关闭", 2)
    end
end)

local ESPItemGroup = Tabs.ESP:AddLeftGroupbox("物品透视")
ESPItemGroup:AddToggle('ItemESP', { Text = '透视物品', Default = false, }):OnChanged(function(state)
    ItemESP = state
    if state then
        local runtimeItems = workspace:FindFirstChild("RuntimeItems")
        if runtimeItems then
            for _, v in ipairs(runtimeItems:GetChildren()) do
                if v:IsA("Model") then createESP(v, v.Name, Color3.fromRGB(255, 215, 0)) end
            end
        end
        itemsConnection = runtimeItems and runtimeItems.ChildAdded:Connect(function(v)
            if v:IsA("Model") and ItemESP then createESP(v, v.Name, Color3.fromRGB(255, 215, 0)) end
        end)
    else
        if itemsConnection then itemsConnection:Disconnect() end
        local runtimeItems = workspace:FindFirstChild("RuntimeItems")
        if runtimeItems then
            for _, v in ipairs(runtimeItems:GetChildren()) do removeESP(v) end
        end
    end
end)

ESPItemGroup:AddToggle('BondESP', { Text = '透视债券', Default = false, }):OnChanged(function(state)
    BondESP = state
