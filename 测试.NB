LockLeft:AddToggle("FollowBack", { Text = "锁背", Default = false, Callback = function(state)
    LockS.followEnabled = state
    if state then LockS.circleEnabled = false end
    LockS.toggleConnection()
end })

LockLeft:AddToggle("Circle", { Text = "转圈", Default = false, Callback = function(state)
    LockS.circleEnabled = state
    if state then LockS.followEnabled = false end
    LockS.toggleConnection()
end })

LockLeft:AddToggle("LookAt", { Text = "看着玩家", Default = false, Callback = function(state)
    LockS.lookEnabled = state
    LockS.toggleConnection()
end })

function LockS.getRoot(pl)
    if pl and pl.Character then return pl.Character:FindFirstChild("HumanoidRootPart") end
end

function LockS.getPlayerByName(name)
    for _, p in pairs(Players:GetPlayers()) do if p.Name == name then return p end end
end

function LockS.updateLoop(dt)
    if not LockS.selectedTargetName then return end
    local target = LockS.getPlayerByName(LockS.selectedTargetName)
    local targetRoot = LockS.getRoot(target)
    local myRoot = LockS.getRoot(player)
    if not targetRoot or not myRoot then return end
    local targetPos = targetRoot.Position
    local finalPos = nil
    if LockS.circleEnabled then
        LockS.circleAngle += (LockS.CIRCLE_SPEED * dt)
        local x = math.cos(LockS.circleAngle) * LockS.CIRCLE_RADIUS
        local z = math.sin(LockS.circleAngle) * LockS.CIRCLE_RADIUS
        finalPos = targetPos + Vector3.new(x, 0, z)
    elseif LockS.followEnabled then
        local offset = targetRoot.CFrame.LookVector * LockS.BEHIND_DISTANCE
        finalPos = targetPos - offset
    end
    if finalPos then
        if LockS.lookEnabled then
            myRoot.CFrame = CFrame.new(finalPos, Vector3.new(targetPos.X, finalPos.Y, targetPos.Z))
        else
            myRoot.CFrame = CFrame.new(finalPos) * myRoot.CFrame.Rotation
        end
    elseif LockS.lookEnabled then
        local myPos = myRoot.Position
        myRoot.CFrame = CFrame.new(myPos, Vector3.new(targetPos.X, myPos.Y, targetPos.Z))
    end
end

function LockS.toggleConnection()
    if LockS.followEnabled or LockS.circleEnabled or LockS.lookEnabled then
        if not LockS.mainConnection then LockS.mainConnection = RunService.RenderStepped:Connect(LockS.updateLoop) end
    else
        if LockS.mainConnection then LockS.mainConnection:Disconnect() LockS.mainConnection = nil end
    end
end

EmoteLeft:AddButton({ Text = "刷新击杀表情", Func = function()
    table.clear(T.state.killEmotes)
    for _, e in pairs(rs:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
