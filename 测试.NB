TabMain:Section({Title = "杀戮光环"})
TabMain:Dropdown({
    Title = "攻击方式", Values = {"范围","全图"}, Value = "范围",
    Callback = function(v) Features.KillAuraMethod = v end
})
TabMain:Toggle({
    Title = "杀戮光环", Value = false,
    Callback = function(v)
        Features.KillAura = v
        if v then
            task.spawn(function()
                while Features.KillAura do
                    local hrp = getHRP()
                    if hrp then
                        local tool = getAnyTool(false)
                        if tool then
                            equipTool(tool)
                            for _, enemy in ipairs(Workspace.Characters:GetChildren()) do
                                if enemy:IsA("Model") and enemy:FindFirstChild("HumanoidRootPart") and enemy:FindFirstChild("HitRegisters") and enemy~=LP.Character then
                                    local should = false
                                    if Features.KillAuraMethod=="范围" then
                                        if (hrp.Position-enemy.HumanoidRootPart.Position).Magnitude <= Features.KillAuraRange then should = true end
                                    else should = true end
                                    if should then
                                        pcall(function()
                                            ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(enemy, tool, true, hrp.CFrame)
                                        end)
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0)
                end
                local t = getAnyTool(false); unequipTool(t)
            end)
        end
    end
})
TabMain:Slider({
    Title = "攻击范围", Value = {Min = 10, Max = 200, Default = 35},
    Callback = function(v) Features.KillAuraRange = v end
})

TabMain:Button({
    Title = "显示当前武器",
    Callback = function()
        local tool = getAnyTool(false)
        WindUI:Notify({Title = "武器", Content = "当前: "..(tool and tool.Name or "无"), Duration = 3})
    end
})

TabMain:Section({Title = "树木"})
TabMain:Input({
    Title = "砍树范围", Value = "500",
    Callback = function(v)
        local n = tonumber(v)
        if n then Features.ChopRange = n else WindUI:Notify({Title="错误",Content="请输入数字",Duration=2}) end
    end
})
TabMain:Toggle({
    Title = "自动砍树", Value = false,
    Callback = function(v)
        Features.ChopAura = v
        if v then
            task.spawn(function()
                while Features.ChopAura do
                    local hrp = getHRP()
                    if hrp then
                        local tool = getAnyTool(true)
                        if tool then
                            equipTool(tool)
                            local function chop(folder)
                                if not folder then return end
                                for _, tree in ipairs(folder:GetChildren()) do
                                    if tree:IsA("Model") and (tree.Name=="Small Tree" or tree.Name=="TreeBig1" or tree.Name=="TreeBig2") and tree.PrimaryPart then
                                        if (tree.PrimaryPart.Position-hrp.Position).Magnitude <= Features.ChopRange then
                                            pcall(function()
                                                ReplicatedStorage.RemoteEvents.ToolDamageObject:InvokeServer(tree, tool, 999, hrp.CFrame)
                                            end)
                                        end
                                    end
                                end
                            end
                            local map = Workspace:FindFirstChild("Map")
                            if map then chop(map:FindFirstChild("Foliage")); chop(map:FindFirstChild("Landmarks")) end
                        end
                    end
                    task.wait(0.1)
                end
                local t = getAnyTool(true); unequipTool(t)
            end)
        end
    end
})

TabMain:Section({Title = "小孩"})
TabMain:Toggle({
    Title = "自动救所有小孩", Value = false,
    Callback = function(v)
        Features.AutoSaveChild = v
        if v then
            task.spawn(function()
                while Features.AutoSaveChild do
                    local hrp = getHRP()
                    if hrp then
                        for _, child in ipairs(Workspace:GetDescendants()) do
                            if not Features.AutoSaveChild then break end
                            if child:IsA("Model") and (child.Name:match("^Lost Child") or child.Name:match("Dino Kid") or child.Name:match("kraken") or child.Name:match("Squid") or child.Name:match("Koala")) then
                                local part = child:FindFirstChild("HumanoidRootPart") or child.PrimaryPart
                                if part then
                                    hrp.CFrame = part.CFrame + Vector3.new(0,5,0)
                                    task.wait(2)
                                end
                            end
                        end
                    end
                    task.wait(1)
                end
            end)
        end
    end
})

-- ==================== 自动装备 ====================
TabEquip:Section({Title = "自动装备武器"})
TabEquip:Toggle({
    Title = "自动装备最佳武器", Value = false,
    Callback = function(v)
        Features.AutoEquipBest = v
        if v then
            task.spawn(function()
                while Features.AutoEquipBest do
                    local c = LP.Character
                    if c then
                        local best, bestDmg = nil, 0
                        for name, id in pairs(ToolsDamageIDs) do
                            local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(name)
                            if t then
                                local dmg = tonumber(id:match("^(%d+)_")) or 0
                                if dmg > bestDmg then bestDmg = dmg; best = t end
                            end
                        end
                        if best then equipTool(best) end
                    end
                    task.wait(0.5)
                end
                local t = getAnyTool(false); unequipTool(t)
            end)
        end
    end
})

TabEquip:Dropdown({
    Title = "选择要装备的武器", Values = {"Old Axe","Good Axe","Strong Axe","Chainsaw","Infernal Sword","Spear"}, Value = "Strong Axe",
    Callback = function(v) Features.SelectedWeapon = v end
})
TabEquip:Toggle({
    Title = "自动装备选定武器", Value = false,
    Callback = function(v)
        Features.AutoEquipSelected = v
        if v then
            task.spawn(function()
                while Features.AutoEquipSelected do
                    local c = LP.Character
                    if c then
                        local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(Features.SelectedWeapon)
                        if t then equipTool(t) else
                            WindUI:Notify({Title="武器未找到",Content=Features.SelectedWeapon.." 不在背包",Duration=3})
                            Features.AutoEquipSelected = false
                            break
                        end
                    end
                    task.wait(0.5)
                end
                local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(Features.SelectedWeapon)
                unequipTool(t)
            end)
        end
    end
})

TabEquip:Section({Title = "工具切换"})
TabEquip:Toggle({
    Title = "随机工具切换", Value = false,
    Callback = function(v)
        Features.AutoToolSwitch = v
        if v then
            task.spawn(function()
                while Features.AutoToolSwitch do
                    local hrp = getHRP()
                    if not hrp then task.wait(1); continue end
                    local hasEnemy = false
                    for _, mob in ipairs(Workspace.Characters:GetChildren()) do
                        if mob:IsA("Model") then
                            local p = mob:FindFirstChildWhichIsA("BasePart")
                            if p and (p.Position-hrp.Position).Magnitude <= 50 then hasEnemy = true; break end
                        end
                    end
                    local hasTree = false
                    local map = Workspace:FindFirstChild("Map")
                    if map then
                        for _, folder in ipairs({map:FindFirstChild("Foliage"), map:FindFirstChild("Landmarks")}) do
                            if folder then
                                for _, obj in ipairs(folder:GetChildren()) do
                                    if obj:IsA("Model") and obj.Name:match("Tree") then
                                        local trunk = obj:FindFirstChild("Trunk")
                                        if trunk and (trunk.Position-hrp.Position).Magnitude <= 50 then hasTree = true; break end
                                    end
                                end
                            end
                        end
                    end
                    if hasEnemy then
                        for _, n in ipairs({"Infernal Sword","Spear","Chainsaw","Strong Axe","Good Axe"}) do
                            local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(n)
                            if t then equipTool(t); break end
                        end
                    elseif hasTree then
                        for _, n in ipairs({"Chainsaw","Strong Axe","Good Axe","Old Axe"}) do
                            local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(n)
                            if t then equipTool(t); break end
                        end
                    else
                        local best, bestDmg = nil, 0
                        for name, id in pairs(ToolsDamageIDs) do
                            local t = LP:FindFirstChild("Inventory") and LP.Inventory:FindFirstChild(name)
                            if t then
                                local dmg = tonumber(id:match("^(%d+)_")) or 0
                                if dmg > bestDmg then bestDmg = dmg; best = t end
                            end
                        end
                        if best then equipTool(best) end
                    end
                    task.wait(1)
                end
                local t = getAnyTool(false); unequipTool(t)
            end)
        end
    end
})

