local tpConn = nil
sAddTog(MainRight, 'OnePunchFlyToggle', { Text = '一拳击飞', Default = false, Callback = function(state)
    if state then
        if RagdollPower then RagdollPower.Value = 10000 end
        local char = player.Character or player.CharacterAdded:Wait()
        local hrp = char:WaitForChild("HumanoidRootPart")
        local lastPos = hrp.Position
        tpConn = RunService.RenderStepped:Connect(function()
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
                char = player.Character or player.CharacterAdded:Wait()
                hrp = char:WaitForChild("HumanoidRootPart")
                lastPos = hrp.Position
            end
            local cur = player.Character.HumanoidRootPart.Position
            if (cur - lastPos).Magnitude > 50 then
                player.Character.HumanoidRootPart.CFrame = CFrame.new(lastPos)
            else
                lastPos = cur
            end
        end)
    else
        if RagdollPower then RagdollPower.Value = 100 end
        if tpConn then tpConn:Disconnect(); tpConn = nil end
    end
end })

