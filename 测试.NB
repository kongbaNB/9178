MainMiscGroup:AddToggle("16", {
    Text = "一拳击飞",
    Default = false,
    Callback = function(state)
        local RagdollPower = ReplicatedStorage.Settings.Multipliers.RagdollPower
        local maxTeleportDistance = 50
        local lastPosition = rootPart.Position
        local connection
        if state then
            RagdollPower.Value = 10000
            connection = RunService.RenderStepped:Connect(function()
                local char = player.Character
                if not char or not char:FindFirstChild("HumanoidRootPart") then return end
                local hrp = char.HumanoidRootPart
                local currentPos = hrp.Position
                if (currentPos - lastPosition).Magnitude > maxTeleportDistance then
                    hrp.CFrame = CFrame.new(lastPosition)
                else
                    lastPosition = currentPos
                end
            end)
        else
            RagdollPower.Value = 100
            if connection then connection:Disconnect() end
        end
    end
})

