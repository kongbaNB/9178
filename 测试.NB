Functions.BestTarget = function(MaxDistance)
    MaxDistance = MaxDistance or math.huge
    local Target = nil
    local MinKills = math.huge
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local rootPart = v.Character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local distance = (player.Character.HumanoidRootPart.Position - rootPart.Position).Magnitude
                local kills = v:GetAttribute("Kills") or 0
                if distance < MaxDistance and kills < MinKills then
                    Target = v
                    MaxDistance = distance
                    MinKills = kills
                end
            end
        end
    end
    return Target
end

Functions.UseAbility = function(Ability)
    if not player.Character then return end
    local Tool = player.Backpack:FindFirstChild(Ability)
    if Tool then
        player.Character.Communicate:FireServer({ Tool = Tool, Goal = "Console Move", ToolName = tostring(Ability) })
    end
end

Functions.RandomAbility = function()
    if not player.PlayerGui:FindFirstChild("Hotbar") then return nil end
    local Hotbar = player.PlayerGui.Hotbar.Backpack.Hotbar
    local Abilities = {}
    for _, v in pairs(Hotbar:GetChildren()) do
        if v.ClassName ~= "UIListLayout" and v.Visible and v.Base.ToolName.Text ~= "N/A" and not v.Base:FindFirstChild("Cooldown") then
            table.insert(Abilities, v)
        end
    end
    if #Abilities > 0 then
        local RandomAbility = Abilities[math.random(1, #Abilities)]
        return RandomAbility.Base.ToolName.Text
    else
        return nil
    end
end

Functions.ActivateUltimate = function()
    local UltimateBar = player:GetAttribute("Ultimate") or 0
    if UltimateBar >= 100 then
        player.Character.Communicate:FireServer({ MoveDirection = Vector3.new(0, 0, 0), Key = Enum.KeyCode.G, Goal = "KeyPress" })
    end
end

Functions.TeleportUnderPlayer = function(targetPlayer)
    if not targetPlayer.Character then return end
    local rootPart = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if rootPart and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local targetCFrame = rootPart.CFrame * CFrame.new(0, -5, 0)
        player.Character:SetPrimaryPartCFrame(targetCFrame)
    end
end

AimLeft:AddToggle("AntiAfk", { Text = "反挂机", Default = true, Callback = function(state)
    getgenvAntiAfk = state
    if state then
        if antiAfkThread then task.cancel(antiAfkThread) antiAfkThread = nil end
        antiAfkThread = task.spawn(function()
            while getgenvAntiAfk do
                pcall(function()
                    VirtualUser:Button2Down(Vector2.new(0,0), Workspace.CurrentCamera.CFrame)
                    task.wait(1)
                    VirtualUser:Button2Up(Vector2.new(0,0), Workspace.CurrentCamera.CFrame)
                    task.wait(10)
                end)
            end
        end)
    else
        if antiAfkThread then task.cancel(antiAfkThread) antiAfkThread = nil end
    end
end })

AimLeft:AddToggle("AutoAim", { Text = "自动瞄准", Default = false, Callback = function(state)
    getgenvAutoAim = state
    if state then
        if autoAimConnection then autoAimConnection:Disconnect() autoAimConnection = nil end
        autoAimConnection = RunService.RenderStepped:Connect(function()
            if not getgenvAutoAim then return end
            local camera = Camera
            if not camera then return end
            local fovRadius = getgenvAimbotFOV / 2
            local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
            local closestEnemy = nil
            local targetPos = nil
            local closestScreenDist = fovRadius
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= player and plr.Character then
                    local targetPart = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Torso")
                    if targetPart then
                        local distance = (targetPart.Position - hrp.Position).Magnitude
                        if distance <= getgenvAimbotDistance then
                            local targetPos2D, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                            if onScreen and targetPos2D.Z > 0 then
                                local screenPos = Vector2.new(targetPos2D.X, targetPos2D.Y)
                                local distFromCenter = (screenCenter - screenPos).Magnitude
                                if distFromCenter <= fovRadius and distFromCenter < closestScreenDist then
                                    closestScreenDist = distFromCenter
                                    closestEnemy = plr
                                    targetPos = targetPart.Position
                                end
                            end
                        end
                    end
                end
            end
            if closestEnemy and targetPos then
                pcall(function()
                    local cameraPos = camera.CFrame.Position
                    camera.CFrame = CFrame.lookAt(cameraPos, targetPos)
                end)
            end
        end)
    else
        if autoAimConnection then autoAimConnection:Disconnect() autoAimConnection = nil end
    end
end })

AimLeft:AddToggle("ShowFOV", { Text = "显示自瞄圈", Default = false, Callback = function(state)
    getgenvShowFOV = state
    if state then
        if fovCircle then pcall(function() fovCircle:Destroy() end) fovCircle = nil end
        local guiParent = game:GetService("CoreGui") or player:FindFirstChild("PlayerGui")
        if not guiParent then return end
        fovCircle = Instance.new("ScreenGui")
        fovCircle.Name = "AimFOVCircle"
        fovCircle.Parent = guiParent
        fovCircle.IgnoreGuiInset = true
        fovCircle.DisplayOrder = 999999
        fovCircle.Enabled = true
        fovCircle.ResetOnSpawn = false
        fovCircle.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        local frame = Instance.new("Frame")
        frame.Name = "FOVFrame"
        frame.Size = UDim2.new(0, getgenvAimbotFOV, 0, getgenvAimbotFOV)
        frame.Position = UDim2.new(0.5, -getgenvAimbotFOV/2, 0.5, -getgenvAimbotFOV/2)
        frame.BackgroundTransparency = 1
        frame.BorderSizePixel = 0
        frame.ZIndex = 999999
        frame.Parent = fovCircle
        local uiCorner = Instance.new("UICorner")
        uiCorner.CornerRadius = UDim.new(1, 0)
        uiCorner.Parent = frame
        local stroke = Instance.new("UIStroke")
        stroke.Thickness = 2
        stroke.Color = Color3.fromRGB(255, 0, 0)
        stroke.Transparency = 0.3
        stroke.Parent = frame
        local centerDot = Instance.new("Frame")
        centerDot.Name = "CenterDot"
        centerDot.Size = UDim2.new(0, 2, 0, 2)
        centerDot.Position = UDim2.new(0.5, -1, 0.5, -1)
        centerDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        centerDot.BackgroundTransparency = 0
        centerDot.BorderSizePixel = 0
        centerDot.ZIndex = 999999
        centerDot.Parent = frame
        local centerCorner = Instance.new("UICorner")
        centerCorner.CornerRadius = UDim.new(1, 0)
        centerCorner.Parent = centerDot
        if fovCircleThread then task.cancel(fovCircleThread) fovCircleThread = nil end
        fovCircleThread = task.spawn(function()
            while fovCircle and fovCircle.Parent and getgenvShowFOV do
                pcall(function()
                    if fovCircle and fovCircle:FindFirstChild("FOVFrame") then
                        local frame = fovCircle.FOVFrame
                        local diameter = getgenvAimbotFOV
                        frame.Size = UDim2.new(0, diameter, 0, diameter)
                        frame.Position = UDim2.new(0.5, -diameter/2, 0.5, -diameter/2)
                        local camera = Camera
                        local fovRadius = getgenvAimbotFOV / 2
                        local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
                        local closestEnemy = nil
                        local closestScreenDist = fovRadius
                        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if hrp then
                            for _, plr in ipairs(Players:GetPlayers()) do
                                if plr ~= player and plr.Character then
                                    local targetPart = plr.Character:FindFirstChild("Head") or plr.Character:FindFirstChild("HumanoidRootPart")
                                    if targetPart then
                                        local distance = (targetPart.Position - hrp.Position).Magnitude
                                        if distance <= getgenvAimbotDistance then
                                            local targetPos2D, onScreen = camera:WorldToViewportPoint(targetPart.Position)
                                            if onScreen and targetPos2D.Z > 0 then
                                                local screenPos = Vector2.new(targetPos2D.X, targetPos2D.Y)
                                                local distFromCenter = (screenCenter - screenPos).Magnitude
                                                if distFromCenter <= fovRadius and distFromCenter < closestScreenDist then
                                                    closestScreenDist = distFromCenter
                                                    closestEnemy = plr
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                        if closestEnemy then
                            frame.UIStroke.Color = Color3.fromRGB(0, 255, 0)
                        else
                            frame.UIStroke.Color = Color3.fromRGB(255, 0, 0)
                        end
                    end
                end)
                task.wait(0.1)
            end
        end)
    else
        if fovCircle then fovCircle.Enabled = false end
    end
end })

AimRight:AddSlider("AimFOV", { Text = "FOV大小", Default = 150, Min = 30, Max = 500, Rounding = 0, Callback = function(v) getgenvAimbotFOV = v end })

AimRight:AddSlider("AimDistance", { Text = "自瞄距离", Default = 3, Min = 1, Max = 300, Rounding = 0, Callback = function(v) getgenvAimbotDistance = v end })

AimLeft:AddToggle("AutoAttackV2", { Text = "自动攻击 v2", Default = false, Callback = function(state)
    getgenvAutoAttack = state
    if state then
        if attackThread then task.cancel(attackThread) attackThread = nil end
        attackThread = task.spawn(function()
            while getgenvAutoAttack do
                pcall(function()
                    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                    if not hrp then return end
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if plr ~= player and plr.Character then
                            local targetRoot = plr.Character:FindFirstChild("HumanoidRootPart")
                            if targetRoot then
                                local distance = (targetRoot.Position - hrp.Position).Magnitude
                                if distance <= getgenvAttackDistance then
                                    local backpack = player:FindFirstChild("Backpack")
                                    if backpack then
                                        local punchTool = backpack:FindFirstChild("Normal Punch")
                                        if punchTool then
                                            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                                            if humanoid then humanoid:EquipTool(punchTool) end
                                        end
                                    end
                                    local Communicate = player.Character:FindFirstChild("Communicate")
                                    if Communicate then
                                        local backpack = player:FindFirstChild("Backpack")
                                        if backpack then
                                            local punchTool = backpack:FindFirstChild("Normal Punch")
                                            if punchTool then
                                                Communicate:FireServer({[1] = { Tool = punchTool, Goal = "Console Move" }})
                                            end
                                        end
                                    end
                                    break
                                end
                            end
                        end
                    end
                end)
                task.wait(0.1)
            end
        end)
    else
        if attackThread then task.cancel(attackThread) attackThread = nil end
    end
end })

AimRight:AddSlider("AttackDist", { Text = "攻击距离", Default = 100, Min = 10, Max = 1000, Rounding = 0, Callback = function(v) getgenvAttackDistance = v end })

AimLeft:AddDropdown("PlayerSelect", { Text = "选择玩家", Default = 1, Values = {}, Callback = function(option)
    getgenvSelectedPlayer = option
end })

AimLeft:AddButton({ Text = "刷新列表", Func = function()
    local names = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local humanoid = plr.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then table.insert(names, plr.Name) end
        end
    end
    getgenvPlayerList = names
    if Toggles.PlayerSelect then Toggles.PlayerSelect:SetValues(names) end
end })

AimLeft:AddButton({ Text = "传送到玩家", Func = function()
    if getgenvSelectedPlayer and getgenvSelectedPlayer ~= "" then
        local target = Players:FindFirstChild(getgenvSelectedPlayer)
        if target and target.Character then
            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot and hrp then
                hrp.CFrame = targetRoot.CFrame * CFrame.new(0, 3, 0)
            end
        end
    end
end }))

AimLeft:AddButton({ Text = "拉到身边", Func = function()
    if getgenvSelectedPlayer and getgenvSelectedPlayer ~= "" then
        local target = Players:FindFirstChild(getgenvSelectedPlayer)
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if target and target.Character and hrp then
            local targetRoot = target.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then targetRoot.CFrame = hrp.CFrame * CFrame.new(0, 3, 0) end
        end
    end
end }))

AimLeft:AddButton({ Text = "切换Bald", Func = function()
    local function tryMethod4(charName)
        local success = pcall(function()
            local char = player.Character
            if not char then return false end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return false end
            if charName == "Bald" then
                if not hrp:FindFirstChild("BaldMode") then
                    local baldMode = Instance.new("BoolValue")
                    baldMode.Name = "BaldMode"
                    baldMode.Value = true
                    baldMode.Parent = hrp
                end
                if hrp:FindFirstChild("HunterMode") then hrp.HunterMode:Destroy() end
            elseif charName == "Hunter" then
                if not hrp:FindFirstChild("HunterMode") then
                    local hunterMode = Instance.new("BoolValue")
                    hunterMode.Name = "HunterMode"
                    hunterMode.Value = true
                    hunterMode.Parent = hrp
                end
                if hrp:FindFirstChild("BaldMode") then hrp.BaldMode:Destroy() end
            end
            hrp:SetAttribute("Mode", charName)
            local modeValue = hrp:FindFirstChild("Mode")
            if not modeValue then
                modeValue = Instance.new("StringValue")
                modeValue.Name = "Mode"
                modeValue.Parent = hrp
            end
            modeValue.Value = charName
            return true
        end)
        return success
    end
    tryMethod4("Bald")
end }))

AimLeft:AddButton({ Text = "切换Hunter", Func = function()
    local function tryMethod4(charName)
        local success = pcall(function()
            local char = player.Character
            if not char then return false end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return false end
            if charName == "Bald" then
