    Numeric = true,
    Callback = function(Value)
        local v = tonumber(Value)
        if v then
            S.Cfg.Y = math.clamp(v, 10, 150)
        end
    end
})

HitboxLeft:AddInput('HitboxZ', {
    Text = '碰撞箱Z轴',
    Default = tostring(S.Cfg.Z),
    Numeric = true,
    Callback = function(Value)
        local v = tonumber(Value)
        if v then
            S.Cfg.Z = math.clamp(v, 10, 150)
        end
    end
})

local LockLeft = Tabs.Lock:AddLeftGroupbox("锁人设置")

local SLock = {}
SLock.Players = Players
SLock.RunService = RunService
SLock.LocalPlayer = LocalPlayer
SLock.v3new = Vector3.new
SLock.cfnew = CFrame.new
SLock.mathcos = math.cos
SLock.mathsin = math.sin
SLock.tableinsert = table.insert
SLock.pairs = pairs
SLock.BEHIND_DISTANCE = 5
SLock.CIRCLE_RADIUS = 6
SLock.CIRCLE_SPEED = 13
SLock.followEnabled = false
SLock.circleEnabled = false
SLock.lookEnabled = false
SLock.selectedTargetName = nil
SLock.circleAngle = 0
SLock.mainConnection = nil
SLock.playerDropdown = nil

function SLock.getRoot(player)
    if player and player.Character then
        return player.Character:FindFirstChild("HumanoidRootPart")
    end
end
function SLock.getPlayerByName(name)
    for _, p in SLock.pairs(SLock.Players:GetPlayers()) do
        if p.Name == name then
            return p
        end
    end
end
function SLock.getPlayerNames()
    local names = {}
    for _, p in SLock.pairs(SLock.Players:GetPlayers()) do
        if p ~= SLock.LocalPlayer then
            SLock.tableinsert(names, p.Name)
        end
    end
    return names
end
function SLock.updateLoop(dt)
    if not SLock.selectedTargetName then return end
    local target = SLock.getPlayerByName(SLock.selectedTargetName)
    local targetRoot = SLock.getRoot(target)
    local myRoot = SLock.getRoot(SLock.LocalPlayer)
    if not targetRoot or not myRoot then return end
    local targetPos = targetRoot.Position
    local finalPos = nil
    if SLock.circleEnabled then
        SLock.circleAngle += (SLock.CIRCLE_SPEED * dt)
        local x = SLock.mathcos(SLock.circleAngle) * SLock.CIRCLE_RADIUS
        local z = SLock.mathsin(SLock.circleAngle) * SLock.CIRCLE_RADIUS
        finalPos = targetPos + SLock.v3new(x, 0, z)
    elseif SLock.followEnabled then
        local offset = targetRoot.CFrame.LookVector * SLock.BEHIND_DISTANCE
        finalPos = targetPos - offset
    end
    if finalPos then
        if SLock.lookEnabled then
            myRoot.CFrame = SLock.cfnew(finalPos, SLock.v3new(targetPos.X, finalPos.Y, targetPos.Z))
        else
            myRoot.CFrame = SLock.cfnew(finalPos) * myRoot.CFrame.Rotation
        end
    elseif SLock.lookEnabled then
        local myPos = myRoot.Position
        myRoot.CFrame = SLock.cfnew(myPos, SLock.v3new(targetPos.X, myPos.Y, targetPos.Z))
    end
end
function SLock.toggleConnection()
    if SLock.followEnabled or SLock.circleEnabled or SLock.lookEnabled then
        if not SLock.mainConnection then
            SLock.mainConnection = SLock.RunService.RenderStepped:Connect(SLock.updateLoop)
        end
    else
        if SLock.mainConnection then
            SLock.mainConnection:Disconnect()
            SLock.mainConnection = nil
        end
    end
end

SLock.playerDropdown = LockLeft:AddDropdown('TargetPlayer', {
    Text = '选择目标玩家',
    Default = nil,
    Values = SLock.getPlayerNames(),
    Multi = false,
    Callback = function(Value)
        SLock.selectedTargetName = Value
    end
})

LockLeft:AddButton({ Text = '刷新玩家列表', Func = function()
    SLock.selectedTargetName = nil
    local newNames = SLock.getPlayerNames()
    local d = SLock.playerDropdown
    if d then
        if d.SetValues then
            d:SetValues(newNames)
        elseif d.Refresh then
            d:Refresh(newNames, true)
        end
        if d.SetValue then
            d:SetValue(nil)
        end
    end
end })

LockLeft:AddToggle('LockBack', {
    Text = '锁背',
    Default = false,
    Callback = function(Value)
        SLock.followEnabled = Value
        if Value then SLock.circleEnabled = false end
        SLock.toggleConnection()
    end
})

LockLeft:AddToggle('LockCircle', {
    Text = '转圈',
    Default = false,
    Callback = function(Value)
        SLock.circleEnabled = Value
        if Value then SLock.followEnabled = false end
        SLock.toggleConnection()
    end
})

LockLeft:AddToggle('LockLook', {
    Text = '看着玩家(需要关移位锁)',
    Default = false,
    Callback = function(Value)
        SLock.lookEnabled = Value
        SLock.toggleConnection()
    end
})

local EmoteLeft = Tabs.Emote:AddLeftGroupbox("表情控制")

local T = {}
T.env = {
    ReplicatedStorage = ReplicatedStorage,
    Players = Players,
}
T.env.LocalPlayer = LocalPlayer
T.env.core = require(ReplicatedStorage:WaitForChild("Core"))
T.env.Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
T.env.HumanoidRootPart = T.env.Character:WaitForChild("HumanoidRootPart")
T.state = {
    killEmotes = {},
    aura = false,
    spam = false,
    auraDelay = 0.5,
    spamDelay = 0.5,
    selectedEmote = "",
    keybind = Enum.KeyCode.G,
    dropdown = nil,
    tmp = {}
}
T.services = {
    UserInputService = UserInputService
}

function T.getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end
function T.useEmote(name)
    local tmp = T.state.tmp
    tmp.emote = T.env.ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):FindFirstChild(name)
    tmp.myRoot = T.getRoot(T.env.LocalPlayer.Character)
    if not tmp.emote or not tmp.myRoot then return end
    tmp.closest = nil
    tmp.dist = math.huge
    for _, p in pairs(T.env.Players:GetPlayers()) do
        if p ~= T.env.LocalPlayer and p.Character then
            tmp.r = T.getRoot(p.Character)
            if tmp.r then
                tmp.d = (tmp.myRoot.Position - tmp.r.Position).Magnitude
                if tmp.d < tmp.dist then
                    tmp.dist = tmp.d
                    tmp.closest = p.Character
                end
            end
        end
    end
    if tmp.closest then
        task.spawn(function()
            _G.KillEmote = true
            pcall(function()
                T.env.core.Get("Combat", "Ability").Activate(tmp.emote, tmp.closest)
            end)
            _G.KillEmote = false
        end)
    end
end
function T.useRandom()
    local list = T.state.killEmotes
    if #list > 0 then
        T.useEmote(list[math.random(#list)])
    end
end

task.spawn(function()
    while true do
        if T.state.aura then
            T.useRandom()
            task.wait(T.state.auraDelay)
        else
            task.wait(0.1)
        end
    end
end)

task.spawn(function()
    while true do
        if T.state.spam and T.state.selectedEmote ~= "" then
            T.useEmote(T.state.selectedEmote)
            task.wait(T.state.spamDelay)
        else
            task.wait(0.1)
        end
    end
end)

T.services.UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == T.state.keybind and T.state.selectedEmote ~= "" then
        T.useEmote(T.state.selectedEmote)
    end
end)

function T.updateDropdown(list)
    local values = (#list > 0 and list) or { "No emotes found" }
    if T.state.dropdown then
        pcall(function()
            T.state.dropdown:Destroy()
        end)
        T.state.dropdown = nil
    end
    T.state.dropdown = EmoteLeft:AddDropdown('KillEmoteSelect', {
        Text = '击杀表情功能(要靠近别人)',
        Default = nil,
        Values = values,
        Multi = false,
        Callback = function(v)
            if v ~= "No emotes found" then
                T.state.selectedEmote = v
                T.useEmote(v)
            end
        end
    })
end

EmoteLeft:AddButton({ Text = '刷新击杀表情', Func = function()
    table.clear(T.state.killEmotes)
    for _, e in pairs(T.env.ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
        T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
    end
    T.updateDropdown(T.state.killEmotes)
end })

for _, e in pairs(T.env.ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
    T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
end
T.updateDropdown(T.state.killEmotes)

EmoteLeft:AddToggle('KillEmoteAura', {
    Text = '击杀表情光环',
    Default = false,
    Callback = function(Value)
        T.state.aura = Value
    end
})

EmoteLeft:AddSlider('AuraDelay', {
    Text = '击杀表情光环间隔',
    Default = 0.5,
    Min = 0.01,
    Max = 5,
    Rounding = 2,
    Callback = function(Value)
        T.state.auraDelay = Value
    end
})

EmoteLeft:AddToggle('KillEmoteSpam', {
    Text = '持续发送你选择的表情',
    Default = false,
    Callback = function(Value)
        T.state.spam = Value
    end
})

EmoteLeft:AddSlider('SpamDelay', {
    Text = '调整你选择的表情速度',
    Default = 0.5,
    Min = 0.01,
    Max = 5,
    Rounding = 2,
    Callback = function(Value)
        T.state.spamDelay = Value
    end
})

T.keyMap = {
    G = Enum.KeyCode.G, F = Enum.KeyCode.F, H = Enum.KeyCode.H, J = Enum.KeyCode.J,
    K = Enum.KeyCode.K, L = Enum.KeyCode.L, Z = Enum.KeyCode.Z, X = Enum.KeyCode.X,
    C = Enum.KeyCode.C, V = Enum.KeyCode.V, B = Enum.KeyCode.B, N = Enum.KeyCode.N,
    M = Enum.KeyCode.M, Q = Enum.KeyCode.Q, E = Enum.KeyCode.E, R = Enum.KeyCode.R,
    T = Enum.KeyCode.T, Y = Enum.KeyCode.Y, U = Enum.KeyCode.U, I = Enum.KeyCode.I,
    O = Enum.KeyCode.O, P = Enum.KeyCode.P,
}
local keyList = {}
for k in pairs(T.keyMap) do
    keyList[#keyList + 1] = k
end
table.sort(keyList)

EmoteLeft:AddDropdown('EmoteKeybind', {
    Text = '快捷键设置',
    Default = "G",
    Values = keyList,
    Multi = false,
    Callback = function(Value)
        T.state.keybind = T.keyMap[Value]
    end
})

EmoteLeft:AddButton({ Text = '随机用一个击杀表情', Func = T.useRandom })

