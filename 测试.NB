AutoCollectGroup:AddToggle('AutoBond', {
    Text = '自动收集债券',
    Default = false,
}):OnChanged(function(value)
    if value then
        AutoBond = true
        autoBondThread = task.spawn(function()
            while AutoBond do
                for i, v in pairs(workspace.RuntimeItems:GetChildren()) do
                    if v.Name == "Bond" then
                        local distance = (game.Players.LocalPlayer.Character.HumanoidRootPart.Position - v.Position).Magnitude
                        if distance < 10 then
                            game:GetService("ReplicatedStorage").Packages.ActivateObjectClient:FireServer(v)
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
        Library:Notify("自动收集债券已启用", 2)
    else
        AutoBond = false
        if autoBondThread then
            task.cancel(autoBondThread)
            autoBondThread = nil
        end
        Library:Notify("自动收集债券已关闭", 2)
    end
end)

