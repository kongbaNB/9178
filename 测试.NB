local origData, skyBak = {}, nil
sAddTog(MainRight, 'AntiLagToggle', { Text = '防卡', Default = false, Callback = function(state)
    if state then
        origData = {}
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Explosion") then origData[v] = v.Enabled v.Enabled = false
            elseif v:IsA("Decal") or v:IsA("Texture") then origData[v] = v.Transparency v.Transparency = 1
            elseif v:IsA("MeshPart") or v:IsA("UnionOperation") or v:IsA("Part") then if v.Name ~= "HumanoidRootPart" then origData[v] = v.Material v.Material = Enum.Material.SmoothPlastic end
            elseif v:IsA("SurfaceGui") or v:IsA("BillboardGui") or v:IsA("Beam") then
                if v:IsA("Beam") then origData[v] = v.Enabled v.Enabled = false
                else origData[v] = v.Enabled ~= nil and v.Enabled or true if v.Enabled ~= nil then v.Enabled = false end end
            end
        end
        origData["GlobalShadows"] = Lighting.GlobalShadows origData["FogEnd"] = Lighting.FogEnd
        Lighting.GlobalShadows = false Lighting.FogEnd = 9e9
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky then skyBak = sky:Clone() sky:Destroy() end
        local ns = Instance.new("Sky") ns.SkyboxBk="" ns.SkyboxDn="" ns.SkyboxFt="" ns.SkyboxLf="" ns.SkyboxRt="" ns.SkyboxUp="" ns.SunAngularSize=0 ns.MoonAngularSize=0 ns.Parent=Lighting
        Lighting.Ambient = Color3.fromRGB(128,128,128) Lighting.OutdoorAmbient = Color3.fromRGB(128,128,128)
    else
        for obj, val in pairs(origData) do
            if typeof(obj)=="Instance" and obj.Parent then
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Explosion") then obj.Enabled=val
                elseif obj:IsA("Decal") or obj:IsA("Texture") then obj.Transparency=val
                elseif obj:IsA("MeshPart") or obj:IsA("UnionOperation") or obj:IsA("Part") then obj.Material=val
                elseif obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") or obj:IsA("Beam") then
                    if obj:IsA("Beam") then obj.Enabled=val elseif obj.Enabled~=nil then obj.Enabled=val end
                end
            elseif obj=="GlobalShadows" then Lighting.GlobalShadows=val
            elseif obj=="FogEnd" then Lighting.FogEnd=val end
        end
        if skyBak then local curSky = Lighting:FindFirstChildOfClass("Sky") if curSky then curSky:Destroy() end skyBak.Parent=Lighting skyBak=nil end
        origData = {}
    end
end })

local clone, platform, origCFrame, origCamSub
local Camera = workspace.CurrentCamera
local function mkPlat(pos) local p = Instance.new("Part") p.Size=Vector3.new(10,1,10) p.Position=pos-Vector3.new(0,3,0) p.Anchored=true p.CanCollide=true p.Transparency=0.5 p.Parent=workspace return p end
local function mkClone(char) local c = char:Clone() for _, v in ipairs(c:GetDescendants()) do if v:IsA("BasePart") then v.Transparency=0.5 end end c.Parent=workspace return c end
local function toggleInvis(state)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    if state then
        origCFrame = hrp.CFrame
        hrp.CFrame = hrp.CFrame + Vector3.new(0,-50,0)
        platform = mkPlat(hrp.Position)
        task.wait(1)
        clone = mkClone(char)
        clone:MoveTo(origCFrame.Position)
        Camera.CameraSubject = clone:FindFirstChildWhichIsA("Humanoid")
        player.Character = clone
    else
        if clone then clone:Destroy() clone=nil end
        if platform then platform:Destroy() platform=nil end
        if origCFrame then hrp.CFrame=origCFrame origCFrame=nil end
        Camera.CameraSubject = char:FindFirstChildWhichIsA("Humanoid")
        player.Character = char
    end
end
sAddTog(MainRight, 'InvisibilityToggle', { Text = '隐身', Default = false, Callback = toggleInvis })

local circleParts, circleConn = {}, nil
sAddTog(MainRight, 'ShowRangeCircleToggle', { Text = '墙打/杀戮光环范围显示', Default = false, Callback = function(state)
    local function mkCircle(r, seg, thick)
        local parts = {}
        for i=1,seg do
            local p = Instance.new("Part") p.Anchored=true p.CanCollide=false p.Material=Enum.Material.Neon
            p.Size=Vector3.new(thick,0.2,r*2*math.pi/seg) p.Color=Color3.fromRGB(180,180,180) p.Parent=workspace
            table.insert(parts,p)
        end
        return parts
    end
    local function delCircle()
        if circleConn then circleConn:Disconnect() circleConn=nil end
        for _,p in ipairs(circleParts) do if p and p.Parent then p:Destroy() end end
        circleParts = {}
    end
    if state then
        delCircle()
        circleParts = mkCircle(60,60,0.2)
        local t = 0
        circleConn = RunService.RenderStepped:Connect(function(dt)
            t = t + dt
            local char = player.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local rp = char.HumanoidRootPart.Position
                local hum = char:FindFirstChild("Humanoid")
                local off = hum and hum.HipHeight/2+0.1 or 0.9
                local pos = rp - Vector3.new(0,off,0)
                for i,p in ipairs(circleParts) do
                    local ang = (i/#circleParts)*2*math.pi
                    p.Position = Vector3.new(pos.X+math.cos(ang)*60, pos.Y, pos.Z+math.sin(ang)*60)
                    p.Orientation = Vector3.new(0,-math.deg(ang),0)
                    local cr = math.sin(t+i*0.1)*40+180
                    local cg = math.sin(t+i*0.1+2)*40+180
                    local cb = math.sin(t+i*0.1+4)*40+180
                    p.Color = Color3.fromRGB(cr,cg,cb)
                end
            end
        end)
    else delCircle() end
end })

