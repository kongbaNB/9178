    Func = function()
        local active = true
        local spawnedTasks = {}
        local function buildCombatArgs()
            return {
                [1] = ReplicatedStorage.Characters.Gon.WallCombo,
                [2] = "Characters:Gon:WallCombo",
                [3] = 1,
                [4] = 33036,
                [5] = {
                    HitboxCFrames = {},
                    BestHitCharacter = workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum"),
                    HitCharacters = {workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum")},
                    Ignore = {}, DeathInfo = {}, Actions = {},
                    HitInfo = { IsFacing = true, IsInFront = true },
                    BlockedCharacters = {},
                    ServerTime = os.clock(),
                    FromCFrame = CFrame.new(534.693, 5.532, 79.486)
                },
                [6] = "Action651",
                [7] = 0
            }
        end
        local abilityArgs = {
            [1] = ReplicatedStorage.Characters.Gon.WallCombo,
            [2] = 33036,
            [4] = workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum"),
            [5] = Vector3.new(527.693, 4.532, 79.978)
        }
        for i = 1, 10000 do
            local t = task.spawn(function()
                if active then
                    pcall(function()
                        ReplicatedStorage.Remotes.Abilities.Ability:FireServer(unpack(abilityArgs))
                        ReplicatedStorage.Remotes.Combat.Action:FireServer(unpack(buildCombatArgs()))
                    end)
                end
            end)
            table.insert(spawnedTasks, t)
        end
        task.delay(3, function()
            active = false
            for _, t in ipairs(spawnedTasks) do task.cancel(t) end
            local localContainers = workspace:FindFirstChild("Container(Drawing)")
            if localContainers then
                for _, v in ipairs(localContainers:GetChildren()) do
                    if v.Name:match(tostring(player.UserId)) then v:Destroy() end
                end
            end
            Library:Notify("卡服已执行", 3)
        end)
    end
})

-- 全图秒杀
local _F = {}
_F.P = Players _F.R = RunService _F.RS = ReplicatedStorage _F.W = workspace _F.L = player
_F.Cfg = { Enabled = false, Range = 67.5, Friends = true, Target = "Closest" }
_F.Data = { List = {}, Idx = 1, FCon = nil, KCon = nil, OSub = nil, OType = nil, SCFrame = nil, SCCFrame = nil, SCType = nil }
_F.Dash = function()
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        require(_F.RS:WaitForChild("Core")).Library("Remote").Send("Dash", char.HumanoidRootPart.CFrame, "L", 1)
    end
end
_F.HRP = function()
    local c = player.Character
    return c and c:FindFirstChild("Humanoid") and c.Humanoid.RootPart
end
_F.IsF = function(p) return p and player:IsFriendsWith(p.UserId) end
_F.GetT = function()
    local tgs = {}
    local root = _F.HRP()
    if not root then return tgs end
    local pos = root.Position
    for _, v in ipairs(Players:GetPlayers()) do
        local char = v.Character
        if char and v ~= player and char:FindFirstChild(' ') == nil then
            if _F.Cfg.Friends and _F.IsF(v) then continue end
            local hum = char:FindFirstChild('Humanoid')
            local hrp = char:FindFirstChild('HumanoidRootPart')
            if hum and hrp then
                local dist = (hrp.Position - pos).Magnitude
                if dist < _F.Cfg.Range then
                    local lchar = player.Character
                    if lchar then
                        local cs = char:GetAttribute("Cutscene")
                        local csV = not cs or cs == lchar:GetAttribute("Cutscene")
                        if hrp and not char:GetAttribute("Ignore") and csV and
                           ((not char:GetAttribute("Grabbed") or char:GetAttribute("Grabbed") == lchar.Name) and
                           (not char:GetAttribute("Victim") or char:GetAttribute("Victim") == lchar.Name)) and
                           not char:GetAttribute("Invincible") and not char:GetAttribute("Grabbing") then
                            table.insert(tgs, {c = char, d = dist, h = hum:GetAttribute("Health") or hum.Health or 0})
                        end
                    end
                end
            end
        end
    end
    if _F.Cfg.Target == "Closest" and #tgs > 0 then
        table.sort(tgs, function(a,b) return a.d < b.d end)
        return {tgs[1]}
    end
    return tgs
end
_F.Aura = function(n)
    local root = _F.HRP()
    if not root then return end
    local tgs = _F.GetT()
    for _, data in ipairs(tgs) do
        if data.c then
            for i=1, n do
                _F.Data.List[_F.Data.Idx] = data.c
                _F.Data.Idx = _F.Data.Idx + 1
            end
        end
    end
    if _F.Data.Idx > 1 then
        local name = player.Data.Character.Value
        local combo = _F.RS.Characters[name].WallCombo
        _F.RS.Remotes.Abilities.Ability:FireServer(combo, 69)
        _F.RS.Remotes.Combat.Action:FireServer(combo, "", 4, 69, {BestHitCharacter=nil, HitCharacters=_F.Data.List, Ignore={}, Actions={}})
        for k in pairs(_F.Data.List) do _F.Data.List[k] = nil end
        _F.Data.Idx = 1
    end
end
_F.GetR = function()
    local al = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local hu = p.Character:FindFirstChild("Humanoid")
            local hr = p.Character:FindFirstChild("HumanoidRootPart")
            if hu and hr and (hu:GetAttribute("Health") or 0) > 0 and not hu:GetAttribute("Godmode") then
                table.insert(al, p)
            end
        end
    end
    return #al > 0 and al[math.random(1, #al)] or nil
end
_F.TP = function(p)
    if not p or not p.Character then return false end
    local hr = p.Character:FindFirstChild("HumanoidRootPart")
    if not hr then return false end
    pcall(function()
        require(player.PlayerScripts.Character.FullCustomReplication).Override(player.Character, CFrame.new(hr.Position - Vector3.new(0, 30, 0)))
    end)
    return true
end
_F.Spec = function(p)
    local cam = workspace.CurrentCamera
    if cam and p and p.Character then
        local hu = p.Character:FindFirstChildOfClass("Humanoid")
        if hu then cam.CameraSubject = hu end
    end
end
_F.Loop = function()
    local c = player.Character
    if not c or not c.Parent then return end
    local r = _F.GetR()
    if r then _F.TP(r) _F.Spec(r) task.wait(0.5) end
end
_F.Grav = function(b)
    local c = player.Character
    if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = not b
            if not b then p.Velocity = Vector3.new(0,0,0) end
        end
    end
end
_F.Save = function()
    local c = player.Character
    local hr = c and c:FindFirstChild("HumanoidRootPart")
    if not hr then return false end
    _F.Data.SCFrame = hr.CFrame
    local cam = workspace.CurrentCamera
    if cam then
        _F.Data.SCCFrame = cam.CFrame
        _F.Data.SCType = cam.CameraType
    end
    return true
end
_F.Rest = function()
    if not _F.Data.SCFrame or not player.Character then return end
    pcall(function() require(player.PlayerScripts.Character.FullCustomReplication).Override(player.Character, _F.Data.SCFrame) end)
    task.delay(0.1, function()
        local cam = workspace.CurrentCamera
        if cam and _F.Data.SCCFrame then
            cam.CameraType = _F.Data.SCType
            cam.CFrame = _F.Data.SCCFrame
        end
    end)
end
_F.Start = function()
    if not _F.Save() then return end
    _F.Grav(false)
    local cam = workspace.CurrentCamera
    if cam then
        _F.Data.OSub = cam.CameraSubject
        _F.Data.OType = cam.CameraType
    end
    _F.Data.FCon = RunService.Heartbeat:Connect(_F.Loop)
    _F.Data.KCon = RunService.Heartbeat:Connect(function()
        _F.Dash()
        local cn = player.Data.Character.Value
        _F.Aura(cn == "Gon" and 20 or 50)
    end)
end
_F.Stop = function()
    if _F.Data.FCon then _F.Data.FCon:Disconnect() _F.Data.FCon = nil end
    if _F.Data.KCon then _F.Data.KCon:Disconnect() _F.Data.KCon = nil end
    _F.Rest()
    _F.Grav(true)
    local cam = workspace.CurrentCamera
    if cam and _F.Data.OSub then
        cam.CameraSubject = _F.Data.OSub
        cam.CameraType = _F.Data.OType
    end
end

ViolentGroup:AddToggle("22", {
    Text = "全图秒杀",
    Default = false,
    Callback = function(state)
        _F.Cfg.Enabled = state
        if state then _F.Start() else _F.Stop() end
    end
})

player.CharacterAdded:Connect(function()
    if _F.Cfg.Enabled then _F.Stop() _F.Cfg.Enabled = false end
end)

-- 墙打秒杀
local wallComboEnabled = false
local ignoreFriends = false
local wallComboConn = nil
local dashConn = nil
local lastWallComboTime = 0
local lastDashTime = 0
local Core = require(ReplicatedStorage:WaitForChild("Core"))

local function hasValidTargetsForWallCombo(range)
    local head = player.Character and player.Character:FindFirstChild("Head")
    if not head then return false end
    local hrpPos = head.Position
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
            if not (ignoreFriends and player:IsFriendsWith(pl.UserId)) then
                if (pl.Character.HumanoidRootPart.Position - hrpPos).Magnitude <= range then return true end
            end
        end
    end
    return false
end

local function executeWallCombo()
    local head = player.Character and player.Character:FindFirstChild("Head")
    if not head then return end
    if tick() - lastWallComboTime < 0.05 then return end
    if not hasValidTargetsForWallCombo(100) then return end
    lastWallComboTime = tick()
    local res
    pcall(function() res = Core.Get("Combat","Hit").Box(nil, player.Character, {Size = Vector3.new(100,100,100)}) end)
    if not res then return end
    pcall(function()
        local charValue = player.Data.Character.Value
        Core.Get("Combat","Ability").Activate(ReplicatedStorage.Characters[charValue].WallCombo, res, head.Position + Vector3.new(0,0,2.5))
    end)
end

local function fireDash()
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if tick() - lastDashTime < 0.1 then return end
    lastDashTime = tick()
    pcall(function()
        ReplicatedStorage.Remotes.Character.Dash:FireServer(hrp.CFrame, "F", hrp.CFrame.LookVector, nil, tick())
    end)
end

local function toggleWallCombo(state)
    wallComboEnabled = state
    if wallComboConn then wallComboConn:Disconnect() end
    if dashConn then dashConn:Disconnect() end
    if state then
        wallComboConn = RunService.Heartbeat:Connect(executeWallCombo)
        dashConn = RunService.Heartbeat:Connect(fireDash)
    end
end

ViolentGroup:AddToggle("25", {
    Text = "墙打秒杀",
    Default = false,
    Callback = toggleWallCombo
})

ViolentGroup:AddToggle("26", {
    Text = "墙打秒杀忽略好友",
    Default = false,
    Callback = function(state) ignoreFriends = state end
})

-- 杀戮光环v1
local Configs = { IgnoreFriends = false, MaxDistance = 100, Damage = 9999, HealthLimit = 0, DashInterval = 0.7, AttackInterval = 0.001 }
local runningAuraV1 = false
local auraV1Conn
local lastDashAuraV1 = 0
local lastAttackAuraV1 = 0
local localCharacterName = player.Data.Character.Value
local abilityV1 = ReplicatedStorage.Characters[localCharacterName].WallCombo
local AbilitiesRemote = ReplicatedStorage.Remotes.Abilities.Ability
local CombatRemote = ReplicatedStorage.Remotes.Combat.Action

local function sendKillAuraV1()
    if tick() - lastAttackAuraV1 < Configs.AttackInterval then return end
    lastAttackAuraV1 = tick()
    local localRootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not localRootPart then return end
    -- dash
    if tick() - lastDashAuraV1 >= Configs.DashInterval then
        lastDashAuraV1 = tick()
        pcall(function() ReplicatedStorage.Remotes.Character.Dash:FireServer(localRootPart.CFrame, "L", localRootPart.CFrame.LookVector, nil, tick()) end)
    end
    local maxDistSq = Configs.MaxDistance * Configs.MaxDistance
    for _, targetPlayer in ipairs(Players:GetPlayers()) do
        if targetPlayer ~= player then
            local targetChar = targetPlayer.Character
            if targetChar then
                local targetRootPart = targetChar:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetChar:FindFirstChild("Humanoid")
                if targetRootPart and targetHumanoid and targetHumanoid.Health > Configs.HealthLimit then
                    if not (Configs.IgnoreFriends and player:IsFriendsWith(targetPlayer.UserId)) then
                        if (targetRootPart.Position - localRootPart.Position).Magnitude <= Configs.MaxDistance then
                            pcall(function()
                                AbilitiesRemote:FireServer(abilityV1, Configs.Damage, {}, targetRootPart.Position)
                                CombatRemote:FireServer(
                                    abilityV1, localCharacterName .. ":WallCombo", 2, Configs.Damage,
                                    {
                                        HitboxCFrames = {targetRootPart.CFrame, targetRootPart.CFrame},
                                        BestHitCharacter = targetChar,
                                        HitCharacters = {targetChar},
                                        Ignore = {},
                                        DeathInfo = {},
                                        BlockedCharacters = {},
                                        HitInfo = {IsFacing = false, IsInFront = true},
                                        ServerTime = os.time(),
                                        Actions = {
                                            ActionNumber1 = { [targetPlayer.Name] = {
                                                StartCFrameStr = tostring(localRootPart.CFrame),
                                                Local = true,
                                                Collision = false,
                                                Animation = "Punch1Hit",
                                                Preset = "Punch",
                                                Velocity = Vector3.zero,
                                                FromPosition = targetRootPart.Position,
                                                Seed = math.random(1,999999)
                                            }}
                                        },
                                        FromCFrame = targetRootPart.CFrame
                                    },
                                    "Action150", 0
                                )
                            end)
                        end
                    end
                end
            end
        end
    end
end

ViolentGroup:AddToggle("23", {
    Text = "杀戮光环v1(慢)",
    Default = false,
    Callback = function(state)
        runningAuraV1 = state
        if state then
            auraV1Conn = RunService.Heartbeat:Connect(sendKillAuraV1)
        else
            if auraV1Conn then auraV1Conn:Disconnect() end
        end
    end
})

-- 杀戮光环v2
local enabledAuraV2 = false
local auraV2Conn
local PlayersListV2 = {}
local indexV2 = 1
local RANGE_V2 = 70
local DASH_INTERVAL_V2 = 0.25
local lastDashV2 = 0

local function getTargetsV2()
    local targets = {}
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return targets end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            if player:IsFriendsWith(p.UserId) then continue end
            local hum = p.Character:FindFirstChild("Humanoid")
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if hum and root and hum.Health > 0 then
                if (root.Position - hrp.Position).Magnitude <= RANGE_V2 then
                    if not p.Character:GetAttribute("Invincible") then
                        table.insert(targets, p.Character)
                    end
                end
            end
        end
    end
    return targets
end

local function KillAuraV2(count)
    if tick() - lastDashV2 >= DASH_INTERVAL_V2 then
        lastDashV2 = tick()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then pcall(function() ReplicatedStorage.Remotes.Character.Dash:FireServer(hrp.CFrame, "L", hrp.CFrame.LookVector, nil, tick()) end) end
    end
    local targets = getTargetsV2()
    for _, char in ipairs(targets) do
        for i = 1, count do
            PlayersListV2[indexV2] = char
            indexV2 += 1
        end
    end
    if indexV2 > 1 then
        local combo = ReplicatedStorage.Characters[player.Data.Character.Value].WallCombo
        ReplicatedStorage.Remotes.Abilities.Ability:FireServer(combo, 69)
        ReplicatedStorage.Remotes.Combat.Action:FireServer(combo, "", 4, 69, { BestHitCharacter = nil, HitCharacters = PlayersListV2, Ignore = {}, Actions = {} })
        table.clear(PlayersListV2)
        indexV2 = 1
    end
end

ViolentGroup:AddToggle("23.5", {
    Text = "杀戮光环v2(快)",
    Default = false,
    Callback = function(state)
        enabledAuraV2 = state
        if state then
            auraV2Conn = RunService.Heartbeat:Connect(function()
                local count = (player.Data.Character.Value == "Gon") and 20 or 50
                KillAuraV2(count)
            end)
        else
            if auraV2Conn then auraV2Conn:Disconnect() end
        end
    end
})

ViolentGroup:AddToggle("24", {
    Text = "杀戮光环忽略好友",
    Default = false,
    Callback = function(state) Configs.IgnoreFriends = state end
})

-- ==================== 碰撞箱扩大 Tab ====================
local HitboxGroup = Tabs.Hitbox:AddLeftGroupbox("碰撞箱扩大")
pcall(function() setthreadidentity(8) end)

local S = {}
S.Players = Players S.RunService = RunService S.ReplicatedStorage = ReplicatedStorage
S.Cfg = { Hitbox = false, X = 150, Y = 150, Z = 150, Enhancer = false, Multi = 3 }
S.Cache = {} S.Conn = nil S.DashT = 0
local LP = player
getgenv().HitboxEnabled = false

function S:HRP()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

function S:GetCore()
    if self.Cache.Core then return self.Cache.Core end
    local ok, core = pcall(function() return require(self.ReplicatedStorage:WaitForChild("Core", 10)) end)
    if ok then self.Cache.Core = core return core end
end

function S:ToggleHitbox(state)
    self.Cfg.Hitbox = state
    getgenv().HitboxEnabled = state
    local core = self:GetCore()
    if not core or not core.Get then return end
    local hit = core.Get("Combat", "Hit")
    if not hit or not hit.Box then return end
    if state then
        if not self.Cache.OrigBox then self.Cache.OrigBox = hit.Box end
        hit.Box = function(_, char, data)
            data = data or {}
            data.Size = Vector3.new(self.Cfg.X, self.Cfg.Y, self.Cfg.Z)
            return self.Cache.OrigBox(nil, char, data)
        end
    else
        if self.Cache.OrigBox then hit.Box = self.Cache.OrigBox end
    end
end

function S:Dash()
    if tick() - self.DashT < 0.18 then return end
    self.DashT = tick()
    local hrp = self:HRP()
    if not hrp then return end
    pcall(function() self:GetCore().Library("Remote").Send("Dash", hrp.CFrame, "L", 1) end)
end

function S:EnableEnhancer()
    if self.Cache.HitProc then return end
    local ok, hit = pcall(function() return require(LP.PlayerScripts:WaitForChild("Combat"):WaitForChild("Hit")) end)
    if not ok or not hit.Process then return end
    self.Cache.HitProc = hit.Process
    hit.Process = function(...)
        local best, targets, blocked = self.Cache.HitProc(...)
        if not targets or #targets == 0 then return best, targets, blocked end
        self:Dash()
        local r = self.ReplicatedStorage.Remotes.Combat.Action
        for _ = 1, self.Cfg.Multi do
            pcall(function() r:FireServer(nil, "", 4, 69, {BestHitCharacter=nil, HitCharacters=targets, Ignore={}, Actions={}}) end)
        end
        return best, targets, blocked
    end
end

function S:DisableEnhancer()
    if not self.Cache.HitProc then return end
    local ok, hit = pcall(function() return require(LP.PlayerScripts.Combat.Hit) end)
    if ok then hit.Process = self.Cache.HitProc end
    self.Cache.HitProc = nil
end

function S:StartDashLoop()
    if self.Conn then return end
    self.Conn = self.RunService.Heartbeat:Connect(function() self:Dash() end)
end

function S:StopDashLoop()
    if self.Conn then self.Conn:Disconnect() self.Conn = nil end
end

HitboxGroup:AddToggle("Hitbox", {
    Text = "碰撞箱扩大",
    Default = false,
    Tooltip = "如果你不会调参数这些你就直接开启碰撞箱扩大功能就行了",
    Callback = function(v)
        if v then
            S:ToggleHitbox(true) S:EnableEnhancer() S:StartDashLoop()
        else
            S:ToggleHitbox(false) S:DisableEnhancer() S:StopDashLoop()
        end
    end
})

HitboxGroup:AddInput("HitboxX", {
    Text = "碰撞箱X轴",
    Default = "150",
    Callback = function(v)
        local val = tonumber(v)
        if val then S.Cfg.X = math.clamp(val, 10, 150) end
    end
})

HitboxGroup:AddInput("HitboxY", {
    Text = "碰撞箱Y轴",
    Default = "150",
    Callback = function(v)
        local val = tonumber(v)
        if val then S.Cfg.Y = math.clamp(val, 10, 150) end
    end
})

HitboxGroup:AddInput("HitboxZ", {
    Text = "碰撞箱Z轴",
    Default = "150",
    Callback = function(v)
        local val = tonumber(v)
        if val then S.Cfg.Z = math.clamp(val, 10, 150) end
    end
})

-- ==================== 锁人 Tab ====================
local LockGroup = Tabs.Lock:AddLeftGroupbox("锁人")
local Lock = {}
Lock.Players = Players Lock.RunService = RunService Lock.LocalPlayer = player
Lock.v3new = Vector3.new Lock.cfnew = CFrame.new Lock.mathcos = math.cos Lock.mathsin = math.sin
Lock.BEHIND_DISTANCE = 5 Lock.CIRCLE_RADIUS = 6 Lock.CIRCLE_SPEED = 13
Lock.followEnabled = false Lock.circleEnabled = false Lock.lookEnabled = false Lock.selectedTargetName = nil
Lock.circleAngle = 0 Lock.mainConnection = nil

function Lock.getRoot(p) return p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") end
function Lock.getPlayerByName(name) for _, p in pairs(Players:GetPlayers()) do if p.Name == name then return p end end end
function Lock.getPlayerNames()
    local names = {}
    for _, p in pairs(Players:GetPlayers()) do if p ~= player then table.insert(names, p.Name) end end
    return names
end

function Lock.updateLoop(dt)
    if not Lock.selectedTargetName then return end
    local target = Lock.getPlayerByName(Lock.selectedTargetName)
    local targetRoot = Lock.getRoot(target)
    local myRoot = Lock.getRoot(player)
    if not targetRoot or not myRoot then return end
    local targetPos = targetRoot.Position
    local finalPos = nil
    if Lock.circleEnabled then
        Lock.circleAngle += (Lock.CIRCLE_SPEED * dt)
        local x = Lock.mathcos(Lock.circleAngle) * Lock.CIRCLE_RADIUS
        local z = Lock.mathsin(Lock.circleAngle) * Lock.CIRCLE_RADIUS
        finalPos = targetPos + Lock.v3new(x, 0, z)
    elseif Lock.followEnabled then
        local offset = targetRoot.CFrame.LookVector * Lock.BEHIND_DISTANCE
        finalPos = targetPos - offset
    end
    if finalPos then
        if Lock.lookEnabled then
            myRoot.CFrame = Lock.cfnew(finalPos, Lock.v3new(targetPos.X, finalPos.Y, targetPos.Z))
        else
            myRoot.CFrame = Lock.cfnew(finalPos) * myRoot.CFrame.Rotation
        end
    elseif Lock.lookEnabled then
        local myPos = myRoot.Position
        myRoot.CFrame = Lock.cfnew(myPos, Lock.v3new(targetPos.X, myPos.Y, targetPos.Z))
    end
end

function Lock.toggleConnection()
    if Lock.followEnabled or Lock.circleEnabled or Lock.lookEnabled then
        if not Lock.mainConnection then Lock.mainConnection = RunService.RenderStepped:Connect(Lock.updateLoop) end
    else
        if Lock.mainConnection then Lock.mainConnection:Disconnect() Lock.mainConnection = nil end
    end
end

local playerDropdown
LockGroup:AddDropdown("LockTarget", {
    Text = "选择目标玩家",
    Values = Lock.getPlayerNames(),
    Default = nil,
    Multi = false,
    Callback = function(name) Lock.selectedTargetName = name end
})

LockGroup:AddButton({
    Text = "刷新玩家列表",
    Func = function()
        Lock.selectedTargetName = nil
        local newNames = Lock.getPlayerNames()
        if playerDropdown and playerDropdown.SetValues then playerDropdown:SetValues(newNames) end
    end
})

LockGroup:AddToggle("FollowBack", { Text = "锁背", Default = false, Callback = function(s) Lock.followEnabled = s if s then Lock.circleEnabled = false end Lock.toggleConnection() end })
LockGroup:AddToggle("Circle", { Text = "转圈", Default = false, Callback = function(s) Lock.circleEnabled = s if s then Lock.followEnabled = false end Lock.toggleConnection() end })
LockGroup:AddToggle("LookAt", { Text = "看着玩家(需要关移位锁)", Default = false, Callback = function(s) Lock.lookEnabled = s Lock.toggleConnection() end })

-- ==================== 击杀表情功能 Tab ====================
local EmoteGroup = Tabs.Emote:AddLeftGroupbox("击杀表情功能")
local T = {}
T.env = { ReplicatedStorage = ReplicatedStorage, Players = Players, LocalPlayer = player }
T.env.core = require(ReplicatedStorage:WaitForChild("Core"))
T.env.Character = player.Character or player.CharacterAdded:Wait()
T.env.HumanoidRootPart = T.env.Character:WaitForChild("HumanoidRootPart")
T.state = { killEmotes = {}, aura = false, spam = false, auraDelay = 0.5, spamDelay = 0.5, selectedEmote = "", keybind = Enum.KeyCode.G, dropdown = nil }
T.services = { UserInputService = UIS }

function T.getRoot(char) return char and char:FindFirstChild("HumanoidRootPart") end

function T.useEmote(name)
    local tmp = T.state.tmp
    tmp.emote = ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):FindFirstChild(name)
    tmp.myRoot = T.getRoot(player.Character)
    if not tmp.emote or not tmp.myRoot then return end
    tmp.closest = nil
    tmp.dist = math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local r = T.getRoot(p.Character)
            if r then
                local d = (tmp.myRoot.Position - r.Position).Magnitude
                if d < tmp.dist then tmp.closest = p.Character tmp.dist = d end
            end
        end
    end
    if tmp.closest then
        task.spawn(function()
            _G.KillEmote = true
            pcall(function() T.env.core.Get("Combat", "Ability").Activate(tmp.emote, tmp.closest) end)
            _G.KillEmote = false
        end)
    end
end

function T.useRandom()
    local list = T.state.killEmotes
    if #list > 0 then T.useEmote(list[math.random(#list)]) end
end

task.spawn(function()
    while true do
        if T.state.aura then T.useRandom() task.wait(T.state.auraDelay) else task.wait(0.1) end
    end
end)

task.spawn(function()
    while true do
        if T.state.spam and T.state.selectedEmote ~= "" then T.useEmote(T.state.selectedEmote) task.wait(T.state.spamDelay) else task.wait(0.1) end
    end
end)

UIS.InputBegan:Connect(function(i,g)
    if not g and i.KeyCode == T.state.keybind and T.state.selectedEmote ~= "" then
        T.useEmote(T.state.selectedEmote)
    end
end)

function T.updateDropdown(list)
    local values = (#list > 0 and list) or {"No emotes found"}
    if T.state.dropdown then pcall(function() T.state.dropdown:Destroy() end) T.state.dropdown = nil end
    T.state.dropdown = EmoteGroup:AddDropdown("EmoteSelect", {
        Text = "击杀表情功能(要靠近别人)",
        Values = values,
        Multi = false,
        Default = nil,
        Callback = function(v)
            if v ~= "No emotes found" then T.state.selectedEmote = v T.useEmote(v) end
        end
    })
end

EmoteGroup:AddButton({
    Text = "刷新击杀表情",
    Func = function()
        table.clear(T.state.killEmotes)
        for _, e in pairs(ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
            T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
        end
        T.updateDropdown(T.state.killEmotes)
    end
})

for _, e in pairs(ReplicatedStorage:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
    T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
end
T.updateDropdown(T.state.killEmotes)

EmoteGroup:AddToggle("AuraEmote", { Text = "击杀表情光环", Default = false, Callback = function(v) T.state.aura = v end })
EmoteGroup:AddSlider("AuraDelay", { Text = "击杀表情光环间隔", Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v) T.state.auraDelay = v end })
EmoteGroup:AddToggle("SpamEmote", { Text = "持续发送你选择的表情", Default = false, Callback = function(v) T.state.spam = v end })
EmoteGroup:AddSlider("SpamDelay", { Text = "调整你选择的表情速度", Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v) T.state.spamDelay = v end })

local keyList = {"G","F","H","J","K","L","Z","X","C","V","B","N","M","Q","E","R","T","Y","U","I","O","P"}
EmoteGroup:AddDropdown("KeybindEmote", {
    Text = "快捷键设置",
    Values = keyList,
    Default = "G",
    Callback = function(v) T.state.keybind = Enum.KeyCode[v] end
})

EmoteGroup:AddButton({ Text = "随机用一个击杀表情", Func = T.useRandom })

-- ==================== 设置 Tab ====================
local SettingsGroup = Tabs.Settings:AddLeftGroupbox("菜单")
SettingsGroup:AddButton({
    Text = "卸载脚本",
    Func = function()
        for _, conn in ipairs(jumpConnections) do conn:Disconnect() end
        if pingLoop then task.cancel(pingLoop) end
        if wallComboConn then wallComboConn:Disconnect() end
        if dashConn then dashConn:Disconnect() end
        if auraV1Conn then auraV1Conn:Disconnect() end
        if auraV2Conn then auraV2Conn:Disconnect() end
        _F.Stop()
        S:ToggleHitbox(false) S:DisableEnhancer() S:StopDashLoop()
        if Lock.mainConnection then Lock.mainConnection:Disconnect() end
        noClipEnabled = false
        moveSpeed = 16
        if humanoid then humanoid.WalkSpeed = 16 end
        Library:Unload()
    end
})
SettingsGroup:AddButton({
    Text = "重载界面",
    Func = function()
        Library:Unload()
        loadstring(game:HttpGet("https://pastebin.com/raw/你的脚本地址"))()
    end
})
SettingsGroup:AddLabel("菜单快捷键")
SettingsGroup:AddKeyPicker("MenuKeybind", {
    Default = "RightShift",
    NoUI = true,
    Text = "Menu keybind"
})
Library.ToggleKeybind = Tabs.Settings:GetOptions().MenuKeybind

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("MyScriptTheme")
    ThemeManager:ApplyToTab(Tabs.Settings)
end

if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("MyScriptConfig")
    SaveManager:BuildConfigSection(Tabs.Settings)
end
