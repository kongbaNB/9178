local serversFile = "servers_" .. plrId .. ".json"
local savedServers = {}
local function loadSavedServers()
    local success, data = pcall(function() return readfile(serversFile) end)
    if success and data then
        local decoded = HttpService:JSONDecode(data)
        if decoded then
            savedServers = {}
            for _, item in ipairs(decoded) do
                if type(item) == "string" then
                    table.insert(savedServers, {id = item, name = item})
                elseif type(item) == "table" and item.id then
                    table.insert(savedServers, {id = item.id, name = item.name or item.id})
                end
            end
        end
    end
    local seen = {}
    local unique = {}
    for _, entry in ipairs(savedServers) do
        if not seen[entry.id] then
            seen[entry.id] = true
            table.insert(unique, entry)
        end
    end
    savedServers = unique
end
local function saveServers()
    pcall(function() writefile(serversFile, HttpService:JSONEncode(savedServers)) end)
end
local function addServerId(id, name)
    if not id or id == "" then return end
    for _, entry in ipairs(savedServers) do
        if entry.id == id then
            if name and name ~= entry.name then
                entry.name = name
                saveServers()
            end
            return
        end
    end
    table.insert(savedServers, {id = id, name = name or id})
    saveServers()
end
local function removeServerId(id)
    local newList = {}
    for _, entry in ipairs(savedServers) do
        if entry.id ~= id then
            table.insert(newList, entry)
        end
    end
    savedServers = newList
    saveServers()
end
local function renameServerId(id, newName)
    if not newName or newName == "" then return end
    for _, entry in ipairs(savedServers) do
        if entry.id == id then
            entry.name = newName
            saveServers()
            return true
        end
    end
    return false
end
loadSavedServers()
local UILib = loadstring(game:HttpGet("https://raw.githubusercontent.com/kongbaNB/ui/refs/heads/main/恐脚本.UI"))()

local window = UILib:CreateWindow({
    Title = "恐脚本--通用" .. string.rep(" ", 6) .. "您已执行 " .. count .. " 次，谢谢您的支持！",
    ToggleText = "打开菜单",
    ToggleTextClose = "关闭菜单",
})

local Main = window.Main

local function copyToClipboard(text, label)
    local success = pcall(function()
        if setclipboard then
            setclipboard(text)
        elseif game:GetService("ClipboardService") then
            game:GetService("ClipboardService"):SetClipboard(text)
        else
            error("无法访问剪贴板")
        end
    end)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = label or "提示",
        Text = success and ("✅ 已复制: " .. text) or ("❌ 复制失败，请手动复制：" .. text),
        Duration = 3,
    })
end

