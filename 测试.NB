    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Error",
        Text = "UI library failed to load",
        Duration = 5,
    })
    return
end

local function safeCall(f, ...)
    local ok, err = pcall(f, ...)
    if not ok then warn(err) end
end

