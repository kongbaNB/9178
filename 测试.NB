TabMap:Label("从篝火开始高空螺旋扩大扫描")
TabMap:Button({
    Title = "开始自动加载地图",
    Callback = function()
        if Features.MapLoad then WindUI:Notify({Title="地图",Content="已在加载中",Duration=2}); return end
        Features.MapLoad = true
        mapLoadLoop()
        WindUI:Notify({Title="地图",Content="开始高空螺旋扫描",Duration=3})
    end
})
