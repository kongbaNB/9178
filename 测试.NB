        Features.MapLoad = false
        WindUI:Notify({Title="地图",Content="已停止，返回篝火",Duration=2})
    end
})

-- ==================== 后台循环 ====================
RunService.Heartbeat:Connect(function()
    if Features.Speed and Humanoid and Humanoid.Parent then Humanoid.WalkSpeed = Features.SpeedVal end
    if Features.GodMode then pcall(function() ReplicatedStorage.RemoteEvents.DamagePlayer:FireServer(-math.huge) end) end
    if CollisionBox.Show then
        for _, m in ipairs(Workspace:GetDescendants()) do
            if m:IsA("Model") and m:FindFirstChild("HumanoidRootPart") then updateHitbox(m) end
        end
    end
    if Features.KidESP then updateKidESP() end
end)

