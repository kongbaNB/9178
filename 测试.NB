TabFun:Toggle({
    Title = "自动形成图案", Value = false,
    Callback = function(v)
        Features.Pattern = v
        if v then
            task.spawn(function()
                while Features.Pattern do
                    local logs = {}
                    for _, item in ipairs(Workspace.Items:GetChildren()) do
                        if item.Name:lower():find("log") and item:IsA("Model") then table.insert(logs, item) end
                    end
                    if #logs > 0 then
                        local poses = genPattern(#logs)
                        for i, log in ipairs(logs) do
                            local main = log:FindFirstChildWhichIsA("BasePart")
                            if main then
                                pcall(function()
                                    main.CFrame = CFrame.new(poses[i] or poses[1])
                                    main.AssemblyLinearVelocity = Vector3.zero
                                end)
                            end
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    end
})

-- ==================== 恶搞朋友 ====================
local trapPlayerList = {"无"}
local trapDropdownRef = nil

local function updateTrapList()
    local new = {"无"}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(new, p.Name) end
    end
    trapPlayerList = new
    if trapDropdownRef then trapDropdownRef:Refresh(trapPlayerList, true) end
end
Players.PlayerAdded:Connect(updateTrapList)
Players.PlayerRemoving:Connect(updateTrapList)
updateTrapList()

trapDropdownRef = TabTroll:Dropdown({
    Title = "选择攻击玩家", Values = trapPlayerList, Value = "无",
    Callback = function(v) Features.BearTrapTarget = v end
})

TabTroll:Toggle({
    Title = "自动捕兽夹攻击", Value = false,
    Callback = function(v)
        Features.BearTrap = v
        if v then
            task.spawn(function()
                while Features.BearTrap do
                    if Features.BearTrapTarget == "无" then WindUI:Notify({Title="提示",Content="请先选择玩家",Duration=3}); Features.BearTrap = false; break end
                    local target = Players:FindFirstChild(Features.BearTrapTarget)
                    if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then task.wait(1); continue end
                    local tPos = target.Character.HumanoidRootPart.Position + Vector3.new(0,1,0)
                    local traps = {}
                    for _, s in ipairs(Workspace.Structures:GetChildren()) do if s.Name:find("Bear Trap") then table.insert(traps,s) end end
                    for _, i in ipairs(Workspace.Items:GetChildren()) do if i.Name:find("Bear Trap") then table.insert(traps,i) end end
                    for _, trap in ipairs(traps) do
                        if not Features.BearTrap then break end
                        if not trap.PrimaryPart then
                            for _, p in ipairs(trap:GetChildren()) do if p:IsA("BasePart") then trap.PrimaryPart = p; break end end
                        end
                        if trap.PrimaryPart then
                            pcall(function()
                                ReplicatedStorage.RemoteEvents.RequestStartDraggingItem:FireServer(trap)
                                trap:SetPrimaryPartCFrame(CFrame.new(tPos))
                                ReplicatedStorage.RemoteEvents.StopDraggingItem:FireServer(trap)
                                ReplicatedStorage.RemoteEvents.RequestSetTrap:FireServer(trap)
                            end)
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})

