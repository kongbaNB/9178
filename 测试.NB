-- 安全添加函数，防止崩溃
local function sCall(f,...) pcall(f,...) end
local function sAddBtn(p,cfg) if p then sCall(p.AddButton,p,cfg) end end
local function sAddTog(p,id,cfg) if p then sCall(p.AddToggle,p,id,cfg) end end
local function sAddSld(p,id,cfg) if p then sCall(p.AddSlider,p,id,cfg) end end
local function sAddDrp(p,id,cfg)
    if not p then return end
    if not cfg.Values or #cfg.Values==0 then cfg.Values = {"-"}; cfg.Default = 1 end
    sCall(p.AddDropdown,p,id,cfg)
end
local function sAddInp(p,id,cfg) if p then sCall(p.AddInput,p,id,cfg) end end
local function sAddLab(p,txt) if p then sCall(p.AddLabel,p,txt) end end

