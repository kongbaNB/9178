-- ==================== 收集 ====================
TabCollect:Section({Title = "收集"})
local collectMap = {
    ["燃料类"] = {["木头"]="Log",["煤"]="Coal",["油桶"]="Fuel Canister",["椅子"]="Chair",["生物燃料"]="Biofuel"},
    ["钢铁类"] = {["螺栓"]="Bolt",["破风扇"]="Broken Fan",["坏微波炉"]="Broken Microwave",["旧收音机"]="Old Radio",["洗衣机"]="Washing Machine",["旧汽车引擎"]="Old Car Engine",["轮胎"]="Tyre",["金属板"]="Sheet Metal"},
    ["食物类"] = {["蛋糕"]="Cake",["牛排"]="Steak",["肉丁"]="Morsel",["胡萝卜"]="Carrot",["苹果"]="Apple",["浆果"]="Berry",["辣椒"]="Chili",["玉米"]="Corn",["南瓜"]="Pumpkin"},
    ["回血类"] = {["绷带"]="Bandage",["医疗包"]="MedKit"},
    ["武器装备"] = {["步枪"]="Rifle",["皮革背心"]="Leather Body",["左轮弹药"]="Revolver Ammo",["左轮手枪"]="Revolver",["步枪弹药"]="Rifle Ammo",["好的背包"]="Good Sack",["巨袋"]="Large Bag",["强力斧头"]="Strong Axe",["锯齿"]="Saw Blade",["好的斧头"]="Good Axe",["长矛"]="Spear",["强力手电筒"]="Strong Flashlight",["弓弩"]="Crossbow",["老鱼杆"]="Old Rod"},
    ["动物特殊"] = {["黄鼠狼皮"]="Arctic Fox Pelt",["教徒尸体"]="Cultist",["弓弩教徒尸体"]="Crossbow Cultist",["教徒宝石"]="Cultist Gem",["狼尸体"]="Wolf Corpse",["狼皮"]="Bunny Foot"}
}
local allCollectItems = {}
local allCollectValues = {}
for cat, items in pairs(collectMap) do
    for cn, en in pairs(items) do
        table.insert(allCollectValues, cn)
        allCollectItems[cn] = en
    end
end
local selectedCollect = {}
local autoCollect = false
TabCollect:Dropdown({
    Title = "选择要收集的物品（多选）", Values = allCollectValues, Value = {},
    Multi = true,
    Callback = function(opts)
        selectedCollect = {}
        for _, o in ipairs(opts) do if allCollectItems[o] then selectedCollect[allCollectItems[o]] = true end end
    end
})
TabCollect:Toggle({
    Title = "自动收集选择的物品", Value = false,
    Callback = function(v)
        autoCollect = v
        if v then
            task.spawn(function()
                while autoCollect do
                    for _, item in ipairs(Workspace.Items:GetChildren()) do
                        if not autoCollect then break end
                        if selectedCollect[item.Name] and item:IsA("Model") then
                            local hrp = getHRP()
                            if hrp then
                                moveItemToPos(item, hrp.Position + Vector3.new(0, 0, 2))
                                task.wait(0.05)
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})

-- ==================== 玩家功能 ====================
TabPlayer:Toggle({
    Title = "速度 (开/关)", Value = false,
    Callback = function(v)
        Features.Speed = v
        if not v and Humanoid then Humanoid.WalkSpeed = 16 end
    end
})
TabPlayer:Slider({
    Title = "速度设置", Value = {Min = 1, Max = 150, Default = 16},
    Callback = function(v) Features.SpeedVal = v end
})
TabPlayer:Toggle({
    Title = "无限跳", Value = false,
    Callback = function(v)
        Features.InfJump = v
        if v then
            if infJumpConn then infJumpConn:Disconnect() end
            infJumpConn = UIS.JumpRequest:Connect(function()
                local c = LP.Character
                if c then
                    local r = c:FindFirstChild("HumanoidRootPart")
                    if r then r.Velocity = Vector3.new(r.Velocity.X, 50, r.Velocity.Z) end
                end
            end)
        else
            if infJumpConn then infJumpConn:Disconnect(); infJumpConn = nil end
        end
    end
})
TabPlayer:Toggle({
    Title = "穿墙", Value = false,
    Callback = function(v)
        Features.Noclip = v
        if v then
            if noclipConn then noclipConn:Disconnect() end
            noclipConn = RunService.Stepped:Connect(function()
                local c = LP.Character
                if c then
                    for _, p in ipairs(c:GetDescendants()) do
                        if p:IsA("BasePart") then p.CanCollide = false end
                    end
                end
            end)
        else
            if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
        end
    end
})
TabPlayer:Toggle({
    Title = "秒互动", Value = false,
    Callback = function(v)
        Features.InstantInteract = v
        if v then
            if interactConn then interactConn:Disconnect() end
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then obj.HoldDuration = 0 end
            end
            interactConn = Workspace.DescendantAdded:Connect(function(d)
                if d:IsA("ProximityPrompt") then d.HoldDuration = 0 end
            end)
        else
            if interactConn then interactConn:Disconnect(); interactConn = nil end
        end
    end
})
TabPlayer:Button({
    Title = "召唤撸管",
    Callback = function()
        WindUI:Notify({Title="撸管",Content="生成中...",Duration=2})
        loadLuGuan()
    end
})

-- ==================== 视觉 ====================
TabVisual:Toggle({
    Title = "全亮", Value = false,
    Callback = function(v)
        Features.Fullbright = v
        if v then
            Lighting.Brightness = 2; Lighting.Ambient = Color3.new(1,1,1); Lighting.OutdoorAmbient = Color3.new(1,1,1)
            Lighting.ShadowSoftness = 0; Lighting.GlobalShadows = false
        else
            Lighting.Brightness = 1; Lighting.Ambient = Color3.new(0,0,0); Lighting.OutdoorAmbient = Color3.new(0.7,0.7,0.7)
            Lighting.GlobalShadows = true
        end
    end
})
TabVisual:Toggle({
    Title = "夜视", Value = false,
    Callback = function(v)
        Features.NightVision = v
        if v then
            Lighting.Ambient = Color3.new(1,1,1); Lighting.ColorShift_Bottom = Color3.new(1,1,1); Lighting.ColorShift_Top = Color3.new(1,1,1)
            Lighting.FogEnd = 100000; Lighting.FogStart = 100000; Lighting.Brightness = 1; Lighting.GlobalShadows = false; Lighting.OutdoorAmbient = Color3.new(1,1,1); Lighting.ClockTime = 12
        else
            Lighting.Ambient = Color3.new(0,0,0); Lighting.ColorShift_Bottom = Color3.new(0,0,0); Lighting.ColorShift_Top = Color3.new(0,0,0)
            Lighting.FogEnd = 1000; Lighting.FogStart = 0; Lighting.Brightness = 1; Lighting.GlobalShadows = true; Lighting.OutdoorAmbient = Color3.new(0.7,0.7,0.7)
        end
    end
})
TabVisual:Toggle({
    Title = "关闭雾效", Value = false,
    Callback = function(v)
        Features.NoFog = v
        if v then Lighting.FogEnd = 100000 else Lighting.FogEnd = 1000 end
    end
})
TabVisual:Toggle({
    Title = "关闭篝火夜间效果", Value = false,
    Callback = function(v)
        Features.NoCampfireEffect = v
        local cc = Lighting:FindFirstChild("ColorCorrection")
        if cc then cc.Enabled = not v end
    end
})
TabVisual:Toggle({
    Title = "小孩透视", Value = false,
    Callback = function(v)
        Features.KidESP = v
        if not v then
            for _, gui in pairs(kidESPData) do if gui then gui:Destroy() end end
            kidESPData = {}
        end
    end
})

