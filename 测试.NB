    end
    if T.state.dropdown then T.state.dropdown:Destroy() T.state.dropdown = nil end
    T.state.dropdown = EmoteLeft:AddDropdown("KillEmoteSelect", { Text = "击杀表情", Default = 1, Values = T.state.killEmotes, Callback = function(v)
        if v ~= "No emotes found" then T.state.selectedEmote = v T.useEmote(v) end
    end })
end })

for _, e in pairs(rs:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):GetChildren()) do
    table.insert(T.state.killEmotes, e.Name)
end

if #T.state.killEmotes > 0 then
    T.state.dropdown = EmoteLeft:AddDropdown("KillEmoteSelect", { Text = "击杀表情", Default = 1, Values = T.state.killEmotes, Callback = function(v)
        if v ~= "No emotes found" then T.state.selectedEmote = v T.useEmote(v) end
    end })
end

function T.getRoot(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

function T.useEmote(name)
    local tmp = T.state.tmp
    tmp.emote = rs:WaitForChild("Cosmetics"):WaitForChild("KillEmote"):FindFirstChild(name)
    tmp.myRoot = T.getRoot(player.Character)
    if not tmp.emote or not tmp.myRoot then return end
    tmp.closest = nil
    tmp.dist = math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            tmp.r = T.getRoot(p.Character)
            if tmp.r then
                tmp.d = (tmp.myRoot.Position - tmp.r.Position).Magnitude
                if tmp.d < tmp.dist then
                    tmp.dist = tmp.d
                    tmp.closest = p.Character
                end
            end
        end
    end
    if tmp.closest then
        task.spawn(function()
            _G.KillEmote = true
            pcall(function() T.env.core.Get("Combat", "Ability").Activate(tmp.emote, tmp.closest) end)
            _G.KillEmote = false
        end)
    end
end

function T.useRandom()
    local list = T.state.killEmotes
    if #list > 0 then T.useEmote(list[math.random(#list)]) end
end

task.spawn(function()
    while true do
        if T.state.aura then
            T.useRandom()
            task.wait(T.state.auraDelay)
        else
            task.wait(0.1)
        end
    end
end)

task.spawn(function()
    while true do
        if T.state.spam and T.state.selectedEmote ~= "" then
            T.useEmote(T.state.selectedEmote)
            task.wait(T.state.spamDelay)
        else
            task.wait(0.1)
        end
    end
end)

