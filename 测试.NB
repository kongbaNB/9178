end })

local _F = {}
_F.P = Players
_F.R = RunService
_F.RS = ReplicatedStorage
_F.W = Workspace
_F.L = player
_F.Cfg = { Enabled = false, Range = 67.5, Friends = true, Target = "Closest" }
_F.Data = { List = {}, Idx = 1, FCon = nil, KCon = nil, OSub = nil, OType = nil, SCFrame = nil, SCCFrame = nil, SCType = nil }
_F.Dash = function()
    local char = _F.L.Character or _F.L.CharacterAdded:Wait()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        pcall(function()
            require(_F.RS:WaitForChild("Core")).Library("Remote").Send("Dash", hrp.CFrame, "L", 1)
        end)
    end
end
_F.HRP = function()
    local c = _F.L.Character
    if c and c:FindFirstChild('Humanoid') and c.Humanoid.RootPart then
        return c.Humanoid.RootPart
    end
    return nil
end
_F.IsF = function(p)
    if not p or p == _F.L then return false end
    return _F.L:IsFriendsWith(p.UserId)
end
_F.GetT = function()
    local tgs = {}
    local root = _F.HRP()
    if not root then return tgs end
    local pos = root.Position
    for _, v in ipairs(_F.P:GetPlayers()) do
        local char = v.Character
        if char and v ~= _F.L and char:FindFirstChild(' ') == nil then
            if _F.Cfg.Friends and _F.IsF(v) then continue end
            local hum = char:FindFirstChild('Humanoid')
            local hrp = char:FindFirstChild('HumanoidRootPart')
            if hum and hrp then
                local dist = (hrp.Position - pos).Magnitude
                if dist < _F.Cfg.Range then
                    local lchar = _F.L.Character
                    if lchar then
                        local lName = lchar.Name
                        local cs = char:GetAttribute("Cutscene")
                        local csV = not cs or cs == lchar:GetAttribute("Cutscene")
                        if hrp and not char:GetAttribute("Ignore") and csV and
                           ((not char:GetAttribute("Grabbed") or char:GetAttribute("Grabbed") == lName) and
                           (not char:GetAttribute("Victim") or char:GetAttribute("Victim") == lName)) and
                           not char:GetAttribute("Invincible") and not char:GetAttribute("Grabbing") then
                            table.insert(tgs, {c = char, d = dist, h = hum:GetAttribute("Health") or hum.Health or 0})
                        end
                    end
                end
            end
        end
    end
    if _F.Cfg.Target == "Closest" and #tgs > 0 then
        table.sort(tgs, function(a, b) return a.d < b.d end)
        return {tgs[1]}
    end
    return tgs
end
_F.Aura = function(n)
    local root = _F.HRP()
    if not root then return end
    local tgs = _F.GetT()
    for _, data in ipairs(tgs) do
        if data.c then
            for i=1, n do
                _F.Data.List[_F.Data.Idx] = data.c
                _F.Data.Idx = _F.Data.Idx + 1
            end
        end
    end
    if _F.Data.Idx > 1 then
        local name = _F.L.Data.Character.Value
        local combo = _F.RS.Characters[name].WallCombo
        _F.RS.Remotes.Abilities.Ability:FireServer(combo, 69)
        _F.RS.Remotes.Combat.Action:FireServer(combo, "", 4, 69, {BestHitCharacter=nil, HitCharacters=_F.Data.List, Ignore={}, Actions={}})
        for k in pairs(_F.Data.List) do _F.Data.List[k] = nil end
        _F.Data.Idx = 1
    end
end
_F.GetR = function()
    local al = {}
    for _, p in ipairs(_F.P:GetPlayers()) do
        if p ~= _F.L and p.Character then
            local hu = p.Character:FindFirstChild("Humanoid")
            local hr = p.Character:FindFirstChild("HumanoidRootPart")
            if hu and hr and (hu:GetAttribute("Health") or 0) > 0 and not hu:GetAttribute("Godmode") then
                table.insert(al, p)
            end
        end
    end
    return #al > 0 and al[math.random(1, #al)] or nil
end
_F.TP = function(p)
    if not p or not p.Character then return false end
    local hr = p.Character:FindFirstChild("HumanoidRootPart")
    if not hr then return false end
    pcall(function()
        require(_F.L.PlayerScripts.Character.FullCustomReplication).Override(_F.L.Character, CFrame.new(hr.Position - Vector3.new(0, 30, 0)))
    end)
    return true
end
_F.Spec = function(p)
    local cam = _F.W.CurrentCamera
    if cam and p and p.Character then
        local hu = p.Character:FindFirstChildOfClass("Humanoid")
        if hu then cam.CameraType = Enum.CameraType.Custom; cam.CameraSubject = hu end
    end
end
_F.Loop = function()
    local c = _F.L.Character
    if not c or not c.Parent then return end
    local r = _F.GetR()
    if r then
        _F.TP(r)
        _F.Spec(r)
        task.wait(0.5)
    end
end
_F.Grav = function(b)
    local c = _F.L.Character
    if not c then return end
    for _, p in ipairs(c:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = not b
            if not b then p.Velocity = Vector3.new(0,0,0) end
        end
    end
end
_F.Save = function()
    local c = _F.L.Character
    local hr = c and c:FindFirstChild("HumanoidRootPart")
    if not hr then return false end
    _F.Data.SCFrame = hr.CFrame
    local cam = _F.W.CurrentCamera
    if cam then
        _F.Data.SCCFrame = cam.CFrame
        _F.Data.SCType = cam.CameraType
    end
    return true
end
_F.Rest = function()
    if not _F.Data.SCFrame or not _F.L.Character then return end
    pcall(function() require(_F.L.PlayerScripts.Character.FullCustomReplication).Override(_F.L.Character, _F.Data.SCFrame) end)
    task.delay(0.1, function()
        local cam = _F.W.CurrentCamera
        if cam and _F.Data.SCCFrame then
            cam.CameraType = _F.Data.SCType
            cam.CFrame = _F.Data.SCCFrame
        end
    end)
end
_F.Start = function()
    if not _F.Save() then return end
    _F.Grav(false)
    local cam = _F.W.CurrentCamera
    if cam then
        _F.Data.OSub = cam.CameraSubject
        _F.Data.OType = cam.CameraType
    end
    _F.Data.FCon = _F.R.Heartbeat:Connect(_F.Loop)
    _F.Data.KCon = _F.R.Heartbeat:Connect(function()
        _F.Dash()
        local cn = _F.L.Data.Character.Value
        _F.Aura(cn == "Gon" and 20 or 50)
    end)
end
_F.Stop = function()
    if _F.Data.FCon then _F.Data.FCon:Disconnect(); _F.Data.FCon = nil end
    if _F.Data.KCon then _F.Data.KCon:Disconnect(); _F.Data.KCon = nil end
    _F.Rest()
    _F.Grav(true)
    local cam = _F.W.CurrentCamera
    if cam and _F.Data.OSub then
        cam.CameraSubject = _F.Data.OSub
        cam.CameraType = _F.Data.OType
    end
end
addToggle(ViolenceLeft, 'FullMapKillToggle', { Text = '全图秒杀', Default = false, Callback = function(state)
    _F.Cfg.Enabled = state
    if _F.Cfg.Enabled then _F.Start() else _F.Stop() end
end })
_F.L.CharacterAdded:Connect(function()
    if _F.Cfg.Enabled then _F.Stop(); _F.Cfg.Enabled = false end
end)

local Core = safeRequire(ReplicatedStorage, {"Core"})
if Core then
    local charValueObj = safeWait(player, "Data", 2)
    charValueObj = charValueObj and safeWait(charValueObj, "Character", 2)
    local charValue = charValueObj and charValueObj.Value
    local chars = ReplicatedStorage:FindFirstChild("Characters")
    local ability = chars and charValue and chars:FindFirstChild(charValue) and chars[charValue]:FindFirstChild("WallCombo")
    local wallComboCooldown = 0.05
    local lastWallComboTime = 0
    local wallComboKey = Enum.KeyCode.E
    local lastDashTime = 0
    local wallComboEnabled = false
    local ignoreFriends = false
    local wallComboConn, dashConn = nil, nil
    local function isFriend3(targetPlayer)
        local ok, res = pcall(function() return player:IsFriendsWith(targetPlayer.UserId) end)
        return ok and res
    end
    local function shouldIgnorePlayerModel(model)
        if not model then return false end
        if ignoreFriends then
            for _, pl in ipairs(Players:GetPlayers()) do
                if pl ~= player and pl.Character == model then
                    if isFriend3(pl) then return true end
                end
            end
        end
        return false
    end
    local function getHead()
        local character = player.Character
        if not character then return nil end
        return character:FindFirstChild("Head")
    end
    local function hasValidTargetsForWallCombo(range)
        local head = getHead()
        if not head then return false end
        local hrpPos = head.Position
        for _, pl in ipairs(Players:GetPlayers()) do
            if pl ~= player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then
                if not shouldIgnorePlayerModel(pl.Character) then
                    local d = (pl.Character.HumanoidRootPart.Position - hrpPos).Magnitude
                    if d <= range then return true end
                end
            end
        end
        return false
    end
    local function executeWallCombo()
        local head = getHead()
        if not head then return end
        if tick() - lastWallComboTime < wallComboCooldown then return end
        if not hasValidTargetsForWallCombo(100) then return end
        lastWallComboTime = tick()
        local res
        local success = pcall(function()
            res = Core.Get("Combat","Hit").Box(nil, player.Character, {Size = Vector3.new(100,100,100)})
        end)
        if not success or not res then return end
        pcall(function()
            Core.Get("Combat","Ability").Activate(chars[charValue].WallCombo, res, head.Position + Vector3.new(0,0,2.5))
        end)
    end
    local function fireDash()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if tick() - lastDashTime < 0.1 then return end
        lastDashTime = tick()
        local args = { hrp.CFrame, "F", hrp.CFrame.LookVector, nil, tick() }
        local dashRemote = safeGet(ReplicatedStorage, {"Remotes", "Character", "Dash"})
        if dashRemote then dashRemote:FireServer(unpack(args)) end
    end
    local function toggleWallComboFunc(state)
        wallComboEnabled = state
        if wallComboConn then wallComboConn:Disconnect(); wallComboConn = nil end
        if dashConn then dashConn:Disconnect(); dashConn = nil end
        if wallComboEnabled then
            wallComboConn = RunService.Heartbeat:Connect(executeWallCombo)
            dashConn = RunService.Heartbeat:Connect(fireDash)
        end
    end
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode == wallComboKey then executeWallCombo() end
    end)

    local Configs = {
        IgnoreFriends = false,
        MaxDistance = 100,
        Damage = 9999,
        HealthLimit = 0,
        DashInterval = 0.7,
        AttackInterval = 0.001
    }
    local running = false
    local auraConn
    local lastDash = 0
    local lastAttack = 0
    local data = safeWait(player, "Data", 2)
    local charValue2 = data and safeWait(data, "Character", 2)
    local localCharacterName = charValue2 and charValue2.Value
    local ability2 = localCharacterName and ReplicatedStorage:FindFirstChild("Characters") and ReplicatedStorage.Characters:FindFirstChild(localCharacterName) and ReplicatedStorage.Characters[localCharacterName]:FindFirstChild("WallCombo")
    local AbilitiesRemote = safeGet(ReplicatedStorage, {"Remotes", "Abilities", "Ability"})
    local CombatRemote = safeGet(ReplicatedStorage, {"Remotes", "Combat", "Action"})
    local function getLocalRootPart()
        local c = player.Character
        return c and c:FindFirstChild("HumanoidRootPart")
    end
    local function triggerDash()
        if tick() - lastDash < Configs.DashInterval then return end
        lastDash = tick()
        local hrp = getLocalRootPart()
        if not hrp then return end
        local dashRemote = safeGet(ReplicatedStorage, {"Remotes", "Character", "Dash"})
        if dashRemote then
            pcall(function() dashRemote:FireServer(hrp.CFrame, "L", hrp.CFrame.LookVector, nil, tick()) end)
        end
    end
    local function sendKillAura()
        if not ability2 or not AbilitiesRemote or not CombatRemote then return end
        if tick() - lastAttack < Configs.AttackInterval then return end
        lastAttack = tick()
        local localRootPart = getLocalRootPart()
        if not localRootPart then return end
        triggerDash()
        local maxDistSq = Configs.MaxDistance * Configs.MaxDistance
        for _, targetPlayer in ipairs(Players:GetPlayers()) do
            if targetPlayer ~= player and targetPlayer.Character then
                local targetRootPart = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                local targetHumanoid = targetPlayer.Character:FindFirstChild("Humanoid")
                if targetRootPart and targetHumanoid and targetHumanoid.Health > Configs.HealthLimit then
                    if not (Configs.IgnoreFriends and player:IsFriendsWith(targetPlayer.UserId)) then
                        local delta = localRootPart.Position - targetRootPart.Position
                        if delta.Magnitude * delta.Magnitude <= maxDistSq then
                            pcall(function()
                                AbilitiesRemote:FireServer(ability2, Configs.Damage, {}, targetRootPart.Position)
                                CombatRemote:FireServer(ability2, localCharacterName .. ":WallCombo", 2, Configs.Damage, {
                                    HitboxCFrames = {targetRootPart.CFrame, targetRootPart.CFrame},
                                    BestHitCharacter = targetPlayer.Character,
                                    HitCharacters = {targetPlayer.Character},
                                    Ignore = {}, DeathInfo = {}, BlockedCharacters = {},
                                    HitInfo = {IsFacing = false, IsInFront = true},
                                    ServerTime = os.time(),
                                    Actions = { ActionNumber1 = { [targetPlayer.Name] = {
                                        StartCFrameStr = tostring(localRootPart.CFrame), Local = true, Collision = false,
                                        Animation = "Punch1Hit", Preset = "Punch", Velocity = Vector3.zero,
                                        FromPosition = targetRootPart.Position, Seed = math.random(1,999999)
                                    } } },
                                    FromCFrame = targetRootPart.CFrame
                                }, "Action150", 0)
                            end)
                        end
                    end
                end
            end
        end
    end
    local function startAura()
        if auraConn then auraConn:Disconnect(); auraConn = nil end
        auraConn = RunService.Heartbeat:Connect(function()
            if running then sendKillAura() end
        end)
    end
    local function stopAura()
        if auraConn then auraConn:Disconnect(); auraConn = nil end
    end

    addToggle(ViolenceLeft, 'KillAuraV1Toggle', { Text = '杀戮光环v1(慢)', Default = false, Callback = function(state)
        running = state
        if running then startAura() else stopAura() end
    end })

    local enabled2 = false
    local conn2
    local PlayersList = {}
    local index = 1
    local RANGE = 70
    local DASH_INTERVAL2 = 0.25
    local lastDash2 = 0
    local function KillAuraV2(count)
        if not player.Data or not player.Data.Character or not ReplicatedStorage.Characters then return end
        local comboName = player.Data.Character.Value
        local combo = ReplicatedStorage.Characters[comboName] and ReplicatedStorage.Characters[comboName].WallCombo
        if not combo then return end
        local now = tick()
        if now - lastDash2 < DASH_INTERVAL2 then return end
        lastDash2 = now
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local dashRemote = safeGet(ReplicatedStorage, {"Remotes", "Character", "Dash"})
        if dashRemote then
            pcall(function() dashRemote:FireServer(hrp.CFrame, "L", hrp.CFrame.LookVector, nil, now) end)
        end
        local targets = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid")
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if hum and root and hum.Health > 0 and (root.Position - hrp.Position).Magnitude <= RANGE then
                    if not p.Character:GetAttribute("Invincible") then
                        table.insert(targets, p.Character)
                    end
                end
            end
        end
        for _, char in ipairs(targets) do
            for _ = 1, count do
                PlayersList[index] = char
                index = index + 1
            end
        end
        if index > 1 then
            ReplicatedStorage.Remotes.Abilities.Ability:FireServer(combo, 69)
            ReplicatedStorage.Remotes.Combat.Action:FireServer(combo, "", 4, 69, {
                BestHitCharacter = nil,
                HitCharacters = PlayersList,
                Ignore = {},
                Actions = {}
            })
            table.clear(PlayersList)
            index = 1
        end
    end
    addToggle(ViolenceLeft, 'KillAuraV2Toggle', { Text = '杀戮光环v2(快)', Default = false, Callback = function(state)
        enabled2 = state
        if enabled2 then
            conn2 = RunService.Heartbeat:Connect(function()
                local count = (player.Data.Character.Value == "Gon") and 20 or 50
                KillAuraV2(count)
            end)
        else
            if conn2 then conn2:Disconnect(); conn2 = nil end
        end
    end })
    addToggle(ViolenceLeft, 'KillAuraIgnoreFriendsToggle', { Text = '杀戮光环忽略好友', Default = false, Callback = function(state)
        Configs.IgnoreFriends = state
    end })
    addToggle(ViolenceLeft, 'WallComboKillToggle', { Text = '墙打秒杀', Default = false, Callback = toggleWallComboFunc })
    addToggle(ViolenceLeft, 'WallComboIgnoreFriendsToggle', { Text = '墙打秒杀忽略好友', Default = false, Callback = function(state)
        ignoreFriends = state
    end })
else
    addToggle(ViolenceLeft, 'KillAuraV1Toggle', { Text = '杀戮光环v1(慢)', Default = false, Callback = function() Library:Notify("Core未加载", 3) end })
    addToggle(ViolenceLeft, 'KillAuraV2Toggle', { Text = '杀戮光环v2(快)', Default = false, Callback = function() Library:Notify("Core未加载", 3) end })
    addToggle(ViolenceLeft, 'KillAuraIgnoreFriendsToggle', { Text = '杀戮光环忽略好友', Default = false })
    addToggle(ViolenceLeft, 'WallComboKillToggle', { Text = '墙打秒杀', Default = false })
    addToggle(ViolenceLeft, 'WallComboIgnoreFriendsToggle', { Text = '墙打秒杀忽略好友', Default = false })
end

local HitboxTab = Tabs.Hitbox
if HitboxTab then
    local HitboxGroup = safeCall(HitboxTab.AddLeftGroupbox, HitboxTab, "碰撞箱扩大")
    if HitboxGroup then
        local S = {
            Players = Players,
            RunService = RunService,
            ReplicatedStorage = ReplicatedStorage,
            Cfg = { Hitbox = false, X = 150, Y = 150, Z = 150, Enhancer = false, Multi = 3 },
            Cache = {},
            Conn = nil,
            DashT = 0
        }
        local LP = player
        getgenv().HitboxEnabled = false
        function S:HRP()
            local c = LP.Character
            return c and c:FindFirstChild("HumanoidRootPart")
        end
        function S:GetCore()
            if self.Cache.Core then return self.Cache.Core end
            local ok, core = pcall(function()
                return require(self.ReplicatedStorage:WaitForChild("Core", 2))
            end)
            if ok then self.Cache.Core = core; return core end
        end
        function S:ToggleHitbox(state)
            self.Cfg.Hitbox = state
            getgenv().HitboxEnabled = state
            local core = self:GetCore()
            if not core or not core.Get then return end
            local hit = core.Get("Combat", "Hit")
            if not hit or not hit.Box then return end
            if state then
                if not self.Cache.OrigBox then
                    self.Cache.OrigBox = hit.Box
                end
                hit.Box = function(_, char, data)
                    data = data or {}
                    data.Size = Vector3.new(self.Cfg.X, self.Cfg.Y, self.Cfg.Z)
                    return self.Cache.OrigBox(nil, char, data)
                end
            else
                if self.Cache.OrigBox then
                    hit.Box = self.Cache.OrigBox
                end
            end
        end
        function S:Dash()
            if tick() - self.DashT < 0.18 then return end
            self.DashT = tick()
            local hrp = self:HRP()
            if not hrp then return end
            pcall(function()
                self:GetCore().Library("Remote").Send("Dash", hrp.CFrame, "L", 1)
            end)
        end
        function S:EnableEnhancer()
            if self.Cache.HitProc then return end
            local ok, hit = pcall(function()
                return require(LP.PlayerScripts:WaitForChild("Combat", 2):WaitForChild("Hit", 2))
            end)
            if not ok or not hit.Process then return end
            self.Cache.HitProc = hit.Process
            hit.Process = function(...)
                local best, targets, blocked = self.Cache.HitProc(...)
                if not targets or #targets == 0 then return best, targets, blocked end
                self:Dash()
                local r = self.ReplicatedStorage.Remotes.Combat.Action
                for _ = 1, self.Cfg.Multi do
                    pcall(function()
                        r:FireServer(nil, "", 4, 69, {BestHitCharacter=nil, HitCharacters=targets, Ignore={}, Actions={}})
                    end)
                end
                return best, targets, blocked
            end
        end
        function S:DisableEnhancer()
            if not self.Cache.HitProc then return end
            local ok, hit = pcall(function()
                return require(LP.PlayerScripts.Combat.Hit)
            end)
            if ok then hit.Process = self.Cache.HitProc end
            self.Cache.HitProc = nil
        end
        function S:StartDashLoop()
            if self.Conn then return end
            self.Conn = self.RunService.Heartbeat:Connect(function() self:Dash() end)
        end
        function S:StopDashLoop()
            if self.Conn then self.Conn:Disconnect(); self.Conn = nil end
        end
        addToggle(HitboxGroup, 'ExpandHitboxToggle', { Text = '碰撞箱扩大', Default = false, Callback = function(v)
            if v then
                S:ToggleHitbox(true)
                S:EnableEnhancer()
                S:StartDashLoop()
            else
                S:ToggleHitbox(false)
                S:DisableEnhancer()
                S:StopDashLoop()
            end
        end })
        addInput(HitboxGroup, 'HitboxXInput', { Text = '碰撞箱X轴', Default = "150", Numeric = true, Callback = function(v)
            v = tonumber(v)
            if v then S.Cfg.X = math.clamp(v, 10, 150) end
        end })
        addInput(HitboxGroup, 'HitboxYInput', { Text = '碰撞箱Y轴', Default = "150", Numeric = true, Callback = function(v)
            v = tonumber(v)
            if v then S.Cfg.Y = math.clamp(v, 10, 150) end
        end })
        addInput(HitboxGroup, 'HitboxZInput', { Text = '碰撞箱Z轴', Default = "150", Numeric = true, Callback = function(v)
            v = tonumber(v)
            if v then S.Cfg.Z = math.clamp(v, 10, 150) end
        end })
    end
end

local LockTab = Tabs.Lock
if LockTab then
    local LockLeft = safeCall(LockTab.AddLeftGroupbox, LockTab, "锁人")
    if LockLeft then
        local S2 = {}
        S2.Players = Players
        S2.RunService = RunService
        S2.LocalPlayer = player
        S2.BEHIND_DISTANCE = 5
        S2.CIRCLE_RADIUS = 6
        S2.CIRCLE_SPEED = 13
        S2.followEnabled = false
        S2.circleEnabled = false
        S2.lookEnabled = false
        S2.selectedTargetName = nil
        S2.circleAngle = 0
        S2.mainConnection = nil
        function S2.getRoot(p)
            if p and p.Character then return p.Character:FindFirstChild("HumanoidRootPart") end
        end
        function S2.getPlayerByName(name)
            for _, p in pairs(Players:GetPlayers()) do
                if p.Name == name then return p end
            end
        end
        function S2.getPlayerNames()
            local names = {}
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= player then table.insert(names, p.Name) end
            end
            return names
        end
        function S2.updateLoop(dt)
            if not S2.selectedTargetName then return end
            local target = S2.getPlayerByName(S2.selectedTargetName)
            local targetRoot = S2.getRoot(target)
            local myRoot = S2.getRoot(player)
            if not targetRoot or not myRoot then return end
            local targetPos = targetRoot.Position
            local finalPos = nil
            if S2.circleEnabled then
                S2.circleAngle = S2.circleAngle + (S2.CIRCLE_SPEED * dt)
                local x = math.cos(S2.circleAngle) * S2.CIRCLE_RADIUS
                local z = math.sin(S2.circleAngle) * S2.CIRCLE_RADIUS
                finalPos = targetPos + Vector3.new(x, 0, z)
            elseif S2.followEnabled then
                local offset = targetRoot.CFrame.LookVector * S2.BEHIND_DISTANCE
                finalPos = targetPos - offset
            end
            if finalPos then
                if S2.lookEnabled then
                    myRoot.CFrame = CFrame.new(finalPos, Vector3.new(targetPos.X, finalPos.Y, targetPos.Z))
                else
                    myRoot.CFrame = CFrame.new(finalPos) * myRoot.CFrame.Rotation
                end
            elseif S2.lookEnabled then
                local myPos = myRoot.Position
                myRoot.CFrame = CFrame.new(myPos, Vector3.new(targetPos.X, myPos.Y, targetPos.Z))
            end
        end
        function S2.toggleConnection()
            if S2.followEnabled or S2.circleEnabled or S2.lookEnabled then
                if not S2.mainConnection then
                    S2.mainConnection = RunService.RenderStepped:Connect(S2.updateLoop)
                end
            else
                if S2.mainConnection then S2.mainConnection:Disconnect(); S2.mainConnection = nil end
            end
        end
        local playerDropdown
        addDropdown(LockLeft, 'TargetPlayerDropdown', {
            Text = '选择目标玩家',
            Values = S2.getPlayerNames(),
            Default = 1,
            Multi = false,
            Callback = function(name)
                S2.selectedTargetName = name
            end
        })
        playerDropdown = LockLeft:FindFirstChild? and LockLeft:FindFirstChild("TargetPlayerDropdown") or nil
        addButton(LockLeft, { Text = '刷新玩家列表', Func = function()
            S2.selectedTargetName = nil
            local newNames = S2.getPlayerNames()
            if playerDropdown then
                if playerDropdown.SetValues then playerDropdown:SetValues(newNames)
                elseif playerDropdown.Refresh then playerDropdown:Refresh(newNames, true) end
                if playerDropdown.SetValue then playerDropdown:SetValue(nil) end
            end
        end })
        addToggle(LockLeft, 'LockBehindToggle', { Text = '锁背', Default = false, Callback = function(state)
            S2.followEnabled = state
            if state then S2.circleEnabled = false end
            S2.toggleConnection()
        end })
        addToggle(LockLeft, 'CircleLockToggle', { Text = '转圈', Default = false, Callback = function(state)
            S2.circleEnabled = state
            if state then S2.followEnabled = false end
            S2.toggleConnection()
        end })
        addToggle(LockLeft, 'LookAtPlayerToggle', { Text = '看着玩家(需要关移位锁)', Default = false, Callback = function(state)
            S2.lookEnabled = state
            S2.toggleConnection()
        end })
    end
end

local EmoteTab = Tabs.Emote
if EmoteTab then
    local EmoteLeft = safeCall(EmoteTab.AddLeftGroupbox, EmoteTab, "击杀表情")
    if EmoteLeft then
        local T = {}
        T.env = {
            ReplicatedStorage = ReplicatedStorage,
            Players = Players,
            LocalPlayer = player,
            core = safeRequire(ReplicatedStorage, {"Core"})
        }
        T.env.Character = player.Character or player.CharacterAdded:Wait()
        T.env.HumanoidRootPart = T.env.Character:WaitForChild("HumanoidRootPart")
        T.state = {
            killEmotes = {},
            aura = false,
            spam = false,
            auraDelay = 0.5,
            spamDelay = 0.5,
            selectedEmote = "",
            keybind = Enum.KeyCode.G,
            dropdown = nil,
            tmp = {}
        }
        function T.getRoot(char)
            return char and char:FindFirstChild("HumanoidRootPart")
        end
        function T.useEmote(name)
            local tmp = T.state.tmp
            local cosmetics = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
            tmp.emote = cosmetics and cosmetics:FindFirstChild("KillEmote") and cosmetics.KillEmote:FindFirstChild(name)
            tmp.myRoot = T.getRoot(T.env.LocalPlayer.Character)
            if not tmp.emote or not tmp.myRoot then return end
            if not T.env.core then Library:Notify("击杀表情不可用（Core缺失）", 3); return end
            tmp.closest = nil
            tmp.dist = math.huge
            for _, p in pairs(T.env.Players:GetPlayers()) do
                if p ~= T.env.LocalPlayer and p.Character then
                    tmp.r = T.getRoot(p.Character)
                    if tmp.r then
                        tmp.d = (tmp.myRoot.Position - tmp.r.Position).Magnitude
                        if tmp.d < tmp.dist then
                            tmp.dist = tmp.d
                            tmp.closest = p.Character
                        end
                    end
                end
            end
            if tmp.closest then
                task.spawn(function()
                    _G.KillEmote = true
                    pcall(function()
                        T.env.core.Get("Combat", "Ability").Activate(tmp.emote, tmp.closest)
                    end)
                    _G.KillEmote = false
                end)
            end
        end
        function T.useRandom()
            local list = T.state.killEmotes
            if #list > 0 then T.useEmote(list[math.random(#list)]) end
        end
        task.spawn(function()
            while true do
                if T.state.aura then T.useRandom() task.wait(T.state.auraDelay) else task.wait(0.1) end
            end
        end)
        task.spawn(function()
            while true do
                if T.state.spam and T.state.selectedEmote ~= "" then
                    T.useEmote(T.state.selectedEmote)
                    task.wait(T.state.spamDelay)
                else
                    task.wait(0.1)
                end
            end
        end)
        UserInputService.InputBegan:Connect(function(i, g)
            if not g and i.KeyCode == T.state.keybind and T.state.selectedEmote ~= "" then
                T.useEmote(T.state.selectedEmote)
            end
        end)
        function T.updateDropdown(list)
            local values = (#list > 0 and list) or { "No emotes found" }
            if T.state.dropdown then
                pcall(function() T.state.dropdown:Destroy() end)
                T.state.dropdown = nil
            end
            addDropdown(EmoteLeft, 'KillEmoteDropdown', {
                Text = '击杀表情功能(要靠近别人)',
                Values = values,
                Default = 1,
                Multi = false,
                Callback = function(v)
                    if v ~= "No emotes found" then
                        T.state.selectedEmote = v
                        T.useEmote(v)
                    end
                end
            })
        end
        addButton(EmoteLeft, { Text = '刷新击杀表情', Func = function()
            table.clear(T.state.killEmotes)
            local cosmetics = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
            if cosmetics and cosmetics:FindFirstChild("KillEmote") then
                for _, e in pairs(cosmetics.KillEmote:GetChildren()) do
                    T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
                end
            end
            T.updateDropdown(T.state.killEmotes)
        end })
        local cosmeticsInit = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
        if cosmeticsInit and cosmeticsInit:FindFirstChild("KillEmote") then
            for _, e in pairs(cosmeticsInit.KillEmote:GetChildren()) do
                T.state.killEmotes[#T.state.killEmotes + 1] = e.Name
            end
        end
        T.updateDropdown(T.state.killEmotes)
        addToggle(EmoteLeft, 'KillEmoteAuraToggle', { Text = '击杀表情光环', Default = false, Callback = function(v)
            T.state.aura = v
        end })
        addSlider(EmoteLeft, 'KillEmoteAuraDelaySlider', { Text = '击杀表情光环间隔', Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v)
            T.state.auraDelay = v
        end })
        addToggle(EmoteLeft, 'SpamEmoteToggle', { Text = '持续发送你选择的表情', Default = false, Callback = function(v)
            T.state.spam = v
        end })
        addSlider(EmoteLeft, 'SpamEmoteDelaySlider', { Text = '调整你选择的表情速度', Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v)
            T.state.spamDelay = v
        end })
        local keyMap = {
            G = Enum.KeyCode.G, F = Enum.KeyCode.F, H = Enum.KeyCode.H, J = Enum.KeyCode.J,
            K = Enum.KeyCode.K, L = Enum.KeyCode.L, Z = Enum.KeyCode.Z, X = Enum.KeyCode.X,
            C = Enum.KeyCode.C, V = Enum.KeyCode.V, B = Enum.KeyCode.B, N = Enum.KeyCode.N,
            M = Enum.KeyCode.M, Q = Enum.KeyCode.Q, E = Enum.KeyCode.E, R = Enum.KeyCode.R,
            T = Enum.KeyCode.T, Y = Enum.KeyCode.Y, U = Enum.KeyCode.U, I = Enum.KeyCode.I,
            O = Enum.KeyCode.O, P = Enum.KeyCode.P,
        }
        local keyList = {}
        for k in pairs(keyMap) do table.insert(keyList, k) end
        table.sort(keyList)
        addDropdown(EmoteLeft, 'KeybindDropdown', {
            Text = '快捷键设置',
            Values = keyList,
            Default = 1,
            Callback = function(v) T.state.keybind = keyMap[v] end
        })
        addButton(EmoteLeft, { Text = '随机用一个击杀表情', Func = function() T.useRandom() end })
    end
end

if Tabs.Settings then
    local SettingsGroup = safeCall(Tabs.Settings.AddLeftGroupbox, Tabs.Settings, "脚本管理")
    if SettingsGroup then
        addButton(SettingsGroup, { Text = '卸载脚本', Func = function() Library:Unload() end })
    end
end

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("MyScriptTheme")
    if Tabs.Settings then ThemeManager:ApplyToTab(Tabs.Settings) end
end

if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("MyScriptConfig")
    if Tabs.Settings then SaveManager:BuildConfigSection(Tabs.Settings) end
end
