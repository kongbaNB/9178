local AutoBandageGroup = Tabs.Auto:AddLeftGroupbox("自动绷带")
AutoBandageGroup:AddSlider('MinHealth', {
    Text = '使用绷带血量',
    Default = 30,
    Min = 1,
    Max = 100,
    Rounding = 0,
}):OnChanged(function(value)
    MinHealth = value
end)
AutoBandageGroup:AddToggle('AutoBandage', {
    Text = '自动使用绷带',
    Default = false,
}):OnChanged(function(value)
    if value then
        AutoBandage = true
        autoBandageThread = task.spawn(function()
            while AutoBandage do
                pcall(function()
                    for _,v in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
                        if v.Name == "Bandage" then
                            if game.Players.LocalPlayer.Character.Humanoid.Health <= MinHealth then
                                v.Parent = game:GetService("Players").LocalPlayer.Character
                                game:GetService("Players").LocalPlayer.Character.Bandage.Use:FireServer()
                            end
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
        Library:Notify("自动使用绷带已启用", 2)
    else
        AutoBandage = false
        if autoBandageThread then
            task.cancel(autoBandageThread)
            autoBandageThread = nil
        end
        Library:Notify("自动使用绷带已关闭", 2)
    end
end)

