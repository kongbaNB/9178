local player = Players.LocalPlayer

local function safeWait(parent, name, timeout)
    timeout = timeout or 2
    local obj = nil
    pcall(function() obj = parent:WaitForChild(name, timeout) end)
    return obj
end

local function safeGet(rs, path)
    local obj = rs
    for _, name in ipairs(path) do
        if obj and obj:FindFirstChild(name) then
            obj = obj[name]
        else
            return nil
        end
    end
    return obj
end

local function safeRequire(inst, path)
    local obj = safeGet(inst, path)
    if obj and obj:IsA("ModuleScript") then
        local ok, mod = pcall(require, obj)
        if ok then return mod end
    end
    return nil
end

