end })

local multiCut = toggles and toggles:FindFirstChild("MultiUseCutscenes")
sAddTog(MainLeft2, 'MultiUseCutscenesToggle', { Text = '艾斯帕大招技能多次使用(全角色通用)', Default = false, Callback = function(state) if multiCut then multiCut.Value = state end end })

local QEfly = true
local FLYING = false
local flyKd, flyKu, mobFly
local iyfs = 2
local vfs = 2
local FLY_STATE = false
local function getRoot(ch) return ch:FindFirstChild("HumanoidRootPart") or ch:FindFirstChild("Torso") or ch:FindFirstChild("UpperTorso") end
local function NOFLY()
    FLYING = false
    if flyKd then flyKd:Disconnect() flyKd=nil end
    if flyKu then flyKu:Disconnect() flyKu=nil end
    if mobFly then mobFly:Disconnect() mobFly=nil end
    local ch = player.Character
    if ch then
        local hum = ch:FindFirstChildOfClass("Humanoid")
        local rt = getRoot(ch)
        if hum then hum.PlatformStand = false end
        if rt then for _, v in pairs(rt:GetChildren()) do if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then v:Destroy() end end end
    end
    pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
end
local function sFLY(vfly)
    local ch = player.Character or player.CharacterAdded:Wait()
    local hum = ch:FindFirstChildOfClass("Humanoid") or ch:WaitForChild("Humanoid")
    local rt = getRoot(ch)
    if not rt then return end
    if flyKd then flyKd:Disconnect() end
    if flyKu then flyKu:Disconnect() end
    if mobFly then mobFly:Disconnect() end
    local CTRL = {F=0,B=0,L=0,R=0,Q=0,E=0}
    local BG = Instance.new("BodyGyro") local BV = Instance.new("BodyVelocity")
    BG.P=9e4 BG.MaxTorque=Vector3.new(9e9,9e9,9e9) BG.CFrame=rt.CFrame BG.Parent=rt
    BV.MaxForce=Vector3.new(9e9,9e9,9e9) BV.Velocity=Vector3.new(0,0,0) BV.Parent=rt
    FLYING = true
    flyKd = UserInputService.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Keyboard then
            if inp.KeyCode==Enum.KeyCode.W then CTRL.F=iyfs end
            if inp.KeyCode==Enum.KeyCode.S then CTRL.B=-iyfs end
            if inp.KeyCode==Enum.KeyCode.A then CTRL.L=-iyfs end
            if inp.KeyCode==Enum.KeyCode.D then CTRL.R=iyfs end
            if inp.KeyCode==Enum.KeyCode.E and QEfly then CTRL.Q=iyfs*2 end
            if inp.KeyCode==Enum.KeyCode.Q and QEfly then CTRL.E=-iyfs*2 end
        end
    end)
    flyKu = UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Keyboard then
            if inp.KeyCode==Enum.KeyCode.W then CTRL.F=0 end
            if inp.KeyCode==Enum.KeyCode.S then CTRL.B=0 end
            if inp.KeyCode==Enum.KeyCode.A then CTRL.L=0 end
            if inp.KeyCode==Enum.KeyCode.D then CTRL.R=0 end
            if inp.KeyCode==Enum.KeyCode.E then CTRL.Q=0 end
            if inp.KeyCode==Enum.KeyCode.Q then CTRL.E=0 end
        end
    end)
    mobFly = RunService.RenderStepped:Connect(function()
        if not FLYING then return end
        local cam = workspace.CurrentCamera
        local mv = Vector3.new(CTRL.L+CTRL.R, CTRL.Q+CTRL.E, CTRL.F+CTRL.B)
        local ok, ctrl = pcall(function() return require(player.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("ControlModule")) end)
        if ok and ctrl then
            local v = ctrl:GetMoveVector()
            mv = Vector3.new(v.X*(vfly and vfs or iyfs), mv.Y, -v.Z*(vfly and vfs or iyfs))
        end
        BV.Velocity = (cam.CFrame.RightVector*mv.X + Vector3.new(0,mv.Y,0) + cam.CFrame.LookVector*mv.Z)*50
        BG.CFrame = cam.CFrame
        hum.PlatformStand = true
    end)
end
local function applyFly() sFLY() player.CharacterAdded:Connect(function() if FLY_STATE then task.wait(0.5) sFLY() end end) end
sAddTog(MainLeft2, 'FlyToggle', { Text = '飞行', Default = false, Callback = function(state) FLY_STATE=state if state then applyFly() else NOFLY() end end })
sAddSld(MainLeft2, 'FlySpeedSlider', { Text = '飞行速度', Default = 2, Min = 1, Max = 10, Rounding = 0, Callback = function(v) iyfs=v vfs=v end })

local tpwalking = false
local tpwSpeed = 100
sAddTog(MainLeft2, 'SpeedToggle', { Text = '速度', Default = false, Callback = function(state)
    tpwalking = state
    if state then
        task.spawn(function()
            while tpwalking do
                local chr = player.Character or player.CharacterAdded:Wait()
                local hrp = chr:FindFirstChild("HumanoidRootPart")
                local hum = chr:FindFirstChildWhichIsA("Humanoid")
                local dt = RunService.Heartbeat:Wait()
                if hrp and hum and hum.MoveDirection.Magnitude>0 then
                    hrp.CFrame = hrp.CFrame + (hum.MoveDirection * tpwSpeed * dt)
                end
            end
        end)
    end
end })
sAddSld(MainLeft2, 'SpeedAdjustSlider', { Text = '速度调节', Default = 100, Min = 0, Max = 250, Rounding = 0, Callback = function(v) tpwSpeed=v end })
sAddSld(MainLeft2, 'DashSpeedSlider', { Text = '冲刺加速(默认值100)', Default = 100, Min = 0, Max = 1000, Rounding = 0, Callback = function(v) local ds = multipliers and multipliers:FindFirstChild("DashSpeed") if ds then ds.Value=v end end })
sAddSld(MainLeft2, 'JumpHeightSlider', { Text = '跳跃增强(默认值100)', Default = 100, Min = 0, Max = 1000, Rounding = 0, Callback = function(v) local jh = multipliers and multipliers:FindFirstChild("JumpHeight") if jh then jh.Value=v end end })
sAddSld(MainLeft2, 'MeleeSpeedSlider', { Text = '攻击加速(默认值100)', Default = 100, Min = 0, Max = 1000, Rounding = 0, Callback = function(v) local ms = multipliers and multipliers:FindFirstChild("MeleeSpeed") if ms then ms.Value=v end end })

local ViolenceLeft
if Tabs.Violence then ViolenceLeft = Tabs.Violence:AddLeftGroupbox("暴力功能") end

local activeGod = false
local function wallComboUltra()
    local pc = player.Character
    if not pc then return end
    local head = pc:FindFirstChild("Head")
    if not head then return end
    local charData = player:FindFirstChild("Data")
    local charVal = charData and charData:FindFirstChild("Character") and charData.Character.Value
    if not charVal then return end
    local cf = ReplicatedStorage:FindFirstChild("Characters")
    if not cf or not cf:FindFirstChild(charVal) then return end
    local wca = cf[charVal]:FindFirstChild("WallCombo")
    if not wca then return end
    local an = "Action"..math.random(1000,9999)
    local rid = math.random(100000,999999)
    local args = { wca, "Characters:"..charVal..":WallCombo", 1, rid, { HitboxCFrames={nil}, BestHitCharacter=pc, HitCharacters={pc}, Ignore={[an]={pc}}, DeathInfo={}, Actions={[an]={}}, HitInfo={ Blocked=false, IsFacing=true, IsInFront=true }, BlockedCharacters={}, ServerTime=tick(), FromCFrame=nil }, an }
    pcall(function() ReplicatedStorage.Remotes.Abilities.Ability:FireServer(wca, rid) end)
    pcall(function() ReplicatedStorage.Remotes.Combat.Action:FireServer(unpack(args)) end)
end
task.spawn(function() while task.wait(0.01) do if activeGod then pcall(wallComboUltra) end end end)
sAddTog(ViolenceLeft, 'GodModeToggle', { Text = '无敌', Default = false, Callback = function(state) activeGod = state end })

sAddBtn(ViolenceLeft, { Text = '卡服', Func = function()
    local a2 = true
    local ts = {}
    local function bca() return { [1]=ReplicatedStorage.Characters.Gon.WallCombo, [2]="Characters:Gon:WallCombo", [3]=1, [4]=33036, [5]={ ["HitboxCFrames"]={}, ["BestHitCharacter"]=workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum"), ["HitCharacters"]={workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum")}, ["Ignore"]={}, ["DeathInfo"]={}, ["Actions"]={}, ["HitInfo"]={ ["IsFacing"]=true, ["IsInFront"]=true }, ["BlockedCharacters"]={}, ["ServerTime"]=os.clock(), ["FromCFrame"]=CFrame.new(534.693,5.532,79.486) }, [6]="Action651", [7]=0 } end
    local aArgs = { [1]=ReplicatedStorage.Characters.Gon.WallCombo, [2]=33036, [4]=workspace.Characters.NPCs:FindFirstChild("The Ultimate Bum"), [5]=Vector3.new(527.693,4.532,79.978) }
    for i=1,10000 do
        local t = task.spawn(function() if a2 then pcall(function() local ca = bca() ReplicatedStorage.Remotes.Abilities.Ability:FireServer(unpack(aArgs)) ReplicatedStorage.Remotes.Combat.Action:FireServer(unpack(ca)) end) end end)
        table.insert(ts,t)
    end
    task.delay(3,function()
        a2=false
        for _,t in ipairs(ts) do if task.cancel then task.cancel(t) end end
        ts={}
        local lc = workspace:FindFirstChild("Container(Drawing)")
        if lc then for _,v in ipairs(lc:GetChildren()) do if v.Name:match(tostring(player.UserId)) then v:Destroy() end end end
    end)
end })

local _F = {}
_F.P = Players _F.R = RunService _F.RS = ReplicatedStorage _F.W = Workspace _F.L = player
_F.Cfg = { Enabled=false, Range=67.5, Friends=true, Target="Closest" }
_F.Data = { List={}, Idx=1, FCon=nil, KCon=nil, OSub=nil, OType=nil, SCFrame=nil, SCCFrame=nil, SCType=nil }
_F.Dash = function() local ch = _F.L.Character or _F.L.CharacterAdded:Wait() local hrp = ch:FindFirstChild("HumanoidRootPart") if hrp then pcall(function() require(_F.RS:WaitForChild("Core")).Library("Remote").Send("Dash", hrp.CFrame, "L", 1) end) end end
_F.HRP = function() local c = _F.L.Character if c and c:FindFirstChild('Humanoid') and c.Humanoid.RootPart then return c.Humanoid.RootPart end return nil end
_F.IsF = function(p) if not p or p==_F.L then return false end return _F.L:IsFriendsWith(p.UserId) end
_F.GetT = function()
    local tgs = {} local rt = _F.HRP() if not rt then return tgs end local pos = rt.Position
    for _, v in ipairs(_F.P:GetPlayers()) do
        local ch = v.Character
        if ch and v~=_F.L and ch:FindFirstChild(' ')==nil then
            if _F.Cfg.Friends and _F.IsF(v) then continue end
            local hum = ch:FindFirstChild('Humanoid') local hrp = ch:FindFirstChild('HumanoidRootPart')
            if hum and hrp then
                local dist = (hrp.Position-pos).Magnitude
                if dist < _F.Cfg.Range then
                    local lc = _F.L.Character
                    if lc then
                        local ln = lc.Name local cs = ch:GetAttribute("Cutscene") local csv = not cs or cs==lc:GetAttribute("Cutscene")
                        if hrp and not ch:GetAttribute("Ignore") and csv and ((not ch:GetAttribute("Grabbed") or ch:GetAttribute("Grabbed")==ln) and (not ch:GetAttribute("Victim") or ch:GetAttribute("Victim")==ln)) and not ch:GetAttribute("Invincible") and not ch:GetAttribute("Grabbing") then
                            table.insert(tgs, {c=ch, d=dist, h=hum:GetAttribute("Health") or hum.Health or 0})
                        end
                    end
                end
            end
        end
    end
    if _F.Cfg.Target=="Closest" and #tgs>0 then table.sort(tgs,function(a,b) return a.d<b.d end) return {tgs[1]} end
    return tgs
end
_F.Aura = function(n)
    local rt = _F.HRP() if not rt then return end
    local tgs = _F.GetT()
    for _, d in ipairs(tgs) do if d.c then for i=1,n do _F.Data.List[_F.Data.Idx]=d.c _F.Data.Idx=_F.Data.Idx+1 end end end
    if _F.Data.Idx>1 then
        local name = _F.L.Data.Character.Value local combo = _F.RS.Characters[name].WallCombo
        _F.RS.Remotes.Abilities.Ability:FireServer(combo,69)
        _F.RS.Remotes.Combat.Action:FireServer(combo,"",4,69,{BestHitCharacter=nil, HitCharacters=_F.Data.List, Ignore={}, Actions={}})
        for k in pairs(_F.Data.List) do _F.Data.List[k]=nil end _F.Data.Idx=1
    end
end
_F.GetR = function()
    local al = {}
    for _, p in ipairs(_F.P:GetPlayers()) do
        if p~=_F.L and p.Character then
            local hu = p.Character:FindFirstChild("Humanoid") local hr = p.Character:FindFirstChild("HumanoidRootPart")
            if hu and hr and (hu:GetAttribute("Health") or 0)>0 and not hu:GetAttribute("Godmode") then table.insert(al,p) end
        end
    end
    return #al>0 and al[math.random(1,#al)] or nil
end
_F.TP = function(p)
    if not p or not p.Character then return false end
    local hr = p.Character:FindFirstChild("HumanoidRootPart") if not hr then return false end
    pcall(function() require(_F.L.PlayerScripts.Character.FullCustomReplication).Override(_F.L.Character, CFrame.new(hr.Position-Vector3.new(0,30,0))) end)
    return true
end
_F.Spec = function(p)
    local cam = _F.W.CurrentCamera
    if cam and p and p.Character then local hu = p.Character:FindFirstChildOfClass("Humanoid") if hu then cam.CameraType=Enum.CameraType.Custom cam.CameraSubject=hu end end
end
_F.Loop = function()
    local c = _F.L.Character if not c or not c.Parent then return end
    local r = _F.GetR()
    if r then _F.TP(r) _F.Spec(r) task.wait(0.5) end
end
_F.Grav = function(b)
    local c = _F.L.Character if not c then return end
    for _, p in ipairs(c:GetDescendants()) do if p:IsA("BasePart") then p.Anchored = not b if not b then p.Velocity=Vector3.new(0,0,0) end end end
end
_F.Save = function()
    local c = _F.L.Character local hr = c and c:FindFirstChild("HumanoidRootPart") if not hr then return false end
    _F.Data.SCFrame = hr.CFrame
    local cam = _F.W.CurrentCamera
    if cam then _F.Data.SCCFrame=cam.CFrame _F.Data.SCType=cam.CameraType end
    return true
end
_F.Rest = function()
    if not _F.Data.SCFrame or not _F.L.Character then return end
    pcall(function() require(_F.L.PlayerScripts.Character.FullCustomReplication).Override(_F.L.Character, _F.Data.SCFrame) end)
    task.delay(0.1, function() local cam = _F.W.CurrentCamera if cam and _F.Data.SCCFrame then cam.CameraType=_F.Data.SCType cam.CFrame=_F.Data.SCCFrame end end)
end
_F.Start = function()
    if not _F.Save() then return end _F.Grav(false)
    local cam = _F.W.CurrentCamera if cam then _F.Data.OSub=cam.CameraSubject _F.Data.OType=cam.CameraType end
    _F.Data.FCon = _F.R.Heartbeat:Connect(_F.Loop) _F.Data.KCon = _F.R.Heartbeat:Connect(function() _F.Dash() local cn = _F.L.Data.Character.Value _F.Aura(cn=="Gon" and 20 or 50) end)
end
_F.Stop = function()
    if _F.Data.FCon then _F.Data.FCon:Disconnect() _F.Data.FCon=nil end
    if _F.Data.KCon then _F.Data.KCon:Disconnect() _F.Data.KCon=nil end
    _F.Rest() _F.Grav(true)
    local cam = _F.W.CurrentCamera if cam and _F.Data.OSub then cam.CameraSubject=_F.Data.OSub cam.CameraType=_F.Data.OType end
end
sAddTog(ViolenceLeft, 'FullMapKillToggle', { Text = '全图秒杀', Default = false, Callback = function(state) _F.Cfg.Enabled=state if state then _F.Start() else _F.Stop() end end })
_F.L.CharacterAdded:Connect(function() if _F.Cfg.Enabled then _F.Stop() _F.Cfg.Enabled=false end end)

local Core = nil pcall(function() Core = require(ReplicatedStorage:WaitForChild("Core")) end)
if Core then
    local charValue = player:FindFirstChild("Data") and player.Data:FindFirstChild("Character") and player.Data.Character.Value
    local chars = ReplicatedStorage:FindFirstChild("Characters")
    local ability = chars and charValue and chars:FindFirstChild(charValue) and chars[charValue]:FindFirstChild("WallCombo")
    local wccd = 0.05 local lastWc = 0 local wckey = Enum.KeyCode.E local lastDash = 0 local wcEnabled = false local ignFriends = false local wcconn, dashconn = nil, nil
    local function isF3(tp) local ok,res = pcall(function() return player:IsFriendsWith(tp.UserId) end) return ok and res end
    local function shdIgn(m) if not m then return false end if ignFriends then for _,pl in ipairs(Players:GetPlayers()) do if pl~=player and pl.Character==m then if isF3(pl) then return true end end end end return false end
    local function gh() local ch = player.Character if not ch then return nil end return ch:FindFirstChild("Head") end
    local function hvt(r) local hd = gh() if not hd then return false end local hp = hd.Position for _,pl in ipairs(Players:GetPlayers()) do if pl~=player and pl.Character and pl.Character:FindFirstChild("HumanoidRootPart") then if not shdIgn(pl.Character) then if (pl.Character.HumanoidRootPart.Position-hp).Magnitude <= r then return true end end end end return false end
    local function exeWc()
        local hd = gh() if not hd then return end local now = tick()
        if now - lastWc < wccd then return end if not hvt(100) then return end lastWc = now
        local res local ok = pcall(function() res = Core.Get("Combat","Hit").Box(nil, player.Character, {Size=Vector3.new(100,100,100)}) end)
        if not ok or not res then return end
        pcall(function() Core.Get("Combat","Ability").Activate(chars[charValue].WallCombo, res, hd.Position+Vector3.new(0,0,2.5)) end)
    end
    local function fd()
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
        local now = tick() if now - lastDash < 0.1 then return end lastDash = now
        local args = { hrp.CFrame, "F", hrp.CFrame.LookVector, nil, now }
        local dr = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Character") and ReplicatedStorage.Remotes.Character:FindFirstChild("Dash")
        if dr then dr:FireServer(unpack(args)) end
    end
    local function twf(state)
        wcEnabled = state
        if wcconn then wcconn:Disconnect() wcconn=nil end
        if dashconn then dashconn:Disconnect() dashconn=nil end
        if wcEnabled then wcconn = RunService.Heartbeat:Connect(exeWc) dashconn = RunService.Heartbeat:Connect(fd) end
    end
    UserInputService.InputBegan:Connect(function(input,proc) if proc then return end if input.KeyCode==wckey then exeWc() end end)
    local Configs = { IgnoreFriends=false, MaxDistance=100, Damage=9999, HealthLimit=0, DashInterval=0.7, AttackInterval=0.001 }
    local running = false local auraConn local lDash=0 local lAtt=0
    local data = player:FindFirstChild("Data") local cv2 = data and data:FindFirstChild("Character") local lcn = cv2 and cv2.Value
    local ab2 = lcn and ReplicatedStorage:FindFirstChild("Characters") and ReplicatedStorage.Characters:FindFirstChild(lcn) and ReplicatedStorage.Characters[lcn]:FindFirstChild("WallCombo")
    local AR = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Abilities") and ReplicatedStorage.Remotes.Abilities:FindFirstChild("Ability")
    local CR = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Combat") and ReplicatedStorage.Remotes.Combat:FindFirstChild("Action")
    local function glrp() local c = player.Character return c and c:FindFirstChild("HumanoidRootPart") end
    local function td()
        if tick()-lDash < Configs.DashInterval then return end lDash=tick()
        local hrp = glrp() if not hrp then return end
        local dr = ReplicatedStorage.Remotes.Character:FindFirstChild("Dash")
        if dr then pcall(function() dr:FireServer(hrp.CFrame,"L",hrp.CFrame.LookVector,nil,tick()) end) end
    end
    local function ska()
        if not ab2 or not AR or not CR then return end
        if tick()-lAtt < Configs.AttackInterval then return end lAtt=tick()
        local lrp = glrp() if not lrp then return end td()
        local mdsq = Configs.MaxDistance*Configs.MaxDistance
        for _, tp in ipairs(Players:GetPlayers()) do
            if tp~=player and tp.Character then
                local trp = tp.Character:FindFirstChild("HumanoidRootPart")
                local thum = tp.Character:FindFirstChild("Humanoid")
                if trp and thum and thum.Health>Configs.HealthLimit then
                    if not (Configs.IgnoreFriends and player:IsFriendsWith(tp.UserId)) then
                        local delta = lrp.Position - trp.Position
                        if delta.Magnitude*delta.Magnitude <= mdsq then
                            pcall(function()
                                AR:FireServer(ab2,Configs.Damage,{},trp.Position)
                                CR:FireServer(ab2,lcn..":WallCombo",2,Configs.Damage,{
                                    HitboxCFrames={trp.CFrame,trp.CFrame},
                                    BestHitCharacter=tp.Character,
                                    HitCharacters={tp.Character},
                                    Ignore={},DeathInfo={},BlockedCharacters={},
                                    HitInfo={IsFacing=false,IsInFront=true},
                                    ServerTime=os.time(),
                                    Actions={ ActionNumber1={ [tp.Name]={
                                        StartCFrameStr=tostring(lrp.CFrame),Local=true,Collision=false,
                                        Animation="Punch1Hit",Preset="Punch",Velocity=Vector3.zero,
                                        FromPosition=trp.Position,Seed=math.random(1,999999)
                                    } } },
                                    FromCFrame=trp.CFrame
                                },"Action150",0)
                            end)
                        end
                    end
                end
            end
        end
    end
    local function sa() if auraConn then auraConn:Disconnect() auraConn=nil end auraConn = RunService.Heartbeat:Connect(function() if running then ska() end end) end
    local function st() if auraConn then auraConn:Disconnect() auraConn=nil end end
    sAddTog(ViolenceLeft, 'KillAuraV1Toggle', { Text = '杀戮光环v1(慢)', Default = false, Callback = function(state) running=state if state then sa() else st() end end })
    local en2=false local c2 local plist={} local idx=1 local RNG=70 local DINT=0.25 local ld2=0
    local function kav2(count)
        if not player.Data or not player.Data.Character or not ReplicatedStorage.Characters then return end
        local cn = player.Data.Character.Value local combo = ReplicatedStorage.Characters[cn] and ReplicatedStorage.Characters[cn].WallCombo
        if not combo then return end
        local now = tick() if now-ld2 < DINT then return end ld2=now
        local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
        local dr = ReplicatedStorage.Remotes.Character:FindFirstChild("Dash") if dr then pcall(function() dr:FireServer(hrp.CFrame,"L",hrp.CFrame.LookVector,nil,now) end) end
        local tgs = {}
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=player and p.Character then
                local hum = p.Character:FindFirstChild("Humanoid") local r = p.Character:FindFirstChild("HumanoidRootPart")
                if hum and r and hum.Health>0 and (r.Position-hrp.Position).Magnitude<=RNG and not p.Character:GetAttribute("Invincible") then table.insert(tgs,p.Character) end
            end
        end
        for _,ch in ipairs(tgs) do for _=1,count do plist[idx]=ch idx=idx+1 end end
        if idx>1 then
            ReplicatedStorage.Remotes.Abilities.Ability:FireServer(combo,69)
            ReplicatedStorage.Remotes.Combat.Action:FireServer(combo,"",4,69,{BestHitCharacter=nil,HitCharacters=plist,Ignore={},Actions={}})
            table.clear(plist) idx=1
        end
    end
    sAddTog(ViolenceLeft, 'KillAuraV2Toggle', { Text = '杀戮光环v2(快)', Default = false, Callback = function(state)
        en2=state
        if en2 then c2 = RunService.Heartbeat:Connect(function() local cnt = (player.Data.Character.Value=="Gon") and 20 or 50 kav2(cnt) end)
        else if c2 then c2:Disconnect() c2=nil end end
    end })
    sAddTog(ViolenceLeft, 'KillAuraIgnoreFriendsToggle', { Text = '杀戮光环忽略好友', Default = false, Callback = function(state) Configs.IgnoreFriends=state end })
    sAddTog(ViolenceLeft, 'WallComboKillToggle', { Text = '墙打秒杀', Default = false, Callback = twf })
    sAddTog(ViolenceLeft, 'WallComboIgnoreFriendsToggle', { Text = '墙打秒杀忽略好友', Default = false, Callback = function(state) ignFriends=state end })
else
    sAddLab(ViolenceLeft,"Core缺失，部分暴力功能不可用")
    sAddTog(ViolenceLeft, 'KillAuraV1Toggle', { Text = '杀戮光环v1(慢)', Default = false, Callback = function() Library:Notify("Core missing",3) end })
    sAddTog(ViolenceLeft, 'KillAuraV2Toggle', { Text = '杀戮光环v2(快)', Default = false, Callback = function() Library:Notify("Core missing",3) end })
    sAddTog(ViolenceLeft, 'KillAuraIgnoreFriendsToggle', { Text = '杀戮光环忽略好友', Default = false })
    sAddTog(ViolenceLeft, 'WallComboKillToggle', { Text = '墙打秒杀', Default = false })
    sAddTog(ViolenceLeft, 'WallComboIgnoreFriendsToggle', { Text = '墙打秒杀忽略好友', Default = false })
end

local HitboxTab = Tabs.Hitbox and Tabs.Hitbox:AddLeftGroupbox("碰撞箱扩大")
if HitboxTab then
    local S = {} S.Players=Players S.RunService=RunService S.ReplicatedStorage=ReplicatedStorage S.Cfg={ Hitbox=false, X=150, Y=150, Z=150, Enhancer=false, Multi=3 } S.Cache={} S.Conn=nil S.DashT=0
    local LP = player getgenv().HitboxEnabled=false
    function S:HRP() local c=LP.Character return c and c:FindFirstChild("HumanoidRootPart") end
    function S:GetCore() if self.Cache.Core then return self.Cache.Core end local ok,core=pcall(function() return require(self.ReplicatedStorage:WaitForChild("Core",2)) end) if ok then self.Cache.Core=core return core end end
    function S:ToggleHitbox(state)
        self.Cfg.Hitbox=state getgenv().HitboxEnabled=state
        local core=self:GetCore() if not core or not core.Get then return end
        local hit=core.Get("Combat","Hit") if not hit or not hit.Box then return end
        if state then if not self.Cache.OrigBox then self.Cache.OrigBox=hit.Box end hit.Box=function(_,char,data) data=data or {} data.Size=Vector3.new(self.Cfg.X,self.Cfg.Y,self.Cfg.Z) return self.Cache.OrigBox(nil,char,data) end
        else if self.Cache.OrigBox then hit.Box=self.Cache.OrigBox end end
    end
    function S:Dash() if tick()-self.DashT<0.18 then return end self.DashT=tick() local hrp=self:HRP() if not hrp then return end pcall(function() self:GetCore().Library("Remote").Send("Dash",hrp.CFrame,"L",1) end) end
    function S:EnableEnhancer()
        if self.Cache.HitProc then return end local ok,hit=pcall(function() return require(LP.PlayerScripts:WaitForChild("Combat",2):WaitForChild("Hit",2)) end)
        if not ok or not hit.Process then return end self.Cache.HitProc=hit.Process
        hit.Process=function(...)
            local best,targets,blocked=self.Cache.HitProc(...)
            if not targets or #targets==0 then return best,targets,blocked end
            self:Dash()
            local r=self.ReplicatedStorage.Remotes.Combat.Action
            for _=1,self.Cfg.Multi do pcall(function() r:FireServer(nil,"",4,69,{BestHitCharacter=nil,HitCharacters=targets,Ignore={},Actions={}}) end) end
            return best,targets,blocked
        end
    end
    function S:DisableEnhancer() if not self.Cache.HitProc then return end local ok,hit=pcall(function() return require(LP.PlayerScripts.Combat.Hit) end) if ok then hit.Process=self.Cache.HitProc end self.Cache.HitProc=nil end
    function S:StartDashLoop() if self.Conn then return end self.Conn=self.RunService.Heartbeat:Connect(function() self:Dash() end) end
    function S:StopDashLoop() if self.Conn then self.Conn:Disconnect() self.Conn=nil end end
    sAddTog(HitboxTab, 'ExpandHitboxToggle', { Text = '碰撞箱扩大', Default = false, Callback = function(v) if v then S:ToggleHitbox(true) S:EnableEnhancer() S:StartDashLoop() else S:ToggleHitbox(false) S:DisableEnhancer() S:StopDashLoop() end end })
    sAddInp(HitboxTab, 'HitboxXInput', { Text = '碰撞箱X轴', Default = "150", Numeric = true, Callback = function(v) v=tonumber(v) if v then S.Cfg.X=math.clamp(v,10,150) end end })
    sAddInp(HitboxTab, 'HitboxYInput', { Text = '碰撞箱Y轴', Default = "150", Numeric = true, Callback = function(v) v=tonumber(v) if v then S.Cfg.Y=math.clamp(v,10,150) end end })
    sAddInp(HitboxTab, 'HitboxZInput', { Text = '碰撞箱Z轴', Default = "150", Numeric = true, Callback = function(v) v=tonumber(v) if v then S.Cfg.Z=math.clamp(v,10,150) end end })
end

local LockLeft = Tabs.Lock and Tabs.Lock:AddLeftGroupbox("锁人")
if LockLeft then
    local S2 = {} S2.Players=Players S2.RunService=RunService S2.LocalPlayer=player
    S2.BEHIND_DISTANCE=5 S2.CIRCLE_RADIUS=6 S2.CIRCLE_SPEED=13
    S2.followEnabled=false S2.circleEnabled=false S2.lookEnabled=false S2.selectedTargetName=nil S2.circleAngle=0 S2.mainConnection=nil
    function S2.getRoot(p) if p and p.Character then return p.Character:FindFirstChild("HumanoidRootPart") end end
    function S2.getPlayerByName(name) for _,p in ipairs(Players:GetPlayers()) do if p.Name==name then return p end end end
    function S2.getPlayerNames() local names={} for _,p in ipairs(Players:GetPlayers()) do if p~=player then table.insert(names,p.Name) end end return names end
    function S2.updateLoop(dt)
        if not S2.selectedTargetName then return end
        local t = S2.getPlayerByName(S2.selectedTargetName) local tr = S2.getRoot(t) local mr = S2.getRoot(player)
        if not tr or not mr then return end local tp = tr.Position local fp = nil
        if S2.circleEnabled then S2.circleAngle=S2.circleAngle+(S2.CIRCLE_SPEED*dt) local x=math.cos(S2.circleAngle)*S2.CIRCLE_RADIUS local z=math.sin(S2.circleAngle)*S2.CIRCLE_RADIUS fp=tp+Vector3.new(x,0,z)
        elseif S2.followEnabled then local off=tr.CFrame.LookVector*S2.BEHIND_DISTANCE fp=tp-off end
        if fp then
            if S2.lookEnabled then mr.CFrame=CFrame.new(fp,Vector3.new(tp.X,fp.Y,tp.Z)) else mr.CFrame=CFrame.new(fp)*mr.CFrame.Rotation end
        elseif S2.lookEnabled then local mp=mr.Position mr.CFrame=CFrame.new(mp,Vector3.new(tp.X,mp.Y,tp.Z)) end
    end
    function S2.toggleConnection()
        if S2.followEnabled or S2.circleEnabled or S2.lookEnabled then
            if not S2.mainConnection then S2.mainConnection=RunService.RenderStepped:Connect(S2.updateLoop) end
        else if S2.mainConnection then S2.mainConnection:Disconnect() S2.mainConnection=nil end end
    end
    sAddDrp(LockLeft, 'TargetPlayerDropdown', { Text = '选择目标玩家', Values = S2.getPlayerNames(), Default = 1, Multi = false, Callback = function(name) S2.selectedTargetName=name end })
    sAddBtn(LockLeft, { Text = '刷新玩家列表', Func = function()
        S2.selectedTargetName=nil
        local nn = S2.getPlayerNames()
        local dd = LockLeft:FindFirstChild("TargetPlayerDropdown")
        if dd then if dd.SetValues then dd:SetValues(nn) elseif dd.Refresh then dd:Refresh(nn,true) end if dd.SetValue then dd:SetValue(nil) end end
    end })
    sAddTog(LockLeft, 'LockBehindToggle', { Text = '锁背', Default = false, Callback = function(state) S2.followEnabled=state if state then S2.circleEnabled=false end S2.toggleConnection() end })
    sAddTog(LockLeft, 'CircleLockToggle', { Text = '转圈', Default = false, Callback = function(state) S2.circleEnabled=state if state then S2.followEnabled=false end S2.toggleConnection() end })
    sAddTog(LockLeft, 'LookAtPlayerToggle', { Text = '看着玩家(需要关移位锁)', Default = false, Callback = function(state) S2.lookEnabled=state S2.toggleConnection() end })
end

local EmoteLeft = Tabs.Emote and Tabs.Emote:AddLeftGroupbox("击杀表情")
if EmoteLeft then
    local T = {}
    T.env = { ReplicatedStorage=ReplicatedStorage, Players=Players, LocalPlayer=player }
    T.env.core = pcall(function() return require(ReplicatedStorage:WaitForChild("Core")) end) and require(ReplicatedStorage:WaitForChild("Core")) or nil
    T.env.Character = player.Character or player.CharacterAdded:Wait() T.env.HumanoidRootPart = T.env.Character:WaitForChild("HumanoidRootPart")
    T.state = { killEmotes={}, aura=false, spam=false, auraDelay=0.5, spamDelay=0.5, selectedEmote="", keybind=Enum.KeyCode.G, dropdown=nil, tmp={} }
    function T.getRoot(ch) return ch and ch:FindFirstChild("HumanoidRootPart") end
    function T.useEmote(name)
        local tmp = T.state.tmp
        local cos = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
        tmp.emote = cos and cos:FindFirstChild("KillEmote") and cos.KillEmote:FindFirstChild(name)
        tmp.myRoot = T.getRoot(T.env.LocalPlayer.Character)
        if not tmp.emote or not tmp.myRoot then return end
        if not T.env.core then Library:Notify("Core missing",3) return end
        tmp.closest=nil tmp.dist=math.huge
        for _, p in ipairs(T.env.Players:GetPlayers()) do
            if p~=T.env.LocalPlayer and p.Character then
                tmp.r = T.getRoot(p.Character)
                if tmp.r then
                    tmp.d = (tmp.myRoot.Position - tmp.r.Position).Magnitude
                    if tmp.d < tmp.dist then tmp.dist=tmp.d tmp.closest=p.Character end
                end
            end
        end
        if tmp.closest then
            task.spawn(function()
                _G.KillEmote = true
                pcall(function() T.env.core.Get("Combat","Ability").Activate(tmp.emote, tmp.closest) end)
                _G.KillEmote = false
            end)
        end
    end
    function T.useRandom() local l = T.state.killEmotes if #l>0 then T.useEmote(l[math.random(#l)]) end end
    task.spawn(function() while true do if T.state.aura then T.useRandom() task.wait(T.state.auraDelay) else task.wait(0.1) end end end)
    task.spawn(function() while true do if T.state.spam and T.state.selectedEmote~="" then T.useEmote(T.state.selectedEmote) task.wait(T.state.spamDelay) else task.wait(0.1) end end end)
    UserInputService.InputBegan:Connect(function(i,g) if not g and i.KeyCode==T.state.keybind and T.state.selectedEmote~="" then T.useEmote(T.state.selectedEmote) end end)
    function T.updateDropdown(lst)
        local vals = (#lst>0 and lst) or {"No emotes found"}
        if T.state.dropdown then pcall(function() T.state.dropdown:Destroy() end) T.state.dropdown=nil end
        T.state.dropdown = EmoteLeft:AddDropdown('KillEmoteDropdown', { Text = '击杀表情功能(要靠近别人)', Values = vals, Default = 1, Multi = false, Callback = function(v) if v~="No emotes found" then T.state.selectedEmote=v T.useEmote(v) end end })
    end
    sAddBtn(EmoteLeft, { Text = '刷新击杀表情', Func = function()
        table.clear(T.state.killEmotes)
        local cos = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
        if cos and cos:FindFirstChild("KillEmote") then for _,e in ipairs(cos.KillEmote:GetChildren()) do T.state.killEmotes[#T.state.killEmotes+1]=e.Name end end
        T.updateDropdown(T.state.killEmotes)
    end })
    local cosI = T.env.ReplicatedStorage:FindFirstChild("Cosmetics")
    if cosI and cosI:FindFirstChild("KillEmote") then for _,e in ipairs(cosI.KillEmote:GetChildren()) do T.state.killEmotes[#T.state.killEmotes+1]=e.Name end end
    T.updateDropdown(T.state.killEmotes)
    sAddTog(EmoteLeft, 'KillEmoteAuraToggle', { Text = '击杀表情光环', Default = false, Callback = function(v) T.state.aura=v end })
    sAddSld(EmoteLeft, 'KillEmoteAuraDelaySlider', { Text = '击杀表情光环间隔', Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v) T.state.auraDelay=v end })
    sAddTog(EmoteLeft, 'SpamEmoteToggle', { Text = '持续发送你选择的表情', Default = false, Callback = function(v) T.state.spam=v end })
    sAddSld(EmoteLeft, 'SpamEmoteDelaySlider', { Text = '调整你选择的表情速度', Default = 0.5, Min = 0.01, Max = 5, Rounding = 2, Callback = function(v) T.state.spamDelay=v end })
    local km = { G=Enum.KeyCode.G, F=Enum.KeyCode.F, H=Enum.KeyCode.H, J=Enum.KeyCode.J, K=Enum.KeyCode.K, L=Enum.KeyCode.L, Z=Enum.KeyCode.Z, X=Enum.KeyCode.X, C=Enum.KeyCode.C, V=Enum.KeyCode.V, B=Enum.KeyCode.B, N=Enum.KeyCode.N, M=Enum.KeyCode.M, Q=Enum.KeyCode.Q, E=Enum.KeyCode.E, R=Enum.KeyCode.R, T=Enum.KeyCode.T, Y=Enum.KeyCode.Y, U=Enum.KeyCode.U, I=Enum.KeyCode.I, O=Enum.KeyCode.O, P=Enum.KeyCode.P }
    local kl = {} for k in pairs(km) do table.insert(kl,k) end table.sort(kl)
    sAddDrp(EmoteLeft, 'KeybindDropdown', { Text = '快捷键设置', Values = kl, Default = 1, Callback = function(v) T.state.keybind=km[v] end })
    sAddBtn(EmoteLeft, { Text = '随机用一个击杀表情', Func = function() T.useRandom() end })
end

local SettingsGroup = Tabs.Settings and Tabs.Settings:AddLeftGroupbox("脚本管理")
if SettingsGroup then sAddBtn(SettingsGroup, { Text = '卸载脚本', Func = function() Library:Unload() end }) end

if ThemeManager then
    ThemeManager:SetLibrary(Library)
    ThemeManager:SetFolder("MyScriptTheme")
    if Tabs.Settings then ThemeManager:ApplyToTab(Tabs.Settings) end
end

if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    SaveManager:SetFolder("MyScriptConfig")
    if Tabs.Settings then SaveManager:BuildConfigSection(Tabs.Settings) end
end
