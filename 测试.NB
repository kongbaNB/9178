        local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
        local lastPosition = HumanoidRootPart.Position
        tpConnection = RunService.RenderStepped:Connect(function()
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
                Character = player.Character or player.CharacterAdded:Wait()
                HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
                lastPosition = HumanoidRootPart.Position
            end
            local currentPos = player.Character.HumanoidRootPart.Position
            local distance = (currentPos - lastPosition).Magnitude
            if distance > 50 then
                player.Character.HumanoidRootPart.CFrame = CFrame.new(lastPosition)
            else
                lastPosition = currentPos
            end
        end)
    else
        if RagdollPower then RagdollPower.Value = 100 end
        if tpConnection then tpConnection:Disconnect(); tpConnection = nil end
    end
end })

