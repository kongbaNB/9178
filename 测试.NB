NoticeGroup:AddLabel('请务必先开启“篡改”功能')

local activeToggles = {}
local function keepAfterRespawn(name, applyFunc)
    activeToggles[name] = { active = false, apply = applyFunc }
    local function onCharAdded()
        local data = activeToggles[name]
        if data and data.active then
            task.wait(0.5)
            pcall(data.apply, true)
        end
    end
    player.CharacterAdded:Connect(onCharAdded)
end

local MainLeft = Tabs.Main:AddLeftGroupbox("核心")
MainLeft:AddButton({
    Text = '篡改（必需第一步）',
    Func = function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/dream77239/ubg-script/refs/heads/main/%E6%8B%A6%E6%88%AA.txt"))()
    end
})
MainLeft:AddToggle('FakeBlock', {
    Text = '假防',
    Default = false,
    Callback = function(state)
        local fakeBlockEnabled = state
        local BlockRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Combat"):WaitForChild("Block")
        local char = player.Character or player.CharacterAdded:Wait()
        local function enableBlock() pcall(function() BlockRemote:FireServer(true) end) end
        if fakeBlockEnabled then
            enableBlock()
            task.spawn(function()
                while fakeBlockEnabled do
                    task.wait(0.01)
                    local isBlocking = pcall(function() return char:GetAttribute("IsBlocking") end)
                    if isBlocking == false then enableBlock() end
                end
            end)
        end
    end
})

