local function addButton(parent, cfg)
    if not parent then return end
    safeCall(parent.AddButton, parent, cfg)
end
local function addToggle(parent, id, cfg)
    if not parent then return end
    safeCall(parent.AddToggle, parent, id, cfg)
end
local function addSlider(parent, id, cfg)
    if not parent then return end
    safeCall(parent.AddSlider, parent, id, cfg)
end
local function addDropdown(parent, id, cfg)
    if not parent then return end
    if not cfg.Values or #cfg.Values == 0 then
        cfg.Values = {"None"}
    end
    safeCall(parent.AddDropdown, parent, id, cfg)
end
local function addInput(parent, id, cfg)
    if not parent then return end
    safeCall(parent.AddInput, parent, id, cfg)
end

