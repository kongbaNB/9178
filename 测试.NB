addButton(MainRight2, { Text = '删除击杀表情特效', Func = function()
    local KillEmote = ReplicatedStorage:FindFirstChild("Cosmetics") and ReplicatedStorage.Cosmetics:FindFirstChild("KillEmote")
    if not KillEmote then return end
    local function removeEffects(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("ParticleEmitter") or child:IsA("Trail") or child:IsA("Beam") or child:IsA("Fire") or child:IsA("Smoke") or child:IsA("Sparkles") or child:IsA("Light") then
                child:Destroy()
            else
                removeEffects(child)
            end
        end
    end
    removeEffects(KillEmote)
end })

