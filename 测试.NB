local MovVisual = Tabs.Movement:AddRightGroupbox("视觉")
MovVisual:AddToggle('AnywhereWall', {
    Text = '随处墙打',
    Default = false,
    Callback = function(state)
        local wall = Instance.new("Part")
        wall.Size = Vector3.new(12,6,2)
        wall.Transparency = 0.6
        wall.Anchored = true
        wall.CanCollide = true
        wall.Parent = workspace
        if state then
            local conn = RunService.RenderStepped:Connect(function()
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then wall.CFrame = hrp.CFrame * CFrame.new(0,0,-8) end
            end)
        else
            wall:Destroy()
        end
    end
})
MovVisual:AddToggle('AntiLag', {
    Text = '防卡',
    Default = false,
    Callback = function(state)
        if state then
            for _, v in ipairs(workspace:GetDescendants()) do
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") then v.Enabled = false end
                if v:IsA("Decal") or v:IsA("Texture") then v.Transparency = 1 end
            end
            game.Lighting.GlobalShadows = false
            game.Lighting.FogEnd = 9e9
        end
    end
})
MovVisual:AddToggle('ShowRange', {
    Text = '范围显示',
    Default = false,
    Callback = function(state)
        local circle = {}
        if state then
            local r = 60
            for i=1,60 do
                local p = Instance.new("Part")
                p.Anchored = true
                p.CanCollide = false
                p.Size = Vector3.new(0.2,0.2, r*2*math.pi/60)
                p.Material = Enum.Material.Neon
                p.Parent = workspace
                circle[i] = p
            end
            local conn = RunService.RenderStepped:Connect(function()
                local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end
                local pos = hrp.Position - Vector3.new(0,0.9,0)
                for i,p in ipairs(circle) do
                    local angle = (i/60)*2*math.pi
                    p.Position = pos + Vector3.new(math.cos(angle)*r,0,math.sin(angle)*r)
                end
            end)
        else
            for _,p in ipairs(circle) do p:Destroy() end
        end
    end
})
MovVisual:AddButton({
    Text = '删除墙打特效',
    Func = function()
        local paths = {
            ReplicatedStorage.Characters.Gon.WallCombo.GonWallCombo.Center,
            ReplicatedStorage.Characters.Mob.WallCombo.MobWallCombo.Center,
            ReplicatedStorage.Characters.Sukuna.WallCombo.SukunaWallCombo
        }
        for _,obj in ipairs(paths) do if obj then for _,c in ipairs(obj:GetChildren()) do c:Destroy() end end end
    end
})
MovVisual:AddButton({
    Text = '删除击杀特效',
    Func = function()
        local emote = ReplicatedStorage.Cosmetics.KillEmote
        for _,v in ipairs(emote:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") then v:Destroy() end
        end
    end
})

local ViolentLeft = Tabs.Violence:AddLeftGroupbox("无敌/卡服")
ViolentLeft:AddToggle('Godmode', {
    Text = '无敌',
    Default = false,
    Callback = function(state)
        local active = state
        if state then
            task.spawn(function()
                while active do
                    pcall(function()
                        local charName = player.Data.Character.Value
                        local combo = ReplicatedStorage.Characters[charName].WallCombo
                        ReplicatedStorage.Remotes.Abilities.Ability:FireServer(combo, 69)
                        ReplicatedStorage.Remotes.Combat.Action:FireServer(combo,"",4,69,{ HitCharacters = {player.Character}, Ignore = {}, Actions = {} })
                    end)
                    task.wait(0.01)
                end
            end)
        end
    end
})
ViolentLeft:AddButton({
    Text = '卡服',
    Func = function()
        local args = {
            ReplicatedStorage.Characters.Gon.WallCombo, "Characters:Gon:WallCombo", 1, 33036,
            { BestHitCharacter = workspace.Characters.NPCs["The Ultimate Bum"], HitCharacters = {workspace.Characters.NPCs["The Ultimate Bum"]}, Ignore = {}, Actions = {}, HitInfo = {IsFacing=true, IsInFront=true}, BlockedCharacters = {}, ServerTime = os.clock(), FromCFrame = CFrame.new(534.693, 5.532, 79.486) },
            "Action651", 0
        }
        for i=1,10000 do task.spawn(function() pcall(function() ReplicatedStorage.Remotes.Abilities.Ability:FireServer(unpack(args)) ReplicatedStorage.Remotes.Combat.Action:FireServer(unpack(args)) end) end) end
    end
})

local ViolentRight = Tabs.Violence:AddRightGroupbox("杀戮光环")
ViolentRight:AddToggle('KillAuraV1', {
    Text = '杀戮光环V1(慢)',
    Default = false,
    Callback = function(state)
        if state then
            local conn = RunService.Heartbeat:Connect(function()
                local Core = require(ReplicatedStorage:WaitForChild("Core"))
                local charName = player.Data.Character.Value
                local ability = ReplicatedStorage.Characters[charName].WallCombo
                local maxDist = 100
                local lc = player.Character
                if not lc then return end
                for _,t in ipairs(Players:GetPlayers()) do
                    if t ~= player and t.Character and t.Character:FindFirstChild("HumanoidRootPart") then
                        if (t.Character.HumanoidRootPart.Position - lc.HumanoidRootPart.Position).Magnitude < maxDist then
                            pcall(function() Core.Get("Combat","Ability").Activate(ability, t.Character) end)
                        end
                    end
                end
            end)
        end
    end
})
ViolentRight:AddToggle('KillAuraV2', {
    Text = '杀戮光环V2(快)',
    Default = false,
    Callback = function(state)
        if state then
            local conn = RunService.Heartbeat:Connect(function()
                local charName = player.Data.Character.Value
                local combo = ReplicatedStorage.Characters[charName].WallCombo
                local targets = {}
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not root then return end
                for _,p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        if (p.Character.HumanoidRootPart.Position - root.Position).Magnitude < 70 then
                            table.insert(targets, p.Character)
                        end
                    end
                end
                if #targets > 0 then
                    ReplicatedStorage.Remotes.Abilities.Ability:FireServer(combo, 69)
                    ReplicatedStorage.Remotes.Combat.Action:FireServer(combo,"",4,69,{HitCharacters=targets, Ignore={}, Actions={}})
                end
            end)
        end
    end
})
ViolentRight:AddToggle('WallOneShot', {
    Text = '墙打秒杀',
    Default = false,
    Callback = function(state)
        if state then
            local conn = RunService.Heartbeat:Connect(function()
                local Core = require(ReplicatedStorage:WaitForChild("Core"))
                local lc = player.Character
                if not lc or not lc:FindFirstChild("Head") then return end
                local charName = player.Data.Character.Value
                for _,p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        if (p.Character.HumanoidRootPart.Position - lc.Head.Position).Magnitude < 100 then
                            pcall(function() Core.Get("Combat","Ability").Activate(ReplicatedStorage.Characters[charName].WallCombo, p.Character) end)
                        end
                    end
                end
            end)
        end
    end
})

local HitboxGroup = Tabs.HitboxLock:AddLeftGroupbox("碰撞箱")
HitboxGroup:AddToggle('HitboxExpand', {
    Text = '开启扩大',
    Default = false,
    Callback = function(state)
        local Core = require(ReplicatedStorage:WaitForChild("Core"))
        local orig = Core.Get("Combat","Hit").Box
        if state then
            Core.Get("Combat","Hit").Box = function(_, char, data) data = data or {}; data.Size = Vector3.new(150,150,150); return orig(nil, char, data) end
        else
            Core.Get("Combat","Hit").Box = orig
        end
    end
})
HitboxGroup:AddInput('HitboxX', { Text = 'X轴', Default = "150", Callback = function(v) end })
HitboxGroup:AddInput('HitboxY', { Text = 'Y轴', Default = "150", Callback = function(v) end })
HitboxGroup:AddInput('HitboxZ', { Text = 'Z轴', Default = "150", Callback = function(v) end })

local LockGroup = Tabs.HitboxLock:AddRightGroupbox("锁人")
local lockDropdown = LockGroup:AddDropdown('LockTarget', {
    Text = '选择目标',
    Values = {"无"},
    Default = "无",
    Callback = function(name)
        local t = Players:FindFirstChild(name)
        if t then
            local conn = RunService.RenderStepped:Connect(function()
                local my = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local tr = t.Character and t.Character:FindFirstChild("HumanoidRootPart")
                if my and tr then my.CFrame = CFrame.new(tr.Position + Vector3.new(0,0,-5), tr.Position) end
            end)
            player.CharacterAdded:Connect(function() if conn then conn:Disconnect() end end)
        end
    end
})
LockGroup:AddToggle('LockBack', { Text = '锁背', Default = false, Callback = function(s) end })
LockGroup:AddToggle('Circle', { Text = '转圈', Default = false, Callback = function(s) end })
LockGroup:AddToggle('LookAt', { Text = '看着玩家', Default = false, Callback = function(s) end })
LockGroup:AddButton({
    Text = '刷新玩家',
    Func = function()
        local names = {}
        for _,p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(names, p.Name) end end
        if #names == 0 then names = {"无"} end
        pcall(function() lockDropdown:SetValues(names) end)
    end
})
Players.PlayerAdded:Connect(function()
    local names = {}
    for _,p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(names, p.Name) end end
    if #names == 0 then names = {"无"} end
    pcall(function() lockDropdown:SetValues(names) end)
end)
Players.PlayerRemoving:Connect(function()
    local names = {}
    for _,p in ipairs(Players:GetPlayers()) do if p ~= player then table.insert(names, p.Name) end end
    if #names == 0 then names = {"无"} end
    pcall(function() lockDropdown:SetValues(names) end)
end)

