local MovLeft = Tabs.Movement:AddLeftGroupbox("移动")
MovLeft:AddToggle('TPWalkToggle', {
    Text = '高速移动',
    Default = false,
    Callback = function(state)
        local tpwalking = state
        local tpSpeed = 100
        if state then
            task.spawn(function()
                while tpwalking do
                    local chr = player.Character
                    if chr then
                        local hrp = chr:FindFirstChild("HumanoidRootPart")
                        local hum = chr:FindFirstChildWhichIsA("Humanoid")
                        local delta = RunService.Heartbeat:Wait()
                        if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                            hrp.CFrame = hrp.CFrame + hum.MoveDirection * tpSpeed * delta
                        end
                    end
                end
            end)
        end
    end
})
MovLeft:AddSlider('TPWalkSpeed', { Text = '移动速度', Default = 100, Min = 0, Max = 250, Rounding = 0, Callback = function(v) end })

