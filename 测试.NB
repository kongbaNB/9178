-- 安全获取 ReplicatedStorage 中的对象，带默认值
local function safeGet(pathArray, default)
    local obj = ReplicatedStorage
    for _, name in ipairs(pathArray) do
        if obj and obj:FindFirstChild(name) then
            obj = obj[name]
        else
            return default
        end
    end
    return obj
end

