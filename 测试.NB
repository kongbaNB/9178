local pingLoop
MainMiscGroup:AddToggle("14", {
    Text = "Ping乱码",
    Default = false,
    Callback = function(state)
        if state then
            pingLoop = task.spawn(function()
                local Ping = player:WaitForChild("Info"):WaitForChild("Ping")
                while state do
                    for i = 0, 999, 25 do
                        if not state then break end
                        Ping.Value = i
                        task.wait(0.03)
                    end
                    for i = 999, 0, -25 do
                        if not state then break end
                        Ping.Value = i
                        task.wait(0.03)
                    end
                end
            end)
        else
            if pingLoop then task.cancel(pingLoop) end
        end
    end
})

