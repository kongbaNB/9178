                    hunterMode.Name = "HunterMode"
                    hunterMode.Value = true
                    hunterMode.Parent = hrp
                end
                if hrp:FindFirstChild("BaldMode") then hrp.BaldMode:Destroy() end
            end
            hrp:SetAttribute("Mode", charName)
