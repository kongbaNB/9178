-- ==================== 宝箱功能 ====================
TabChest:Toggle({
    Title = "自动开全部宝箱", Value = false,
    Callback = function(v)
        Features.AutoOpenChest = v
        if v then
            task.spawn(function()
                while Features.AutoOpenChest do
                    local hrp = getHRP()
                    if hrp then
                        local original = hrp.CFrame
                        local chests = getChests()
                        for _, chest in ipairs(chests) do
                            if not Features.AutoOpenChest then break end
                            local part = chest.PrimaryPart or chest:FindFirstChildWhichIsA("BasePart")
                            if part then
                                hrp.CFrame = part.CFrame + Vector3.new(0, 6, 0)
                                for _, prompt in ipairs(chestPrompts(chest)) do
                                    pcall(function() fireproximityprompt(prompt, math.huge) end)
                                end
                                local t = tick()
                                while Features.AutoOpenChest and tick()-t < 3 do task.wait() end
                            end
                        end
                        hrp.CFrame = original
                    end
                    task.wait(1)
                end
            end)
        end
    end
})
TabChest:Toggle({
    Title = "宝箱光环", Value = false,
    Callback = function(v)
        Features.ChestAura = v
        if v then
            task.spawn(function()
                while Features.ChestAura do
                    local hrp = getHRP()
                    if hrp then
                        for _, obj in ipairs(Workspace:GetDescendants()) do
                            if obj:IsA("Model") and obj.Name:match("^Item Chest") then
                                local part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                                if part and (hrp.Position - part.Position).Magnitude <= Features.ChestAuraRange then
                                    for _, prompt in ipairs(obj:GetDescendants()) do
                                        if prompt:IsA("ProximityPrompt") then
                                            pcall(function() fireproximityprompt(prompt, math.huge) end)
                                        end
                                    end
                                end
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})
TabChest:Slider({
    Title = "宝箱光环范围", Value = {Min = 1, Max = 200, Default = 50},
    Callback = function(v) Features.ChestAuraRange = v end
})
TabChest:Button({
    Title = "传送到最近宝箱",
    Callback = function()
        local hrp = getHRP()
        if not hrp then return end
        local chests = getChests()
        local nearest, minDist = nil, math.huge
        for _, chest in ipairs(chests) do
            local part = chest.PrimaryPart or chest:FindFirstChildWhichIsA("BasePart")
            if part then
                local dist = (hrp.Position - part.Position).Magnitude
                if dist < minDist then minDist = dist; nearest = part end
            end
        end
        if nearest then hrp.CFrame = nearest.CFrame + Vector3.new(0, 5, 0)
        else WindUI:Notify({Title="宝箱",Content="未找到宝箱",Duration=3}) end
    end
})

-- ==================== 火堆 ====================
TabFire:Section({Title = "燃料类"})
local fuelMap = {["木头"]="Log",["煤"]="Coal",["油桶"]="Fuel Canister",["椅子"]="Chair",["生物燃料"]="Biofuel"}
local selectedFuel = {}
local fuelPos = Vector3.new(1.4, 25.9, -0.9)
TabFire:Dropdown({
    Title = "选择要收集的物品（多选）", Values = {"木头","煤","油桶","椅子","生物燃料"}, Value = {},
    Multi = true,
    Callback = function(opts)
        selectedFuel = {}
        for _, o in ipairs(opts) do selectedFuel[fuelMap[o]] = true end
    end
})
local autoFuel = false
TabFire:Toggle({
    Title = "自动扔选择的燃料", Value = false,
    Callback = function(v)
        autoFuel = v
        if v then
            task.spawn(function()
                while autoFuel do
                    for _, item in ipairs(Workspace.Items:GetChildren()) do
                        if not autoFuel then break end
                        if selectedFuel[item.Name] and item:IsA("Model") then
                            moveItemToPos(item, fuelPos)
                            task.wait(0.1)
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})
TabFire:Button({
    Title = "传送回火旁",
    Callback = function()
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(-0.0967, 7.937, -0.178) end
    end
})

-- ==================== 传送功能 ====================
TabTP:Section({Title = "基础传送点"})
TabTP:Button({
    Title = "传送到营火",
    Callback = function()
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(0.431, 15.776, -1.886) end
    end
})
TabTP:Button({
    Title = "传送到要塞",
    Callback = function()
        local target = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Landmarks") and Workspace.Map.Landmarks:FindFirstChild("Stronghold")
        if target then
            local door = target:FindFirstChild("Functional") and target.Functional:FindFirstChild("EntryDoors") and target.Functional.EntryDoors:FindFirstChild("DoorRight")
            if door then
                local model = door:FindFirstChild("Model")
                if model then
                    local dest = model:GetChildren()[5]
                    if dest and dest:IsA("BasePart") then
                        local hrp = getHRP()
                        if hrp then hrp.CFrame = dest.CFrame + Vector3.new(0, 5, 0) end
                    end
                end
            end
        end
    end
})
TabTP:Button({
    Title = "传送到安全区",
    Callback = function()
        local part = Workspace:FindFirstChild("SafeZonePart") or Instance.new("Part")
        part.Size = Vector3.new(30, 3, 30); part.Position = Vector3.new(0, 350, 0)
        part.Anchored = true; part.Parent = Workspace
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(0, 360, 0) end
    end
})
TabTP:Button({
    Title = "传送到商人",
    Callback = function()
        local hrp = getHRP()
        if hrp then hrp.CFrame = CFrame.new(-37.08, 3.98, -16.33) end
    end
})
TabTP:Button({
    Title = "传送到随机树",
    Callback = function()
        local hrp = getHRP()
        if not hrp then return end
        local map = Workspace:FindFirstChild("Map")
        if not map then return end
        local trees = {}
        for _, f in ipairs({map:FindFirstChild("Foliage"), map:FindFirstChild("Landmarks")}) do
            if f then
                for _, obj in ipairs(f:GetChildren()) do
                    if obj:IsA("Model") and obj.Name == "Small Tree" then
                        local trunk = obj:FindFirstChild("Trunk") or obj.PrimaryPart
                        if trunk then table.insert(trees, trunk) end
                    end
                end
            end
        end
        if #trees > 0 then
            local t = trees[math.random(1, #trees)]
            hrp.CFrame = CFrame.new(t.Position + Vector3.new(3, 0, 3))
        end
    end
})

TabTP:Section({Title = "儿童传送"})
local childList, childNames = getChildrenList()
local childDropdown = TabTP:Dropdown({
    Title = "选择儿童", Values = childNames, Value = childNames[1] or "无"
})
TabTP:Button({
    Title = "刷新儿童列表",
    Callback = function()
        local list, names = getChildrenList()
        childDropdown:Refresh(names, true)
        WindUI:Notify({Title="儿童",Content="找到 "..#names.." 个小孩",Duration=2})
    end
})
TabTP:Button({
    Title = "传送到儿童",
    Callback = function()
        local selected = childDropdown.Value
        if not selected or selected == "无" then WindUI:Notify({Title="错误",Content="请先选择儿童",Duration=3}); return end
        local list, names = getChildrenList()
        for i, name in ipairs(names) do
            if name == selected then
                local part = list[i] and (list[i]:FindFirstChild("HumanoidRootPart") or list[i].PrimaryPart)
                if part then
                    local hrp = getHRP()
                    if hrp then hrp.CFrame = part.CFrame + Vector3.new(0, 5, 0) end
                end
                break
            end
        end
    end
})

TabTP:Section({Title = "宝箱传送"})
local chestList, chestNames = getChests()
local chestDropdown = TabTP:Dropdown({
    Title = "选择宝箱", Values = chestNames, Value = chestNames[1] or "无"
})
TabTP:Button({
    Title = "刷新宝箱列表",
    Callback = function()
        local list, names = getChests()
        chestDropdown:Refresh(names, true)
        WindUI:Notify({Title="宝箱",Content="找到 "..#names.." 个宝箱",Duration=2})
    end
})
TabTP:Button({
    Title = "传送到宝箱",
    Callback = function()
        local selected = chestDropdown.Value
        if not selected or selected == "无" then return end
        local list, names = getChests()
        for i, name in ipairs(names) do
            if name == selected then
                local part = list[i] and (list[i].PrimaryPart or list[i]:FindFirstChildWhichIsA("BasePart"))
                if part then
                    local hrp = getHRP()
                    if hrp then hrp.CFrame = part.CFrame + Vector3.new(0, 5, 0) end
                end
                break
            end
        end
    end
})

-- ==================== 带来（修复医疗+篝火/工作台） ====================
TabBring:Section({Title = "拉取设置"})
TabBring:Dropdown({
    Title = "拉取到", Values = {"自己","篝火","建造台"}, Value = "自己",
    Callback = function(v) PullConfig.Target = v end
})
TabBring:Slider({
    Title = "拉取间隔(秒)", Value = {Min = 0.1, Max = 5, Default = 0.5},
    Callback = function(v) PullConfig.Speed = v end
})
TabBring:Toggle({
    Title = "开始拉取", Value = false,
    Callback = function(v)
        PullConfig.Enabled = v
        if v then
            task.spawn(function()
                while PullConfig.Enabled do
                    local all = {}
                    local target = getPullPos()
                    local function gather(list)
                        for _, en in ipairs(list) do
                            for _, item in ipairs(Workspace.Items:GetChildren()) do
                                if item.Name == en then table.insert(all, item) end
                            end
                        end
                    end
                    gather(PullConfig.Fuel)
                    gather(PullConfig.Scrap)
                    gather(PullConfig.Equip)
                    gather(PullConfig.Food)
                    gather(PullConfig.Med) -- 修复：医疗补全

                    for _, item in ipairs(all) do
                        if not PullConfig.Enabled then break end
                        moveItemToPos(item, target)
                        task.wait(math.max(0.1, PullConfig.Speed))
                    end
                    task.wait(1)
                end
            end)
        end
    end
})

